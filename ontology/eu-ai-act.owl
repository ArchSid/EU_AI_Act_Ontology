    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES"/>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OF_NATIONAL_RULES"/>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OBJECTION_DEADLINE"/>
