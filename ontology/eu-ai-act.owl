    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINANCIAL_FRAUD_DETECTION_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">FINANCIAL FRAUD DETECTION AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems used for detecting financial fraud (Annex III 5(b))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_51">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 51</rdfs:label>
    <skos:definition xml:lang="en">**Article 51** serves as the regulatory framework establishing the classification and specific criteria used to identify general-purpose AI (GPAI) models that pose systemic risks. It defines the conditions under which a GPAI model is categorized as having systemic risk, a designation that includes criteria for high-impact capabilities and specific compute thresholds. Furthermore, this article is cross-referenced in Article 90, highlighting its pivotal role in the governance structure for high-im</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_XIII"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AFFECTED_WORKERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">AFFECTED WORKERS</rdfs:label>
    <skos:definition xml:lang="en">Workers who are directly subject to the use of a high-risk AI system in the workplace and must be informed by their employer.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SINGLE_POINT_OF_CONTACT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">SINGLE POINT OF CONTACT</rdfs:label>
    <skos:definition xml:lang="en">A Single Point of Contact is a specific market surveillance authority designated by a Member State to serve as the primary liaison for the Regulation. This role is formally required under Article 70(2), ensuring there is a dedicated entity responsible for coordinating and facilitating communication regarding the Regulation's implementation and enforcement.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGISTRATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REGISTRATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The "REGISTRATION OBLIGATION" constitutes a critical regulatory requirement under the EU AI Act, mandating that specific AI systems be documented and submitted to the centralized EU database to ensure transparency and compliance. This duty applies broadly to both providers and deployers, including public authorities and Union institutions, to ensure that all relevant high-risk AI systems are accounted for and traceable.

Primarily, the REGISTRATION OBLIGATION requires providers to submit and mai</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_49"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_71"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_IX"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_49_2_"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_49_3_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AuthorisedRepresentative">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Authorised Representative</rdfs:label>
    <skos:definition xml:lang="en">A person in the Union mandated by a provider established outside the Union. (Article 3(5))</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DELEGATED_ACTS_AMENDING_ANNEX_III">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#DelegatedAct"/>
    <rdfs:label xml:lang="en">DELEGATED ACTS AMENDING ANNEX III</rdfs:label>
    <skos:definition xml:lang="en">DELEGATED ACTS AMENDING ANNEX III consist of regulatory measures adopted by the European Commission. These acts serve the purpose of updating Annex III by adding, modifying, or refining the list of use-cases classified as high-risk AI systems. These updates are strictly based on the risk criteria established under Article 7, with a specific focus on the requirements and criteria defined in Article 7(2).</skos:definition>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_7_1_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_ASSESSMENT_CRITERIA"/>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_71">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 71</rdfs:label>
    <skos:definition xml:lang="en">Article 71 serves as the regulatory provision responsible for the establishment, definition, and ongoing maintenance of the EU database for the registration of high-risk AI systems. This article acts as the formal reference governing how this specific database is created and operated within the framework of European Union AI regulations. By defining the scope and purpose of the database, Article 71 ensures there is a centralized, mandated system for the registration of high-risk artificial intel</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_6_2_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSPARENCY_REQUIREMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TRANSPARENCY REQUIREMENTS</rdfs:label>
    <skos:definition xml:lang="en">Obligations under the Regulation regarding the transparent provision of AI systems; violation of these when accompanied by a risk triggers specific enforcement procedures.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_VERIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">BIOMETRIC VERIFICATION</rdfs:label>
    <skos:definition xml:lang="en">Systems used to confirm that a specific person is who they claim to be for access to services, devices, or premises. Sole purpose is authentication (Recital 15)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_IDENTIFICATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM"/>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_DATA"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_EXCEPTIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">LAW ENFORCEMENT EXCEPTIONS</rdfs:label>
    <skos:definition xml:lang="en">Narrowly defined situations allowing the use of real-time remote biometric identification, including search for crime victims, threats to life/safety/terrorist attacks, and localisation of suspects of serious criminal offences (Recital 33).</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_TIME_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_33"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_64">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 64</rdfs:label>
    <skos:definition xml:lang="en">Article establishing and defining the AI Office</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GPAI_MODEL_PROVIDER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">GPAI MODEL PROVIDER</rdfs:label>
    <skos:definition xml:lang="en">A "GPAI Model Provider" is defined as any natural or legal person who develops a general-purpose AI model and places that model on the Union market. As established in Article 3(64) of the AI Act, this role carries specific responsibilities and regulatory obligations.

The GPAI Model Provider is ultimately responsible for ensuring the model’s compliance with all applicable transparency and copyright obligations. Furthermore, these providers are subject to oversight, including supervision and enfo</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RESERVATION_OF_RIGHTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_MARKET"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PRESUMPTION_OF_CONFORMITY"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#COPYRIGHT_COMPLIANCE_POLICY"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TRAINING_DATA_SUMMARY_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_DOCUMENTATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK_CRITERIA"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_106">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 106</rdfs:label>
    <skos:definition xml:lang="en">Article amending Directive (EU) 2016/797 regarding AI safety components</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2016_797"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1862">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2018/1862</rdfs:label>
    <skos:definition xml:lang="en">Legislation on the establishment, operation and use of the Schengen Information System (SIS) for police and judicial cooperation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COUNCIL_REGULATION__EU__NO_1024_2013">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">COUNCIL REGULATION (EU) NO 1024/2013</rdfs:label>
    <skos:definition xml:lang="en">Council Regulation (EU) No 1024/2013 is a foundational legislative act that establishes the legal framework for the Single Supervisory Mechanism (SSM). This regulation is instrumental in European financial oversight, as it confers specific, critical tasks upon the European Central Bank (ECB) regarding the prudential supervision of credit institutions within the European Union. By centralizing these supervisory powers, the regulation aims to ensure the safety and soundness of the banking system a</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION_2019_2144">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION 2019/2144</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2019/2144 is a legislative framework that has been subject to specific updates through the Artificial Intelligence Act. Notably, this regulation has been amended by Article 109 of the AI Act, with the revisions specifically addressing AI safety components within the scope of the regulation.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_11"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CYBERSECURITY_PURPOSE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">CYBERSECURITY PURPOSE</rdfs:label>
    <skos:definition xml:lang="en">The intent of using systems solely for enabling cybersecurity and personal data protection measures; acts as an exclusion condition for high-risk classification of biometric systems and critical infrastructure safety components (Recital 54, 55)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MONITORING_OF_THE_PERFORMANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MONITORING OF THE PERFORMANCE</rdfs:label>
    <skos:definition xml:lang="en">Duty for deployers to observe the functioning of an AI system in a real-life setting</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HUMAN_OVERSIGHT_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">HUMAN OVERSIGHT MEASURES</rdfs:label>
    <skos:definition xml:lang="en">Measures needed to ensure appropriate oversight of the AI system, which must be assessed in the technical documentation per Article 14.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_14"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAWFUL_MEDICAL_TREATMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">LAWFUL MEDICAL TREATMENT</rdfs:label>
    <skos:definition xml:lang="en">Exemption for psychological treatment or physical rehabilitation when carried out according to applicable standards and consent.</skos:definition>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_MANIPULATIVE_AI_PRACTICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VISA_INFORMATION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">VISA INFORMATION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The Visa Information System is a large-scale information technology system utilized for the management of visa applications and visa processing. As a critical component of the relevant Union legislative framework, it is explicitly listed in Annex X. Currently, the Visa Information System is subject to ongoing efforts to reform its legal framework, which are also detailed within the regulations listed in Annex X.</skos:definition>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2021_1133"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2021_1134"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3</rdfs:label>
    <skos:definition xml:lang="en">ARTICLE 3 serves as the section of the Regulation dedicated to establishing and specifying the key terms and definitions necessary for the interpretation and application of the Regulation. By defining these essential concepts, ARTICLE 3 provides the foundational terminology required to ensure clarity and consistency throughout the document.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROHPC_JOINT_UNDERTAKING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">EUROHPC JOINT UNDERTAKING</rdfs:label>
    <skos:definition xml:lang="en">A Union-level structure providing high-performance computing resources, utilized to build AI expertise and capabilities</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PENALTIES_FOR_MISLEADING_INFORMATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PENALTIES FOR MISLEADING INFORMATION</rdfs:label>
    <skos:definition xml:lang="en">Administrative fines for supplying incorrect, incomplete, or misleading information to notified bodies or national competent authorities. Amount: up to EUR 7,500,000 or 1% of total worldwide annual turnover, whichever is higher</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_99"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_35">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 35</rdfs:label>
    <skos:definition xml:lang="en">Article concerning identification numbers and lists of notified bodies</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROFESSIONAL_INTEGRITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PROFESSIONAL INTEGRITY</rdfs:label>
    <skos:definition xml:lang="en">A standard of conduct requiring notified bodies to carry out tasks with the highest degree of integrity and requisite competence</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATURAL_PERSONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">NATURAL PERSONS</rdfs:label>
    <skos:definition xml:lang="en">**NATURAL PERSONS** under the scope of the Act are individuals residing within the Union whose fundamental rights, dignity, and protection against non-discrimination are safeguarded against the potential harms of artificial intelligence. These individuals are explicitly shielded by the regulation from prohibited AI practices, such as manipulative profiling and intrusive emotion recognition. 

Furthermore, the Act specifically protects Natural Persons whose biometric data, social behavior, or per</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEMS_FOR_EMOTION_INFERENCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESPONSE_MECHANISMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RESPONSE MECHANISMS</rdfs:label>
    <skos:definition xml:lang="en">Mechanisms required in the sandbox to promptly mitigate risks to data subjects and stop processing if necessary</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DOWNSTREAM_PROVIDER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">DOWNSTREAM PROVIDER</rdfs:label>
    <skos:definition xml:lang="en">A "Downstream Provider" refers to an entity that integrates or utilizes an AI system—including general-purpose AI (GPAI) systems—that has been built upon or incorporates an upstream AI model. These providers sit further down the AI supply chain, taking foundational models and integrating them into their own distinct AI products or services.

Because Downstream Providers rely on the underlying technology provided by upstream model developers, they depend on receiving specific information from tho</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_SOLUTIONS_FOR_MARKING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLAINT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#LABELING_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_84">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 84</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 84** pertains to the framework for Union AI testing support activities, specifically addressing the designation and responsibilities of the relevant support structures. It outlines the mandate for these entities to facilitate the testing of artificial intelligence systems, ensuring that there is a formal and organized approach to evaluating AI technologies within the Union. By defining both the status and the specific tasks of these Union AI testing support structures, Article 84 estab</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EVENT_RECORDING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EVENT RECORDING</rdfs:label>
    <skos:definition xml:lang="en">The specific duty to capture start and end dates/times, input data, and search results for high-risk AI systems under Article 12(3)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SIGNIFICANT_DESIGN_CHANGE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SIGNIFICANT DESIGN CHANGE</rdfs:label>
    <skos:definition xml:lang="en">A trigger condition for existing high-risk AI systems to become subject to this Regulation if they undergo major design modifications after 2 August 2026 (Article 111(2))</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NON_HIGH_RISK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">NON-HIGH-RISK</rdfs:label>
    <skos:definition xml:lang="en">Classification status granted to AI systems that would normally be high-risk but satisfy the specified exclusion conditions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUBSTANTIAL_MODIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">SUBSTANTIAL MODIFICATION</rdfs:label>
    <skos:definition xml:lang="en">A "Substantial Modification" refers to a specific type of alteration made to a high-risk AI system, such as changes to its software architecture or its intended purpose. When such a modification occurs, it triggers a regulatory requirement for the system to undergo a new conformity assessment to ensure it remains compliant. Furthermore, the act of implementing a substantial modification carries significant legal implications: the party responsible for making these changes is legally considered t</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_III__SECTION_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_6"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INFORMATION_DISCLOSURE_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">INFORMATION DISCLOSURE OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Duty to draw up and make available information and documentation for downstream providers of AI systems per Article 53(1)(b).</skos:definition>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_XII"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_HARMONISATION_LEGISLATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">UNION HARMONISATION LEGISLATION</rdfs:label>
    <skos:definition xml:lang="en">**Union Harmonisation Legislation** refers to an established framework of European Union legislative acts designed to govern product safety across a wide range of sectors. This collection of existing rules—which includes specific regulations and directives such as Regulation (EC) No 300/2008, Regulation (EU) No 167/2013, and Directive 2014/90/EU—covers a diverse array of products, including machinery, toys, and medical devices. Much of this legislation is rooted in the "New Legislative Framework</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_49"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_I"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIAS_DETECTION_AND_CORRECTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">BIAS DETECTION AND CORRECTION</rdfs:label>
    <skos:definition xml:lang="en">**BIAS DETECTION AND CORRECTION** refers to the critical obligation to assess, identify, and mitigate biases within datasets, particularly those utilized in high-risk artificial intelligence systems. This process is essential for ensuring fairness and preventing discriminatory outcomes in algorithmic decision-making. 

Because achieving this level of fairness often requires analyzing sensitive information, BIAS DETECTION AND CORRECTION functions as a specific, legally recognized objective that p</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_10"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_BIAS_MITIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CONFORMITY ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">Conformity Assessment is a critical mandatory procedure within the framework of the EU AI Act designed to verify and demonstrate that high-risk AI systems meet all prescribed regulatory requirements. This procedural requirement must be satisfied before a high-risk AI system is placed on the market or put into service, and it is also required following any substantial modification to the system.

The core purpose of Conformity Assessment is to ensure that the obligations set out in the AI Act—spe</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION_ON_HORIZONTAL_CYBERSECURITY_REQUIREMENTS_FOR_PRODUCTS_WITH_DIGITAL_ELEMENTS"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_III__SECTION_2"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_43"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_858">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2018/858</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2018/858 is the primary legislative framework concerning the approval and market surveillance of motor vehicles and their trailers, as well as the systems, components, and separate technical units intended for such vehicles. This regulation establishes a comprehensive set of rules ensuring that vehicles and their associated parts meet rigorous safety and performance standards before they can be placed on the market.

Furthermore, the regulation has been updated to address modern </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WRITTEN_MANDATE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">WRITTEN MANDATE</rdfs:label>
    <skos:definition xml:lang="en">A legal requirement for providers established in third countries to appoint an authorised representative in the Union via a written mandate (Recital 82)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_INSTITUTIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">UNION INSTITUTIONS</rdfs:label>
    <skos:definition xml:lang="en">**UNION INSTITUTIONS** are designated as EU bodies, offices, or agencies that operate as deployers of technology or systems. In this capacity, they are held to the same registration obligations as public authorities. Furthermore, these institutions are subject to regulatory oversight by the European Data Protection Supervisor, which possesses the authority to issue potential fines to them to ensure strict compliance with the relevant Regulations.</skos:definition>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REASONABLY_FORESEEABLE_MISUSE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">REASONABLY FORESEEABLE MISUSE</rdfs:label>
    <skos:definition xml:lang="en">Use of an AI system not in accordance with its intended purpose, potentially resulting from human behavior or interaction with other systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EVALUATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EVALUATION</rdfs:label>
    <skos:definition xml:lang="en">The process conducted by the AI Office, potentially involving independent experts, to assess compliance of general-purpose AI models</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#APPLICATION_FOR_NOTIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">APPLICATION FOR NOTIFICATION</rdfs:label>
    <skos:definition xml:lang="en">The formal submission by a conformity assessment body to a notifying authority to become a notified body, including proof of competence, accreditation, and descriptions of activities, as per Article 29</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_29"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_ARTIFICIAL_INTELLIGENCE_BOARD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">EUROPEAN ARTIFICIAL INTELLIGENCE BOARD</rdfs:label>
    <skos:definition xml:lang="en">The European Artificial Intelligence Board (often referred to simply as "the Board") is a central governing and advisory body established under the AI Act. Composed of representatives from Member States, with participation from the AI Office and the European Data Protection Supervisor (EDPS), the Board serves a critical function in the uniform application and enforcement of AI regulations across the European Union.

The Board’s primary mandate is to facilitate consistency, coordination, and coop</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_LITERACY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MEMBER_STATES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADVISORY_FORUM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STANDING_SUBGROUP_FOR_MARKET_SURVEILLANCE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EXIT_REPORT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STANDING_SUB_GROUPS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFYING_AUTHORITIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DELEGATED_ACT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_IN_REAL_WORLD_CONDITIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_I"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_7"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODELS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOXES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_OFFICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_STANDARDS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMON_SPECIFICATIONS"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_65"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_66"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_67"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_57"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_59"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_60"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_71"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_73"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_74_11_"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_112"/>
    <euai:conductsEvaluationOf rdf:resource="https://w3id.org/euaiact/ontology#SERIOUS_INCIDENT"/>
    <euai:conductsEvaluationOf rdf:resource="https://w3id.org/euaiact/ontology#EU_DATABASE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_FROM_HIGH_RISK_CLASSIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION FROM HIGH-RISK CLASSIFICATION</rdfs:label>
    <skos:definition xml:lang="en">The principle that AI systems which do not materially influence decision-making outcomes (e.g., narrow procedural tasks, improvement of human activity) may not be considered high-risk (Recital 53)</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_5">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 5</rdfs:label>
    <skos:definition xml:lang="en">**Article 5** of the AI Act serves as a foundational provision governing prohibited AI practices. It establishes a definitive list of AI systems and practices that are banned within the European Union, primarily due to their unacceptable risk to fundamental rights and societal values.

Central to the scope of Article 5 are specific prohibitions regarding biometric identification and categorization. These include restrictions on predictive policing, untargeted scraping of facial images from the i</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TFEU"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_PROHIBITED_PRACTICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONTENT_GENERATION_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">CONTENT GENERATION AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems (including general-purpose AI models) capable of generating synthetic content. Providers are required to embed technical marking and detection solutions to verify AI-generated content.</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#MARKING_AND_DETECTION_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">GENERAL-PURPOSE AI MODEL</rdfs:label>
    <skos:definition xml:lang="en">A General-Purpose AI (GPAI) model is defined as an AI model that displays significant generality and is capable of competently performing a wide range of distinct tasks, regardless of the manner in which it is placed on the market. These models are typically trained with large amounts of data using self-supervision at scale and can be integrated into a variety of downstream systems or applications. Notably, GPAI models serve as the foundational architecture upon which many other AI systems are b</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_97"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITALS_106_110"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK_THRESHOLD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TEXT_AND_DATA_MINING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISKS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPUTE_THRESHOLD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLIANCE_WITH_THE_REGULATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ENERGY_EFFICIENT_DEVELOPMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PRESUMPTION_OF_CONFORMITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMON_SPECIFICATIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_IMPACT_CAPABILITIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLIANCE_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INPUT_AND_OUTPUT_MODALITIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MODEL_CAPABILITY_EVALUATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNAL_MARKET_IMPACT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#USER_REACH_METRIC"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPUTE_METRIC"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MODALITY_THRESHOLD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CAPABILITY_BENCHMARK"/>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK"/>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_51"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#RESEARCH_AND_PROTOTYPING_EXCLUSION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_RELATED_REQUIREMENTS"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_COPYRIGHT_LAW"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_V"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNAL_MARKET_IMPACT_CRITERION"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_V__SECTIONS_2_AND_3"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_51_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(51)</rdfs:label>
    <skos:definition xml:lang="en">Definition of non-personal data</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RISK MANAGEMENT MEASURES</rdfs:label>
    <skos:definition xml:lang="en">Appropriate and targeted actions adopted to address identified risks, ensuring residual risk is acceptable, as described in Article 9(2)(d) and 9(5)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RESIDUAL_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_13"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_VII">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER VII</rdfs:label>
    <skos:definition xml:lang="en">A section of the Regulation that applies from 2 August 2025 according to Article 113.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_113"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">LAW ENFORCEMENT AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">A **Law Enforcement Authority**, as defined in Article 3(45), is a public body or authority entrusted by Member State law with the prevention, investigation, detection, or prosecution of criminal offenses, or the execution of criminal penalties. Tasked with maintaining public security and criminal justice, these entities are increasingly integrating AI systems into their operational functions.

When utilizing AI technologies, particularly high-risk AI systems, Law Enforcement Authorities are sub</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_TIME_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_EXCEPTIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PRIOR_AUTHORISATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#URGENCY_EXCEPTION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REFERENCE_DATABASE_OF_PERSONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISATION_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#URGENT_DEPLOYMENT_AUTHORISATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_SUPPORT_AI"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION_IN_DATABASE"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#SYSTEM_REGISTRATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#DATABASE"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#EU_DATABASE_REGISTRATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#DOCUMENTATION_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISATION_FOR_EXCEPTIONAL_USE"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_LAW"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_LAW_ENFORCEMENT_VICTIM_ASSESSMENT"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_POLYGRAPHS_IN_LAW_ENFORCEMENT"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_EVIDENCE_EVALUATION_IN_LAW_ENFORCEMENT"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_OFFENDING_RISK_ASSESSMENT"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_LAW_ENFORCEMENT_PROFILING"/>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#URGENT_DEPLOYMENT_EXCEPTION"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_45_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_26">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 26</rdfs:label>
    <skos:definition xml:lang="en">Article 26 defines the specific obligations for deployers of high-risk AI systems. As a regulatory provision, it outlines the requirements and responsibilities that entities or individuals must adhere to when utilizing AI systems that have been classified as high-risk. By specifying these duties, the article ensures that deployers operate within a defined framework of accountability and compliance when implementing such technologies.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_14">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 14</rdfs:label>
    <skos:definition xml:lang="en">Recital 14 serves as a formal provision that references external regulations to establish a precise definition for the term "biometric data." By incorporating these external standards, Recital 14 ensures clarity and consistency in the interpretation of biometric information within the applicable legal framework.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMERGENCY_SERVICE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EMERGENCY SERVICE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems used to evaluate and classify emergency calls, dispatch, or establish priority for emergency services like police, fire, and medical aid</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXEMPTION_FOR_POINT_2_OF_ANNEX_III">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXEMPTION FOR POINT 2 OF ANNEX III</rdfs:label>
    <skos:definition xml:lang="en">A specific condition exempting certain high-risk AI systems from the registration obligation under Article 49(1) and 49(3)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANCILLARY_FEATURE_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">ANCILLARY FEATURE EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">Condition under which a biometric categorisation system is excluded from regulation if the feature is purely ancillary, intrinsically linked to a principal commercial service, and not a means of circumventing the Regulation.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ONLINE_MARKETPLACE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SOCIAL_NETWORK_SERVICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEMS_FOR_PREDICTING_CRIMINAL_BEHAVIOUR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEMS FOR PREDICTING CRIMINAL BEHAVIOUR</rdfs:label>
    <skos:definition xml:lang="en">Systems that assess the likelihood of offending based solely on profiling, personality traits, or characteristics, which are prohibited under Recital 42.</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_PREDICTIVE_RISK_ASSESSMENTS"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HUMAN_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMMUNICATION_CAMPAIGNS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">COMMUNICATION CAMPAIGNS</rdfs:label>
    <skos:definition xml:lang="en">An obligation for the Commission to raise awareness about the obligations arising from the Regulation among providers and deployers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#USER_REACH_METRIC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">USER REACH METRIC</rdfs:label>
    <skos:definition xml:lang="en">The **USER REACH METRIC** serves as a quantitative measurement based on the total count of registered end-users. This metric is primarily utilized to evaluate and assess the overall scale, significance, and real-world impact of a general-purpose AI model. By tracking the number of users who have registered, organizations can determine the extent of a model's reach and its influence within its target audience.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FEEDBACK_LOOPS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">FEEDBACK LOOPS</rdfs:label>
    <skos:definition xml:lang="en">**FEEDBACK LOOPS** represent a critical risk mechanism within learning systems where the data outputs generated by a model subsequently influence the inputs for future operations. This cyclical process creates a vulnerability where biased outputs can be fed back into the system, potentially leading to bias amplification. Because of this inherent risk, providers of learning systems are required to actively mitigate these loops to ensure that biased information does not compromise future system op</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_100">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 100</rdfs:label>
    <skos:definition xml:lang="en">Article 100 serves as the specific regulatory provision governing the imposition and calculation of administrative fines applicable to Union institutions, bodies, offices, and agencies. This article outlines the framework and procedures for these entities regarding financial penalties, ensuring a standardized approach within the context of their administrative obligations.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMMON_SPECIFICATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">COMMON SPECIFICATIONS</rdfs:label>
    <skos:definition xml:lang="en">An exceptional fall-back solution established by the Commission via implementing acts to facilitate provider compliance when harmonised standards are absent, insufficient, or delayed</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STANDARDISATION_REQUEST"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_41"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SECTION_2_OF_CHAPTER_II"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_V__SECTIONS_2_AND_3"/>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#PRESUMPTION_OF_CONFORMITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CODE_OF_CONDUCT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#CodeOfPractice"/>
    <rdfs:label xml:lang="en">CODE OF CONDUCT</rdfs:label>
    <skos:definition xml:lang="en">The "Code of Conduct" serves as a voluntary instrument designed to enhance the ethical development and deployment of artificial intelligence. It primarily targets providers of AI systems that are not classified as high-risk, encouraging these entities to voluntarily adopt the mandatory requirements established for high-risk AI systems. By doing so, the Code of Conduct promotes consistency in safety and ethical standards across the broader AI landscape.

As outlined in Article 95 of the relevant </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_LITERACY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STAKEHOLDERS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#VOLUNTARY_CODES_OF_CONDUCT_EVALUATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_ETHICAL_GUIDELINES_FOR_TRUSTWORTHY_AI"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ENVIRONMENTAL_SUSTAINABILITY_REQUIREMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INCLUSIVE_AND_DIVERSE_DESIGN"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NEGATIVE_IMPACT_ASSESSMENT"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER_OF_GENERAL_PURPOSE_AI_MODEL"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#NON_HIGH_RISK_AI_SYSTEM"/>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#MANDATORY_REQUIREMENTS"/>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#UNION_ETHICS_GUIDELINES_FOR_TRUSTWORTHY_AI"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_95"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROSPECTIVE_PROVIDER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PROSPECTIVE PROVIDER</rdfs:label>
    <skos:definition xml:lang="en">A "Prospective Provider" is a natural or legal person—such as an SME, start-up, or other innovator—that intends to develop, place on the market, or deploy an AI system within the Union. This status characterizes entities currently in the preparatory phases of AI development or implementation rather than those who have already finalized their product.

Prospective Providers are subject to specific regulatory requirements, particularly those concerning the submission and adherence to real-world te</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPETENT_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING_PLAN"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INFORMED_CONSENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EXEMPTION_FROM_FINES_FOR_OTHER_LAW"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_AND_EXPERIMENTATION_FACILITY"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#MITIGATION_OF_SIGNIFICANT_RISKS"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#EU_DATABASE"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#WRITTEN_AGREEMENT"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#EXEMPTION_FROM_ADMINISTRATIVE_FINES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECORDS_OF_PROCESSING_ACTIVITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RECORDS OF PROCESSING ACTIVITIES</rdfs:label>
    <skos:definition xml:lang="en">Documentation of processing activities which must include the reasons why the processing of special categories of personal data was strictly necessary</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROCESSING_OF_SPECIAL_CATEGORIES_OF_PERSONAL_DATA"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_53">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 53</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 53** serves as a foundational provision regarding the regulatory requirements for providers of general-purpose AI (GPAI) models. It establishes a comprehensive framework of obligations aimed at ensuring accountability and clarity in the development and deployment of these technologies.

Specifically, **ARTICLE 53** mandates rigorous transparency obligations for providers of general-purpose AI models. These requirements are designed to ensure that downstream providers and other relevant</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER_OF_GENERAL_PURPOSE_AI_MODELS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_XII"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_81">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 81</rdfs:label>
    <skos:definition xml:lang="en">Article 81 serves as the governing provision for the Union safeguard procedure. It establishes the formal mechanism for evaluating and handling national measures taken against AI systems, providing the necessary framework for ensuring consistent oversight and regulatory compliance across the Union.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MICROENTERPRISES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">MICROENTERPRISES</rdfs:label>
    <skos:definition xml:lang="en">Small enterprises (as defined by Recommendation 2003/361/EC) that may benefit from simplified compliance procedures for quality management systems under Article 63</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#QUALITY_MANAGEMENT_SYSTEM"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_9_TO_15_AND_72_TO_73"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_6_3_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 6(3)</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 6(3)** is a regulatory provision that outlines the framework for classifying AI systems, specifically focusing on the threshold between systems deemed "high-risk" and those that are not. 

This article plays a crucial role in the classification process by establishing the conditions under which an AI system is designated as high-risk, often by referencing criteria found in Annex III. Conversely, it serves as the definitive reference point for determining whether an AI system falls outs</skos:definition>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IDENTITY_CHECK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">IDENTITY CHECK</rdfs:label>
    <skos:definition xml:lang="en">IDENTITY CHECK refers to the authorized procedural process of identifying individuals who are either unable or unwilling to provide proof of identity. This measure is preserved under both Union and national law, ensuring that specific designated authorities retain the power to verify the identities of such persons.

As a functional capability, IDENTITY CHECK is designated for use by key state actors, including law enforcement, border control, immigration, and asylum authorities. By maintaining t</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ESSENTIAL_PUBLIC_SERVICES_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">ESSENTIAL PUBLIC SERVICES AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">**ESSENTIAL PUBLIC SERVICES AI SYSTEM**

The ESSENTIAL PUBLIC SERVICES AI SYSTEM refers to artificial intelligence technologies utilized by public authorities to make critical determinations regarding individual eligibility for vital services and support. These systems play a central role in managing access to essential resources, including healthcare, social security, and housing assistance. Due to the significant impact these decisions have on the lives and well-being of citizens, such AI syst</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_SERVICES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CYBERSECURITY_MEASURES_FOR_DATA_PROTECTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CYBERSECURITY MEASURES FOR DATA PROTECTION</rdfs:label>
    <skos:definition xml:lang="en">Mandatory technical and organizational measures to ensure the security and confidentiality of information obtained by authorities</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ENVIRONMENTAL_SUSTAINABILITY_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ENVIRONMENTAL SUSTAINABILITY REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">A specific requirement for codes of conduct involving the assessment and minimization of impact on environmental sustainability, as per Article 95(2)(b)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVIDER_NOTIFICATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROVIDER NOTIFICATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The requirement for the notified body to inform concerned providers within 10 days of a suspension or restriction.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMMON_SPECIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">COMMON SPECIFICATION</rdfs:label>
    <skos:definition xml:lang="en">A set of technical specifications as defined in Article 2, point (4) of Regulation (EU) No 1025/2012 that provides means to comply with certain requirements established under this Regulation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_PARLIAMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">EUROPEAN PARLIAMENT</rdfs:label>
    <skos:definition xml:lang="en">The European Parliament is a central legislative body within the European Union that serves as one of the co-legislating institutions responsible for the adoption of Regulation (EU) 2024/1689 (the AI Act). 

Beyond its legislative function, the European Parliament plays a critical role in oversight and governance. It is the institution empowered to revoke delegated acts, oppose extensions of delegation, or object to specific delegated acts, ensuring democratic control over regulatory implementat</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2024_1689"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DELEGATED_ACT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1139">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2018/1139</rdfs:label>
    <skos:definition xml:lang="en">**REGULATION (EU) 2018/1139** serves as the foundational legal framework establishing common rules in the field of civil aviation and creating the European Union Aviation Safety Agency (EASA). Its primary purpose is to ensure a high and uniform level of civil aviation safety throughout the European Union.

To keep pace with technological advancements, the regulation has been updated to address modern challenges. Notably, REGULATION (EU) 2018/1139 was amended by Article 108 to explicitly incorpor</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_UNION_AVIATION_SAFETY_AGENCY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INDEPENDENT_EXPERT">
    <euai:conductsEvaluationOf rdf:resource="https://w3id.org/euaiact/ontology#EVALUATION"/>
    <rdfs:label xml:lang="en">INDEPENDENT EXPERT</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MACHINERY_DIRECTIVE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">MACHINERY DIRECTIVE</rdfs:label>
    <skos:definition xml:lang="en">The Machinery Directive, formally known as Directive 2006/42/EC, is a foundational piece of European Union legislation established to regulate product safety for machinery. This directive serves as a critical regulatory framework that manufacturers and providers must adhere to when placing machinery on the market. Furthermore, Directive 2006/42/EC is increasingly recognized as a key piece of legislation regarding the governance and safety compliance of product safety components that involve the </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HIGH_IMPACT_CAPABILITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">HIGH-IMPACT CAPABILITIES</rdfs:label>
    <rdfs:label xml:lang="en">HIGH IMPACT CAPABILITIES</rdfs:label>
    <skos:definition xml:lang="en">"High-impact capabilities" refer to the specific functionalities within a general-purpose AI model that equal or surpass those found in the most advanced existing models. These capabilities serve as a critical benchmark for evaluating and classifying systemic risk, acting as a primary indicator for determining whether such models possess the potential to cause significant harm.</skos:definition>
    <skos:definition xml:lang="en">A classification category for GPAI models that meet specific computational thresholds or equivalent impact criteria, triggering notification obligations (Article 51(1))</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISKS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_SPECIFICATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TECHNICAL SPECIFICATIONS</rdfs:label>
    <skos:definition xml:lang="en">Technical standards to be applied, including harmonised standards, ensuring compliance with Section 2 requirements (Article 17(2)(e)).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MANDATE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">MANDATE</rdfs:label>
    <skos:definition xml:lang="en">The legal instrument establishing the relationship between the provider and the authorised representative, empowering the representative to perform specific tasks.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPLEMENTING_ACT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#DelegatedAct"/>
    <rdfs:label xml:lang="en">IMPLEMENTING ACT</rdfs:label>
    <skos:definition xml:lang="en">The "IMPLEMENTING ACT" is a specific type of legal instrument adopted by the European Commission to ensure the uniform application and enforcement of regulations across member states. It serves as a versatile tool used by the Commission to address various operational and regulatory needs, ranging from administrative templates to scientific oversight and the standardization of technical rules.

In its regulatory capacity, the IMPLEMENTING ACT is utilized to establish common specifications for pro</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_98_2_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#OFFICIAL_JOURNAL_OF_THE_EUROPEAN_UNION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SCIENTIFIC_PANEL"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_56_6_"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_OF_CHAPTER_III_SECTION_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_98">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 98</rdfs:label>
    <skos:definition xml:lang="en">**Article 98** serves as the regulatory provision that establishes and governs the committee procedure designed to assist the European Commission in its functions. By outlining the framework for this committee procedure, Article 98 ensures a structured approach for the Commission to receive necessary support and oversight during its decision-making and implementation processes.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SEPARATE_VERIFICATION_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SEPARATE VERIFICATION REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">Requirement for at least two natural persons to verify and confirm identification resulting from certain high-risk AI systems (Annex III point 1(a)), with specific exemptions for law enforcement/migration contexts</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_14"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NationalCompetentAuthority">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">National Competent Authority</rdfs:label>
    <skos:definition xml:lang="en">A Member State authority designated to supervise application of the Act. (Article 70)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REAL_TIME_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">REAL-TIME REMOTE BIOMETRIC IDENTIFICATION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The **Real-Time Remote Biometric Identification System** is a sophisticated AI technology defined as a remote biometric identification system where the capturing, comparison, and identification of biometric data occur instantaneously or near-instantaneously without significant delay. This process utilizes live or "near-live" material, such as real-time video footage, to identify natural persons. 

Under the AI Act, these systems are categorized as high-risk and are subject to stringent oversight</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_17"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_33"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_42_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PUBLICLY_ACCESSIBLE_SPACE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_32"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CRITICAL_INFRASTRUCTURE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX__LIST_OF_CRIMINAL_OFFENCES_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADVERSE_LEGAL_EFFECT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_16_TFEU"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_10_OF_DIRECTIVE__EU_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_10_OF_DIRECTIVE__EU__2016_680"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_OBJECTIVES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PUBLICLY_ACCESSIBLE_SPACES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CRIMINAL_OFFENCES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HUMAN_OVERSIGHT"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_AI_PRACTICES"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CRIMINAL_OFFENCE_THRESHOLD"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISATION_REQUIREMENT"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PRIOR_AUTHORISATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ADVERSE_LEGAL_EFFECT_PROHIBITION"/>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OBLIGATION"/>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#DATA_DELETION_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MODEL_LIFECYCLE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MODEL LIFECYCLE</rdfs:label>
    <skos:definition xml:lang="en">The entire duration of a model's existence where providers must ensure cybersecurity and risk mitigation, as referenced in Recital 115</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CYBERSECURITY_PROTECTION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMOTION_RECOGNITION_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EMOTION RECOGNITION AI</rdfs:label>
    <skos:definition xml:lang="en">Emotion recognition AI encompasses artificial intelligence systems specifically designed and intended to identify, analyze, and interpret human emotions. These technologies are categorized under Annex III 1(c) of regulatory frameworks, such as the EU AI Act, which classifies them as high-risk systems due to their capacity to influence and interpret sensitive human behavioral and psychological data.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRICS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATORY_SANDBOXES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">REGULATORY SANDBOXES</rdfs:label>
    <skos:definition xml:lang="en">Testing environment for AI systems, applicable even to research and development activities that result in market placement</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_MERE_EXPRESSION_DETECTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION FOR MERE EXPRESSION DETECTION</rdfs:label>
    <skos:definition xml:lang="en">Condition under Recital 18 where systems detecting gestures, movements, or expressions are not considered emotion recognition systems unless those expressions are used to identify or infer emotions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATORY_AUTHORITIES_OF_THIRD_COUNTRIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">REGULATORY AUTHORITIES OF THIRD COUNTRIES</rdfs:label>
    <skos:definition xml:lang="en">Entities in third countries with whom the Commission or Member States may exchange confidential information under bilateral or multilateral arrangements</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPETENT_JUDICIAL_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">COMPETENT JUDICIAL AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">A judicial or independent administrative body that issues binding decisions, grants/rejects authorisations, and supervises the use of real-time remote biometric identification systems.</skos:definition>
    <euai:grants rdf:resource="https://w3id.org/euaiact/ontology#PRIOR_AUTHORISATION"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_93_MITIGATION_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ARTICLE 93 MITIGATION MEASURES</rdfs:label>
    <skos:definition xml:lang="en">Measures requested by the Commission to ensure compliance, address systemic risks, or restrict market access</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_53"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_54"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_92"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_16">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 16</rdfs:label>
    <skos:definition xml:lang="en">Recital defining 'biometric categorisation' and providing exclusions for ancillary features.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_TRAINING_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA TRAINING REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">Technical requirement for data used to train AI systems; non-compliance triggers mandatory re-training prior to new conformity assessment</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_III__SECTION_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LIABILITY_FOR_DAMAGE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">LIABILITY FOR DAMAGE</rdfs:label>
    <skos:definition xml:lang="en">Providers and prospective providers remain liable under Union and national law for damage inflicted on third parties during sandbox experimentation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_VII">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX VII</rdfs:label>
    <skos:definition xml:lang="en">**ANNEX VII**

ANNEX VII outlines the conformity assessment procedure utilized to verify that products meet regulatory standards. Specifically, ANNEX VII describes a process that centers on the thorough assessment of both the manufacturer's quality management system and the associated technical documentation. This procedure is a critical regulatory step, requiring oversight and evaluation by a notified body to ensure full compliance. Furthermore, ANNEX VII details the specific requirements for o</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPETENT_AUTHORITIES_FOR_FINANCIAL_SERVICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">COMPETENT AUTHORITIES FOR FINANCIAL SERVICES</rdfs:label>
    <skos:definition xml:lang="en">The Competent Authorities for Financial Services are the regulatory and supervisory bodies specifically mandated to oversee and enforce financial services law within the European Union. These authorities are formally defined under Regulation (EU) No 575/2013, as well as Directives 2008/48/EC, 2009/138/EC, and 2013/36/EU.

Beyond their established duties in the financial sector, these Competent Authorities for Financial Services have been designated to supervise the implementation and enforcement</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_575_2013"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_CENTRAL_BANK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_ECONOMIC_AND_SOCIAL_COMMITTEE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">EUROPEAN ECONOMIC AND SOCIAL COMMITTEE</rdfs:label>
    <skos:definition xml:lang="en">An advisory body that receives the enforcement assessment report from the Commission.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_49">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 49</rdfs:label>
    <skos:definition xml:lang="en">RECITAL 49 is a component of the AI Act preamble that addresses the necessary adjustments to existing legal frameworks. Specifically, this recital concerns the amendment of sector-specific Union harmonisation legislation to ensure that these existing laws are updated to incorporate the new requirements established by the AI Act, particularly those pertaining to high-risk AI systems. By integrating these obligations, RECITAL 49 ensures that the regulatory oversight of high-risk AI is consistently</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_20_OF_REGULATION__EU__2019_1020">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 20 OF REGULATION (EU) 2019/1020</rdfs:label>
    <skos:definition xml:lang="en">Specific article governing the procedure for national competent authorities to notify the Commission of serious incidents.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_III_POINT_1">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <rdfs:label xml:lang="en">ANNEX III POINT 1</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_II">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX II</rdfs:label>
    <skos:definition xml:lang="en">"ANNEX II" serves as a critical component within the legal framework governing Artificial Intelligence, specifically detailing a list of specific criminal offences. This Annex is directly referenced in Article 5(1), first subparagraph, point (h)(iii), of the relevant legislation. Its primary purpose is to define the precise scope of criminal activities that trigger specific legal considerations regarding the use of AI systems in law enforcement contexts. Furthermore, "ANNEX II" identifies the sp</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5_1__H__III_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CRIMINAL_OFFENCES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_56_6_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 56(6)</rdfs:label>
    <skos:definition xml:lang="en">Article referencing the procedure for the Commission to approve codes of practice</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STOP_BUTTON">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">STOP BUTTON</rdfs:label>
    <skos:definition xml:lang="en">A specific technical measure or procedure allowing natural persons to interrupt the system and bring it to a safe state</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ROAD_TRAFFIC_SAFETY_COMPONENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">ROAD TRAFFIC SAFETY COMPONENT</rdfs:label>
    <skos:definition xml:lang="en">AI systems used as safety components in the management and operation of road traffic (Annex III 2)</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#CRITICAL_INFRASTRUCTURE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#Deployer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Deployer</rdfs:label>
    <skos:definition xml:lang="en">A natural or legal person that uses an AI system under their authority. (Article 3(4))</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROTECTION_OF_CONFIDENTIAL_INFORMATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROTECTION OF CONFIDENTIAL INFORMATION</rdfs:label>
    <skos:definition xml:lang="en">Duty of authorities to protect intellectual property, trade secrets, public security, and confidential business information when carrying out their tasks</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION_2024_1689">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION 2024/1689</rdfs:label>
    <skos:definition xml:lang="en">Regulation 2024/1689, widely known as the EU Artificial Intelligence Act, serves as the definitive legislative framework governing artificial intelligence within the European Union. This regulation establishes a comprehensive system of harmonized rules designed to oversee the development, deployment, and utilization of artificial intelligence technologies.

By providing a structured classification system, Regulation 2024/1689 sets out clear standards for the regulation of various AI models. The </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_19"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_43"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_47"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_57"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_58"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_109"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_110"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1241">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2018/1241</rdfs:label>
    <skos:definition xml:lang="en">The legislative act amending Regulation (EU) 2016/794 to establish ETIAS.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_67">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 67</rdfs:label>
    <skos:definition xml:lang="en">Text defining requirements for high-quality data, data governance, and mitigation of bias for high-risk AI systems</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#DATA_SETS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PRIVACY_PRESERVING_TECHNIQUES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CERTIFIED_COMPLIANCE_SERVICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERNAL_PROCESS_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">INTERNAL PROCESS EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">The "INTERNAL PROCESS EXCLUSION" refers to a specific regulatory or policy exemption regarding model obligations. This condition establishes that providers of a model are exempt from certain requirements when they utilize their own model exclusively for internal processes. 

For this exclusion to apply, the usage must meet two primary criteria: 
1. The internal processes must not be essential for the provision of a product or service to third parties. 
2. The usage of the model must not adversel</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DOCUMENTATION_SUBMISSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DOCUMENTATION SUBMISSION</rdfs:label>
    <skos:definition xml:lang="en">Notified bodies are required to make available and submit upon request all relevant documentation, including provider documentation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_23">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 23</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 23** serves as a regulatory provision that outlines and defines the specific obligations required of importers. It establishes the mandatory responsibilities and duties that importers must adhere to within the context of the relevant framework.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">LAW ENFORCEMENT</rdfs:label>
    <skos:definition xml:lang="en">The category of "LAW ENFORCEMENT" is classified as a high-risk domain concerning the deployment of artificial intelligence systems. This domain encompasses any AI tools that are used by, or on behalf of, law enforcement authorities. 

Specifically, this area includes AI systems designed to perform critical functions such as assessing the risk of criminal victimization, evaluating evidence, and assessing the risk of reoffending or committing a crime. As detailed in Annex III(6), these high-risk a</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_RULES"/>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_46_"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_LAW_ENFORCEMENT_VICTIM_ASSESSMENT"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_POLYGRAPHS_IN_LAW_ENFORCEMENT"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_EVIDENCE_EVALUATION_IN_LAW_ENFORCEMENT"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_OFFENDING_RISK_ASSESSMENT"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_LAW_ENFORCEMENT_PROFILING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPETITION_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">COMPETITION AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">National authorities that receive annual reports regarding market surveillance information of potential interest for competition rules</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUPERVISORY_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">SUPERVISORY AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">Authorities responsible for the supervision of law enforcement and judicial authorities; they assess if international cooperation frameworks include adequate safeguards.</skos:definition>
    <euai:conductsEvaluationOf rdf:resource="https://w3id.org/euaiact/ontology#PUBLIC_AUTHORITIES_OF_A_THIRD_COUNTRY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_PROFILING_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">LAW ENFORCEMENT PROFILING AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems used for profiling in the course of detection, investigation, or prosecution of criminal offences</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2019_790">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE (EU) 2019/790</rdfs:label>
    <skos:definition xml:lang="en">Directive (EU) 2019/790, widely known as the Directive on Copyright and Related Rights in the Digital Single Market, is a significant piece of European Union legislation. It establishes a modernized legal framework designed to address copyright challenges within the evolving digital landscape.

The directive is instrumental in defining various copyright exceptions and limitations that are applicable across the EU. Notably, it plays a key role in regulating text and data mining (TDM) activities, </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ConformityAssessment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Conformity Assessment</rdfs:label>
    <skos:definition xml:lang="en">The process to demonstrate a high-risk AI system meets the requirements. (Article 43)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_23_3_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 23(3)</rdfs:label>
    <skos:definition xml:lang="en">Specifies obligations of the importer regarding labeling and contact information</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SCIENTIFIC_PANEL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">SCIENTIFIC PANEL</rdfs:label>
    <skos:definition xml:lang="en">The **Scientific Panel** is a body of independent experts established by the Commission to support the implementation and enforcement of the AI Act. Its primary purpose is to integrate the broader scientific community into the regulation’s operational framework.

Specifically, the Scientific Panel is established pursuant to Article 68 and plays a crucial role in assisting the Commission with evaluations, as referenced in Article 92. Its mandate includes supporting enforcement and regulatory acti</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#QUALIFIED_ALERTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_ARTIFICIAL_INTELLIGENCE_BOARD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MEMBER_STATES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DECLARATION_OF_INTERESTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_81"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#QUALIFIED_ALERT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_68_2_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_92_EVALUATIONS"/>
    <euai:providesInstructionsTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#AI_OFFICE"/>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#CONCRETE_AND_IDENTIFIABLE_RISK"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#IMPARTIALITY_AND_OBJECTIVITY_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFICATION_OBJECTION_DEADLINE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NOTIFICATION OBJECTION DEADLINE</rdfs:label>
    <skos:definition xml:lang="en">The timeframe within which the Commission or other Member States may raise objections to a notification: two weeks if based on accreditation, two months if based on documentary evidence, as per Article 30(4)</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_30"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_SAFEGUARD_PROCEDURE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">UNION SAFEGUARD PROCEDURE</rdfs:label>
    <skos:definition xml:lang="en">The Union Safeguard Procedure is a formal regulatory mechanism defined under Article 81 of the relevant legislation. Within this framework, the European Commission is tasked with evaluating specific national measures implemented by market surveillance authorities in response to concerns regarding AI systems. This procedure serves as a structured oversight process, ensuring that actions taken against AI systems at a national level are subject to central review and assessment by the Commission.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_81"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SAFEGUARD_PROCEDURE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SAFEGUARD PROCEDURE</rdfs:label>
    <skos:definition xml:lang="en">A specific enforcement mechanism for ensuring adequate and timely action against AI systems that present a risk to health, safety, or fundamental rights.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_TO_HEALTH__SAFETY_OR_FUNDAMENTAL_RIGHTS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NON_COMPLIANCE_PROCEDURE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NON-COMPLIANCE PROCEDURE</rdfs:label>
    <skos:definition xml:lang="en">Procedure for addressing non-compliance, including reporting to the Commission and other Member States, and taking restrictive measures such as withdrawal from the market</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_79"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_72">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 72</rdfs:label>
    <skos:definition xml:lang="en">Article 72 serves as a critical regulatory provision within the legal framework governing artificial intelligence, specifically focusing on the post-market monitoring of AI systems. Its primary objective is to establish comprehensive requirements for the post-market monitoring systems that providers of high-risk AI systems must implement.

By formalizing these requirements, Article 72 functions as the legal basis for ensuring ongoing oversight and accountability after an AI system has been deplo</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SAFETY_COMPONENT_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">SAFETY COMPONENT AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">**Safety Component AI Systems**

A Safety Component AI System is defined as an artificial intelligence system that functions as a safety component of a product, or serves as a product in its own right. These systems are specifically characterized by their role in ensuring the safe operation of the technology they are integrated into or constitute. Due to the critical nature of their function, these AI systems are subject to Union harmonization legislation. When an AI system acts as a safety comp</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_47"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_HARMONISATION_LEGISLATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_CLASSIFICATION_RULE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2002_58_EC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2002/58/EC</rdfs:label>
    <skos:definition xml:lang="en">Directive 2002/58/EC is the European Union’s directive focused on privacy and electronic communications. Its primary purpose is to protect the private life of individuals and ensure the confidentiality of their communications across electronic networks. 

This directive remains highly relevant to the evolving technological landscape, particularly regarding artificial intelligence (AI) systems. It serves as a critical regulatory framework for AI systems that operate within the electronic communic</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PRODUCT_SAFETY_COMPONENT_RULE">
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_HARMONISATION_LEGISLATION_PRODUCTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_BODY"/>
    <rdfs:label xml:lang="en">PRODUCT SAFETY COMPONENT RULE</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ALTERNATIVE_ADEQUATE_MEANS_OF_COMPLIANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ALTERNATIVE ADEQUATE MEANS OF COMPLIANCE</rdfs:label>
    <skos:definition xml:lang="en">A mechanism for providers who do not follow codes of practice or harmonised standards to prove compliance, subject to Commission assessment per Article 53(4).</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LIMITATION_DEROGATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">LIMITATION DEROGATIONS</rdfs:label>
    <skos:definition xml:lang="en">Provisions to avoid overlaps by integrating quality management system and monitoring obligations of the AI Act into existing procedures under financial services law for credit/insurance institutions</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATED_FINANCIAL_INSTITUTIONS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GUIDANCE_AND_ADVICE_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">GUIDANCE AND ADVICE OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The potential duty/power of national competent authorities to provide guidance on the implementation of the Regulation, particularly to SMEs and start-ups.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_ASSISTIVE_FUNCTIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION FOR ASSISTIVE FUNCTIONS</rdfs:label>
    <skos:definition xml:lang="en">Exemption from labeling obligations for AI systems performing primarily assistive functions for standard editing or not substantially altering input/semantics</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EDUCATION_LEVEL_ASSESSMENT_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EDUCATION LEVEL ASSESSMENT AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems assessing appropriate level of education individuals will receive or access (Annex III 3(c))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EDUCATION_AND_VOCATIONAL_TRAINING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUBLIC_ASSISTANCE_ELIGIBILITY_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">PUBLIC ASSISTANCE ELIGIBILITY AI</rdfs:label>
    <skos:definition xml:lang="en">AI system used by public authorities to evaluate eligibility for essential public benefits and services.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_I_PRODUCT_SAFETY_COMPONENT_RULE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">ANNEX I PRODUCT SAFETY COMPONENT RULE</rdfs:label>
    <skos:definition xml:lang="en">Rule where an AI system is a safety component of, or is itself, a product covered by Union harmonisation legislation listed in Annex I and requires third-party conformity assessment</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_79">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 79</rdfs:label>
    <skos:definition xml:lang="en">Article 79 establishes a comprehensive legal framework for addressing AI systems that present risks to health, safety, or fundamental rights, even when those systems are ostensibly in compliance with regulatory requirements. Serving as a crucial mechanism for safeguarding the public, this article defines the procedure at the national level for competent authorities to handle AI systems that, despite being compliant, still pose a risk.

Furthermore, Article 79 details the enforcement procedures n</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_59">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 59</rdfs:label>
    <skos:definition xml:lang="en">**Article 59** refers to a specific legal provision that functions as an essential component within the framework of artificial intelligence regulation. Primarily, this article governs the processing of personal data necessary for the development of certain AI systems that are designed to operate in the public interest, specifically within the environment of an AI regulatory sandbox. 

Furthermore, Article 59 plays a significant role in the administration of these sandboxes by establishing that </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COURT_OF_JUSTICE_OF_THE_EUROPEAN_UNION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">COURT OF JUSTICE OF THE EUROPEAN UNION</rdfs:label>
    <skos:definition xml:lang="en">The Court of Justice of the European Union (CJEU) serves as the highest judicial body within the European Union. Its role encompasses the authority to review decisions made by the European Commission, particularly those established under the AI Act and other relevant regulations.

In exercising its judicial oversight, the Court possesses unlimited jurisdiction regarding penalties and fines. This authority empowers the Court to not only review Commission decisions but also to cancel, reduce, or i</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_261_TFEU"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_DATA_PROTECTION_SUPERVISOR"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FINE_IMPOSITION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">POST MARKET MONITORING</rdfs:label>
    <rdfs:label xml:lang="en">POST-MARKET MONITORING</rdfs:label>
    <skos:definition xml:lang="en">A duty of the provider to monitor the operation of a high-risk AI system after it has been placed on the market or put into service to ensure ongoing compliance and identify risks.</skos:definition>
    <skos:definition xml:lang="en">**Post-market monitoring** refers to the essential regulatory system designed to oversee the performance and associated risks of an artificial intelligence (AI) system after it has been officially placed on the market. As referenced in Article 72, this framework functions as an ongoing requirement that extends throughout the entire lifecycle of the AI system.

The primary objective of post-market monitoring is to ensure that AI systems maintain consistent standards and adhere to regulatory oblig</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_72"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_72"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WORKER_PERFORMANCE_MONITORING_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">WORKER PERFORMANCE MONITORING AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems used to monitor and evaluate performance and behaviour in work-related relationships (Annex III 4(b))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EMPLOYMENT__WORKERS__MANAGEMENT_AND_ACCESS_TO_SELF_EMPLOYMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CYBERSECURITY_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CYBERSECURITY REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">A cybersecurity requirement encompasses a multifaceted set of obligations designed to ensure robust protection within the digital landscape, particularly concerning artificial intelligence (AI) systems and the regulatory bodies governing them. 

For high-risk AI systems, cybersecurity requirements are mandatory. These systems must adhere to specific security standards as outlined in Article 15 of the governing regulations. A key mechanism for demonstrating compliance involves Regulation (EU) 201</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_27_OF_DIRECTIVE__EU__2016_680">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 27 OF DIRECTIVE (EU) 2016/680</rdfs:label>
    <skos:definition xml:lang="en">Article governing data protection impact assessments under the Law Enforcement Directive</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2019_1937">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE (EU) 2019/1937</rdfs:label>
    <skos:definition xml:lang="en">**DIRECTIVE (EU) 2019/1937** is a critical piece of legislation concerning the protection of persons who report breaches of Union law. It establishes a comprehensive framework for whistleblowing and complaint mechanisms, ensuring that individuals who report infringements are protected from retaliation.

Within the broader legal context—specifically regarding its interaction with other regulations such as the EU AI Act—DIRECTIVE (EU) 2019/1937 serves as an essential governance tool. It mandates t</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CIRCUMVENTION_PROHIBITION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CIRCUMVENTION PROHIBITION</rdfs:label>
    <skos:definition xml:lang="en">Requirement that integration of features or functionality must not be a means to circumvent the applicability of the rules of the AI Act.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANCILLARY_FEATURE_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LARGE_GENERATIVE_AI_MODEL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">LARGE GENERATIVE AI MODEL</rdfs:label>
    <skos:definition xml:lang="en">A typical example of a general-purpose AI model that allows for flexible generation of content like text, audio, images, or video, as described in Recital 99</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">MARKET SURVEILLANCE AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">The Market Surveillance Authority refers to the national competent authority or regulatory body designated by Member States to enforce, supervise, and implement the provisions of the AI Act. Acting as the primary point of contact for the enforcement of the Regulation, these bodies exercise their powers independently and impartially to ensure the safety, conformity, and compliance of AI systems within the Union market.

In their capacity as market regulators, these authorities are responsible for</skos:definition>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#ANNUAL_REPORTING"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OF_AUTHORISATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#WITHDRAWAL_OF_AUTHORISATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TESTING_OF_HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MEMBER_STATES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_30"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_1020"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRICS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT__MIGRATION__ASYLUM_AND_BORDER_CONTROL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATION_OF_JUSTICE_AND_DEMOCRATIC_PROCESSES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INVESTIGATIVE_AND_CORRECTIVE_POWERS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_OFFICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#JOINT_INVESTIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_ARTIFICIAL_INTELLIGENCE_BOARD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLAINT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DUTY_OF_INFORMATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EXIT_REPORT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING_PLAN"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EXTENSION_OF_TESTING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_IN_REAL_WORLD_CONDITIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_77_1_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_19_OF_REGULATION__EU__2019_1020"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_74"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AND_CONTROL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_I"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ACCESS_TO_SOURCE_CODE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFIDENTIALITY_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_III"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_VI"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_76"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SERIOUS_INCIDENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_77"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_PLAN"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EVALUATION_OF_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NON_COMPLIANCE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_TO_FUNDAMENTAL_RIGHTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DATABASE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_79"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_FINE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PRODUCT_COMPLIANCE"/>
    <euai:grants rdf:resource="https://w3id.org/euaiact/ontology#EXCEPTIONAL_PUBLIC_SECURITY_AUTHORISATION"/>
    <euai:grants rdf:resource="https://w3id.org/euaiact/ontology#DEROGATION_AUTHORISATION"/>
    <euai:grants rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISATION_FOR_EXCEPTIONAL_USE"/>
    <euai:conductsEvaluationOf rdf:resource="https://w3id.org/euaiact/ontology#NOTIFIED_BODY"/>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING_OBLIGATION"/>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#OPERATOR"/>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#FORMAL_NON_COMPLIANCE"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_74_8_"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_74_9_"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_83"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_PUBLIC_AUTHORITIES"/>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#PROVISIONAL_MEASURES"/>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#UNION_SAFEGUARD_PROCEDURE"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_18_OF_REGULATION__EU__2019_1020"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFICATION_OBLIGATION_TO_NATURAL_PERSONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NOTIFICATION OBLIGATION TO NATURAL PERSONS</rdfs:label>
    <skos:definition xml:lang="en">Duty for deployers to inform natural persons when they are subject to the use of a high-risk AI system, including the intended purpose and the type of decisions it makes (Recital 93)</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_13_OF_DIRECTIVE__EU__2016_680"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_75">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 75</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 75** serves as the regulatory framework governing mutual assistance, market surveillance, and the control of general-purpose AI systems. Within this scope, the article explicitly defines the powers and authority granted to market surveillance authorities, specifically regarding their capacity to conduct testing, perform inspections, and carry out enforcement actions to ensure compliance within the AI ecosystem.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_OFFICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_XII">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER XII</rdfs:label>
    <skos:definition xml:lang="en">A section of the Regulation that applies from 2 August 2025 according to Article 113.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_113"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FORMER_PROVIDER_COOPERATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">FORMER PROVIDER COOPERATION</rdfs:label>
    <skos:definition xml:lang="en">Former providers must provide information, technical access, and assistance to new providers to enable compliance, especially for conformity assessments.</skos:definition>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXEMPTION_FROM_FINES_FOR_OTHER_LAW">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXEMPTION FROM FINES FOR OTHER LAW</rdfs:label>
    <skos:definition xml:lang="en">Exemption from administrative fines regarding compliance with other Union and national law if other competent authorities were actively involved in sandbox supervision and guidance.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FREE_AND_OPEN_SOURCE_AI_COMPONENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">FREE AND OPEN-SOURCE AI COMPONENTS</rdfs:label>
    <skos:definition xml:lang="en">Software and data, including models and general-purpose AI models, tools, services, or processes of an AI system released under a free and open-source licence, as described in Recital 102 and 103</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_MEASURES"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_RELATED_REQUIREMENTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MONETISATION_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVIDER_OF_HIGH_RISK_AI_SYSTEMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PROVIDER OF HIGH-RISK AI SYSTEMS</rdfs:label>
    <skos:definition xml:lang="en">Legal or natural person responsible for placing high-risk AI systems on the market, required to implement post-market monitoring systems.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#regulatedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">regulated by</rdfs:label>
    <skos:definition xml:lang="en">Relates an actor or AI system to the authority overseeing it.</skos:definition>
    <rdfs:range rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MONETISATION_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">MONETISATION EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">The condition stating that AI components provided against a price, monetised through technical support/services, or using personal data (excluding microenterprises) do not benefit from open-source exceptions, as described in Recital 103</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SMES">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PUBLIC_AND_PRIVATE_ACTORS"/>
    <rdfs:label xml:lang="en">SMES</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING_PLAN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">REAL-WORLD TESTING PLAN</rdfs:label>
    <skos:definition xml:lang="en">A Real-World Testing Plan is a formal, mandatory document required for the testing of high-risk AI systems in real-world conditions outside of controlled sandbox environments. As defined under the regulatory framework (specifically Article 60 and Article 3(53)), this plan serves as a comprehensive roadmap for providers and prospective providers who intend to conduct such evaluations.

The document must clearly outline the objectives, methodology, scope, and monitoring procedures for the proposed</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_60"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#IMPLEMENTING_ACTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TACIT_APPROVAL"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MANIPULATIVE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">MANIPULATIVE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">An AI system that uses subliminal techniques or manipulative/deceptive practices to distort behavior (Article 5(1)(a))</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_MANIPULATIVE_TECHNIQUES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INDEPENDENT_ADMINISTRATIVE_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">INDEPENDENT ADMINISTRATIVE AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">An independent administrative body empowered to grant or reject express and specific authorisation for the use of real-time remote biometric identification systems.</skos:definition>
    <euai:grants rdf:resource="https://w3id.org/euaiact/ontology#PRIOR_AUTHORISATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DECISION_NO_768_2008_EC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DECISION NO 768/2008/EC</rdfs:label>
    <skos:definition xml:lang="en">Decision No 768/2008/EC is a significant legislative instrument that serves as a core component of the European Union's New Legislative Framework. It functions as a foundational decision establishing a common framework for the marketing of products, acting as a crucial legal basis for ensuring overall product compliance within the EU. Furthermore, it provides the essential rules and consistency required for the placing of products on the market, including those categorized as high-risk AI system</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2016_679__GDPR_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2016/679 (GDPR)</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2016/679, commonly known as the General Data Protection Regulation (GDPR), is a piece of European Union legislation designed to protect natural persons with regard to the processing of their personal data. It sets the foundational data processing obligations that must be adhered to by various technologies, including AI systems. Furthermore, this regulation remains fully in effect and remains unaffected by the introduction of the AI Act, continuing to serve as a primary framework </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_ELECTION_OR_REFERENDUM_INFLUENCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR ELECTION OR REFERENDUM INFLUENCE</rdfs:label>
    <skos:definition xml:lang="en">An AI system intended to be used to influence the outcome of an election or referendum or voting behaviour of natural persons. Classified as high-risk (Recital 62).</skos:definition>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_39_OF_THE_CHARTER"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2024_900"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ASYLUM_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">ASYLUM AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">The **ASYLUM AUTHORITY** is an organization tasked with managing asylum applications and processes. Within the scope of its duties, the **ASYLUM AUTHORITY** is legally permitted to perform identity checks, provided these actions are conducted in compliance with both Union and national laws. Furthermore, when the **ASYLUM AUTHORITY** operates in the capacity of a provider of high-risk AI systems, it is mandated to ensure that it maintains and provides access to all necessary technical documentati</skos:definition>
    <euai:grants rdf:resource="https://w3id.org/euaiact/ontology#IDENTITY_CHECK"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CENELEC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CENELEC</rdfs:label>
    <skos:definition xml:lang="en">European Committee for Electrotechnical Standardization, a permanent member of the advisory forum</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADVISORY_FORUM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_2_OF_TITLE_V_TEU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER 2 OF TITLE V TEU</rdfs:label>
    <skos:definition xml:lang="en">Chapter 2 of Title V of the Treaty on European Union (TEU) functions as the foundational legal framework governing the Union's Common Security and Defence Policy (CSDP). This section of the treaty establishes the operational and policy parameters for how the European Union approaches matters of collective security and defense. 

Beyond its general role in outlining the Union’s defence policy, Chapter 2 of Title V TEU is frequently cited as a significant legal instrument in contemporary policy de</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_18_OF_REGULATION__EU__2019_1020">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 18 OF REGULATION (EU) 2019/1020</rdfs:label>
    <skos:definition xml:lang="en">Article 18 of Regulation (EU) 2019/1020 serves as a critical legal provision that delineates the procedural rights afforded to concerned operators during market surveillance procedures. By establishing these rights, the regulation ensures that operators are afforded due process and necessary protections when their products are subject to regulatory oversight.

Furthermore, Article 18 of Regulation (EU) 2019/1020 is extended to the domain of artificial intelligence regulation. It applies *mutatis</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INPUT_AND_OUTPUT_MODALITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INPUT AND OUTPUT MODALITIES</rdfs:label>
    <skos:definition xml:lang="en">The specific modes of data handling (e.g., text-to-text, multi-modality) and corresponding performance thresholds used to define high-impact capabilities of a model.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADVERSE_LEGAL_EFFECT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ADVERSE LEGAL EFFECT</rdfs:label>
    <skos:definition xml:lang="en">A prohibited outcome where a decision is taken based solely on the output of a remote biometric identification system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_AGENCY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">FUNDAMENTAL RIGHTS AGENCY</rdfs:label>
    <skos:definition xml:lang="en">EU agency and a permanent member of the advisory forum (Article 67(5)).</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADVISORY_FORUM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFORMITY_BASED_ON_ASSESSMENT_OF_QUALITY_MANAGEMENT_SYSTEM_AND_TECHNICAL_DOCUMENTATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CONFORMITY BASED ON ASSESSMENT OF QUALITY MANAGEMENT SYSTEM AND TECHNICAL DOCUMENTATION</rdfs:label>
    <skos:definition xml:lang="en">A specific conformity assessment procedure (Annex VII) involving formal assessment of the quality management system and technical documentation</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_VII"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITALS_144_148">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITALS 144-148</rdfs:label>
    <skos:definition xml:lang="en">Specific recitals in the Regulation providing context on innovation, support measures for SMEs, and implementation</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLIANCE_WITH_THIS_REGULATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MACHINE_BRAIN_INTERFACES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">MACHINE-BRAIN INTERFACES</rdfs:label>
    <skos:definition xml:lang="en">Technology that facilitates manipulative AI practices by controlling stimuli presented to persons.</skos:definition>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#MANIPULATIVE_OR_DECEPTIVE_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNINTENTIONAL_DISTORTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">UNINTENTIONAL DISTORTION</rdfs:label>
    <skos:definition xml:lang="en">Exemption for distortion resulting from unforeseeable factors external to the AI system and outside provider/deployer control.</skos:definition>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_MANIPULATIVE_AI_PRACTICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_97">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 97</rdfs:label>
    <skos:definition xml:lang="en">Recital outlining the definition of general-purpose AI models</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#SystemicRisk"/>
    <rdfs:label xml:lang="en">SYSTEMIC RISK</rdfs:label>
    <skos:definition xml:lang="en">**Systemic Risk** is a critical classification applied to general-purpose AI (GPAI) models under the European Union’s regulatory framework. It identifies models that, due to their significant scale, high-impact capabilities, or reach, pose identifiable and concrete risks at the Union level. These risks carry the potential for major consequences, including widespread accidents, threats to public health and safety, disruption of democratic processes and civic discourse, interference with electoral</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FREE_AND_OPEN_SOURCE_AI_COMPONENTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_RELATED_REQUIREMENTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK_THRESHOLD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#VERY_LARGE_ONLINE_PLATFORM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_IMPACT_CAPABILITIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISK"/>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#OPEN_SOURCE_EXCEPTION"/>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#QUALIFIED_ALERT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_6">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 6</rdfs:label>
    <skos:definition xml:lang="en">**Article 6** serves as a critical regulatory provision that establishes the classification rules for high-risk AI systems. Central to its function, this article defines the criteria and specific conditions under which an AI system is categorized as "high-risk," while also delineating the circumstances under which such systems may be granted exemptions from these rigorous classifications.

Furthermore, **Article 6** integrates broader regulatory frameworks by explicitly referencing the requireme</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_96"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_97"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGISTRATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REGISTRATION</rdfs:label>
    <skos:definition xml:lang="en">**REGISTRATION** refers to the mandatory process required for providers, authorised representatives, and specific deployers of high-risk AI systems within the European Union. This regulatory obligation mandates that these entities input detailed information regarding their high-risk AI systems into the designated EU database. This registration must be completed prior to the systems being placed on the market or put into service, ensuring transparency and compliance with EU standards for AI deplo</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DATABASE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VOLUNTARY_MODEL_TERMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#CodeOfPractice"/>
    <rdfs:label xml:lang="en">VOLUNTARY MODEL TERMS</rdfs:label>
    <skos:definition xml:lang="en">The **VOLUNTARY MODEL TERMS** are a set of contractual templates specifically developed and provided by the AI Office. These templates serve as a resource designed to assist providers and third-party suppliers in formalizing their working relationships and establishing clear, mutually beneficial agreements. By offering these standardized documents, the AI Office facilitates the process of structuring legal collaborations between these entities.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ACCESSIBILITY_REQUIREMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ACCESSIBILITY REQUIREMENTS</rdfs:label>
    <skos:definition xml:lang="en">Technical standards for ensuring information provided about AI systems is accessible to all users, referred to in Article 50(5)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAWFUL_BIOMETRIC_LABELLING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">LAWFUL BIOMETRIC LABELLING</rdfs:label>
    <skos:definition xml:lang="en">The categorization of biometric data sets (e.g., sorting images by hair or eye colour) acquired in line with Union or national law, which is not covered by the prohibition (Recital 30).</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_CATEGORISATION_SYSTEMS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROMPT_REPORTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROMPT REPORTING</rdfs:label>
    <skos:definition xml:lang="en">The requirement to report serious incidents immediately after establishing a causal link between the AI system and the incident (Article 73(2)).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SCIENTIFIC_RESEARCH_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">SCIENTIFIC RESEARCH EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">AI systems and models developed and put into service for the sole purpose of scientific research and development are excluded from the scope of the Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#THIRD_PARTY_CONFORMITY_ASSESSMENT_BODY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">THIRD-PARTY CONFORMITY ASSESSMENT BODY</rdfs:label>
    <skos:definition xml:lang="en">A third-party conformity assessment body is an independent organization formally authorized to conduct regulatory conformity assessments for products. The involvement of such a body is a significant regulatory factor, as its participation often triggers the formal classification of an embedded AI system as "high-risk." Consequently, this entity plays a crucial role in the compliance landscape, serving as the responsible party for performing the necessary evaluations that determine whether an AI-</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_66">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 66</rdfs:label>
    <skos:definition xml:lang="en">The article defining the specific tasks and functions of the European Artificial Intelligence Board.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MODEL_CARDS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MODEL CARDS</rdfs:label>
    <skos:definition xml:lang="en">Documented practice for information sharing along the AI value chain, encouraged for open-source developers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_CATEGORISATION_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">BIOMETRIC CATEGORISATION AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI system used for biometric categorisation for law enforcement purposes, subject to specific data processing rules</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_RULES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TEXT_GENERATION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">TEXT GENERATION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">An AI system that generates or manipulates text which is published with the purpose of informing the public on matters of public interest</skos:definition>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#HUMAN_REVIEW_OR_EDITORIAL_CONTROL_EXCEPTION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_PROTECTION_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">DATA PROTECTION AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">A Data Protection Authority is a national or member state body responsible for overseeing and ensuring compliance with data protection regulations. In the specific context of AI innovation, this authority plays a critical role in the operation of AI regulatory sandboxes; whenever the development or testing of AI within these sandboxes involves the processing of personal data, the relevant Data Protection Authority must be actively involved to ensure that privacy standards and legal safeguards ar</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_PROCESSOR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">DATA PROCESSOR</rdfs:label>
    <skos:definition xml:lang="en">A role under GDPR (Regulation (EU) 2016/679) where an entity processes personal data on behalf of a controller, applicable to providers and deployers of AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_PRESENTING_A_RISK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM PRESENTING A RISK</rdfs:label>
    <skos:definition xml:lang="en">An "AI system presenting a risk" is defined as an artificial intelligence system that poses threats to the health, safety, or fundamental rights of individuals. This classification aligns directly with the criteria established in Regulation (EU) 2019/1020, which outlines the parameters for "products presenting a risk." Consequently, an AI system is categorized as presenting a risk if it meets these defined standards, essentially functioning as an equivalent to the "product presenting a risk" des</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#EVALUATION_OF_AI_SYSTEM"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_79"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_19__OF_REGULATION_2019_1020"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IRELAND">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">IRELAND</rdfs:label>
    <skos:definition xml:lang="en">Ireland is a Member State of the European Union that maintains a distinct legal position regarding certain aspects of judicial and police cooperation in criminal matters. Due to specific opt-out provisions outlined in Article 6a of Protocol No. 21, Ireland is not bound by particular regulations in this domain. This unique status impacts the extent of its obligations under the AI Act, specifically concerning provisions related to police and judicial cooperation within the European Union.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_4_OR_CHAPTER_5_OF_TITLE_V_OF_PART_THREE_OF_THE_TFEU"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_26_10_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPETENT_AUTHORITY_FOR_CRIMINAL_OFFENCES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">COMPETENT AUTHORITY FOR CRIMINAL OFFENCES</rdfs:label>
    <skos:definition xml:lang="en">Authorities responsible for the prevention, investigation, detection, or prosecution of criminal offences, subject to specific data processing rules under Directive (EU) 2016/680</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PERSONAL_DATA_PROTECTION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_9_1__OF_REGULATION__EU__2016_679">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 9(1) OF REGULATION (EU) 2016/679</rdfs:label>
    <skos:definition xml:lang="en">GDPR provision prohibiting the processing of biometric data unless specific exceptions apply</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_DIGITAL_INNOVATION_HUBS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">EUROPEAN DIGITAL INNOVATION HUBS</rdfs:label>
    <skos:definition xml:lang="en">European Digital Innovation Hubs (EDIHs) are organizations specifically designated to facilitate and support digital transformation efforts. Beyond this core mission, they are tasked with contributing to the practical implementation of the Regulation and providing essential technical and scientific support. Furthermore, European Digital Innovation Hubs are recognized as relevant entities that may be granted access to data for the specific purposes of developing and assessing high-risk artificial</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EU_DATABASE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">EU DATABASE</rdfs:label>
    <skos:definition xml:lang="en">The **EU DATABASE** is a central repository established and managed by the European Commission, serving as a critical tool for the oversight and regulation of artificial intelligence systems. As referenced in Article 71 of the relevant regulations, this database functions as an essential resource for market surveillance authorities, enabling them to effectively monitor AI systems and perform necessary checks as mandated by Article 81(8).

Structurally, the **EU DATABASE** is designed to house in</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2019_882"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_71"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMMISSION_DECISION_C_2024__390">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">COMMISSION DECISION C(2024) 390</rdfs:label>
    <skos:definition xml:lang="en">Commission Decision C(2024) 390 is an official act enacted by the European Commission on January 24, 2024. Its primary purpose is to establish the European Artificial Intelligence Office. This decision is also referenced in Recital 45 of related regulatory documentation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUBLIC_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PUBLIC AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">Public authorities are defined as entities tasked with the responsibility of providing essential services, social benefits, and various forms of assistance to the public. As part of their operations, these authorities utilize artificial intelligence (AI) systems to facilitate and streamline decision-making processes. 

Due to the significant impact of these decisions on individuals and society, public authorities that utilize high-risk AI systems are subject to specific regulatory compliance req</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_PUBLIC_SERVICES_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SIGNIFICANT_GENERALITY_THRESHOLD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">SIGNIFICANT GENERALITY THRESHOLD</rdfs:label>
    <skos:definition xml:lang="en">A criteria defined by the Regulation, specifically models with at least a billion parameters and trained with large amounts of data using self-supervision, to determine if a model displays significant generality</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_AS_SAFETY_COMPONENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM AS SAFETY COMPONENT</rdfs:label>
    <skos:definition xml:lang="en">An AI system as a safety component refers to artificial intelligence technology designed to function as a critical safety element within a larger product. These systems are defined specifically under Regulation (EU) 2024/1689 and encompass any AI software or hardware intended to perform safety functions where failure or malfunction could result in adverse impacts on human health or safety.

Because of the potential risks these systems pose, an AI system classified as a safety component is subjec</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_47"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_OF_CHAPTER_III_SECTION_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#IMPLEMENTING_ACT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DELEGATED_ACT"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_IN_CHAPTER_III_SECTION_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HORIZON_EUROPE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">HORIZON EUROPE</rdfs:label>
    <skos:definition xml:lang="en">A Union funding programme and project that should contribute to the objectives of this Regulation</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLIANCE_WITH_THIS_REGULATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">Specific technical or organisational measures (e.g., environmental sustainability, AI literacy, accessibility) that can be incorporated into codes of conduct under Article 95</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_32">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 32</rdfs:label>
    <skos:definition xml:lang="en">Article defining the presumption of conformity for notified bodies</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADOPTION_OF_DELEGATED_AND_IMPLEMENTING_ACTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ADOPTION OF DELEGATED AND IMPLEMENTING ACTS</rdfs:label>
    <skos:definition xml:lang="en">The European Commission must take into account Chapter III Section 2 requirements when adopting delegated or implementing acts involving AI safety components</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_106"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_107"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_108"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_ETHICS_GUIDELINES_FOR_TRUSTWORTHY_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">UNION ETHICS GUIDELINES FOR TRUSTWORTHY AI</rdfs:label>
    <skos:definition xml:lang="en">A framework containing elements for trustworthy AI, including sustainability and inclusion, which providers are encouraged to apply on a voluntary basis</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_47">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 47</rdfs:label>
    <skos:definition xml:lang="en">**Article 47** of the EU AI Act establishes and governs the requirements for the EU declaration of conformity, specifically concerning high-risk AI systems. This article mandates that providers of such systems must issue an EU declaration of conformity, which is required to accompany the high-risk AI system to ensure compliance. 

Furthermore, Article 47 has been amended to include specific procedural obligations regarding delegated acts. When adopting delegated acts that concern AI systems clas</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_IN_CHAPTER_III_SECTION_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DELEGATED_ACTS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INSURANCE_RISK_ASSESSMENT_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">INSURANCE RISK ASSESSMENT AI</rdfs:label>
    <skos:definition xml:lang="en">AI system used for risk assessment and pricing for life and health insurance.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_CATEGORISATION_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">BIOMETRIC CATEGORISATION AI</rdfs:label>
    <skos:definition xml:lang="en">BIOMETRIC CATEGORISATION AI refers to an artificial intelligence system designed to perform biometric categorisation by analyzing sensitive or protected attributes of individuals. These systems are specifically classified under Annex III 1(b) of the relevant regulatory framework, which highlights their high-risk nature due to their use of personal and sensitive data for classification purposes. By processing biometric information to categorize individuals based on protected characteristics, thes</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRICS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FREE_AND_OPEN_SOURCE_AI_COMPONENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">FREE AND OPEN-SOURCE AI COMPONENT</rdfs:label>
    <skos:definition xml:lang="en">AI components released under free and open-source licenses, which may benefit from exceptions regarding transparency-related requirements unless they present systemic risk</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#OPEN_SOURCE_EXCEPTION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CLASSIFICATION_RULE">
    <rdfs:label xml:lang="en">CLASSIFICATION RULE</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_AI_TESTING_SUPPORT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">UNION AI TESTING SUPPORT</rdfs:label>
    <skos:definition xml:lang="en">Entities providing technical support to Member States, coordinated with experts pursuant to Article 84.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COUNCIL_OF_THE_EUROPEAN_UNION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">COUNCIL OF THE EUROPEAN UNION</rdfs:label>
    <skos:definition xml:lang="en">One of the co-legislating bodies that adopted Regulation (EU) 2024/1689</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2024_1689"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_66">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 66</rdfs:label>
    <skos:definition xml:lang="en">Text describing requirements for high-risk AI systems including risk management and provision of instructions for use</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">REMOTE BIOMETRIC IDENTIFICATION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">A **Remote Biometric Identification System** is an AI-driven technology designed to identify natural persons by comparing their biometric data against a reference database. This process typically occurs at a distance and often without the active involvement or cooperation of the individual being identified. As defined in Article 3(41) of the relevant regulation, these systems encompass both "real-time" and "post" identification variants.

Because of the nature of the data processing involved, Re</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PERSONAL_DATA_PROTECTION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_VERIFICATION_EXCLUSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III_USE_CASE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRICS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_VERIFICATION_PURPOSE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CYBERSECURITY_PURPOSE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_54"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_41_"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AISYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRADE_SECRETS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TRADE SECRETS</rdfs:label>
    <skos:definition xml:lang="en">Confidential business information that must be protected while AI value chain parties cooperate with providers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AUTOMATIC_LOGGING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">AUTOMATIC LOGGING</rdfs:label>
    <skos:definition xml:lang="en">**AUTOMATIC LOGGING** refers to the essential technical capability integrated into high-risk AI systems to systematically record events throughout the entire duration of the system's operational lifetime. As mandated by Article 12(1), this feature is a critical compliance requirement designed to ensure comprehensive traceability, allowing for the auditing and monitoring of the system's performance and decision-making processes over time.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECORD_KEEPING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EVALUATION_OF_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EVALUATION OF AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The evaluation of an AI system is a critical procedure performed by market surveillance authorities to ensure that AI technologies adhere to all established requirements and obligations under the Regulation. This process is essential for maintaining safety and accountability standards.

Specifically, the evaluation of an AI system is triggered when a market surveillance authority has reason to believe that a particular AI system may present a risk. In such instances, the authority is required to</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_79"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TAX_AND_CUSTOMS_ADMINISTRATIVE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">TAX AND CUSTOMS ADMINISTRATIVE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems used specifically for administrative proceedings by tax and customs authorities</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TAX_AND_CUSTOMS_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESEARCH_AND_EXPERIMENTATION_LAB">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">RESEARCH AND EXPERIMENTATION LAB</rdfs:label>
    <skos:definition xml:lang="en">**RESEARCH AND EXPERIMENTATION LAB**

The RESEARCH AND EXPERIMENTATION LAB encompasses facilities dedicated to the advancement of artificial intelligence through rigorous research, development, and iterative testing. These labs serve as pivotal components within the broader AI ecosystem, providing the necessary infrastructure and environment to support ongoing innovation. Furthermore, the RESEARCH AND EXPERIMENTATION LAB may actively participate in the regulatory sandbox ecosystem, allowing for </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CREDITWORTHINESS_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">CREDITWORTHINESS AI</rdfs:label>
    <skos:definition xml:lang="en">AI system used to evaluate the creditworthiness of natural persons or establish their credit score.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES"/>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#FINANCIAL_FRAUD_DETECTION_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EDUCATIONAL_ADMISSION_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EDUCATIONAL ADMISSION AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems determining access or admission to educational and vocational training institutions (Annex III 3(a))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EDUCATION_AND_VOCATIONAL_TRAINING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SAFEGUARDS_FOR_FUNDAMENTAL_RIGHTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SAFEGUARDS FOR FUNDAMENTAL RIGHTS</rdfs:label>
    <skos:definition xml:lang="en">The requirement for third countries and international organisations to protect fundamental rights and freedoms of individuals to qualify for the exclusion from the Regulation's scope.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#APPEAL_PROCEDURE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">APPEAL PROCEDURE</rdfs:label>
    <skos:definition xml:lang="en">A mechanism that must be available to challenge decisions made by notified bodies regarding conformity certificates, as mentioned in the text following Article 45.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION__THIRD_COUNTRY_COOPERATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION: THIRD COUNTRY COOPERATION</rdfs:label>
    <skos:definition xml:lang="en">Exemption for public authorities in third countries under international law enforcement/judicial cooperation agreements, per Article 2(4)</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#THIRD_COUNTRY_PUBLIC_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_TRANSFER_SAFEGUARDS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA TRANSFER SAFEGUARDS</rdfs:label>
    <skos:definition xml:lang="en">Mandatory protocols for transferring data collected for real-world testing to third countries, ensuring compliance with Union law on data protection and Regulations (EU) 2022/868 and (EU) 2023/2854</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_74_11_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 74(11)</rdfs:label>
    <skos:definition xml:lang="en">ARTICLE 74(11) serves as a regulatory reference concerning cross-border market surveillance activities. Specifically, this article provides the framework regarding joint activities undertaken by market surveillance authorities, which are supported and facilitated by the Board.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_ASSESSMENT_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">RISK ASSESSMENT AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI system used for risk assessments of natural persons for law enforcement purposes, subject to specific data processing rules</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_RULES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_SOLUTIONS_FOR_CYBERSECURITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TECHNICAL SOLUTIONS FOR CYBERSECURITY</rdfs:label>
    <skos:definition xml:lang="en">Specific measures to prevent, detect, respond to, and resolve attacks like data poisoning, model poisoning, and adversarial examples, as per Article 15(5)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DELEGATION_OF_POWER_PERIOD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DELEGATION OF POWER PERIOD</rdfs:label>
    <skos:definition xml:lang="en">The power to adopt delegated acts is conferred for a period of five years from 1 August 2024, subject to tacit extension unless opposed by the Parliament or Council per Article 97(2)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUBLIC_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PUBLIC AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">A public authority is a government body or public entity that qualifies as a "deployer" under the definition provided in Recital 13 of the relevant regulations. When acting in the capacity of a deployer, a public authority is subject to specific regulatory requirements, which include fulfilling additional transparency and registration obligations to ensure accountability and oversight.

Furthermore, when a public authority puts high-risk AI systems into service for its own use, it operates withi</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#QUALITY_MANAGEMENT_SYSTEM"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HUMAN_CENTRIC_TECHNOLOGY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">HUMAN-CENTRIC TECHNOLOGY</rdfs:label>
    <skos:definition xml:lang="en">A core principle that AI should be developed as a tool for people with the aim of increasing human well-being</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_MITIGATION_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RISK MITIGATION MEASURES</rdfs:label>
    <skos:definition xml:lang="en">Specific measures mandated by the AI Office to address identified systemic risks in general-purpose AI models</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#THIRD_PARTY_SUPPLIER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">THIRD PARTY SUPPLIER</rdfs:label>
    <skos:definition xml:lang="en">Entity that supplies AI systems, tools, services, components, or processes used or integrated into a high-risk AI system</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2009_138_EC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2009/138/EC</rdfs:label>
    <skos:definition xml:lang="en">Directive on the taking-up and pursuit of the business of Insurance and Reinsurance (Solvency II) (Recital 48)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2016_97"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PHYSICAL_CE_MARKING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PHYSICAL CE MARKING</rdfs:label>
    <skos:definition xml:lang="en">A physical marking affixed to high-risk AI systems embedded in a product to indicate conformity with the Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#POLYGRAPH_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">POLYGRAPH AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">Polygraphs and similar tools used by or on behalf of law enforcement for risk assessment</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DEROGATION_AUTHORISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DEROGATION AUTHORISATION</rdfs:label>
    <skos:definition xml:lang="en">An authorization by a market surveillance authority allowing the placing on the market of a high-risk AI system without completing standard conformity assessment procedures for exceptional reasons.</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_46"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_PROTECTION_IMPACT_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DATA PROTECTION IMPACT ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">Deployers use information provided under Article 13 to comply with their obligation to carry out a DPIA under GDPR or Directive (EU) 2016/680.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_26_8_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MIGRATION__ASYLUM_AND_BORDER_CONTROL_MANAGEMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">MIGRATION, ASYLUM AND BORDER CONTROL MANAGEMENT</rdfs:label>
    <skos:definition xml:lang="en">Area involving AI systems used for border management, including polygraphs, risk assessment of entrants, and processing of asylum/visa applications, as listed in Annex III(7)</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_MIGRATION_POLYGRAPHS"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_MIGRATION_RISK_ASSESSMENT"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_ASYLUM_AND_VISA_PROCESSING"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_MIGRATION_DETECTION_AND_IDENTIFICATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EDUCATION_CATEGORY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">EDUCATION CATEGORY</rdfs:label>
    <skos:definition xml:lang="en">Use case domain involving the access and assignment to educational and vocational training institutions (Recital 44)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_96">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 96</rdfs:label>
    <skos:definition xml:lang="en">Article 96 serves as the governing provision regarding the development and implementation of guidelines by the Commission. Specifically, it establishes the legal framework that authorizes the Commission to create guidelines necessary for the proper implementation of the Regulation. Furthermore, Article 96 provides the procedural basis for the implementation of specific guidance concerning Article 6, acting as the primary reference article for these related regulatory requirements.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVISION_OF_STANDARDISED_TEMPLATES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROVISION OF STANDARDISED TEMPLATES</rdfs:label>
    <skos:definition xml:lang="en">Duty of the AI Office to provide standardised templates for areas covered by the Regulation, upon request by the Board.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERNAL_PROCEDURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INTERNAL PROCEDURES</rdfs:label>
    <skos:definition xml:lang="en">Procedural requirements for notified bodies to account for provider size, sector, structure, and system complexity</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRAINING_DATA_SUMMARY_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TRAINING DATA SUMMARY OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Duty to draw up and make publicly available a sufficiently detailed summary of the content used for training the general-purpose AI model</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CriticalInfrastructureAI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#HighRiskAISystem"/>
    <rdfs:label xml:lang="en">CriticalInfrastructureAI</rdfs:label>
    <skos:definition xml:lang="en">AI for management and operation of critical infrastructure</skos:definition>
    <euai:articleReference>Annex III, 2</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_12_1_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 12(1)</rdfs:label>
    <skos:definition xml:lang="en">Article regarding automatic logging capabilities for high-risk AI systems which the authorised representative must provide access to.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION_DECISIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION DECISIONS</rdfs:label>
    <skos:definition xml:lang="en">Decisions made by national data protection authorities to stop the use of remote biometric identification for non-law enforcement purposes</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DEVELOPMENT_AND_QUALITY_CONTROL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DEVELOPMENT AND QUALITY CONTROL</rdfs:label>
    <skos:definition xml:lang="en">Techniques and procedures for development, quality control, and assurance of the high-risk AI system (Article 17(2)(c)).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVIDER_OF_GENERAL_PURPOSE_AI_MODELS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PROVIDER OF GENERAL-PURPOSE AI MODELS</rdfs:label>
    <skos:definition xml:lang="en">A Provider of General-Purpose AI Models is defined as any natural or legal person responsible for the development of a general-purpose AI model or for placing such a model onto the market. As the entity behind the creation and distribution of these models, the provider carries significant regulatory responsibilities.

Specifically, a Provider of General-Purpose AI Models is subject to various obligations mandated under Article 53, which governs the accountability and operational standards for th</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COPYRIGHT_COMPLIANCE_POLICY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPETITIVE_ADVANTAGE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TRAINING_DATA_SUMMARY"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#INFORMATION_DISCLOSURE_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TRAINING_CONTENT_SUMMARY_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REASSESSMENT_OF_SYSTEMIC_RISK"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITIES"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_FINES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION_OF_MANIPULATIVE_AI_PRACTICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION OF MANIPULATIVE AI PRACTICES</rdfs:label>
    <skos:definition xml:lang="en">A ban on AI systems that distort human behavior or exploit vulnerabilities to cause significant harm, detailed in Recital 29.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_29"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMMISSION_EVALUATION_AND_REVIEW">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">COMMISSION EVALUATION AND REVIEW</rdfs:label>
    <skos:definition xml:lang="en">The duty of the Commission to evaluate and review the Regulation by 2 August 2029 and every four years thereafter, as well as annual assessments of high-risk lists, as per Recital 174</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMERGENCY_CALL_CLASSIFICATION_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EMERGENCY CALL CLASSIFICATION AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems used to evaluate and classify emergency calls (Annex III 5(d))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_49_6_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 49(6)</rdfs:label>
    <skos:definition xml:lang="en">Provision empowering the Commission to adopt delegated acts to amend conditions for high-risk classification exclusion</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUBLIC_AND_PRIVATE_ACTORS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PUBLIC AND PRIVATE ACTORS</rdfs:label>
    <skos:definition xml:lang="en">Entities (including SMEs and startups) involved in creating AI systems within the European ecosystem, adhering to Union values</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_RULES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_BODY_OF_THIRD_COUNTRY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CONFORMITY ASSESSMENT BODY OF THIRD COUNTRY</rdfs:label>
    <skos:definition xml:lang="en">Bodies established in non-EU countries that may be authorised to act as notified bodies if they meet Article 31 requirements or equivalent compliance standards, per Article 39</skos:definition>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_39"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TEU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">TEU</rdfs:label>
    <skos:definition xml:lang="en">The Treaty on European Union; referenced alongside TFEU in the context of Denmark's legal position.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_EMOTION_RECOGNITION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR EMOTION RECOGNITION</rdfs:label>
    <skos:definition xml:lang="en">AI systems intended to identify or infer emotions or intentions of natural persons on the basis of biometric data, specifically in the workplace or education sectors</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_EMOTION_RECOGNITION_AI"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2022_868">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2022/868</rdfs:label>
    <skos:definition xml:lang="en">**REGULATION (EU) 2022/868**, also known as the **Data Governance Act** or the **Regulation on European data governance**, is a significant legislative framework within the European Union. This regulation is explicitly referenced in Recital 42 of broader legal or regulatory documentation, highlighting its relevance to specific governance protocols and data management standards within the European Union.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INVESTIGATION_OF_COMPETENCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">INVESTIGATION OF COMPETENCE</rdfs:label>
    <skos:definition xml:lang="en">Duty of the Commission to investigate cases where there are doubts about a notified body's competence or fulfillment of requirements, per Article 37(1)</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_37"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DUTY_OF_INFORMATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DUTY OF INFORMATION</rdfs:label>
    <skos:definition xml:lang="en">Providers must inform distributors, deployers, authorised representatives, and importers of non-conformity, and inform authorities of risks as per Article 20</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RISK MANAGEMENT</rdfs:label>
    <skos:definition xml:lang="en">A requirement for high-risk AI systems to identify, estimate, evaluate, and mitigate risks associated with the intended purpose and reasonably foreseeable misuse</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_66"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UnacceptableRisk">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">UnacceptableRisk</rdfs:label>
    <skos:definition xml:lang="en">Risk level triggering an outright prohibition</skos:definition>
    <euai:articleReference>Article 5</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CONFORMITY ASSESSMENT PROCEDURE</rdfs:label>
    <skos:definition xml:lang="en">The "Conformity Assessment Procedure" serves as a critical mechanism for ensuring that AI systems adhere to the necessary legal and safety requirements established by the Regulation. It is a mandatory process that must be completed before an AI system can be placed on the market, functioning as a vital step in demonstrating that a system meets all applicable compliance standards.

At its core, the Conformity Assessment Procedure is the method used to verify that a high-risk AI system aligns with</skos:definition>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_43"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVISIONAL_MEASURE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROVISIONAL MEASURE</rdfs:label>
    <skos:definition xml:lang="en">An enforcement action taken by a market surveillance authority of a Member State, which can be deemed justified if no objections are raised within the designated period under Article 79(8)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_79"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFICATION_OF_CHANGE_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NOTIFICATION OF CHANGE OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The notified body must inform providers within 10 days if its designation is suspended, restricted, or withdrawn</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION__SERIOUS_INCIDENT_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REPORTING OBLIGATION (SERIOUS INCIDENT)</rdfs:label>
    <skos:definition xml:lang="en">The requirement for a deployer to immediately inform the provider, importer, distributor, and market surveillance authority of a serious incident</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">ESSENTIAL PRIVATE AND PUBLIC SERVICES</rdfs:label>
    <skos:definition xml:lang="en">High-risk domain covering public assistance eligibility, creditworthiness, insurance risk, and emergency response.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#JOINT_INVESTIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">JOINT INVESTIGATION</rdfs:label>
    <skos:definition xml:lang="en">A "Joint Investigation" refers to collaborative enforcement actions undertaken by market surveillance authorities or the European Commission to address non-compliance issues concerning high-risk AI systems. These actions are conducted in accordance with Article 9 of Regulation (EU) 2019/1020. 

Specifically, these joint investigations are initiated or proposed to effectively manage and rectify situations where high-risk AI systems present serious risks across multiple Member States, ensuring a c</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_9_OF_REGULATION__EU__2019_1020"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SINGLE_DEDICATED_INTERFACE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SINGLE DEDICATED INTERFACE</rdfs:label>
    <skos:definition xml:lang="en">A platform developed by the Commission to provide information, facilitate interactions with sandboxes, and allow stakeholder enquiries (Recital 17).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STANDARDISATION_DEVELOPMENT_PROCESS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">STANDARDISATION DEVELOPMENT PROCESS</rdfs:label>
    <skos:definition xml:lang="en">Process in which Member States must facilitate the participation of SMEs and other relevant stakeholders under Article 62(1)(d)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#CodeOfPractice"/>
    <rdfs:label xml:lang="en">CODE OF PRACTICE</rdfs:label>
    <skos:definition xml:lang="en">The Code of Practice serves as a voluntary compliance instrument designed for providers of General-Purpose AI (GPAI) models to effectively demonstrate their adherence to the obligations mandated by the AI Act, particularly those outlined in Articles 53 and 55. These obligations include, but are not limited to, the implementation of requirements regarding the detection and labelling of artificially generated content.

Drafted with the goal of fostering best practices and high standards, the Code </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_55"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_53"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_98_2_"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_56"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESILIENCE_OF_CRITICAL_ENTITIES_DIRECTIVE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RESILIENCE OF CRITICAL ENTITIES DIRECTIVE</rdfs:label>
    <skos:definition xml:lang="en">The Resilience of Critical Entities Directive, formally known as Directive (EU) 2022/2557, serves as a crucial piece of European Union legislation focused on strengthening the physical and digital security of vital infrastructure. This directive establishes a comprehensive framework designed to enhance the resilience of entities that provide essential services to society, ensuring that critical infrastructure remains robust in the face of various threats, including natural disasters, terrorism, </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADVERSE_LEGAL_EFFECT_PROHIBITION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ADVERSE LEGAL EFFECT PROHIBITION</rdfs:label>
    <skos:definition xml:lang="en">A requirement that no decision producing an adverse legal effect on a person may be taken based solely on the output of a real-time remote biometric identification system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INDUSTRY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">INDUSTRY</rdfs:label>
    <skos:definition xml:lang="en">**INDUSTRY** consists of private sector stakeholders and economic operators whose expertise is essential to the development and implementation of regulatory frameworks concerning artificial intelligence. 

These entities are formally engaged by the AI Office to provide critical input regarding the establishment of thresholds and benchmarks necessary for systemic risk assessment. Furthermore, in accordance with Article 56(3), these industry stakeholders are invited to actively support and contrib</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGISTRATION_OF_ENTRY_AND_EXIT_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">REGISTRATION OF ENTRY AND EXIT DATA</rdfs:label>
    <skos:definition xml:lang="en">A core functional requirement for the Entry/Exit System to manage border crossing data.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VICTIM_RISK_ASSESSMENT_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">VICTIM RISK ASSESSMENT AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems used by or on behalf of law enforcement authorities to assess the risk of a natural person becoming a victim of criminal offences</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PERFORMANCE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ACCURACY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ROBUSTNESS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_59"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_XIII">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX XIII</rdfs:label>
    <skos:definition xml:lang="en">**ANNEX XIII** serves as a regulatory component that explicitly outlines the criteria used to determine whether a general-purpose AI (GPAI) model should be designated as presenting systemic risks. This annex provides the specific framework utilized by the European Commission for assessing and designating such models, directly supporting the requirements established in Article 51 of the underlying AI legislation.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_51"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CRITICAL_INFRASTRUCTURE_SAFETY_COMPONENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">CRITICAL INFRASTRUCTURE SAFETY COMPONENT</rdfs:label>
    <skos:definition xml:lang="en">The term "CRITICAL INFRASTRUCTURE SAFETY COMPONENT" refers to AI systems that are specifically intended to function as safety components within the management and operation of critical infrastructure. These systems play a vital role in ensuring the reliability and security of essential services and systems that support society.

Specifically, these AI systems are utilized in the management and operation of critical digital infrastructure, as well as in the oversight of critical public services s</skos:definition>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CRITICAL_INFRASTRUCTURE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CYBERSECURITY_PURPOSE"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_55"/>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#SAFETY_COMPONENT_DEFINITION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_77_1_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 77(1)</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 77(1)** serves as a regulatory reference that outlines the requirements for information sharing concerning serious incidents. Specifically, it mandates that market surveillance authorities must notify certain national public authorities or bodies when such incidents occur. Furthermore, this article encompasses provisions related to the involvement of specific national public authorities or bodies that are tasked with the protection of fundamental rights. In essence, ARTICLE 77(1) estab</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DELEGATED_ACT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#DelegatedAct"/>
    <rdfs:label xml:lang="en">DELEGATED ACT</rdfs:label>
    <skos:definition xml:lang="en">**Delegated Acts**

A Delegated Act is a legislative instrument adopted by the European Commission, primarily authorized under Article 290 of the Treaty on the Functioning of the European Union (TFEU) and Article 97 of the AI Act. These acts serve as a flexible mechanism that empowers the Commission to modify, supplement, or extend specific non-essential provisions of the AI Act to ensure the regulation remains effective and aligned with evolving technological progress.

Functionally, Delegated </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_CLASSIFICATION_RULE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEXES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODELS_WITH_SYSTEMIC_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_IV"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_97"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_44"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_XI"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_I"/>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#EU_DECLARATION_OF_CONFORMITY"/>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURES"/>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_INFORMATION"/>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_VI"/>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_VII"/>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_V"/>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_XII"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_7_3_"/>
    <euai:providesInstructionsTo rdf:resource="https://w3id.org/euaiact/ontology#MEASUREMENT_AND_CALCULATION_METHODOLOGIES"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#DELEGATION_OF_POWER_PERIOD"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#OBJECTION_PERIOD"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_OF_CHAPTER_III_SECTION_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_56">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 56</rdfs:label>
    <skos:definition xml:lang="en">Article 56 functions as a critical regulatory provision specifically addressing the codes of practice for general-purpose AI models. It defines the meaning and scope of these codes, establishing the essential framework and outlining the development process required for their implementation. By setting these standards, Article 56 provides the necessary guidance and structure for the governance of general-purpose AI technologies.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_JUDICIAL_ASSISTANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR JUDICIAL ASSISTANCE</rdfs:label>
    <skos:definition xml:lang="en">System used by or for a judicial authority to research and interpret facts and law, or for alternative dispute resolution, identified in Annex III(8)(a)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_9_OF_REGULATION__EU__2019_1020">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 9 OF REGULATION (EU) 2019/1020</rdfs:label>
    <skos:definition xml:lang="en">Article 9 of Regulation (EU) 2019/1020 serves as a critical legal reference within the European Union's regulatory framework. It establishes the legal basis and governs the procedures for conducting joint activities and investigations. The primary purpose of this article is to promote product compliance and to effectively address serious risks that may arise regarding product safety and conformity. By facilitating these cooperative efforts, Article 9 ensures that market surveillance authorities </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GENERAL_DATE_OF_APPLICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">GENERAL DATE OF APPLICATION</rdfs:label>
    <skos:definition xml:lang="en">The date of 2 August 2026, when the Regulation generally applies (Recital 179).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_101">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 101</rdfs:label>
    <skos:definition xml:lang="en">Article 101 serves as a specific provision within the legal framework, functioning primarily as an exception to the general application date of 2 August 2025 established for other chapters. Beyond its timing provisions, Article 101 is fundamentally an enforcement mechanism centered on financial penalties. It defines the fines applicable to entities for supplying incorrect, incomplete, or misleading information to the relevant authorities. Furthermore, the article establishes fines specifically t</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_113"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MONITORING_OF_SYSTEM_OPERATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">MONITORING OF SYSTEM OPERATION</rdfs:label>
    <skos:definition xml:lang="en">The deployer's duty to monitor the AI system based on the manufacturer's instructions</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLES_102_TO_109">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLES 102 TO 109</rdfs:label>
    <skos:definition xml:lang="en">Specific articles regarding market surveillance or specific obligations applied to high-risk systems under Article 2(2)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MIGRATION__ASYLUM_AND_BORDER_CONTROL_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">MIGRATION, ASYLUM AND BORDER CONTROL AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The Migration, Asylum and Border Control AI System encompasses artificial intelligence technologies deployed by competent public authorities to manage the critical processes of migration, asylum, and border control. These systems are designed to assist officials in various administrative and security functions, playing a significant role in the oversight of international arrivals and residency applications.

Key functionalities of these AI systems include, but are not limited to, the utilization</skos:definition>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ACCURACY_REQUIREMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NON_DISCRIMINATION_REQUIREMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_REQUIREMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRAVEL_DOCUMENT_VERIFICATION_EXCLUSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MIGRATION__ASYLUM_AND_BORDER_CONTROL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROCEDURAL_REQUIREMENTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NON_REFOULEMENT_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ACCURACY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NON_DISCRIMINATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_113">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 113</rdfs:label>
    <skos:definition xml:lang="en">Article concerning the entry into force and application dates of the Regulation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DEEP_FAKES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">DEEP FAKES</rdfs:label>
    <skos:definition xml:lang="en">Content generated or manipulated by AI that appreciably resembles existing persons, objects, places, entities or events, falsely appearing authentic</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2014_17_EU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2014/17/EU</rdfs:label>
    <skos:definition xml:lang="en">**DIRECTIVE 2014/17/EU**, also known as the Mortgage Credit Directive, serves as a crucial regulatory framework concerning credit agreements for consumers relating to residential immovable property. Specifically referenced within Recital 50, this directive plays an essential role in establishing guidelines for the mortgage and credit sector.

While DIRECTIVE 2014/17/EU primarily focuses on consumer protection and standardizing the internal market for residential property credit, recent discussio</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STUDENT_BEHAVIOUR_MONITORING_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">STUDENT BEHAVIOUR MONITORING AI</rdfs:label>
    <skos:definition xml:lang="en">AI system used for monitoring and detecting prohibited student behaviour during tests.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EDUCATION_AND_VOCATIONAL_TRAINING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#conductsEvaluationOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">conductsEvaluationOf</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION_ASSESSMENT_CERTIFICATE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TECHNICAL DOCUMENTATION ASSESSMENT CERTIFICATE</rdfs:label>
    <skos:definition xml:lang="en">A formal certificate issued by a notified body to a provider confirming that an AI system conforms with the requirements set out in Chapter III, Section 2</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_IV"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#isExemptFromHighRisk">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">isExemptFromHighRisk</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMPLOYMENT_AND_WORKERS_MANAGEMENT_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EMPLOYMENT AND WORKERS MANAGEMENT AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The "Employment and Workers Management AI System" refers to artificial intelligence technologies deployed within work-related relationships to manage key aspects of the employee lifecycle. These systems are utilized for recruitment, selection, promotion, termination, task allocation, and performance monitoring. Due to their significant impact on individuals' professional lives and livelihoods, these AI systems are officially classified as high-risk.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EMPLOYMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NON_DISCRIMINATION_REQUIREMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NON_DISCRIMINATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_PROTECTION_AND_PRIVACY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RiskManagementSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Risk Management System</rdfs:label>
    <skos:definition xml:lang="en">A continuous iterative process to identify and mitigate risks. (Article 9)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WORKER_INFORMATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">WORKER INFORMATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Employers deploying high-risk AI systems at the workplace must inform workers' representatives and affected workers about the use of the system before putting it into service.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_LIMITATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TECHNICAL LIMITATIONS</rdfs:label>
    <skos:definition xml:lang="en">Safeguard condition for processing special categories of personal data, including re-use restrictions and security measures</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ENFORCEMENT_ASSESSMENT_REPORT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ENFORCEMENT ASSESSMENT REPORT</rdfs:label>
    <skos:definition xml:lang="en">A duty of the European Commission to assess the enforcement of the Regulation by 2 August 2031 and report findings.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_PARLIAMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COUNCIL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_ECONOMIC_AND_SOCIAL_COMMITTEE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EDUCATION_EVALUATION_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EDUCATION EVALUATION AI</rdfs:label>
    <skos:definition xml:lang="en">AI system used to evaluate learning outcomes or steer the learning process.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EDUCATION_AND_VOCATIONAL_TRAINING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_10_1__OF_REGULATION__EU__2018_1725">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 10(1) OF REGULATION (EU) 2018/1725</rdfs:label>
    <skos:definition xml:lang="en">EU regulation provision prohibiting the processing of biometric data for non-law enforcement purposes, subject to limited exceptions</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION_OF_EMOTION_RECOGNITION_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION OF EMOTION RECOGNITION AI</rdfs:label>
    <skos:definition xml:lang="en">Prohibition on the placing on the market, putting into service, or use of AI systems intended to detect emotional states in workplace and education contexts (Recital 44)</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_44"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VULNERABLE_GROUPS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">VULNERABLE GROUPS</rdfs:label>
    <skos:definition xml:lang="en">"VULNERABLE GROUPS" refers to specific populations that require special attention, heightened protection, and nuanced consideration during the implementation of AI systems and related regulatory processes. This category primarily encompasses individuals under the age of 18, as well as persons with disabilities or other conditions that might render them particularly susceptible to adverse impacts.

The identification of these groups is central to robust risk management processes. Because these in</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2016_2102">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE (EU) 2016/2102</rdfs:label>
    <skos:definition xml:lang="en">**DIRECTIVE (EU) 2016/2102** is the European Union legislation governing the accessibility of websites and mobile applications managed by public sector bodies. This directive establishes a legal framework aimed at ensuring that digital content provided by public authorities is inclusive and accessible to all users, including those with disabilities.

The directive is referenced across various parts of the legislative text, appearing in both Recital 38 and Recital 80. By standardizing accessibili</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ACCESSIBILITY_REQUIREMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ENERGY_EFFICIENT_DEVELOPMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ENERGY EFFICIENT DEVELOPMENT</rdfs:label>
    <skos:definition xml:lang="en">Technical standardisation deliverable specifically concerning general-purpose AI models (Recital 174)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NON_REFOULEMENT_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NON-REFOULEMENT OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The duty to not infringe on the principle of non-refoulement or deny safe and effective legal avenues into the Union when deploying AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SECTION_A_OF_ANNEX_I">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">SECTION A OF ANNEX I</rdfs:label>
    <skos:definition xml:lang="en">Specific section listing products covered by Union harmonisation legislation, for which only specific derogations apply.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_575_2013">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) NO 575/2013</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) No 575/2013 is a piece of legislation that establishes prudential requirements for credit institutions and investment firms. This regulation is explicitly referenced in Recital 46 of relevant financial services legislation, particularly in the context of the scope of artificial intelligence (AI) applications within the financial sector. By setting these foundational prudential standards, the regulation plays a critical role in framing the operational and regulatory environment fo</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ENISA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">ENISA</rdfs:label>
    <skos:definition xml:lang="en">The European Union Agency for Cybersecurity, commonly referred to as ENISA, serves as the central authority responsible for promoting and ensuring a high level of cybersecurity throughout the European Union. Established and regulated by Regulation (EU) 2019/881—also known as the Cybersecurity Act—ENISA functions as the primary body tasked with developing and managing cybersecurity certification frameworks.

In its capacity as the EU's dedicated cybersecurity agency, ENISA provides vital knowledg</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_881"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADVISORY_FORUM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MODEL_TESTING_AND_EVALUATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MODEL TESTING AND EVALUATION</rdfs:label>
    <skos:definition xml:lang="en">An activity in the AI value chain for which providers require assistance from upstream suppliers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#JOINT_INVESTIGATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">JOINT INVESTIGATIONS</rdfs:label>
    <skos:definition xml:lang="en">Collaborative enforcement actions proposed by market surveillance authorities and the Commission to promote compliance or identify non-compliance across Member States</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_9_OF_REGULATION__EU__2019_1020"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_BASED_APPROACH">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">RISK-BASED APPROACH</rdfs:label>
    <skos:definition xml:lang="en">The Risk-Based Approach is a regulatory framework and methodology designed to manage the development and deployment of artificial intelligence (AI) systems. It functions by tailoring the intensity and scope of binding rules and regulatory requirements according to the specific level of risk generated by an AI system. 

Under this framework, the approach is categorized into three primary components: the prohibition of practices deemed unacceptable, the imposition of strict requirements for system</skos:definition>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#UNACCEPTABLE_AI_PRACTICES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEMS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATIONS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_PROVIDER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">GENERAL-PURPOSE AI MODEL PROVIDER</rdfs:label>
    <skos:definition xml:lang="en">General-purpose AI model providers are entities responsible for the development and provision of general-purpose AI models. As key actors within the AI value chain, these providers bear specific obligations regarding documentation and transparency, as detailed in Recital 101. Furthermore, general-purpose AI model providers are invited to participate in the development and implementation of codes of practice to ensure responsible deployment and alignment with regulatory standards.</skos:definition>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DOWNSTREAM_PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_RELATED_REQUIREMENTS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_EXCEPTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">LAW ENFORCEMENT EXCEPTION</rdfs:label>
    <skos:definition xml:lang="en">An exemption from transparency and notification obligations where the use of the AI system is authorised by law to detect, prevent, investigate or prosecute criminal offences</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_SOLUTIONS_FOR_MARKING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TECHNICAL SOLUTIONS FOR MARKING</rdfs:label>
    <skos:definition xml:lang="en">Mandatory methods such as watermarks, metadata identifications, cryptographic methods, or logging methods to identify AI-generated or manipulated content.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONTENT_GENERATION_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_11">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 11</rdfs:label>
    <skos:definition xml:lang="en">**Article 11** serves two distinct functions within the regulatory landscape, depending on the specific legislative context in which it is cited.

First, within the framework of the **EU AI Act**, **Article 11** establishes the mandatory requirements for the technical documentation of high-risk AI systems. It serves as the primary provision ensuring that creators and operators of such systems generate and maintain comprehensive documentation. This documentation is essential for demonstrating com</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_IN_CHAPTER_III_SECTION_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#IMPLEMENTING_ACTS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_HLEG">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">AI HLEG</rdfs:label>
    <skos:definition xml:lang="en">The High-Level Expert Group on Artificial Intelligence, commonly referred to as the AI HLEG, is an independent body appointed by the European Commission. Established to provide expert guidance on AI development and deployment, the AI HLEG is primarily recognized for its pivotal role in formulating ethical standards for the technology.

Most notably, the AI HLEG was responsible for developing the 2019 Ethics Guidelines for Trustworthy AI. This foundational document was authored by the group to es</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ETHICS_GUIDELINES_FOR_TRUSTWORTHY_AI"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ETHICAL_PRINCIPLES_FOR_TRUSTWORTHY_AI"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SAFETY_COMPONENT_DEFINITION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">SAFETY COMPONENT DEFINITION</rdfs:label>
    <skos:definition xml:lang="en">The rule defining a safety component as a system used to directly protect the physical integrity of critical infrastructure or the health and safety of persons/property, provided it is not necessary for the functioning of the system (Recital 55)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_CATEGORISATION_SYSTEMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">BIOMETRIC CATEGORISATION SYSTEMS</rdfs:label>
    <skos:definition xml:lang="en">Biometric categorisation systems are AI-powered technologies that process the biometric data of natural persons to classify them based on specific characteristics. Due to the potential risks these systems pose to fundamental rights and privacy, they are subject to strict regulatory oversight.

Broadly, these systems are defined by their capacity to categorize individuals based on biometric data, and they face specific restrictions, particularly within the context of police and judicial cooperati</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_30"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_AI_PRACTICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FACIAL_RECOGNITION_DATABASE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">FACIAL RECOGNITION DATABASE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI system creating or expanding facial recognition databases through untargeted scraping of internet or CCTV images</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_10_OF_DIRECTIVE__EU_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 10 OF DIRECTIVE (EU)</rdfs:label>
    <skos:definition xml:lang="en">Refers to the rules on the processing of biometric data in the context of Directive (EU) (often relating to the GDPR or Law Enforcement Directive context).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DOCUMENTATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DOCUMENTATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Requirement for each use of a high-risk AI system to be documented in a police file and made available to relevant authorities upon request</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TESTING_EXPERIMENTATION_FACILITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">TESTING EXPERIMENTATION FACILITIES</rdfs:label>
    <skos:definition xml:lang="en">Facilities providing infrastructure and support for testing AI systems, relevant for development and assessment of high-risk AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#appliesTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">appliesTo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFORMITY_REQUIREMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CONFORMITY REQUIREMENTS</rdfs:label>
    <skos:definition xml:lang="en">The specific technical and organizational requirements set out in Section 2 that high-risk AI systems must meet</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OBLIGATION_TO_PROVIDE_ACCESS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">OBLIGATION TO PROVIDE ACCESS</rdfs:label>
    <skos:definition xml:lang="en">Provider must make available to the Commission access to GPAI models (especially those with systemic risk) for evaluation purposes pursuant to Article 92</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EU_INTEROPERABILITY_FRAMEWORK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EU INTEROPERABILITY FRAMEWORK</rdfs:label>
    <skos:definition xml:lang="en">A framework establishing interoperability between various EU information systems in the fields of borders, visa, police, judicial cooperation, asylum, and migration</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_817"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_818"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INSTRUCTIONS_FOR_USE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INSTRUCTIONS FOR USE</rdfs:label>
    <skos:definition xml:lang="en">"INSTRUCTIONS FOR USE" constitute mandatory documentation that must accompany high-risk AI systems when they are placed on the market. Provided by the system's provider to the deployer, these instructions serve as a critical bridge of information, ensuring the deployer understands how to operate the technology safely and effectively.

The documentation, which can be delivered in digital or other formats, encompasses a comprehensive range of details regarding the AI system. This includes the syst</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PERFORMANCE_CHARACTERISTICS"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_73"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_15"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_9_2_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#QUALIFIED_ALERT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">QUALIFIED ALERT</rdfs:label>
    <skos:definition xml:lang="en">A "QUALIFIED ALERT" is a formal notification issued by the scientific panel to the AI Office. Its primary purpose is to draw official attention to specific concerns related to General Purpose AI (GPAI) models or broader Union-level regulatory compliance. Specifically, a QUALIFIED ALERT serves as the mechanism for communicating the following issues:

*   **Systemic or Identifiable Risks:** Under Article 90, the panel utilizes this alert to notify the AI Office regarding suspected systemic risks o</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_90"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_OFFICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WIDESPREAD_INFRINGEMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">WIDESPREAD INFRINGEMENT</rdfs:label>
    <skos:definition xml:lang="en">Any act or omission contrary to Union law protecting the interest of individuals that affects individuals in at least two Member States or occurs concurrently in at least three Member States, as defined in Article 3(61)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUBSTANTIATED_ARGUMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SUBSTANTIATED ARGUMENTS</rdfs:label>
    <skos:definition xml:lang="en">Documentation provided by a GPAI model provider to demonstrate that, despite meeting computation thresholds, the model does not present systemic risks (Article 52(2))</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MARKING_AND_DETECTION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">MARKING AND DETECTION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Requirement for providers of content-generating AI systems to embed machine-readable technical solutions (watermarks, metadata, etc.) to identify AI-generated/manipulated content. Excludes assistive editing tools or systems not substantially altering input data.</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#CONTENT_GENERATION_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_COOPERATION_GROUP">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">ADMINISTRATIVE COOPERATION GROUP</rdfs:label>
    <skos:definition xml:lang="en">Also referred to as ADCO; an administrative cooperation structure under Regulation (EU) 2019/1020, aligned with the Board's standing sub-group for market surveillance per Article 65(6).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CE_MARKING_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CE MARKING OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Requirement to affix CE marking correctly per Article 48, missing or incorrectly affixed marking constitutes formal non-compliance under Article 83</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_83"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SECTION_2_OF_THIS_CHAPTER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SECTION 2 OF THIS CHAPTER</rdfs:label>
    <skos:definition xml:lang="en">Specific requirements applicable to high-risk AI systems as referenced throughout the text (often related to technical documentation, record-keeping, etc.)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LABELING_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">LABELING OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Specific requirement to label AI-generated or manipulated output; limited by exceptions for assistive functions, standard editing, or human-reviewed content</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2022_2065"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_22_REGULATION__EU__NO_1025_2012">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 22 REGULATION (EU) NO 1025/2012</rdfs:label>
    <skos:definition xml:lang="en">Article referring to the committee that the Commission must inform before preparing a draft implementing act</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPOL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">EUROPOL</rdfs:label>
    <skos:definition xml:lang="en">EUROPOL, formally known as the European Union Agency for Law Enforcement Cooperation, is the primary body responsible for supporting law enforcement activities across the European Union. As part of its operational mandate, EUROPOL is officially authorised to request and obtain access to Eurodac data, a critical resource utilized for the purposes of law enforcement to assist in maintaining security and combating crime within the region.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EURODAC"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OBLIGATION_TO_ENSURE_COMPLIANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">OBLIGATION TO ENSURE COMPLIANCE</rdfs:label>
    <skos:definition xml:lang="en">The requirement for entities to ensure the compliance of an AI system if it is used for purposes other than the military, defence, or national security purposes for which it was originally excluded.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PERFORMANCE_OF_AN_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PERFORMANCE OF AN AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The ability of an AI system to achieve its intended purpose</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPETENT_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">COMPETENT AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">Public body or authority responsible for law enforcement or other official activities that may deploy AI systems, subject to specific rules under the Regulation</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_TIME_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISATION_REQUIREMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COOPERATION_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EXIT_REPORT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#WRITTEN_PROOF"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_ECOSYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_IN_REAL_WORLD_CONDITIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROJECT_SUMMARY"/>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#COOPERATION_WITH_COMPETENT_AUTHORITIES"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#DISTRIBUTOR"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROFILING_OF_NATURAL_PERSONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">PROFILING OF NATURAL PERSONS</rdfs:label>
    <skos:definition xml:lang="en">Rule stating that if an AI system performs profiling, it shall always be considered high-risk, regardless of other exemption conditions</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITED AI PRACTICES</rdfs:label>
    <skos:definition xml:lang="en">Prohibited AI practices, as outlined under Article 5, encompass a specific set of actions that are forbidden due to the risks they pose to individuals and society. These regulations strictly prohibit the deployment or use of AI systems that utilize manipulative techniques designed to distort human behavior or exploit the specific vulnerabilities of particular groups or individuals. Such practices are banned because they threaten fundamental rights, can cause significant harm, and directly contra</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1861">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2018/1861</rdfs:label>
    <skos:definition xml:lang="en">Legislation on the establishment, operation and use of the Schengen Information System (SIS) for border checks</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_39_OF_THE_CHARTER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 39 OF THE CHARTER</rdfs:label>
    <skos:definition xml:lang="en">Reference to the right to vote (Recital 62).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MEMBER_STATE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">MEMBER STATE</rdfs:label>
    <skos:definition xml:lang="en">A Member State, represented by national experts, plays a multi-faceted and pivotal role in the implementation and oversight of the Act. As the primary national government entities responsible for the Act’s administration, Member States are tasked with transposing the legislation into national law and establishing the necessary domestic frameworks to ensure compliance.

In their oversight capacity, Member States serve as the national entities responsible for enforcing the Regulation and maintaini</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_LAW"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_TIME_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFYING_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMON_SPECIFICATIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONSULTATION_OF_EXPERTS"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OF_NATIONAL_RULES"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#DOCUMENTATION_KEEPING"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_SHEETS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA SHEETS</rdfs:label>
    <skos:definition xml:lang="en">Documented practice for information sharing along the AI value chain, encouraged for open-source developers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VOLUNTARY_CODE_OF_CONDUCT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#CodeOfPractice"/>
    <rdfs:label xml:lang="en">VOLUNTARY CODE OF CONDUCT</rdfs:label>
    <skos:definition xml:lang="en">Instruments drawn up by the Commission and Member States in cooperation with stakeholders to advance AI literacy among persons dealing with the development, operation, and use of AI.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_LITERACY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_ROBUSTNESS_AND_SAFETY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TECHNICAL ROBUSTNESS AND SAFETY</rdfs:label>
    <skos:definition xml:lang="en">The requirement that AI systems are developed and used to ensure resilience against alteration, unlawful use, and unintended harm</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ETHICAL_PRINCIPLES_FOR_TRUSTWORTHY_AI"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_27">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 27</rdfs:label>
    <skos:definition xml:lang="en">Reference to Recital 27, covering ethical guidelines, principles for AI, and the AI HLEG's contribution to the Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PREPARATORY_TASK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">PREPARATORY TASK</rdfs:label>
    <skos:definition xml:lang="en">Condition where an AI system performs a preparatory task for an assessment relevant to Annex III use cases, potentially exempting it from high-risk classification</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_ETHICAL_GUIDELINES_FOR_TRUSTWORTHY_AI">
    <rdfs:label xml:lang="en">UNION ETHICAL GUIDELINES FOR TRUSTWORTHY AI</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OPEN_SOURCE_EXCEPTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">OPEN-SOURCE EXCEPTION</rdfs:label>
    <rdfs:label xml:lang="en">OPEN SOURCE EXCEPTION</rdfs:label>
    <skos:definition xml:lang="en">Condition where providers of open-source GPAI models are exempt from certain transparency obligations, unless the model presents a systemic risk</skos:definition>
    <skos:definition xml:lang="en">Obligations under Article 53(1)(a) and (b) do not apply to models released under free and open-source licenses, provided parameters are public, unless the model has systemic risk.</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OPEN_SOURCE_GPAI_MODEL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">OPEN-SOURCE GPAI MODEL</rdfs:label>
    <skos:definition xml:lang="en">A general-purpose AI model released under open-source licenses, which poses specific compliance challenges regarding the implementation of obligations after release.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MIGRATION__ASYLUM_AND_BORDER_CONTROL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">MIGRATION, ASYLUM AND BORDER CONTROL</rdfs:label>
    <skos:definition xml:lang="en">The domain of **MIGRATION, ASYLUM AND BORDER CONTROL** is classified as a high-risk area regarding the deployment of artificial intelligence. Within this sector, AI systems are subject to strict scrutiny when utilized for critical tasks such as risk assessment, the examination of immigration or asylum applications, and the use of polygraph testing. Because these applications directly impact individual rights and legal statuses, these systems must adhere to rigorous standards to ensure fairness, </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CRIMINAL_OFFENCES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CRIMINAL OFFENCES</rdfs:label>
    <skos:definition xml:lang="en">Specific legal threshold (e.g., offenses referred to in Annex II punishable by custodial sentence of at least four years) required for the use of biometric identification</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_II"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">FUNDAMENTAL RIGHTS</rdfs:label>
    <skos:definition xml:lang="en">Fundamental Rights, as enshrined in the Charter of Fundamental Rights of the European Union, serve as a critical benchmark for the regulation and governance of Artificial Intelligence (AI) systems. The primary purpose of AI-related regulation is to ensure that these technologies do not infringe upon, but rather protect, the essential liberties and protections guaranteed to individuals under the Charter.

When assessing the potential adverse impacts of AI systems, it is mandatory to consider a co</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_14">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 14</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 14** serves as the primary legal provision governing the mandate for human oversight of high-risk AI systems. It establishes the critical framework for ensuring that such technologies remain subject to meaningful human control, thereby defining both the overarching requirements and the specific implementation measures necessary for compliance.

As the regulation governing human oversight, **ARTICLE 14** mandates that high-risk AI systems must be designed and developed in such a way tha</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERNAL_GOVERNANCE_ARRANGEMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INTERNAL GOVERNANCE ARRANGEMENTS</rdfs:label>
    <skos:definition xml:lang="en">Rules and processes under Union financial services law that allow financial institutions to fulfill quality management system obligations as per Article 17(4).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_15">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 15</rdfs:label>
    <skos:definition xml:lang="en">**RECITAL 15**

RECITAL 15 serves as a foundational clarification within the relevant regulatory framework by explicitly defining the concept of "biometric identification." Furthermore, it establishes a clear distinction between this term and "biometric verification," ensuring that the regulatory scope correctly differentiates between the two processes for legal and technical clarity.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BEST_PRACTICE_EVALUATION_IN_PROCUREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">BEST PRACTICE EVALUATION IN PROCUREMENT</rdfs:label>
    <skos:definition xml:lang="en">Duty of the AI Office to evaluate and promote the convergence of best practices in public procurement regarding AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#hasRiskCategory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has risk category</rdfs:label>
    <skos:definition xml:lang="en">Classifies an AI system into a risk category.</skos:definition>
    <rdfs:domain rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:range rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_GOVERNANCE_AND_MANAGEMENT_PRACTICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA GOVERNANCE AND MANAGEMENT PRACTICES</rdfs:label>
    <skos:definition xml:lang="en">Practices covering design choices, data collection, preparation, and bias mitigation required for training, validation, and testing data sets for high-risk AI systems per Article 10</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_10"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_ARREST_WARRANT_DECISION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">EUROPEAN ARREST WARRANT DECISION</rdfs:label>
    <skos:definition xml:lang="en">The **European Arrest Warrant Decision** is formally established by Council Framework Decision 2002/584/JHA. This legal instrument serves as the foundation for surrender procedures between Member States of the European Union, facilitating the efficient extradition of individuals to face prosecution or serve custodial sentences.

Beyond its primary function as a mechanism for judicial cooperation and the surrender of persons across borders, the European Arrest Warrant Decision is increasingly sig</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LIABILITY_INSURANCE_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">LIABILITY INSURANCE REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">Notified bodies must hold appropriate liability insurance for their activities, unless the Member State assumes liability, as per Article 31(9)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_INSTITUTIONS__BODIES__OFFICES_AND_AGENCIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">UNION INSTITUTIONS, BODIES, OFFICES AND AGENCIES</rdfs:label>
    <skos:definition xml:lang="en">Union institutions, bodies, offices, and agencies are entities of the European Union that fall under the scope of the AI Act. These institutions are specifically subject to the Regulation whenever they act in the capacity of a provider or deployer of an AI system, a clarification reinforced by Recital 23. Furthermore, these entities are subject to oversight by the European Data Protection Supervisor, which may impose fines for non-compliance. In addition to these regulatory obligations, the Euro</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_FINE"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_AND_ORGANISATIONAL_MEASURES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_FRAMEWORK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RISK MANAGEMENT FRAMEWORK</rdfs:label>
    <skos:definition xml:lang="en">A framework provided by Regulation (EU) 2022/2065 for managing risks associated with very large online platforms and search engines</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DOCUMENTATION_PROVISION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DOCUMENTATION PROVISION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Notified bodies must make available and submit all relevant documentation to the notifying authority upon request</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ENVIRONMENTAL_AND_SOCIAL_STAKEHOLDERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">ENVIRONMENTAL AND SOCIAL STAKEHOLDERS</rdfs:label>
    <skos:definition xml:lang="en">Relevant groups whose representation is encouraged in the development of standards</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_STANDARDS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DEMOCRATIC_PROCESSES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">DEMOCRATIC PROCESSES</rdfs:label>
    <skos:definition xml:lang="en">High-risk domain encompassing AI systems intended to influence the outcome of elections, referenda, or voting behaviour (Recital 62).</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GOVERNANCE_AND_ENFORCEMENT_STRUCTURE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">GOVERNANCE AND ENFORCEMENT STRUCTURE</rdfs:label>
    <skos:definition xml:lang="en">Requirement for the operational establishment of infrastructure related to governance and conformity assessment, applicable from 2 August 2025 (Recital 179)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_IDENTIFICATION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">BIOMETRIC IDENTIFICATION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">A **Biometric Identification System** is a specific category of high-risk artificial intelligence system designed to establish an individual's identity. This process is accomplished by comparing biometric data—such as facial recognition, voice patterns, or gait analysis—against a reference database, regardless of whether the individual has provided consent. Notably, this definition excludes biometric verification or authentication systems that are strictly used for access control, such as unlock</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_VERIFICATION_EXCLUSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_DATA"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REFERENCE_DATABASE"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ENHANCED_HUMAN_OVERSIGHT_REQUIREMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">An AI System is defined as a fast-evolving, machine-based family of technologies designed to operate with varying levels of autonomy. Utilizing machine learning, logic-based, or knowledge-based approaches, these systems infer from human-defined objectives and inputs—such as data or other stimuli—how to generate outputs like predictions, content, recommendations, or decisions. These outputs have the capacity to influence physical or virtual environments. Crucially, an AI system is distinct from t</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2_TEU"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_6_TEU"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HUMAN_CENTRIC_TECHNOLOGY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECORD_KEEPING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ETHICAL_PRINCIPLES_FOR_TRUSTWORTHY_AI"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REVERSIBILITY_OF_AI_OUTPUTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PRESUMPTION_OF_CONFORMITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_FINE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HUMAN_OVERSIGHT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DECLARATION_OF_CONFORMITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_III__SECTION_2"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_LABOUR_LAW"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#LAW_ON_THE_PROTECTION_OF_MINORS"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATORY_SANDBOXES"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLIANCE_WITH_THIS_REGULATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOXES"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATIONS"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTIFICIAL_CONTENT_DISCLOSURE_OBLIGATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#LABELING_OBLIGATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2023_988"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#SAFETY_NET"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2017_745"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2017_746"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE_2002_58_EC"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#NEW_LEGISLATIVE_FRAMEWORK"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_SECURITY_AND_MILITARY_EXCLUSION"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#SCIENTIFIC_RESEARCH_EXCLUSION"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#MILITARY__DEFENCE_OR_NATIONAL_SECURITY_ACTIVITY"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#SCIENTIFIC_RESEARCH_AND_DEVELOPMENT_ACTIVITY"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_ASSISTIVE_FUNCTIONS"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REQUIREMENTS_OF_SECTION_2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">REQUIREMENTS OF SECTION 2</rdfs:label>
    <skos:definition xml:lang="en">The "REQUIREMENTS OF SECTION 2" constitute the essential criteria that high-risk AI systems must satisfy to achieve and maintain their regulatory compliance and certification status under the AI Act. Specifically, these mandates, which are referenced in Article 47(2), encompass a comprehensive framework of both technical and organizational requirements. By adhering to these standards, AI systems ensure they are operating within the established legal and safety parameters required by the legislat</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RIGHT_TO_WITHDRAW">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">RIGHT TO WITHDRAW</rdfs:label>
    <skos:definition xml:lang="en">The provider must ensure subjects can withdraw from testing at any time, without justification or detriment, and exercise their right to data deletion, per Article 60(5)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_32">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 32</rdfs:label>
    <skos:definition xml:lang="en">**RECITAL 32** serves as a critical regulatory provision addressing the significant concerns surrounding the deployment of real-time remote biometric identification systems within public spaces. This recital highlights the inherently intrusive nature of such technologies, emphasizing that their usage poses substantial risks, particularly concerning privacy, civil liberties, and the potential for discriminatory outcomes. By identifying these dangers, RECITAL 32 provides essential context regardin</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PERSONAL_NON_PROFESSIONAL_ACTIVITY_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">PERSONAL NON-PROFESSIONAL ACTIVITY EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">The "PERSONAL NON-PROFESSIONAL ACTIVITY EXCLUSION" establishes that the AI Act does not apply to the obligations of deployers who are natural persons using AI systems in the course of a purely personal, non-professional activity. 

There is a noted contradiction in the provided data regarding the specific legal citation for this definition; one source references Article 2(10), while the other cites Article 3(10). Based on the context of the AI Act, the scope and exclusions are typically outlined</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_68">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 68</rdfs:label>
    <skos:definition xml:lang="en">Text identifying actors like providers, notified bodies, and researchers who should have access to data for high-risk AI system assessment</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_DIGITAL_INNOVATION_HUBS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_EXPERIMENTATION_FACILITIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RESEARCHERS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFIED_BODY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_37">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 37</rdfs:label>
    <skos:definition xml:lang="en">Article addressing the challenge to the competence of notified bodies</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVIDER_OF_GENERAL_PURPOSE_AI_MODEL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PROVIDER OF GENERAL-PURPOSE AI MODEL</rdfs:label>
    <skos:definition xml:lang="en">**Provider of General-Purpose AI Model**

A "Provider of General-Purpose AI Model" is defined as any natural or legal person, or their representative, who develops a general-purpose AI model or places such a model on the Union market. 

As the entity primarily responsible for the general-purpose AI model, the provider is subject to a robust framework of compliance and oversight. This includes strict adherence to obligations mandated by regulatory bodies, specifically the AI Office, which conduct</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_18_OF_REGULATION__EU__2019_1020"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_MITIGATION_MEASURES"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_HARMONISED_STANDARD"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_92_EVALUATIONS"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_18_REGULATION_2019_1020"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#OBLIGATION_TO_PROVIDE_ACCESS"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#OBLIGATION_TO_COMPLY_WITH_MEASURES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISED_REPRESENTATIVE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_53"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_55"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_56"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#ALTERNATIVE_ADEQUATE_MEANS_OF_COMPLIANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION_OF_PREDICTIVE_RISK_ASSESSMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION OF PREDICTIVE RISK ASSESSMENTS</rdfs:label>
    <skos:definition xml:lang="en">Duty not to deploy AI systems that predict criminal behavior based solely on individual profiling or personality traits.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MEMBER_STATE_REPRESENTATIVES">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STAKEHOLDERS"/>
    <rdfs:label xml:lang="en">MEMBER STATE REPRESENTATIVES</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SystemicRisk">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">SystemicRisk</rdfs:label>
    <skos:definition xml:lang="en">Risk classification for GPAI models exceeding the compute threshold.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2023_2854">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2023/2854</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2023/2854 is the official designation for the legislation widely known as the Data Act. This regulation establishes harmonized rules regarding the fair access to and use of data. Furthermore, it is explicitly referenced within Recital 43 of the European Union's legislative framework, underscoring its relevance and integration into the broader body of EU law.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_49__C_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(49)(C)</rdfs:label>
    <skos:definition xml:lang="en">Definition of specific serious incidents triggering limited notification obligations for certain high-risk AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_QUALITY_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA QUALITY REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">Requirement for AI systems to be trained and tested on data reflecting the specific geographical, behavioural, contextual, or functional setting of intended use, linked to Article 10(4)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_LAW">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">NATIONAL LAW</rdfs:label>
    <skos:definition xml:lang="en">Reference to the specific national legal frameworks of Member States which define appropriate safeguards and conditions for urgent use of AI systems, or authorize the deployment of such systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPROVEMENT_OF_HUMAN_ACTIVITY_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">IMPROVEMENT OF HUMAN ACTIVITY EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">A condition where an AI system is intended to improve the result of a previously completed human activity, thereby resulting in lowered risk and potential exclusion from high-risk classification</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#MATERIAL_INFLUENCE_CRITERION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DENMARK">
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#PROTOCOL_NO_22"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <rdfs:label xml:lang="en">DENMARK</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXEMPTION_FROM_ADMINISTRATIVE_FINES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXEMPTION FROM ADMINISTRATIVE FINES</rdfs:label>
    <skos:definition xml:lang="en">Prospective providers are exempt from administrative fines for Regulation infringements if they follow the sandbox participation plan and guidance provided by the national competent authority.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION_2017_746">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION 2017/746</rdfs:label>
    <skos:definition xml:lang="en">Union harmonisation legislation applicable to in vitro diagnostic medical devices (Recital 46)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_46"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_59">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 59</rdfs:label>
    <skos:definition xml:lang="en">Recital in the EU AI Act providing context on the high-risk classification of law enforcement AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MANIPULATIVE_OR_DECEPTIVE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">MANIPULATIVE OR DECEPTIVE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems that deploy subliminal components or other manipulative/deceptive techniques to distort human behaviour, impair autonomy, or exploit vulnerabilities, causing significant harm. Prohibited under the Act.</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SIGNIFICANT_HARM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNACCEPTABLE_RISK"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_MANIPULATIVE_AI_PRACTICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_42">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 42</rdfs:label>
    <skos:definition xml:lang="en">Article 42 addresses the presumption of conformity for high-risk AI systems. Specifically, it establishes provisions under which these systems are presumed to satisfy certain requirements based on their adherence to specific standards. This presumption is granted when high-risk AI systems demonstrate compliance through either the quality of their training data or by obtaining relevant cybersecurity certification. Consequently, Article 42 serves as a mechanism to streamline regulatory compliance </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_881"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EDUCATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">EDUCATION</rdfs:label>
    <skos:definition xml:lang="en">In the context of the AI regulatory framework, "EDUCATION" is designated as one of the eight specific high-risk use case domains. As defined in Annex III of the relevant regulations, this domain encompasses a broad range of AI systems deployed within educational and training settings. Specifically, these systems include those designed for evaluating students, such as grading or assessment tools, as well as AI technologies that influence educational pathways, such as admissions screening or curri</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EuropeanAIBoard">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">European AI Board</rdfs:label>
    <skos:definition xml:lang="en">Advisory body composed of Member State representatives. (Article 65)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_68">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 68</rdfs:label>
    <skos:definition xml:lang="en">Article 68 establishes the scientific panel composed of independent experts. This article details the panel's structure, including its specific composition, the tasks it is mandated to perform, and the operating requirements it must adhere to. Furthermore, the article clarifies that the members serving on this panel function in the capacity of independent experts.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#SCIENTIFIC_PANEL"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_III_CATEGORY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">ANNEX III CATEGORY</rdfs:label>
    <skos:definition xml:lang="en">**ANNEX III CATEGORY** represents a classification of domains within the framework of artificial intelligence regulation. These specific domains include law enforcement, migration, asylum, border control, the administration of justice, and democratic processes. Within these sectors, AI systems classified as high-risk are subject to stringent oversight, necessitating specific investigative and corrective powers to ensure compliance, safety, and accountability.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_CONDITION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION CONDITION</rdfs:label>
    <skos:definition xml:lang="en">Four specific criteria under which an AI system, otherwise listed as high-risk under Annex III, may be considered non-high-risk: 1) narrow and limited nature/limited risk, 2) improves the result of a previously completed human activity, 3) detects decision-making patterns or deviations, or 4) performs a task preparatory to an assessment.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NON_HIGH_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_75">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 75</rdfs:label>
    <skos:definition xml:lang="en">The section focusing on technical robustness, resilience against harmful behavior, and the need for fail-safe plans.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_818">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2019/818</rdfs:label>
    <skos:definition xml:lang="en">Legislation establishing the interoperability framework for police, judicial, asylum, and migration systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION_OF_CONSULTANCY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION OF CONSULTANCY</rdfs:label>
    <skos:definition xml:lang="en">Notifying authorities are prohibited from performing activities that conformity assessment bodies perform or providing consultancy services on a commercial or competitive basis, as per Article 29(5)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#conductedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">conducted by</rdfs:label>
    <skos:definition xml:lang="en">Relates a conformity assessment to the body conducting it.</skos:definition>
    <rdfs:domain rdf:resource="https://w3id.org/euaiact/ontology#ConformityAssessment"/>
    <rdfs:range rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HIGH_RISK_AREAS_HEADINGS_AMENDMENT_EVALUATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">HIGH-RISK AREAS HEADINGS AMENDMENT EVALUATION</rdfs:label>
    <skos:definition xml:lang="en">The Commission must evaluate and report on the need to amend the list of high-risk areas headings in the annex by 2 August 2028 and every four years thereafter (Recital 174).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPLEMENTING_ACTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#DelegatedAct"/>
    <rdfs:label xml:lang="en">IMPLEMENTING ACTS</rdfs:label>
    <skos:definition xml:lang="en">**Implementing Acts** are legal instruments adopted by the European Commission that serve various regulatory and procedural functions within the framework of the AI Act. These acts are utilized to ensure the effective application and standardization of requirements across different contexts.

Specifically, Implementing Acts are employed to establish detailed arrangements and procedural safeguards concerning infringement proceedings, as outlined under Article 101(6). They also play a crucial role</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_98_2_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_IN_CHAPTER_III_SECTION_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_73">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 73</rdfs:label>
    <skos:definition xml:lang="en">Article 73 establishes the regulatory framework and specific requirements for the reporting of serious incidents involving high-risk AI systems. It defines the necessary procedures that must be followed when such incidents occur, ensuring a systematic approach to incident management.

Crucially, Article 73 governs the specific obligations of deployers in situations where they are unable to establish contact with the provider of a high-risk AI system. In addition to outlining these reporting mand</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_49_3_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 49(3)</rdfs:label>
    <skos:definition xml:lang="en">Provision detailing the specific information deployers must submit to the EU database regarding high-risk AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_5_1__H__III_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 5(1)(H)(III)</rdfs:label>
    <skos:definition xml:lang="en">Provision within the AI Act referencing criminal offences, which triggers specific legal considerations for AI usage in law enforcement contexts.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUBLIC_AUTHORITIES_OF_A_THIRD_COUNTRY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PUBLIC AUTHORITIES OF A THIRD COUNTRY</rdfs:label>
    <skos:definition xml:lang="en">**PUBLIC AUTHORITIES OF A THIRD COUNTRY** are foreign entities that may be excluded from the scope of the Regulation when they are operating within the framework of cooperation or international agreements specifically related to law enforcement and judicial cooperation. This exclusion is not automatic; rather, it is conditional, requiring these public authorities to provide adequate safeguards in their activities to qualify for this exemption.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_MILITARY__DEFENCE_AND_NATIONAL_SECURITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNATIONAL_COOPERATION_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION__RISK_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REPORTING OBLIGATION (RISK)</rdfs:label>
    <skos:definition xml:lang="en">The requirement for a deployer to inform the provider, distributor, and market surveillance authority if an AI system poses a risk</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INDEPENDENCE_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INDEPENDENCE REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">The obligation for notified bodies to be independent of providers and economic operators of the AI systems they assess, preventing conflicts of interest and prohibiting involvement in design/development</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_DATA_PROCESSING_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">BIOMETRIC DATA PROCESSING AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems that process biometric data to identify/infer emotions, intentions, or specific categories (sex, age, etc.) of natural persons, triggering notification obligations.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_63">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 63</rdfs:label>
    <skos:definition xml:lang="en">Article 63 functions as a regulatory provision that governs derogations for specific operators, specifically targeting microenterprises. This article outlines the specific exemptions or special conditions applicable to these smaller business entities, particularly in the context of their quality management systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INDISCRIMINATE_SURVEILLANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">INDISCRIMINATE SURVEILLANCE</rdfs:label>
    <skos:definition xml:lang="en">A forbidden outcome in the framework of law enforcement when using post-remote biometric identification systems, as prohibited under Recital 95</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_ASYLUM_AND_VISA_PROCESSING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR ASYLUM AND VISA PROCESSING</rdfs:label>
    <skos:definition xml:lang="en">System used to assist in examining applications for asylum, visa, or residence permits and assessing reliability of evidence, identified in Annex III(7)(c)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_49_7_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 49(7)</rdfs:label>
    <skos:definition xml:lang="en">Provision empowering the Commission to adopt delegated acts to delete conditions for high-risk classification exclusion</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ACCESS_TO_DOCUMENTATION_AND_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ACCESS TO DOCUMENTATION AND DATA</rdfs:label>
    <skos:definition xml:lang="en">Obligation for providers to grant market surveillance authorities full access to documentation, training, validation, and testing datasets for high-risk AI systems</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_49_5_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 49(5)</rdfs:label>
    <skos:definition xml:lang="en">Article 49(5) serves as a regulatory provision within the framework governing high-risk AI systems. It specifically dictates the requirements for registration within the designated EU database for those high-risk AI systems that are related to point 2 of Annex III. Furthermore, Article 49(5) mandates that the Commission must provide appropriate guidelines to facilitate this process, ensuring these guidelines are developed only after formally consulting the European Artificial Intelligence Board.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_96"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CREDIT_INSTITUTIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CREDIT INSTITUTIONS</rdfs:label>
    <skos:definition xml:lang="en">Entities subject to prudential requirements under Regulation (EU) No 575/2013 (Recital 46)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_575_2013"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCEPTIONAL_PUBLIC_SECURITY_AUTHORISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EXCEPTIONAL PUBLIC SECURITY AUTHORISATION</rdfs:label>
    <skos:definition xml:lang="en">Market surveillance authorities may authorise the placing on the market or putting into service of AI systems that have not undergone conformity assessment for reasons of public security, protection of life/health, environmental protection, or protection of key assets</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GENERAL_PENALTY_RULES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">GENERAL PENALTY RULES</rdfs:label>
    <skos:definition xml:lang="en">Obligation for Member States to lay down and notify the Commission of rules on penalties, including administrative fines, applicable from 2 August 2025</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION_OF_MANIPULATIVE_TECHNIQUES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION OF MANIPULATIVE TECHNIQUES</rdfs:label>
    <skos:definition xml:lang="en">Prohibition on placing, putting into service, or using AI systems that deploy subliminal techniques to distort behavior (Article 5(1)(a))</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPARTIALITY_AND_OBJECTIVITY_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">IMPARTIALITY AND OBJECTIVITY OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Scientific panel experts must perform tasks with impartiality, objectivity, and confidentiality, and are prohibited from seeking instructions from external parties</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_45_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(45)</rdfs:label>
    <skos:definition xml:lang="en">Definition of law enforcement authority</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION_OF_CERTAIN_AI_PRACTICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION OF CERTAIN AI PRACTICES</rdfs:label>
    <skos:definition xml:lang="en">Requirement to cease practices deemed to carry an unacceptable risk, effective from 2 February 2025</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#APPLICATION_DATE_2_FEBRUARY_2025"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2014_90_EU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2014/90/EU</rdfs:label>
    <skos:definition xml:lang="en">Directive 2014/90/EU is a key legislative act concerning the regulation of marine equipment. This directive was established to standardize requirements for marine equipment placed on board ships, explicitly repealing the earlier Council Directive 96/98/EC to update and improve the regulatory framework.

In its recent evolution, Directive 2014/90/EU has been amended by Article 105 of the AI Act. This amendment serves to integrate specific requirements for artificial intelligence, ensuring that wh</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITALS_29_30">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITALS 29-30</rdfs:label>
    <skos:definition xml:lang="en">Recitals detailing the rationale for prohibiting specific AI practices involving manipulation, deception, exploitation of vulnerabilities, and sensitive biometric categorisation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#SystemicRisk"/>
    <rdfs:label xml:lang="en">GENERAL-PURPOSE AI MODEL WITH SYSTEMIC RISK</rdfs:label>
    <skos:definition xml:lang="en">A "General-Purpose AI Model with Systemic Risk" is a specific classification of general-purpose AI (GPAI) models that possess high-impact capabilities sufficient to pose concrete, identifiable risks at the Union level. These models are subject to additional, stricter regulatory obligations under the European Union’s AI Act to ensure safety and transparency.

A model is designated as having systemic risk based on specific criteria defined in the AI Act. The primary technical benchmark for this cl</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MODEL_EVALUATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_XIII"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_55"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_51"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_92"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_POLICIES"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_93_MITIGATION_MEASURES"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DataGovernance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Data Governance</rdfs:label>
    <skos:definition xml:lang="en">Requirements on training, validation and testing data. (Article 10)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MANDATORY_REQUIREMENTS_FOR_HIGH_RISK_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MANDATORY REQUIREMENTS FOR HIGH-RISK AI</rdfs:label>
    <skos:definition xml:lang="en">Mandatory requirements for high-risk AI systems comprise essential technical and organizational standards designed to ensure that these systems do not pose unacceptable risks. As outlined in Recital 46, these requirements serve the dual purpose of preventing harm in a general sense and specifically safeguarding Union public interests from the potential threats posed by high-risk AI deployment.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_46"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PERSONAL_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PERSONAL DATA</rdfs:label>
    <skos:definition xml:lang="en">Personal Data is defined as any information that relates to an identified or identifiable natural person. This definition is established across two key regulatory references: it is described as the data pertaining to such a person under Article 3(50), and it aligns with the broader definition of personal data provided in Article 4, point (1), of Regulation (EU) 2016/679 (the General Data Protection Regulation). In essence, whether referenced through Article 3(50) or the GDPR, Personal Data encom</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_50_"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_4_1_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPLEMENTING_ACTS_ON_SANDBOXES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#DelegatedAct"/>
    <rdfs:label xml:lang="en">IMPLEMENTING ACTS ON SANDBOXES</rdfs:label>
    <skos:definition xml:lang="en">Acts adopted by the Commission to specify detailed arrangements for the establishment, operation, and supervision of AI regulatory sandboxes, ensuring consistency across the Union (Article 58(1)).</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_58"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_98_2_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTELLECTUAL_PROPERTY_RIGHTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INTELLECTUAL PROPERTY RIGHTS</rdfs:label>
    <skos:definition xml:lang="en">Rights that must be protected while AI value chain parties cooperate with providers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNACCEPTABLE_AI_PRACTICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">UNACCEPTABLE AI PRACTICES</rdfs:label>
    <skos:definition xml:lang="en">Unacceptable AI practices refer to specific artificial intelligence systems or applications that are strictly prohibited under the Regulation. These practices are classified as impermissible due to the nature and intensity of the significant risks they pose to individuals, fundamental rights, and society at large. Because of these severe risks, such systems are deemed incompatible with the requirements set forth in the Regulation and are therefore banned from deployment or use.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REQUEST_FOR_INFORMATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REQUEST FOR INFORMATION</rdfs:label>
    <skos:definition xml:lang="en">A mandatory requirement for a provider to submit documentation (per Articles 53/55) or additional information to the Commission/AI Office, subject to fines for non-compliance</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER_OF_GENERAL_PURPOSE_AI_MODEL"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_91"/>
    <euai:hasConsequence rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_101"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_30">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 30</rdfs:label>
    <skos:definition xml:lang="en">ARTICLE 30 outlines the specific procedures for the notification of conformity assessment bodies, as well as the mandate and usage of electronic notification tools. This article serves to detail the regulatory framework for notifying authorities regarding their process for designating these bodies, ensuring transparency and clarity in the notification mechanism. Additionally, it establishes the requirements and functionalities for the electronic tools used to facilitate these notifications, ensu</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MILITARY__DEFENCE_OR_NATIONAL_SECURITY_ACTIVITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">MILITARY, DEFENCE OR NATIONAL SECURITY ACTIVITY</rdfs:label>
    <skos:definition xml:lang="en">Activities related to military, defence, or national security purposes are excluded from the scope of this Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SERIOUS_INCIDENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#SeriousIncident"/>
    <rdfs:label xml:lang="en">SERIOUS INCIDENT</rdfs:label>
    <skos:definition xml:lang="en">A "Serious Incident" refers to a critical event or malfunctioning associated with an AI system that necessitates urgent regulatory and operational oversight. As defined under Article 3(49), it encompasses any incident directly or indirectly resulting in the death or serious harm to an individual’s health, the serious and irreversible disruption of the management and operation of critical infrastructure, the infringement of fundamental rights, or substantial damage to property or the environment.</skos:definition>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_SERIOUS_INCIDENTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SERIOUS_INCIDENT_REPORTING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_IN_REAL_WORLD_CONDITIONS"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_49_"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_73"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEXES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEXES</rdfs:label>
    <skos:definition xml:lang="en">Specific annexes to this Regulation that set out the minimal set of elements to be included in the technical documentation, as described in Recital 101</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROFILING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PROFILING</rdfs:label>
    <skos:definition xml:lang="en">**PROFILING** is defined as any form of automated processing of personal data that involves utilizing such data to evaluate specific personal aspects related to a natural person. This definition is formally established in Article 4, point (4), of Regulation (EU) 2016/679 (the General Data Protection Regulation or GDPR) and is similarly referenced in Article 3(52) of relevant regulatory frameworks.

In addition to its definition under data protection law, profiling holds significant implications </skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_4"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2016_680"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1725"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_52_"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_4_4_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_LAW_ENFORCEMENT_PROFILING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR LAW ENFORCEMENT PROFILING</rdfs:label>
    <skos:definition xml:lang="en">System used for profiling natural persons during detection, investigation, or prosecution of criminal offences, identified in Annex III(6)(e)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#POLYGRAPHS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">POLYGRAPHS</rdfs:label>
    <skos:definition xml:lang="en">AI systems used to detect the emotional state of natural persons; their use is not governed by the AI Act as lawful ground, but remains subject to applicable requirements under Union/national law (Recital 63).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSITIONAL_PERIOD_OBLIGATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TRANSITIONAL PERIOD OBLIGATIONS</rdfs:label>
    <skos:definition xml:lang="en">Voluntary compliance with Regulation obligations during the transitional period for providers of high-risk AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OVERSIGHT_OF_SIGNIFICANT_RISKS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">OVERSIGHT OF SIGNIFICANT RISKS</rdfs:label>
    <skos:definition xml:lang="en">Requirement for adequate mitigation of significant risks to health, safety, and fundamental rights identified during sandbox testing.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EducationAdmissionAI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#HighRiskAISystem"/>
    <rdfs:label xml:lang="en">EducationAdmissionAI</rdfs:label>
    <skos:definition xml:lang="en">AI determining access to educational institutions</skos:definition>
    <euai:articleReference>Annex III, 3</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_LITERACY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">AI LITERACY</rdfs:label>
    <skos:definition xml:lang="en">**AI Literacy** is a critical set of notions, skills, knowledge, and understanding that enables individuals—specifically providers, deployers, and affected persons—to make informed decisions regarding the deployment and use of artificial intelligence systems. As defined in Article 3(56), it encompasses the ability to understand the technical elements of AI, interpret system outputs, and comprehend the potential impacts of AI on individuals and society, including an awareness of associated risks.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AFFECTED_PERSON"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_4"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_38">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 38</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 38**

Article 38 is a provision that specifically addresses the coordination and cooperation of notified bodies. It establishes the requirement for these entities to engage in various coordination activities, mandating that notified bodies actively participate in these collaborative efforts to ensure consistency and efficiency in their regulatory functions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_290_TFEU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 290 TFEU</rdfs:label>
    <skos:definition xml:lang="en">The article providing the legal basis for the Commission to adopt delegated acts to adapt the regulatory framework, as per Recital 173</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#DELEGATED_ACT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2014_32_EU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2014/32/EU</rdfs:label>
    <skos:definition xml:lang="en">DIRECTIVE 2014/32/EU, commonly known as the Measuring Instruments Directive (MID), is a European Union legislative act designed to regulate the market availability and harmonization of laws for measuring instruments within the EU. It establishes a unified regulatory framework that ensures measuring devices meet consistent standards, thereby facilitating the free movement and trade of these instruments across member states. By harmonizing national laws, the directive aims to maintain high levels </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTENDED_PURPOSE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INTENDED PURPOSE</rdfs:label>
    <skos:definition xml:lang="en">The use for which an AI system is intended by the provider, specified in instructions for use, promotional materials, and technical documentation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_ADMINISTRATION_OF_JUSTICE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR ADMINISTRATION OF JUSTICE</rdfs:label>
    <skos:definition xml:lang="en">An AI system intended to be used by a judicial authority or on its behalf to assist in researching and interpreting facts and the law, or applying the law to a concrete set of facts. Considered high-risk per Recital 61.</skos:definition>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#JUDICIAL_AUTHORITY"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HUMAN_OVERSIGHT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_44">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 44</rdfs:label>
    <skos:definition xml:lang="en">Governs the issuance, validity, and management of certificates for AI systems by notified bodies</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CYBERSECURITY_SCHEME">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CYBERSECURITY SCHEME</rdfs:label>
    <skos:definition xml:lang="en">The "CYBERSECURITY SCHEME" is a certification framework established pursuant to Regulation (EU) 2019/881, commonly known as the Cybersecurity Act. This scheme is designed to play a critical role in the regulatory landscape for high-risk AI systems. When a system meets the requirements set forth by this scheme, it benefits from a presumption of conformity with the cybersecurity standards mandated by the relevant legal framework. Specifically, this certification is utilized to establish a presumpt</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_POLICIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RISK MANAGEMENT POLICIES</rdfs:label>
    <skos:definition xml:lang="en">Internal processes (accountability, governance) that providers of GPAI models with systemic risks must implement to identify and mitigate risks.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADAPTIVE_DESIGNATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">ADAPTIVE DESIGNATION</rdfs:label>
    <skos:definition xml:lang="en">The Commission's power to designate a GPAI model as having systemic risk even if it does not meet the initial quantitative threshold, based on criteria like training data quality, size, autonomy, and scalability.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MITIGATING_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MITIGATING MEASURES</rdfs:label>
    <skos:definition xml:lang="en">Actions taken by providers to reduce risks, particularly systemic risks, in observance of fundamental rights</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#Provider">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Provider</rdfs:label>
    <skos:definition xml:lang="en">A natural or legal person that develops or places an AI system on the market. (Article 3(3))</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_49_1_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 49(1)</rdfs:label>
    <skos:definition xml:lang="en">Article 49(1) delineates the registration obligations specifically applicable to providers of high-risk AI systems. This article establishes the regulatory requirements that these providers must adhere to concerning the registration of their high-risk AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EDUCATION_AND_VOCATIONAL_TRAINING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">EDUCATION AND VOCATIONAL TRAINING</rdfs:label>
    <skos:definition xml:lang="en">"Education and Vocational Training" is classified as a high-risk domain regarding the application of AI systems. This domain encompasses AI technologies utilized within educational and training environments, specifically focusing on critical functions such as facilitating access to educational institutions, evaluating learning outcomes, and monitoring student behavior. According to Recital 56, the designation of this domain as a high-risk use case highlights the necessity for stringent oversight</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SECTION_2_OF_CHAPTER_II">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">SECTION 2 OF CHAPTER II</rdfs:label>
    <skos:definition xml:lang="en">The specific section of the AI Act setting out requirements for high-risk AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_DIGITAL_INNOVATION_HUB">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">EUROPEAN DIGITAL INNOVATION HUB</rdfs:label>
    <skos:definition xml:lang="en">European Digital Innovation Hubs (EDIHs) are EU-supported entities specifically designated to foster digital innovation and facilitate the implementation of relevant European regulations. Functioning as integral pillars within the European technological landscape, these hubs serve multiple strategic purposes.

Primarily, European Digital Innovation Hubs are tasked with supporting the broader digital transformation efforts across the region. They play a critical role in the regulatory sandbox eco</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_22_1_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 22(1)</rdfs:label>
    <skos:definition xml:lang="en">Refers to the requirement for the provider to appoint an authorised representative</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_DATA_PROTECTION_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">NATIONAL DATA PROTECTION AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">The National Data Protection Authority serves as the competent body responsible for oversight and enforcement concerning data protection laws, particularly those governing biometric identification technologies. Its primary role involves regulatory supervision, including the enforcement of legal prohibitions on the use of remote biometric identification systems outside of specific, authorized law enforcement contexts.

The National Data Protection Authority acts as the central point of contact fo</skos:definition>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#ANNUAL_REPORTING"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_9_1__OF_REGULATION__EU__2016_679"/>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_DECISIONS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_76">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 76</rdfs:label>
    <skos:definition xml:lang="en">**RECITAL 76** addresses the critical intersection of safety, security, and operational integrity within AI systems. It outlines the comprehensive landscape of risks associated with AI operations, specifically highlighting the potential for system anomalies that could lead to significant safety impacts. By focusing on these risks, RECITAL 76 emphasizes the necessity of robust oversight to ensure that AI deployments remain safe and predictable under varying conditions.

Furthermore, RECITAL 76 pr</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_36">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 36</rdfs:label>
    <skos:definition xml:lang="en">Article concerning changes to notifications, including cessation of activities, suspension, and withdrawal of designation</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_29"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_30"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_92_EVALUATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ARTICLE 92 EVALUATIONS</rdfs:label>
    <skos:definition xml:lang="en">Evaluations conducted by the Commission or independent experts on GPAI models to assess compliance or investigate systemic risks</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_91"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_90_1__A_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_68"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MEDICAL_DEVICES_REGULATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">MEDICAL DEVICES REGULATION</rdfs:label>
    <skos:definition xml:lang="en">The Medical Devices Regulation, formally known as Regulation (EU) 2017/745, serves as the governing legislative framework for medical devices within the European Union. This comprehensive regulation establishes the standards and requirements that must be met to ensure the safety and performance of medical devices placed on the market. 

A significant aspect of Regulation (EU) 2017/745 is its intersection with evolving technological landscapes, particularly the integration of artificial intellige</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_111">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 111</rdfs:label>
    <skos:definition xml:lang="en">The section of the AI Act establishing the methodology for classifying GPAI models with systemic risks based on capabilities, computation thresholds, and impact.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISKS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MODALITY_THRESHOLD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MODALITY THRESHOLD</rdfs:label>
    <skos:definition xml:lang="en">Assessment of input/output modalities (e.g., text-to-text, text-to-image) and state-of-the-art thresholds determining high-impact capabilities, including specific input types like biological sequences.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REPORTING_OF_INFRINGEMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REPORTING OF INFRINGEMENTS</rdfs:label>
    <skos:definition xml:lang="en">Duty to report infringements of the Regulation, governed by Directive (EU) 2019/1937 per Article 87</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2019_1937"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXIT_REPORT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EXIT REPORT</rdfs:label>
    <skos:definition xml:lang="en">A document provided by the competent authority to a participant detailing activities carried out in the sandbox, results, and learning outcomes. It can be used by providers to demonstrate compliance during conformity assessments</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SINGLE_INFORMATION_PLATFORM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ExclusionCondition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">ExclusionCondition</rdfs:label>
    <skos:definition xml:lang="en">A condition under which an Annex III AI system is NOT classified as high-risk.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_CONDITION__NON_EXPOSURE_TO_OUTPUT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION CONDITION: NON-EXPOSURE TO OUTPUT</rdfs:label>
    <skos:definition xml:lang="en">**EXCLUSION CONDITION: NON-EXPOSURE TO OUTPUT**

The "EXCLUSION CONDITION: NON-EXPOSURE TO OUTPUT" refers to specific criteria under which AI systems are exempt from being classified as high-risk, election-related AI systems. This exclusion applies to AI tools that are utilized for administrative, logistical, or organizational tasks within political campaigns. 

The primary determinant for this exclusion is that natural persons—specifically voters or the public—are not directly exposed to the ou</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMOTION_INFERENCE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EMOTION INFERENCE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI system inferring emotions in workplace or education contexts; prohibited unless for medical or safety reasons</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICE"/>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#EMOTION_INFERENCE_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NE_BIS_IN_IDEM_PRINCIPLE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NE BIS IN IDEM PRINCIPLE</rdfs:label>
    <skos:definition xml:lang="en">A legal principle that Member States must respect when implementing enforcement measures and penalties for infringements of the Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_MIGRATION_RISK_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR MIGRATION RISK ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">System used to assess security, irregular migration, or health risks posed by persons entering a Member State, identified in Annex III(7)(b)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_6_1_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 6(1)</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 6(1)** serves as a critical regulatory provision within the legal framework governing artificial intelligence. This article is primarily responsible for defining the criteria used to classify AI systems as "high-risk." In addition to establishing these classification standards, **ARTICLE 6(1)** sets forth specific obligations that must be met by these high-risk AI systems. Notably, the application of these requirements is subject to a deferred timeline, with the provisions set to becom</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_113"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SPECIAL_CATEGORIES_OF_PERSONAL_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SPECIAL CATEGORIES OF PERSONAL DATA</rdfs:label>
    <skos:definition xml:lang="en">Special Categories of Personal Data refer to a sensitive classification of information that requires heightened protection under European Union law. These categories are formally defined in several key legislative frameworks, specifically Article 9(1) of the General Data Protection Regulation (GDPR), Article 10 of Directive (EU) 2016/680, and Article 10(1) of Regulation (EU) 2018/1725. Due to the sensitive nature of the information involved, the processing of this data is subject to strict limit</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIAS_DETECTION_AND_CORRECTION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_LIMITATIONS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPLIANCE_QUESTIONNAIRE_TEMPLATE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">COMPLIANCE QUESTIONNAIRE TEMPLATE</rdfs:label>
    <skos:definition xml:lang="en">A tool developed by the AI Office to assist deployers in meeting their obligations and reduce administrative burden</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CodeOfPractice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">CodeOfPractice</rdfs:label>
    <skos:definition xml:lang="en">A voluntary compliance instrument for GPAI model providers.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_SUBJECT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">DATA SUBJECT</rdfs:label>
    <skos:definition xml:lang="en">A **DATA SUBJECT** is defined as a natural person whose personal data is processed, including instances where this processing is carried out by AI systems. Regardless of the context in which their data is handled, the **DATA SUBJECT** retains the full scope of rights and guarantees afforded to them under Union data protection law, such as the General Data Protection Regulation (GDPR) and the Law Enforcement Directive (LED). These protections include, but are not limited to, the right to withdraw</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SOLELY_AUTOMATED_INDIVIDUAL_DECISION_MAKING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_10_4_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 10(4)</rdfs:label>
    <skos:definition xml:lang="en">**Article 10(4)** outlines the regulatory requirements concerning data governance and the quality of data sets used for high-risk AI systems. This article specifically details the mandatory standards for training, validation, and testing data sets, ensuring that these systems are developed and evaluated using robust and reliable information. By addressing these criteria, Article 10(4) aims to ensure high-risk AI systems are grounded in sound data management practices, ultimately promoting accura</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GPAI_PROVIDER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">GPAI PROVIDER</rdfs:label>
    <skos:definition xml:lang="en">The entity responsible for placing general-purpose AI models on the market, subject to specific regulatory obligations</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNAL_PROCESS_EXCLUSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RESEARCH_AND_PROTOTYPING_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#URGENCY_EXCEPTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">URGENCY EXCEPTION</rdfs:label>
    <skos:definition xml:lang="en">Allows for the use of biometric systems without prior authorisation in duly justified cases where obtaining it beforehand is objectively impossible. Requires post-hoc authorisation request within 24 hours.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PRIOR_AUTHORISATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">FUNDAMENTAL RIGHTS IMPACT ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">A Fundamental Rights Impact Assessment is a mandatory evaluation required for the deployment of specific artificial intelligence (AI) systems. The assessment serves as a critical procedural safeguard, ensuring that deployers analyze the potential impacts on fundamental rights before putting such systems into operation.

For high-risk AI systems as defined under the relevant framework, particularly those outlined in Annex III (points 5(b) and (c)), the assessment must be conducted by specific dep</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_96"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_27"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_PROTECTION_IMPACT_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_35_OF_REGULATION__EU__2016_679"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_27_OF_DIRECTIVE__EU__2016_680"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_LEVEL_EVALUATION_METHODOLOGY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RISK LEVEL EVALUATION METHODOLOGY</rdfs:label>
    <skos:definition xml:lang="en">Methodology developed by the AI Office to guide evaluations and reviews regarding risk levels and classification inclusion</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_50"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INVESTMENT_FIRMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">INVESTMENT FIRMS</rdfs:label>
    <skos:definition xml:lang="en">Entities subject to prudential requirements under Regulation (EU) No 575/2013 (Recital 46)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_575_2013"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CIVIL_SOCIETY_ORGANISATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CIVIL SOCIETY ORGANISATIONS</rdfs:label>
    <skos:definition xml:lang="en">Civil society organisations are formally recognised as key stakeholders within the regulatory framework governing the development of codes of practice and conduct. They are integrated into the legislative process to ensure diverse perspectives are represented during the drafting phases. Specifically, as outlined in Article 56(3), civil society organisations are invited to support and contribute to the process of drawing up codes of practice. Furthermore, in accordance with Article 95(3), they ar</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_CONDUCT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2021_1134">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2021/1134</rdfs:label>
    <skos:definition xml:lang="en">Legislation reforming the Visa Information System</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_1020">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2019/1020</rdfs:label>
    <skos:definition xml:lang="en">**Regulation (EU) 2019/1020** is the Union regulation governing market surveillance and product compliance. It serves as a fundamental pillar within the New Legislative Framework, providing the essential legal structure for ensuring that products placed on the market meet established safety and regulatory standards.

Within the context of the European Union's regulatory landscape, Regulation (EU) 2019/1020 plays a critical role in supporting the EU AI Act. It functions as the primary mechanism f</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EC__NO_765_2008"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE_2004_42_EC"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CYBERSECURITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CYBERSECURITY</rdfs:label>
    <skos:definition xml:lang="en">**Cybersecurity** in the context of high-risk AI systems is a critical requirement designed to ensure that these systems remain resilient against a wide array of malicious threats and unauthorized activities. It encompasses a comprehensive set of technical and operational measures aimed at safeguarding AI systems, their underlying infrastructure, and their associated data from exploitation.

At its core, **cybersecurity** mandates that high-risk AI systems must be fortified to withstand unauthor</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_76"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_881"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_86">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 86</rdfs:label>
    <skos:definition xml:lang="en">Article 86 is a specific provision within the relevant regulatory framework that establishes the right for individuals to receive an explanation regarding decision-making processes. Specifically, it guarantees that persons affected by high-risk AI systems are entitled to a clear and understandable explanation of the decisions made by those systems, ensuring transparency and accountability in automated individual decision-making.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRAINING__VALIDATION_AND_TESTING_DATA_SETS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TRAINING, VALIDATION AND TESTING DATA SETS</rdfs:label>
    <skos:definition xml:lang="en">The specific data inputs used for developing AI models, which must meet quality criteria regarding representativeness, accuracy, and completeness per Article 10</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_GOVERNANCE_AND_MANAGEMENT_PRACTICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">GENERAL-PURPOSE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">A General-Purpose AI System is defined as an AI system based on or integrating a general-purpose AI model. Its core characteristic is its versatility; it is engineered with the capability to serve a wide variety of purposes. This flexibility allows a General-Purpose AI System to be utilized directly for diverse tasks or to be seamlessly integrated as a component within other, more specialized AI systems.

Because of this broad applicability, a General-Purpose AI System carries specific regulator</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#COOPERATION_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_14_5_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 14(5)</rdfs:label>
    <skos:definition xml:lang="en">Reference for the natural persons involved in the verification of results</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ASSESSMENT_DOCUMENTATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ASSESSMENT DOCUMENTATION</rdfs:label>
    <skos:definition xml:lang="en">Duty for a provider to draw up documentation demonstrating why an AI system is considered non-high-risk before the system is placed on the market or put into service.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MARKING_OF_SYNTHETIC_CONTENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">MARKING OF SYNTHETIC CONTENT</rdfs:label>
    <skos:definition xml:lang="en">Requirement for providers to mark AI-generated outputs in a machine-readable format to ensure they are detectable as artificially generated</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_VERIFICATION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">BIOMETRIC VERIFICATION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">**BIOMETRIC VERIFICATION SYSTEM** refers to AI-based systems specifically designed and utilized for authentication purposes. The primary function of a **BIOMETRIC VERIFICATION SYSTEM** is to confirm an individual's identity to grant them access to specific services, devices, or premises.

Under current regulatory frameworks, such as Recital 54, these systems are explicitly categorized as distinct from broader biometric identification categories. Specifically, a **BIOMETRIC VERIFICATION SYSTEM** </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_VERIFICATION_EXCLUSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NON_COMPLIANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NON-COMPLIANCE</rdfs:label>
    <skos:definition xml:lang="en">A state of failure to meet requirements or obligations, triggering corrective actions or provisional measures by authorities</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESOURCE_PROVISION_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RESOURCE PROVISION REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">Requirement for Member States to ensure national competent authorities have adequate technical, financial, and human resources (Article 70(3)).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_BIAS_MITIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA BIAS MITIGATION</rdfs:label>
    <skos:definition xml:lang="en">Specific measures to detect, prevent, and mitigate biases that could affect health, safety, or fundamental rights, as mandated by Article 10(2)(g)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#hasConsequence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasConsequence</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFICATION_PROCEDURE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NOTIFICATION PROCEDURE</rdfs:label>
    <skos:definition xml:lang="en">The process by which a notifying authority informs the Commission and Member States of a qualified conformity assessment body, as per Article 30</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_30"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_110">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 110</rdfs:label>
    <skos:definition xml:lang="en">Article 110 of the AI Act, which provides the amendment to Directive (EU) 2020/1828 to include the AI Act in its annex.</skos:definition>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE_2020_1828"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AFFECTED_PERSONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">AFFECTED PERSONS</rdfs:label>
    <skos:definition xml:lang="en">**AFFECTED PERSONS** are defined as individuals or entities whose interests, rights, and freedoms are impacted by artificial intelligence systems. This group comprises natural or legal persons whose rights and freedoms are adversely impacted by the use of AI systems, as well as those who are directly affected by decisions made by a deployer based on the output of high-risk AI. Furthermore, AFFECTED PERSONS include those whose specific interests and needs must be taken into account by the AI Offi</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLAINT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RIGHT_TO_AN_EXPLANATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EXPLANATION_OF_DECISION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_114_TFEU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 114 TFEU</rdfs:label>
    <skos:definition xml:lang="en">Legal basis for the AI Act regarding the functioning of the internal market and harmonized rules for AI</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SOCIAL_NETWORK_SERVICE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">SOCIAL NETWORK SERVICE</rdfs:label>
    <skos:definition xml:lang="en">Service provider where ancillary features (e.g., facial/body filters) are used to modify or add to content, intrinsically linked to the service of online content sharing.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LEGAL_REPRESENTATIVE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">LEGAL REPRESENTATIVE</rdfs:label>
    <skos:definition xml:lang="en">Entity appointed by a provider established outside the Union to fulfill obligations on their behalf during real-world testing</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#QUALIFIED_ALERTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">QUALIFIED ALERTS</rdfs:label>
    <skos:definition xml:lang="en">**QUALIFIED ALERTS** are a mechanism designed to enhance the oversight of general-purpose AI models. They serve as a critical notification system where the scientific panel informs the AI Office about potential systemic risks associated with specific AI models—risks that may have been previously overlooked by the European Commission or the model provider. Furthermore, these alerts function as formal notifications regarding general-purpose AI models, which are then reviewed by the Board. Followin</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROFESSIONAL_SECRECY_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROFESSIONAL SECRECY OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Notified body staff must maintain secrecy regarding information obtained during their tasks, except when required by law or in relation to notifying authorities</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUBLIC_AUTHORITY_DEPLOYER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PUBLIC AUTHORITY DEPLOYER</rdfs:label>
    <skos:definition xml:lang="en">Deployers that are public authorities, Union institutions, bodies, offices, or agencies, subject to specific registration requirements under the AI Act</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION_IN_EU_DATABASE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AUTHORISATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">AUTHORISATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The **AUTHORISATION OBLIGATION** refers to a regulatory mandate placed on law enforcement agencies regarding the use of remote biometric identification. Under this obligation, law enforcement is generally required to secure authorization—either *ex ante* (prior to the action) or *post-hoc* (within 48 hours after the action)—from a relevant judicial or administrative authority before proceeding with remote biometric identification.

However, there is a specific exception to this mandate. The requ</skos:definition>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#EXEMPTION_FROM_AUTHORISATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COOPERATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">COOPERATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">**COOPERATION OBLIGATION**

The "COOPERATION OBLIGATION" represents a mandatory requirement for AI system providers to collaborate with relevant stakeholders and regulatory bodies to ensure full compliance with established standards. This obligation manifests in two primary contexts within the AI regulatory framework.

First, providers of general-purpose AI systems are required to cooperate with providers of high-risk AI systems and competent authorities. This collaboration is essential to ensur</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_7_1_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 7(1)</rdfs:label>
    <skos:definition xml:lang="en">Article providing conditions for adding or modifying use-cases in Annex III</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFICATION_TO_MARKET_SURVEILLANCE_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NOTIFICATION TO MARKET SURVEILLANCE AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">Deployers must notify the market surveillance authority of the results of their fundamental rights impact assessment, submitting a completed template</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_88">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 88</rdfs:label>
    <skos:definition xml:lang="en">Article governing the enforcement of obligations of providers of general-purpose AI models</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_68_1_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 68(1)</rdfs:label>
    <skos:definition xml:lang="en">Article referencing the implementing act that sets out fee structures and procedures for the scientific panel.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DEEPFAKE_DISCLOSURE_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DEEPFAKE DISCLOSURE OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Requirement for deployers to clearly disclose that image, audio, or video content (deepfakes) has been artificially created or manipulated.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRAINING_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TRAINING DATA</rdfs:label>
    <skos:definition xml:lang="en">TRAINING DATA refers to the foundational datasets, encompassing both text and other forms of information, that are utilized in the development and refinement of AI systems. This data is essential for both the pre-training and specialized training phases of general-purpose AI models, serving as the raw material through which the system fits and optimizes its learnable parameters. By processing this information, the AI model gains the ability to identify patterns, make predictions, and enhance its</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRAINING_DATA_SUMMARY"/>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#AISYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_49_4_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 49(4)</rdfs:label>
    <skos:definition xml:lang="en">Article governing registration in the EU database for high-risk AI systems in law enforcement/migration/asylum/border control</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_PROTECTION_SUPERVISORY_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">DATA PROTECTION SUPERVISORY AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">Competent authority under Regulation (EU) 2016/679 or Directive (EU) 2016/680, designated by Member States as market surveillance authority for specific high-risk AI systems in law enforcement, border management, justice, and democracy</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_III_USE_CASE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">ANNEX III USE CASE</rdfs:label>
    <skos:definition xml:lang="en">Domains or contexts for AI systems listed in Annex III that generally carry high risk unless specific exclusion conditions apply.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INITIAL_PROVIDER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">INITIAL PROVIDER</rdfs:label>
    <skos:definition xml:lang="en">The original provider of an AI system who is no longer considered the provider when a distributor/importer/third party takes over responsibility via substantial modification or other means)</skos:definition>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#COOPERATION_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#URGENT_DEPLOYMENT_EXCEPTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">URGENT DEPLOYMENT EXCEPTION</rdfs:label>
    <skos:definition xml:lang="en">Law enforcement and civil protection authorities may put a high-risk AI system into service without prior authorisation from market surveillance authorities in duly justified situations, provided authorisation is requested during or after use without undue delay</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECORD_KEEPING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RECORD-KEEPING</rdfs:label>
    <skos:definition xml:lang="en">**RECORD-KEEPING** in the context of AI systems refers to the essential obligation to maintain thorough logs and data trails regarding the operation, activities, and performance of these systems. This practice serves as a critical component of monitoring and accountability frameworks.

For high-risk AI systems, RECORD-KEEPING is not merely a best practice but a mandatory capability and regulatory requirement, specifically mandated by Article 12. This provision requires such systems to possess th</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_12"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CE_MARKING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CE MARKING</rdfs:label>
    <skos:definition xml:lang="en">The **CE marking** serves as a mandatory indicator of conformity for products within the European Economic Area. It signifies that a product, particularly high-risk AI systems, complies with the requirements outlined in applicable Union harmonization legislation, including the provisions set forth in Chapter III, Section 2 of the AI Act. This marking is essential for ensuring the free movement of these systems within the internal market.

Subject to the general principles of Regulation (EC) No 7</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_III__SECTION_2"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EC__NO_765_2008"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2024_900">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2024/900</rdfs:label>
    <skos:definition xml:lang="en">**Regulation (EU) 2024/900** is a legislative act known as the Regulation on the transparency and targeting of political advertising. This regulation establishes a framework of rules designed to ensure democratic processes are upheld. Furthermore, it operates in conjunction with the AI Act, as explicitly noted in Recital 62 of that legislation, ensuring that the use of artificial intelligence in the context of political advertising adheres to established transparency and fairness standards.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_79_1_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 79(1)</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 79(1)**

ARTICLE 79(1) serves as a foundational provision for establishing the regulatory framework surrounding artificial intelligence. Its primary purpose is to define the concept of "risk" specifically within the context of AI systems. This definition is critical for identifying and categorizing potential hazards that may arise during the operation of AI technologies.

Furthermore, ARTICLE 79(1) delineates the specific thresholds and parameters that constitute a "risk" requiring for</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">NATIONAL AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">National competent authorities (referred to in Article 74(8)) that have access to restricted sections of the EU database</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DATABASE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_74_8_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2004_42_EC">
    <rdfs:label xml:lang="en">DIRECTIVE 2004 42 EC</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#POLYGRAPH_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">POLYGRAPH AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems used by law enforcement as polygraphs or similar tools (Annex III 6(b))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BOARD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">BOARD</rdfs:label>
    <skos:definition xml:lang="en">The European Artificial Intelligence Board is a key regulatory entity designed to support the implementation and oversight of artificial intelligence governance. Its responsibilities are multifaceted, serving as a pivotal link between the European Commission, national competent authorities, and the AI Office.

The European Artificial Intelligence Board plays a crucial advisory role, particularly regarding the European Commission. The Commission is required to consult the Board when preparing sta</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STANDARDISED_TEMPLATES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#EVALUATION_AND_REVIEW_REPORT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_DATA_PROTECTION_SUPERVISOR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">EUROPEAN DATA PROTECTION SUPERVISOR</rdfs:label>
    <skos:definition xml:lang="en">The European Data Protection Supervisor (EDPS) serves as a central regulatory body responsible for overseeing the implementation of the AI Act as it pertains to Union institutions, bodies, offices, and agencies. Acting within the scope of this regulation, the EDPS is designated as the competent authority for the supervision of these entities.

Specifically, the EDPS functions as the market surveillance authority for all Union institutions, agencies, and bodies, with the sole exception of the Cou</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1725"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_INSTITUTIONS__BODIES__OFFICES_AND_AGENCIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_ARTIFICIAL_INTELLIGENCE_BOARD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_FINE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_INSTITUTION__BODY__OFFICE_OR_AGENCY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RIGHTS_OF_DEFENCE"/>
    <euai:conductsEvaluationOf rdf:resource="https://w3id.org/euaiact/ontology#UNION_INSTITUTIONS__AGENCIES_AND_BODIES"/>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#UNION_INSTITUTIONS"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#ANNUAL_NOTIFICATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNACCEPTABLE_RISK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">UNACCEPTABLE RISK</rdfs:label>
    <skos:definition xml:lang="en">"UNACCEPTABLE RISK" is the classification level assigned to specific artificial intelligence practices that are prohibited under regulatory frameworks, as detailed in Article 5 of the relevant legislation. This category represents the highest level of risk associated with AI applications. The prohibition of practices falling under this classification is further elaborated in Recitals 29 and 30, which provide context regarding the nature of these prohibited activities. According to Recital 179, t</skos:definition>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_CERTAIN_AI_PRACTICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ETHICS_GUIDELINES_FOR_TRUSTWORTHY_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ETHICS GUIDELINES FOR TRUSTWORTHY AI</rdfs:label>
    <skos:definition xml:lang="en">The **ETHICS GUIDELINES FOR TRUSTWORTHY AI** comprise a set of non-binding ethical principles developed by the High-Level Expert Group on Artificial Intelligence (AI HLEG). Although these guidelines are voluntary in nature, they serve as an influential framework intended to ensure that the development and deployment of artificial intelligence systems are trustworthy, ethically sound, and aligned with human values.

The guidelines are specifically designed to support the development of high-risk </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#KEY_PERFORMANCE_INDICATORS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">KEY PERFORMANCE INDICATORS</rdfs:label>
    <skos:definition xml:lang="en">Metrics used to measure the achievement of objectives within voluntary codes of conduct</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_GOVERNANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA GOVERNANCE</rdfs:label>
    <skos:definition xml:lang="en">Data Governance, within the context of high-risk AI systems as specified by relevant legislation, encompasses a comprehensive set of practices and methodologies designed to ensure the integrity and quality of data throughout the AI lifecycle. It functions as a critical requirement for managing data sets, specifically regarding their use in training, validation, and testing practices.

At its core, Data Governance involves the implementation of rigorous methodologies for data cleaning and managem</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_67"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_CONDITIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION CONDITIONS</rdfs:label>
    <skos:definition xml:lang="en">Conditions under which an AI system is considered not to pose significant risk of harm, currently subject to potential amendment by delegated acts per Article 49(6) and (7)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONSULTATION_PROCEDURE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CONSULTATION PROCEDURE</rdfs:label>
    <skos:definition xml:lang="en">The process triggered when objections are raised against an authorization, requiring the Commission to consult with the relevant Member State and affected operators.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SIGNIFICANT_HARM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">SIGNIFICANT HARM</rdfs:label>
    <skos:definition xml:lang="en">The threshold of adverse impact (physical, psychological, financial) required to trigger prohibitions on manipulative AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_POLYGRAPHS_IN_LAW_ENFORCEMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR POLYGRAPHS IN LAW ENFORCEMENT</rdfs:label>
    <skos:definition xml:lang="en">Polygraph or similar tool used by or on behalf of law enforcement to assess reliability of natural persons, identified in Annex III(6)(b)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REJECTION_CONSEQUENCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REJECTION CONSEQUENCE</rdfs:label>
    <skos:definition xml:lang="en">If authorisation is rejected, use must cease immediately, and all related data must be discarded/deleted.</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#PRIOR_AUTHORISATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_9_2_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 9(2)</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 9(2)** serves as a critical legal reference point within regulatory frameworks, addressing two primary domains: the governance of personal data usage and the management of risks associated with Artificial Intelligence (AI) systems. In its capacity regarding data protection, Article 9(2) outlines the specific legal bases and conditions under which the processing of personal data is permissible. Simultaneously, in the context of AI governance, Article 9(2) functions as a crucial referenc</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMMISSION_DELEGATED_ACT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#DelegatedAct"/>
    <rdfs:label xml:lang="en">COMMISSION DELEGATED ACT</rdfs:label>
    <skos:definition xml:lang="en">Acts adopted by the Commission to modify or align existing Union harmonisation legislation with the technical requirements of the AI Act.</skos:definition>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#UNION_HARMONISATION_LEGISLATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DISTRIBUTOR_OBLIGATION__STORAGE_AND_TRANSPORT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DISTRIBUTOR OBLIGATION: STORAGE AND TRANSPORT</rdfs:label>
    <skos:definition xml:lang="en">Distributors must ensure that, while the high-risk AI system is under their responsibility, storage or transport conditions do not jeopardize the compliance of the system with the requirements set out in Section 2</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SECTION_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROTECTION_OF_WHISTLEBLOWERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROTECTION OF WHISTLEBLOWERS</rdfs:label>
    <skos:definition xml:lang="en">The requirement to protect individuals reporting infringements of the Regulation, enforced via Directive (EU) 2019/1937, as per Recital 172</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINE_IMPOSITION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">FINE IMPOSITION</rdfs:label>
    <skos:definition xml:lang="en">The Commission may impose effective, proportionate, and dissuasive fines on providers for infringements, with specific review power by the CJEU</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EU_DATABASE_DATA_ENTRY_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EU DATABASE DATA ENTRY OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Providers, authorised representatives, and public sector deployers must enter specific data (Annex VIII) into the EU database</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OPEN_SOURCE_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">OPEN-SOURCE EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">**OPEN-SOURCE EXCLUSION**

The "Open-Source Exclusion," as defined in Article 2(12) of the AI Act, outlines specific conditions under which the Act does not apply to artificial intelligence systems. Specifically, the regulation excludes AI systems released under free and open-source licenses from the scope of the Act's requirements. 

However, this exclusion is not absolute. The Open-Source Exclusion ceases to apply if such systems are placed on the market or put into service as high-risk AI sys</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_50"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_FEES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CONFORMITY ASSESSMENT FEES</rdfs:label>
    <skos:definition xml:lang="en">Fees charged by notified bodies for conformity assessments, which must account for the specific interests of SME providers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SECURE_NON_PUBLIC_SECTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SECURE NON-PUBLIC SECTION</rdfs:label>
    <skos:definition xml:lang="en">A specific section of the EU database for registering law enforcement, migration, and border control AI systems</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_TRAVEL_DOCUMENT_VERIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION FOR TRAVEL DOCUMENT VERIFICATION</rdfs:label>
    <skos:definition xml:lang="en">Exception to the migration identification AI systems category (Annex III(7)(d)) regarding the verification of travel documents</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERACTIVE_GENERATIVE_AI_SYSTEMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">INTERACTIVE/GENERATIVE AI SYSTEMS</rdfs:label>
    <skos:definition xml:lang="en">AI systems intended to interact with natural persons or generate content; they are subject to transparency obligations regardless of their high-risk status</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_89">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 89</rdfs:label>
    <skos:definition xml:lang="en">Article governing monitoring actions, including the rights of downstream providers to lodge complaints</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#Obligation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Obligation</rdfs:label>
    <skos:definition xml:lang="en">A duty, requirement, or prohibition imposed by the Act.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SAFETY_COMPONENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">SAFETY COMPONENT</rdfs:label>
    <skos:definition xml:lang="en">A "SAFETY COMPONENT" is defined as a critical element within a product that is subject to specific safety legislation, particularly in the context of high-risk AI systems as outlined in Recital 87. These are AI systems or pieces of software functioning as essential components of products, such as autonomous robots, that fall under Union harmonisation legislation based on the New Legislative Framework.

Because of their role in these systems, "SAFETY COMPONENT" entities are subject to strict regu</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PRODUCT_MANUFACTURER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_I_PRODUCT_SAFETY_COMPONENT_RULE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_74">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 74</rdfs:label>
    <skos:definition xml:lang="en">The section detailing requirements for consistency, accuracy, robustness, and cybersecurity, and the role of the Commission in metrology.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPETENT_PUBLIC_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">COMPETENT PUBLIC AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">A Competent Public Authority is defined as any public authority, including relevant Union institutions, bodies, or agencies, that is mandated to perform essential duties related to migration, asylum, and border control management. These entities hold responsibilities that extend to administrative and law enforcement enforcement tasks within these domains. Furthermore, in the context of technological oversight and governance, the term specifically encompasses those authorities that are actively i</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MIGRATION__ASYLUM_AND_BORDER_CONTROL_AI_SYSTEM"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_MIGRATION_POLYGRAPHS"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_MIGRATION_RISK_ASSESSMENT"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_ASYLUM_AND_VISA_PROCESSING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LOGGING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">LOGGING</rdfs:label>
    <skos:definition xml:lang="en">LOGGING, in the context of high-risk AI systems, refers to the essential technical capability to automatically record events over the entire duration of the system's operational lifetime. This process ensures comprehensive traceability and compliance by maintaining a continuous and accurate record of the system's activities and interactions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_INSTITUTIONS__BODIES__OFFICES__OR_AGENCIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">UNION INSTITUTIONS, BODIES, OFFICES, OR AGENCIES</rdfs:label>
    <skos:definition xml:lang="en">Entities that may use or support law enforcement authorities in using AI systems for law enforcement purposes</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STRATEGY_FOR_REGULATORY_COMPLIANCE">
    <rdfs:label xml:lang="en">STRATEGY FOR REGULATORY COMPLIANCE</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PLACING_ON_THE_MARKET">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PLACING ON THE MARKET</rdfs:label>
    <skos:definition xml:lang="en">"Placing on the market" refers to a regulated activity defined as the initial instance in which an AI system or a general-purpose AI model is made available on the Union market. This process is strictly governed, requiring that any such AI system must fully comply with all harmonized rules, safety requirements, and fundamental rights protections before it can be offered to the market.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_RULES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_I">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX I</rdfs:label>
    <skos:definition xml:lang="en">**ANNEX I** is a critical component of the EU AI Regulation, serving as a comprehensive reference document that lists Union harmonisation legislation relevant to high-risk AI systems. By establishing a clear scope of applicable laws, this annex functions as a foundational guide for product safety, compliance, and regulatory oversight.

Central to its purpose, Annex I catalogues the specific Union harmonisation legislation to which products incorporating AI systems must comply. It is explicitly r</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_HARMONISATION_LEGISLATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESEARCH_AND_DEVELOPMENT_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">RESEARCH AND DEVELOPMENT EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">The "RESEARCH AND DEVELOPMENT EXCLUSION" within the context of the AI Act, formally defined in Article 2(8), establishes that the regulations set forth by the Act do not apply to activities involving the research, testing, or development of AI systems or AI models before they are officially placed on the market or put into service. 

It is important to note that this exclusion is specific and limited in scope: while it protects preliminary development phases, it explicitly excludes any testing c</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TESTING_OF_HIGH_RISK_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TESTING OF HIGH-RISK AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">A process where a market surveillance authority organizes testing of an AI system via technical means if documentation is insufficient to determine fundamental rights infringement</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_ACTIVITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">MARKET SURVEILLANCE ACTIVITIES</rdfs:label>
    <skos:definition xml:lang="en">Activities conducted by market surveillance authorities, which must take into account complaints received under Article 85</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_95">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 95</rdfs:label>
    <skos:definition xml:lang="en">Article governing the creation and voluntary application of codes of conduct for AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#QUALITY_MANAGEMENT_SYSTEM_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">QUALITY MANAGEMENT SYSTEM ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">A conformity assessment procedure involving a notified body as described in Annex VII</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_90_1__A_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 90(1)(A)</rdfs:label>
    <skos:definition xml:lang="en">Article referenced for qualified alerts from the scientific panel regarding systemic risks</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMERGENCY_RESPONSE_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EMERGENCY RESPONSE AI</rdfs:label>
    <skos:definition xml:lang="en">AI system used to evaluate/classify emergency calls or dispatch emergency first response services.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_CATEGORISATION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">BIOMETRIC CATEGORISATION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">A **Biometric Categorisation System** is defined as an AI system designed to assign natural persons to specific categories (such as sex, age, race, religion, political opinions, or sexual orientation) based on their biometric data. The core function of these systems is to identify or categorize individuals using biometric inputs.

The regulatory framework surrounding these systems is nuanced, distinguishing between acceptable use, high-risk status, and outright prohibition based on the nature of</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANCILLARY_FEATURE_EXCLUSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_CATEGORISATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRICS"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_16"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_40_"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_BIOMETRIC_CATEGORISATION_SYSTEMS"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#INFORMATION_OBLIGATION"/>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AISYSTEM"/>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_CATEGORISATION_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_16_1_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 16(1)</rdfs:label>
    <skos:definition xml:lang="en">Provision in Regulation (EU) 2022/2065 regarding the notification of illegal content (Recital 136)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#QUESTIONNAIRE_TEMPLATE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">QUESTIONNAIRE TEMPLATE</rdfs:label>
    <skos:definition xml:lang="en">A tool developed by the AI Office to assist deployers in conducting fundamental rights impact assessments and reducing administrative burden per Recital 96</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_21">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 21</rdfs:label>
    <skos:definition xml:lang="en">Specifies requirements for cooperation with competent authorities, including documentation and log provision</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ACCESSIBILITY_REQUIREMENTS_DIRECTIVE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ACCESSIBILITY REQUIREMENTS DIRECTIVE</rdfs:label>
    <skos:definition xml:lang="en">The Accessibility Requirements Directive, formally known as Directive (EU) 2019/882, establishes a comprehensive legal framework concerning the accessibility requirements for products and services within the European Union. Its primary objective is to harmonize accessibility standards across member states to ensure that essential products and services are usable by persons with disabilities, thereby promoting greater inclusivity and removing barriers within the internal market.

Furthermore, the</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HARMONISED_STANDARD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">HARMONISED STANDARD</rdfs:label>
    <skos:definition xml:lang="en">A Harmonised Standard is a technical standard, as defined in Article 2(1)(c) of Regulation (EU) No 1025/2012, that serves as a critical mechanism for ensuring compliance with regulatory obligations. These standards are developed by recognized European standardisation organisations and are intended to provide concrete technical solutions that facilitate adherence to the requirements set forth by the AI Act.

When a Harmonised Standard is referenced in the Official Journal of the European Union, i</skos:definition>
    <euai:grants rdf:resource="https://w3id.org/euaiact/ontology#PRESUMPTION_OF_CONFORMITY"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#COMMON_SPECIFICATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_10_1__REGULATION__EU__NO_1025_2012"/>
    <euai:presumesConformity rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER_OF_GENERAL_PURPOSE_AI_MODELS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMMON_RULES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">COMMON RULES</rdfs:label>
    <skos:definition xml:lang="en">Implementing acts established by the Commission to mandate obligations from Articles 53 and 55 if a code of practice is not finalized or is deemed inadequate by 2 August 2025</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_53"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_55"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_103">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_167_2013"/>
    <rdfs:label xml:lang="en">ARTICLE 103</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION_OF_BIOMETRIC_CATEGORISATION_SYSTEMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION OF BIOMETRIC CATEGORISATION SYSTEMS</rdfs:label>
    <skos:definition xml:lang="en">A ban on systems deducing sensitive personal data via biometric identification, detailed in Recital 30.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_30"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_74_10_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 74(10)</rdfs:label>
    <skos:definition xml:lang="en">Article referencing specific national authorities or bodies that the authorised representative must provide documentation to.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPARISON_OF_BIOMETRIC_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">COMPARISON OF BIOMETRIC DATA</rdfs:label>
    <skos:definition xml:lang="en">A core functional requirement for the Eurodac system to identify persons.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INNOVATIVE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">INNOVATIVE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">An innovative AI system refers to an artificial intelligence technology that is undergoing development, training, testing, or validation within the structured environment of an AI regulatory sandbox. These systems are specifically designed to be cultivated within this controlled space prior to their formal market entry. The primary purpose of utilizing an AI regulatory sandbox for these systems is to ensure that they are fully compliant with the relevant Regulation and all other applicable laws </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LIABILITY_FOR_DAMAGE"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_MITIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REVERSIBILITY_OF_AI_OUTPUTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">REVERSIBILITY OF AI OUTPUTS</rdfs:label>
    <skos:definition xml:lang="en">A safeguard ensuring that predictions, recommendations, or decisions of an AI system can be effectively reversed and disregarded</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MONITORING_OF_THE_FUNCTIONING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MONITORING OF THE FUNCTIONING</rdfs:label>
    <skos:definition xml:lang="en">Obligation for deployers to monitor the operation of high-risk AI systems to ensure they function as intended and identify issues (Recital 91)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_GOVERNANCE_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA GOVERNANCE REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">Measure for which high-risk AI systems trained on specific data reflecting their intended operational context are presumed to comply</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HARMONISED_RULES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">HARMONISED RULES</rdfs:label>
    <skos:definition xml:lang="en">"Harmonised Rules" refer to a unified body of regulations designed to govern artificial intelligence (AI) systems. These rules establish a comprehensive framework of duties and requirements imposed upon operators to ensure that AI systems are trustworthy, consistent, and safe when placed on the market, put into service, or utilized.

By mandating these uniform obligations, the Harmonised Rules aim to facilitate the proper functioning of the internal market while simultaneously safeguarding cruci</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_114"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_114_TFEU"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_16_TFEU"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_DATA_PROTECTION_BOARD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINANCIAL_INSTITUTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">FINANCIAL INSTITUTION</rdfs:label>
    <skos:definition xml:lang="en">A Financial Institution is defined as a provider regulated under Union financial services law that utilizes high-risk AI systems. As entities operating within this specific regulatory framework, these institutions are subject to distinct compliance and oversight protocols designed to integrate with existing financial sector mandates.

Under these regulations, Financial Institutions are overseen by national financial authorities rather than general AI regulatory bodies, ensuring that the supervis</skos:definition>
    <euai:reducedObligationsApplyTo rdf:resource="https://w3id.org/euaiact/ontology#QUALITY_MANAGEMENT_SYSTEM"/>
    <euai:reducedObligationsApplyTo rdf:resource="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNAL_GOVERNANCE_ARRANGEMENTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FINANCIAL_SUPERVISOR"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#LOG_KEEPING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#Authority">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Regulatory Authority</rdfs:label>
    <skos:definition xml:lang="en">A body responsible for oversight, enforcement, or coordination of the Act.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_79">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 79</rdfs:label>
    <skos:definition xml:lang="en">The section of the AI Act defining that a specific natural or legal person, the provider, takes responsibility for placing the system on the market.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_25">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 25</rdfs:label>
    <skos:definition xml:lang="en">Article addressing the responsibilities along the AI value chain, specifically when distributors, importers, or deployers become providers</skos:definition>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#Actor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Actor</rdfs:label>
    <skos:definition xml:lang="en">An entity with legal standing under the EU AI Act.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HEALTH__SAFETY_AND_FUNDAMENTAL_RIGHTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">HEALTH, SAFETY AND FUNDAMENTAL RIGHTS</rdfs:label>
    <skos:definition xml:lang="en">The specific protected interests that the risk-management system must identify, mitigate, and monitor risks against.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_DATA_PROCESSING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">BIOMETRIC DATA PROCESSING</rdfs:label>
    <skos:definition xml:lang="en">Obligation for law enforcement to comply with Article 10 of Directive (EU) 2016/680 when using AI systems for biometric identification (Recital 94)</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_10_OF_DIRECTIVE__EU__2016_680"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_4_1__OF_DIRECTIVE__EU__2016_680"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_9_OF_REGULATION__EU__2016_679"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ELECTRONIC_NOTIFICATION_TOOL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ELECTRONIC NOTIFICATION TOOL</rdfs:label>
    <skos:definition xml:lang="en">The digital system referenced in Article 30(2) used by the notifying authority to notify the Commission and Member States of changes to a notified body's status</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINANCIAL_FRAUD_DETECTION_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">FINANCIAL FRAUD DETECTION EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">**FINANCIAL FRAUD DETECTION EXCLUSION** refers to a regulatory provision regarding the classification of artificial intelligence systems within the financial sector. Specifically, it defines the conditions under which AI systems designed for detecting financial fraud or for calculating prudential capital are exempt from being categorized as "high-risk." 

This exclusion ensures that AI tools used for these critical financial safety and security purposes—such as identifying fraudulent activities </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPETITIVE_ADVANTAGE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">COMPETITIVE ADVANTAGE</rdfs:label>
    <skos:definition xml:lang="en">The scenario where a provider gains an unfair market position by applying lower copyright standards than those required in the Union; this is a regulatory concern addressed by the Act</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SECTORAL_GROUP_OF_NOTIFIED_BODIES">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
    <rdfs:label xml:lang="en">SECTORAL GROUP OF NOTIFIED BODIES</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ESSENTIAL_SERVICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">ESSENTIAL SERVICES</rdfs:label>
    <skos:definition xml:lang="en">**ESSENTIAL SERVICES** constitute one of the eight high-risk use case domains identified in Annex III of the relevant regulatory framework. This classification encompasses the critical areas required for the basic functioning of daily life, including both public and private sectors. Specifically, this domain covers public assistance, healthcare, and social security, as well as essential private services such as housing, electricity, and telecommunications.

In the context of modern governance an</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">MARKET SURVEILLANCE</rdfs:label>
    <skos:definition xml:lang="en">The duty to supervise the implementation of the AI Act, including ex post monitoring of AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OBLIGATION_TO_ESTABLISH_RISK_MANAGEMENT_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">OBLIGATION TO ESTABLISH RISK MANAGEMENT SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">Duty of the provider to establish, implement, document, and maintain a risk management system for high-risk AI systems throughout their lifecycle per Article 9(1)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_41">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 41</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 41**

Article 41 serves as a critical regulatory provision concerning the use and implementation of common specifications within the relevant legal framework. Primarily, this article outlines the formal process and specific conditions under which the Commission is authorized to adopt implementing acts for these common specifications.

Beyond establishing this procedural framework, Article 41 functions as a key reference point for manufacturers. It defines how these common specification</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_10_OF_REGULATION__EU__NO_1025_2012"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EQUALITY_BODIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">EQUALITY BODIES</rdfs:label>
    <skos:definition xml:lang="en">National public authorities that supervise the application of Union law protecting fundamental rights, whose independence is preserved by this Regulation.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2024_1689"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPROVEMENT_OF_PREVIOUS_HUMAN_ACTIVITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">IMPROVEMENT OF PREVIOUS HUMAN ACTIVITY</rdfs:label>
    <skos:definition xml:lang="en">Condition where an AI system is intended to improve the result of a previously completed human activity, potentially exempting it from high-risk classification</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COORDINATION_ACTIVITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">COORDINATION ACTIVITIES</rdfs:label>
    <skos:definition xml:lang="en">Notified bodies are required to participate in coordination activities as defined in Article 38</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#hasRequirement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has requirement</rdfs:label>
    <skos:definition xml:lang="en">Relates a high-risk AI system to a technical requirement.</skos:definition>
    <rdfs:domain rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:range rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WITHDRAWAL_OF_AN_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">WITHDRAWAL OF AN AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">Measure aiming to prevent an AI system in the supply chain from being made available on the market</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_MILITARY__DEFENCE_AND_NATIONAL_SECURITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION FOR MILITARY, DEFENCE AND NATIONAL SECURITY</rdfs:label>
    <skos:definition xml:lang="en">AI systems placed on the market, put into service, or used for military, defence, or national security purposes are excluded from the scope of the Regulation, unless used for other (civilian/humanitarian) purposes.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_4_2__TEU"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITED_PRACTICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITED PRACTICES</rdfs:label>
    <skos:definition xml:lang="en">"Prohibited practices" refers to specific artificial intelligence activities that are banned under the Regulation. This list of prohibited AI practices is not static; it is subject to regular review, with the Commission tasked with conducting an annual assessment to ensure the list remains relevant and aligned with technological and societal developments, as outlined in Recital 174 and Recital 179. To ensure compliance and oversight, market surveillance authorities are mandated to submit annual </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EARLY_APPLICATION_DATE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPLIANCE_WITH_THIS_REGULATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">COMPLIANCE WITH THIS REGULATION</rdfs:label>
    <skos:definition xml:lang="en">**COMPLIANCE WITH THIS REGULATION** represents the overarching obligation imposed on AI operators—including providers and deployers—to strictly adhere to the requirements set forth by the AI Act. This mandatory duty ensures that any given AI system fully meets all regulatory standards whenever the system is utilized for non-excluded purposes. Furthermore, this obligation is triggered when research activities evolve and result in the placement of an AI system on the market. To assist operators in</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_I">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER I</rdfs:label>
    <skos:definition xml:lang="en">A section of the Regulation that applies from 2 February 2025 according to Article 113.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_113"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TESTING_IN_REAL_WORLD_CONDITIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TESTING IN REAL-WORLD CONDITIONS</rdfs:label>
    <rdfs:label xml:lang="en">TESTING IN REAL WORLD CONDITIONS</rdfs:label>
    <skos:definition xml:lang="en">Temporary testing of an AI system outside laboratory environments to gather data and verify conformity; does not qualify as placing on the market if conditions in Article 57 or 60 are met, as defined in Article 3(57)</skos:definition>
    <skos:definition xml:lang="en">**Testing in Real World Conditions** refers to a regulatory mechanism designed to facilitate the deployment and evaluation of artificial intelligence systems outside of controlled laboratory environments. This framework is primarily governed by Articles 57, 59, and 60 of the applicable AI regulations.

The concept encompasses two primary operational modes. First, it involves testing activities conducted within established AI regulatory sandboxes. In this context, developers may test innovative A</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_57"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_60"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING_PLAN"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_DURATION_LIMIT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INFORMED_CONSENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_61"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_PLAN"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION_OF_TESTING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_68_2_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 68(2)</rdfs:label>
    <skos:definition xml:lang="en">**Article 68(2)** serves as a regulatory provision that establishes the framework for both the composition and the operational requirements of scientific support personnel. This article defines the specific tasks and the necessary criteria that members of the scientific panel must fulfill to execute their responsibilities effectively. Furthermore, Article 68(2) outlines the requisite standards and criteria that independent experts must meet in order to be eligible to assist in evaluations, ensur</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LEGALLY_DESIGNATED_REPRESENTATIVE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">LEGALLY DESIGNATED REPRESENTATIVE</rdfs:label>
    <skos:definition xml:lang="en">Individual or body authorized to act on behalf of the subjects of the testing in real world conditions</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LOGS_OF_PROCESSING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">LOGS OF PROCESSING</rdfs:label>
    <skos:definition xml:lang="en">Records of personal data processing in the sandbox that must be kept for the duration of participation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SEGREGATION_OF_DUTIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SEGREGATION OF DUTIES</rdfs:label>
    <skos:definition xml:lang="en">Operational requirement mandating that decisions relating to the notification of conformity assessment bodies be taken by different persons than those who carried out the assessment, as per Article 29(4)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MEASUREMENT_AND_CALCULATION_METHODOLOGIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MEASUREMENT AND CALCULATION METHODOLOGIES</rdfs:label>
    <skos:definition xml:lang="en">Technical protocols detailed by delegated acts to allow for comparable and verifiable documentation of GPAI model characteristics</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUBLIC_ASSISTANCE_BENEFIT_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">PUBLIC ASSISTANCE BENEFIT AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems used by public authorities to evaluate eligibility for essential public assistance benefits and services (Annex III 5(a))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_III_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">ANNEX III AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems covered by Annex III, subject to specific certificate validity periods as defined in the introductory text.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CERTIFICATE_EXTENSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROTECTION_OF_VULNERABLE_GROUPS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PROTECTION OF VULNERABLE GROUPS</rdfs:label>
    <skos:definition xml:lang="en">Mandatory safeguards for testing subjects who are vulnerable due to age or disability, per Article 60(g)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LARGE_SCALE_IT_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">LARGE-SCALE IT SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">Large-scale IT systems listed in Annex X; subject to compliance deadlines by 31 December 2030 (Article 111(1))</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLIANCE_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_X"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COOPERATION_WITH_COMPETENT_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">COOPERATION WITH COMPETENT AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">Providers must provide documentation and logs upon a reasoned request by a competent authority as per Article 21</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_21"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_62">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 62</rdfs:label>
    <skos:definition xml:lang="en">Article concerning measures for support of SMEs and start-ups</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AGRICULTURAL_AND_FORESTRY_VEHICLES_REGULATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">AGRICULTURAL AND FORESTRY VEHICLES REGULATION</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) No 167/2013 is a key piece of European Union legislation established to govern the approval and market surveillance of agricultural and forestry vehicles. This regulation plays a critical role in standardizing the safety and operational requirements for these specific vehicle types. Beyond its primary function in ensuring compliance and market safety within the agricultural and forestry sectors, the regulation is also highly relevant to the evolving field of artificial intelligen</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMMIGRATION_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">IMMIGRATION AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">The **IMMIGRATION AUTHORITY** is an organization tasked with overseeing immigration processes. Within its mandate, the **IMMIGRATION AUTHORITY** is permitted to conduct identity checks, provided that these actions strictly adhere to the conditions established by both Union and national law. Furthermore, in instances where the **IMMIGRATION AUTHORITY** acts as a provider of high-risk AI systems, it is mandated to ensure that it maintains and provides access to the necessary technical documentatio</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#IDENTITY_CHECK"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REFERENCE_DATABASE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">REFERENCE DATABASE</rdfs:label>
    <skos:definition xml:lang="en">A repository of stored biometric data against which an individual’s biometric data is compared for the purpose of identification.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HighRiskAISystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">High-Risk AI System</rdfs:label>
    <skos:definition xml:lang="en">An AI system listed in Annex III or embedded in a product covered by Union harmonisation legislation. (Article 6)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EC__NO_810_2009">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EC) NO 810/2009</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EC) No 810/2009, commonly referred to as the Visa Code, establishes the harmonized procedures and conditions for the issuance of visas for short-term stays in the territory of the European Union. Beyond its primary function in facilitating visa processing, this regulation is also significant in the context of the European Union's technological governance, as it is considered relevant to the implementation of high-risk artificial intelligence systems within the fields of migration, as</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONSUMER_ORGANISATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CONSUMER ORGANISATIONS</rdfs:label>
    <skos:definition xml:lang="en">Consumer organisations are essential stakeholder groups that represent the interests of consumers. Their active participation and representation are highly encouraged in the development of standards, as their inclusion ensures that consumer needs and perspectives are properly integrated into the standard-setting process.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_STANDARD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_STANDARDS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HIGH_RISK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">HIGH RISK</rdfs:label>
    <rdfs:label xml:lang="en">HIGH-RISK</rdfs:label>
    <skos:definition xml:lang="en">"HIGH RISK" is a classification level applied to AI systems that have the potential to significantly impact fundamental rights, safety, health, livelihood, democracy, the rule of law, and individual freedoms. These systems are subject to specific regulatory oversight and must adhere to mandatory requirements to mitigate these risks.

Under the framework of the AI Act, specifically as outlined in Article 6, AI systems designated as "HIGH RISK" are legally obligated to comply with stringent requir</skos:definition>
    <skos:definition xml:lang="en">Classification status for AI systems, including those in Annex III or those involving profiling or remote biometric identification, that pose significant risks to health, safety, or fundamental rights.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CIVIL_SOCIETY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CIVIL SOCIETY</rdfs:label>
    <skos:definition xml:lang="en">Groups and stakeholders engaged by the AI Office to inform the development of systemic risk assessment frameworks.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_45">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 45</rdfs:label>
    <skos:definition xml:lang="en">Specifies the information obligations of notified bodies, requiring them to inform notifying and other notified bodies about certification decisions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_71_4_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 71(4)</rdfs:label>
    <skos:definition xml:lang="en">Article governing the registration of real-world testing for certain high-risk AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_MARKET">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">UNION MARKET</rdfs:label>
    <skos:definition xml:lang="en">The jurisdiction/market where providers place AI models and must comply with the Regulation, ensuring a level playing field</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK_MITIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SYSTEMIC RISK MITIGATION</rdfs:label>
    <skos:definition xml:lang="en">Duty to assess and mitigate systemic risks at the Union level stemming from the development, placing on the market, or use of the model per Article 55(1)(b)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_85">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 85</rdfs:label>
    <skos:definition xml:lang="en">Article 85 establishes the fundamental right for any person to lodge a formal complaint with a market surveillance authority concerning potential infringements. By providing this legal mechanism, the article ensures that individuals have a recognized pathway to report violations, thereby facilitating oversight and enforcement within the market surveillance framework.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RIGHTS_OF_DEFENCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RIGHTS OF DEFENCE</rdfs:label>
    <skos:definition xml:lang="en">Procedural guarantees for parties involved in proceedings conducted by the European Data Protection Supervisor, including the right to be heard and access to the file, subject to personal data and business secret protections.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_DATA_PROTECTION_SUPERVISOR"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ACADEMIA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">ACADEMIA</rdfs:label>
    <skos:definition xml:lang="en">ACADEMIA refers to academic institutions and stakeholders invited to participate in the development of regulatory frameworks. Specifically, ACADEMIA is recognized as an interested party capable of supporting the process of drafting both codes of practice and codes of conduct. In the context of regulatory compliance, academic institutions are invited to provide their expertise to assist in drawing up codes of practice, as outlined in Article 56(3). Furthermore, these academic stakeholders are als</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_CONDUCT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2024_1689">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2024/1689</rdfs:label>
    <skos:definition xml:lang="en">The Artificial Intelligence Act, providing a uniform legal framework for AI in the Union</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNAL_MARKET"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPETENCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">COMPETENCE</rdfs:label>
    <skos:definition xml:lang="en">Specific requirement for notified bodies to possess the necessary expertise and technical capability</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_OFFENDING_RISK_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR OFFENDING RISK ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">System used by law enforcement to assess the risk of a natural person offending or re-offending, or to assess personality/criminal behavior, identified in Annex III(6)(d)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CERTIFICATE_EXTENSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CERTIFICATE EXTENSION</rdfs:label>
    <skos:definition xml:lang="en">The process of extending a certificate validity for up to five years for Annex I systems or four years for Annex III systems based on re-assessment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADCO_SUB_GROUP">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">ADCO SUB-GROUP</rdfs:label>
    <skos:definition xml:lang="en">The standing sub-group for market surveillance, acting as the administrative cooperation group (ADCO) for the Regulation per Regulation (EU) 2019/1020</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_1020"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_33_OF_REGULATION__EU__2019_1020"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BiometricIdentificationSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#HighRiskAISystem"/>
    <rdfs:label xml:lang="en">BiometricIdentificationSystem</rdfs:label>
    <skos:definition xml:lang="en">AI systems for biometric identification of persons</skos:definition>
    <euai:articleReference>Annex III, 1</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_II">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER II</rdfs:label>
    <skos:definition xml:lang="en">A section of the Regulation that applies from 2 February 2025 according to Article 113.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_113"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXAMINATION_AND_VALIDATION_PROCEDURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">EXAMINATION AND VALIDATION PROCEDURES</rdfs:label>
    <skos:definition xml:lang="en">Procedures for testing and validation carried out at different stages of the AI system lifecycle (Article 17(2)(d)).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VERY_LARGE_ONLINE_SEARCH_ENGINES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">VERY LARGE ONLINE SEARCH ENGINES</rdfs:label>
    <skos:definition xml:lang="en">Providers of search engines subject to obligations to mitigate systemic risks arising from artificially generated content</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2022_2065"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STAKEHOLDERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">STAKEHOLDERS</rdfs:label>
    <skos:definition xml:lang="en">Stakeholders constitute a diverse group of entities that play a critical role in the regulatory and developmental framework of AI systems. These parties are essential for providing expert insight, oversight, and collaborative input at various stages of governance and standardization.

Broadly, stakeholders encompass a wide array of sectors, including business entities, civil society organizations, academic institutions, research organizations, trade unions, and consumer protection groups. These </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERNAL_COMPETENCES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INTERNAL COMPETENCES</rdfs:label>
    <skos:definition xml:lang="en">Sufficient administrative, technical, legal and scientific personnel availability required by notified bodies to evaluate external tasks</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_ASSESSMENT_CRITERIA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RISK ASSESSMENT CRITERIA</rdfs:label>
    <skos:definition xml:lang="en">The Risk Assessment Criteria, as outlined in Article 7(2), serve as the fundamental framework used by the Commission to evaluate and determine whether specific AI systems should be classified as high-risk and subsequently added to the Annex III list of high-risk use cases.

These criteria encompass a broad spectrum of factors designed to assess the potential impact and safety of AI technologies. They include critical operational and functional elements such as an AI system’s intended purpose, it</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_7_2_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SocialScoringPublicAuthority">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ProhibitedAIPractice"/>
    <rdfs:label xml:lang="en">SocialScoringPublicAuthority</rdfs:label>
    <skos:definition xml:lang="en">Social scoring by public authorities leading to detrimental treatment</skos:definition>
    <euai:articleReference>Article 5(1)(c)</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_93">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 93</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 93**

Article 93 is a regulatory provision that outlines the specific measures requested by the European Commission and the associated commitments made by providers. It functions as a critical component of the enforcement framework, establishing accountability for providers, specifically including providers of General Purpose AI (GPAI) models. 

Failure to comply with the measures requested under Article 93 carries significant consequences, as non-compliance can lead to the imposition </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CAPABILITY_BENCHMARK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CAPABILITY BENCHMARK</rdfs:label>
    <skos:definition xml:lang="en">Evaluations of model capabilities including task execution without additional training, adaptability to new tasks, level of autonomy, scalability, and access to external tools.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_54">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 54</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 54**

ARTICLE 54 serves as a critical component of the regulatory framework for artificial intelligence, specifically establishing the core obligations for providers of general-purpose AI (GPAI) models. This article defines the responsibilities that these providers must adhere to, ensuring accountability and oversight in the development and deployment of such technologies.

Furthermore, ARTICLE 54 explicitly governs the role and mandate of authorised representatives for GPAI models. Th</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INFORMATION_PROVISION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">INFORMATION PROVISION</rdfs:label>
    <skos:definition xml:lang="en">Duty of the Board, Member States, and national competent authorities to provide information to the Commission upon request without undue delay</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUBLIMINAL_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">SUBLIMINAL AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI system deploying subliminal techniques beyond consciousness or manipulative/deceptive techniques to distort behavior and cause significant harm</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_6_TEU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 6 TEU</rdfs:label>
    <skos:definition xml:lang="en">Reference to the Charter of Fundamental Rights as a standard for AI development</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_33">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 33</rdfs:label>
    <skos:definition xml:lang="en">**RECITAL 33** serves as a critical regulatory component, specifically outlining the narrow and exhaustively listed exceptions under which the use of real-time remote biometric identification is permissible for law enforcement purposes. It provides the necessary legal framework and constraints for law enforcement agencies regarding the deployment of these biometric technologies, ensuring that such use is strictly limited to the specific scenarios defined within the text.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FEE_PAYMENT_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">FEE PAYMENT OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Potential duty for Member States to pay fees for advice and support provided by the scientific panel experts.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION__NATIONAL_SECURITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION: NATIONAL SECURITY</rdfs:label>
    <skos:definition xml:lang="en">AI systems used exclusively for military, defence, or national security purposes are outside the scope of the Regulation, per Article 2(3)</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_DATA_PROTECTION_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">NATIONAL DATA PROTECTION AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">National Data Protection Authorities are regulatory bodies tasked with overseeing and enforcing data protection standards. These authorities possess the specific power to receive data disclosures. Crucially, the AI Act’s disclosure rules are designed to coexist with their existing mandates, ensuring that the current or future regulatory powers of National Data Protection Authorities remain entirely unaffected by the provisions of this Regulation.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INVESTIGATIVE_AND_CORRECTIVE_POWERS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2016_680"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION__SCIENTIFIC_RESEARCH">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION: SCIENTIFIC RESEARCH</rdfs:label>
    <skos:definition xml:lang="en">AI systems developed solely for scientific research and development are excluded from the scope, per Article 2(6)</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_III">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX III</rdfs:label>
    <skos:definition xml:lang="en">**ANNEX III** of the EU AI Act serves as a critical regulatory component, specifically functioning as the definitive list of high-risk AI system categories and use case domains. Referenced directly under Article 6(2), this annex delineates the specific areas and applications of AI that are subject to heightened regulatory scrutiny, oversight measures, and compliance obligations due to their potential impact on fundamental rights and safety.

The systems identified within ANNEX III are subject to</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III_USE_CASE_RULE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_6_2_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRICS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STAKEHOLDER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">STAKEHOLDER</rdfs:label>
    <skos:definition xml:lang="en">Parties including representatives of affected groups, independent experts, and civil society organisations who may be involved in the fundamental rights impact assessment process per Recital 96</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AUTHORISATION_DECISION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">AUTHORISATION DECISION</rdfs:label>
    <skos:definition xml:lang="en">A formal decision by the Commission regarding the justification of a conformity assessment body's authorisation when objections have been raised, addressed to the Member State and the body.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VOLUNTARY_CODES_OF_CONDUCT_EVALUATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">VOLUNTARY CODES OF CONDUCT EVALUATION</rdfs:label>
    <skos:definition xml:lang="en">The Commission must evaluate the impact and effectiveness of voluntary codes of conduct by 2 August 2028 and every three years thereafter (Recital 174).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#placeOnMarket">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">places on market</rdfs:label>
    <skos:definition xml:lang="en">Relates a provider to an AI system they make available.</skos:definition>
    <rdfs:domain rdf:resource="https://w3id.org/euaiact/ontology#Provider"/>
    <rdfs:range rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGISTRATION_OF_TESTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REGISTRATION OF TESTING</rdfs:label>
    <skos:definition xml:lang="en">**REGISTRATION OF TESTING**

Under Article 60 of the relevant regulations, the "REGISTRATION OF TESTING" framework mandates that entities conducting testing for AI systems in real-world conditions must fulfill a specific duty to register and disclose comprehensive information. This registration process is required to ensure transparency and oversight during real-world trials.

To comply with this mandate, the entity must provide five key categories of information:

1.  **Identification:** Unique</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_60"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2016_679">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2016/679</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2016/679, widely known as the General Data Protection Regulation (GDPR), serves as a fundamental framework for data protection and privacy within the European Union. Its provisions impose strict limitations on the processing of personal data, ensuring that such activities are conducted lawfully, fairly, and transparently.

In addition to these general processing limits, Regulation (EU) 2016/679 establishes mandatory compliance requirements for specific technological applications.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPORTANT_AND_CRITICAL_PRODUCTS_WITH_DIGITAL_ELEMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">IMPORTANT AND CRITICAL PRODUCTS WITH DIGITAL ELEMENTS</rdfs:label>
    <skos:definition xml:lang="en">A specific category of products with digital elements that, when also classified as high-risk AI systems, trigger specific conformity assessment derogations as per Recital 78.</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNAL_CONTROL"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ExploitativeAI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ProhibitedAIPractice"/>
    <rdfs:label xml:lang="en">ExploitativeAI</rdfs:label>
    <skos:definition xml:lang="en">AI exploiting vulnerabilities of specific groups</skos:definition>
    <euai:articleReference>Article 5(1)(b)</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ClassificationRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">ClassificationRule</rdfs:label>
    <skos:definition xml:lang="en">A rule or criterion determining whether an AI system is classified as high-risk.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DESIGNATION_MANAGEMENT_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DESIGNATION MANAGEMENT OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The **DESIGNATION MANAGEMENT OBLIGATION** refers to the comprehensive set of procedural duties imposed on a notifying authority following a change in designation, such as a restriction, suspension, or withdrawal of a notified body. This process ensures regulatory oversight, transparency, and continuity for affected providers and certificates.

Upon a designation change, the notifying authority is mandated to maintain comprehensive files and assess the impact of the change on any certificates pre</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NON_PROFESSIONAL_SCIENTIFIC_RESEARCH_DEVELOPER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">NON-PROFESSIONAL/SCIENTIFIC RESEARCH DEVELOPER</rdfs:label>
    <skos:definition xml:lang="en">Persons developing or using models for non-professional or scientific research, who are exempt from mandatory compliance but encouraged to comply voluntarily</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMMISSION_RECOMMENDATION_2003_361_EC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">COMMISSION RECOMMENDATION 2003/361/EC</rdfs:label>
    <skos:definition xml:lang="en">Commission Recommendation 2003/361/EC is the official European Commission document that establishes the standardized criteria for defining micro, small, and medium-sized enterprises (SMEs). This classification is critical for regulatory and policy contexts, as it provides a clear framework for distinguishing smaller businesses from larger entities.

Notably, Commission Recommendation 2003/361/EC is referenced in Recital 44 of the Artificial Intelligence Act (AI Act). In this context, the definit</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRAVEL_DOCUMENT_VERIFICATION_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">TRAVEL DOCUMENT VERIFICATION EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">The "TRAVEL DOCUMENT VERIFICATION EXCLUSION" refers to a specific regulatory or operational provision that exempts certain entities or situations from standard procedures involving the scrutiny of travel documents. This exclusion is specifically applicable to scenarios involving high-risk classifications within the broader domains of migration, asylum, and border control. In essence, it serves as a policy mechanism that modifies or suspends the requirement to verify travel documents for individu</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_10_OF_DIRECTIVE__EU__2016_680">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 10 OF DIRECTIVE (EU) 2016/680</rdfs:label>
    <skos:definition xml:lang="en">Article 10 of Directive (EU) 2016/680 serves as a critical regulatory provision governing the processing of biometric data specifically for law enforcement purposes. This article is closely associated with Recital 94, which provides necessary context for its application.

Functioning as a fundamental component of the broader Directive (EU) 2016/680, Article 10 establishes the legal framework and limitations under which law enforcement authorities may process biometric data. While it sets the fou</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_III_CATEGORIES_1__6__OR_7">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">ANNEX III CATEGORIES 1, 6, OR 7</rdfs:label>
    <skos:definition xml:lang="en">Specific high-risk use case categories (e.g., law enforcement, migration, asylum) where specific information handling and access restrictions apply</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ACCESS_TO_TECHNICAL_DOCUMENTATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_34">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 34</rdfs:label>
    <skos:definition xml:lang="en">Article 34 serves as a regulatory provision that explicitly defines the obligations of notified bodies. This article specifically outlines the operational responsibilities that these entities must adhere to in the execution of their duties.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_17">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 17</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 17** details the necessary requirements for the implementation and maintenance of a quality management system. Specifically, it establishes the regulatory framework and operational standards that providers of high-risk AI systems must adhere to, ensuring these systems meet established quality and safety benchmarks throughout their lifecycle.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#QUALITY_MANAGEMENT_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION_OF_BIOMETRIC_DATA_PROCESSING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION OF BIOMETRIC DATA PROCESSING</rdfs:label>
    <skos:definition xml:lang="en">General prohibition under Regulation (EU) 2016/679 and Regulation (EU) 2018/1725 regarding biometric data processing, subject to limited exceptions</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_9_1__OF_REGULATION__EU__2016_679"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_10_1__OF_REGULATION__EU__2018_1725"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#QUALITY_MANAGEMENT_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">QUALITY MANAGEMENT REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">A specific operational standard that notified bodies must satisfy to fulfill their tasks, ensuring consistency and reliability of conformity assessments under Article 31(2).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXEMPTION_FROM_AUTHORISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXEMPTION FROM AUTHORISATION</rdfs:label>
    <skos:definition xml:lang="en">The authorisation requirement does not apply when the system is used for the initial identification of a potential suspect based on objective and verifiable facts directly linked to the offence</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2013_36_EU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2013/36/EU</rdfs:label>
    <skos:definition xml:lang="en">Directive 2013/36/EU, also known as the Capital Requirements Directive (CRD IV), is a key piece of European Union legislation that governs the access to the activity of credit institutions and the prudential supervision of both credit institutions and investment firms. Specifically, Recital 49 of the directive emphasizes the fundamental importance of robust supervisory frameworks to maintain financial stability and market integrity.

In the contemporary regulatory landscape, Directive 2013/36/EU</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COUNCIL_REGULATION__EU__NO_1024_2013"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_IDENTIFICATION_AND_ANALYSIS">
    <rdfs:label xml:lang="en">RISK IDENTIFICATION AND ANALYSIS</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CORRECTIVE_ACTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CORRECTIVE ACTION</rdfs:label>
    <skos:definition xml:lang="en">**CORRECTIVE ACTION** refers to the mandatory steps that operators, including providers and distributors, must undertake to ensure that an AI system aligns with regulatory requirements. When an AI system is identified as non-compliant, or when it poses risks to health, safety, or fundamental rights, the responsible entity is obligated to take immediate measures to rectify the situation.

These actions involve bringing the system into conformity, restricting its availability, withdrawing it from </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOXES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">AI REGULATORY SANDBOXES</rdfs:label>
    <skos:definition xml:lang="en">AI Regulatory Sandboxes serve as controlled environments specifically designed for the development, testing, and validation of artificial intelligence (AI) systems. These frameworks provide a secure, regulated space where innovation can be assessed before products are formally placed on the market, including research activities that may lead to commercial deployment.

To foster innovation, AI Regulatory Sandboxes prioritize accessibility for small and medium-sized enterprises (SMEs) and start-up</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#URGENT_DEPLOYMENT_AUTHORISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">URGENT DEPLOYMENT AUTHORISATION</rdfs:label>
    <skos:definition xml:lang="en">An authorization mechanism allowing law enforcement or civil protection authorities to deploy high-risk AI systems in urgent, life-threatening situations without prior authorization, subject to post-hoc request.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TRANSPARENCY OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The **Transparency Obligation** constitutes a regulatory framework designed to ensure that artificial intelligence (AI) systems operate with openness, accountability, and clarity. This mandate, primarily defined by the requirements set forth in Article 50, ensures that providers, deployers, and operators of AI systems fulfill specific duties to maintain public trust and protect fundamental rights.

At its core, the Transparency Obligation requires that AI systems be sufficiently documented, expl</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AISYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ACCESSIBILITY_REQUIREMENTS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUTTING_INTO_SERVICE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PUTTING INTO SERVICE</rdfs:label>
    <skos:definition xml:lang="en">"Putting into service" refers to the regulated activity involving the initial launch or utilization of an AI system within the Union for its intended purpose. This process encompasses two primary scenarios: either the supply of an AI system for its first use directly to a deployer, or the use of an AI system for one’s own purposes. As a regulated activity, "putting into service" requires that AI systems adhere to all specific regulatory obligations and compliance standards before they are utiliz</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_RULES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#Article">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Article</rdfs:label>
    <skos:definition xml:lang="en">A reference to a specific article, annex, or recital of the EU AI Act.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_72">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 72</rdfs:label>
    <skos:definition xml:lang="en">RECITAL 72 is a specific section of the EU AI Act that establishes the framework for critical transparency and oversight obligations regarding artificial intelligence systems. This recital explicitly addresses the essential requirements for technical documentation, automatic logging, and post-market monitoring. By detailing these provisions, RECITAL 72 ensures that developers and deployers of AI systems maintain rigorous standards for accountability, performance tracking, and the ongoing assessm</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_57">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 57</rdfs:label>
    <skos:definition xml:lang="en">**Article 57** of the AI Act serves as a key provision within the regulation, primarily governing the establishment and operation of AI regulatory sandboxes. Its function is to define the frameworks under which these controlled environments operate, ensuring that the Board can effectively harmonize practices related to the sandboxes.

The scope and application of Article 57 are multi-faceted. In addition to its primary role concerning regulatory sandboxes, the article includes specific mandates </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_IN_CHAPTER_III_SECTION_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#IMPLEMENTING_ACTS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IN_VITRO_DIAGNOSTIC_MEDICAL_DEVICES_REGULATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">IN VITRO DIAGNOSTIC MEDICAL DEVICES REGULATION</rdfs:label>
    <skos:definition xml:lang="en">The In Vitro Diagnostic Medical Devices Regulation (IVDR), formally known as Regulation (EU) 2017/746, establishes the legal framework governing in vitro diagnostic medical devices within the European Union. This regulation sets out the requirements that manufacturers must meet to place such devices on the market, ensuring high standards of safety, quality, and performance.

A significant aspect of the In Vitro Diagnostic Medical Devices Regulation is its intersection with evolving digital healt</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_9_TO_15_AND_72_TO_73">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 9 TO 15 AND 72 TO 73</rdfs:label>
    <skos:definition xml:lang="en">A cluster of articles representing key obligations (e.g., risk management, data governance, human oversight) that microenterprises must still fulfill despite simplified quality management systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#appliesThroughout">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">appliesThroughout</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_AND_ORGANISATIONAL_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TECHNICAL AND ORGANISATIONAL MEASURES</rdfs:label>
    <skos:definition xml:lang="en">**Technical and organisational measures** represent a crucial framework of strategies, procedures, and design requirements that operators and Union institutions must implement to mitigate risks, ensure the safety and compliance of systems, and protect personal data. 

In the context of data privacy, **technical and organisational measures** are essential for safeguarding personal data processed within environments such as sandboxes. These measures must ensure that data remains protected througho</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CREDIT_SCORING_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">CREDIT SCORING AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">**CREDIT SCORING AI SYSTEMS** are automated technologies designed to evaluate the credit scores or creditworthiness of natural persons. These systems play a critical role in the financial ecosystem, as the assessments they generate directly influence an individual's access to vital financial resources and essential services. Due to this significant impact on people's lives and economic opportunities, these systems are formally classified as high-risk.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_SERVICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEMS_FOR_EMOTION_INFERENCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEMS FOR EMOTION INFERENCE</rdfs:label>
    <skos:definition xml:lang="en">Systems that identify or infer emotions of natural persons; criticized for lack of reliability and potential for discrimination per Recital 44.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFIDENTIALITY_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CONFIDENTIALITY REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">Obligation for notifying authorities to safeguard the confidentiality of information obtained, in accordance with Article 78, as per Article 29(6)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_4_OR_CHAPTER_5_OF_TITLE_V_OF_PART_THREE_OF_THE_TFEU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER 4 OR CHAPTER 5 OF TITLE V OF PART THREE OF THE TFEU</rdfs:label>
    <skos:definition xml:lang="en">Legal framework defining areas of police cooperation and judicial cooperation in criminal matters where Ireland has specific positionings regarding the AI Act</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_111">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 111</rdfs:label>
    <skos:definition xml:lang="en">Article 111 of the AI Act, dealing with AI systems and general-purpose AI models already placed on the market or put into service.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_SUPPORT_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">LAW ENFORCEMENT SUPPORT AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems used by law enforcement for assessing criminal victimisation risk, as polygraphs, or for evaluation purposes.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_78">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 78</rdfs:label>
    <skos:definition xml:lang="en">Text outlining the conformity assessment procedures for products with digital elements that are also classified as high-risk AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_INSTITUTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">UNION INSTITUTION</rdfs:label>
    <skos:definition xml:lang="en">Union institutions, bodies, offices, and agencies refer to the entities within the European Union structure that operate under specific legal frameworks governing their functions, technological deployments, and data practices. These organizations are subject to Regulation (EU) 2018/1725, which establishes specific rules regarding the protection of natural persons with regard to the processing of personal data. Furthermore, these institutions are subject to regulatory oversight regarding their ut</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PERSONAL_DATA_PROTECTION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_SUPPORT_AI"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_ANCILLARY_ADMINISTRATIVE_ACTIVITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR ANCILLARY ADMINISTRATIVE ACTIVITIES</rdfs:label>
    <skos:definition xml:lang="en">An AI system used for tasks like anonymisation/pseudonymisation or administrative tasks that do not affect the actual administration of justice. These are excluded from high-risk classification (Recital 61).</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_ALTERNATIVE_DISPUTE_RESOLUTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR ALTERNATIVE DISPUTE RESOLUTION</rdfs:label>
    <skos:definition xml:lang="en">An AI system used by alternative dispute resolution bodies to research and interpret facts and law, considered high-risk when outcomes produce legal effects for parties (Recital 61).</skos:definition>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ALTERNATIVE_DISPUTE_RESOLUTION_BODY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2017_746">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2017/746</rdfs:label>
    <skos:definition xml:lang="en">**REGULATION (EU) 2017/746** is a piece of European Union legislation that governs in vitro diagnostic (IVD) medical devices. Beyond setting the standard for the regulation of these devices, the regulation plays a critical role in the oversight of modern medical technologies; specifically, it impacts the scope of serious incident reporting requirements for artificial intelligence (AI) systems that function as safety components within these diagnostic devices. By establishing these regulatory fra</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVIDER_TRANSITION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROVIDER TRANSITION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The requirement for a provider to secure a new qualified notified body within three months if the current one is suspended/restricted and lacks the capability to support existing certificates.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_IV">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX IV</rdfs:label>
    <skos:definition xml:lang="en">**ANNEX IV**

ANNEX IV serves as a critical regulatory component, defining the mandatory requirements for the technical documentation associated with AI systems. It functions as a foundational reference document that specifies the minimum elements that must be included in this documentation to ensure compliance and transparency.

The scope of ANNEX IV is referenced across various provisions of the regulatory framework. Specifically, it is explicitly cited in Article 11(1) regarding general techn</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DEEP_FAKE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">DEEP FAKE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">An AI system that generates or manipulates image, audio or video content constituting a deep fake</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_EXCEPTION"/>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#EXEMPTION_FOR_ARTISTIC_CREATIVE_WORK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUBSIDIARY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">SUBSIDIARY</rdfs:label>
    <skos:definition xml:lang="en">A separate legal entity under the control of a notified body that may perform conformity assessment tasks; must meet Article 31 requirements</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_31"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_40_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(40)</rdfs:label>
    <skos:definition xml:lang="en">Definition of biometric categorisation system</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_54_3__OF_REGULATION__EU__2019_881">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 54(3) OF REGULATION (EU) 2019/881</rdfs:label>
    <skos:definition xml:lang="en">Article referenced regarding the cybersecurity certification of products</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REPORTING_OF_SERIOUS_INCIDENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REPORTING OF SERIOUS INCIDENTS</rdfs:label>
    <skos:definition xml:lang="en">The duty for providers to report serious incidents to market surveillance authorities within specific deadlines (Article 73).</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_73"/>
    <euai:hasDeadline rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_DEADLINE"/>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#PROMPT_REPORTING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEMS_CREATING_FACIAL_RECOGNITION_DATABASES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEMS CREATING FACIAL RECOGNITION DATABASES</rdfs:label>
    <skos:definition xml:lang="en">Systems that create or expand databases through untargeted scraping of facial images from the internet or CCTV, prohibited under Recital 43.</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_FACIAL_RECOGNITION_SCRAPING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGISTRATION_IN_DATABASE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REGISTRATION IN DATABASE</rdfs:label>
    <skos:definition xml:lang="en">**REGISTRATION IN DATABASE** refers to a mandatory obligation imposed on law enforcement authorities regarding the deployment of real-time remote biometric identification systems. Under the Regulation, these authorities are required to formally register the use of such systems in a designated database prior to their deployment or use. This procedure ensures regulatory compliance and oversight, serving as a prerequisite for operational activity, unless specific exemptions or alternative provision</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_INTERACTING_WITH_NATURAL_PERSONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM INTERACTING WITH NATURAL PERSONS</rdfs:label>
    <skos:definition xml:lang="en">AI systems interacting with natural persons are defined as technologies engineered to engage directly with human users or to generate content for their consumption. Due to the inherent potential for impersonation or deception, these systems are subject to strict transparency obligations. Specifically, such AI systems must clearly disclose their identity, ensuring that natural persons are fully aware they are interacting with an artificial intelligence rather than another human being. These requi</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SECURITY_CONTROLS">
    <rdfs:label xml:lang="en">SECURITY CONTROLS</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FORMAL_NON_COMPLIANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">FORMAL NON-COMPLIANCE</rdfs:label>
    <skos:definition xml:lang="en">Situations such as incorrect CE marking, missing declaration of conformity, or missing technical documentation that providers must rectify</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_83"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATABASE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATABASE</rdfs:label>
    <skos:definition xml:lang="en">Refers to the system where law enforcement authorities must register the AI system as required by the Regulation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 1</rdfs:label>
    <skos:definition xml:lang="en">Article defining the subject matter and purpose of the Regulation, including harmonised rules, prohibitions, and requirements</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_RULES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_MONITORING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SUPPORT_FOR_INNOVATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISKS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#SystemicRisk"/>
    <rdfs:label xml:lang="en">GENERAL-PURPOSE AI MODEL WITH SYSTEMIC RISKS</rdfs:label>
    <skos:definition xml:lang="en">**GENERAL-PURPOSE AI MODEL WITH SYSTEMIC RISKS**

A "General-Purpose AI Model with Systemic Risks" is a classification assigned to general-purpose AI (GPAI) models that possess the potential to cause significant harm or disruption. These models are identified based on two primary criteria: the possession of high-impact capabilities or a significant market reach that could lead to widespread consequences. Due to the inherent dangers associated with such models, they are subject to strict regulato</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_POLICY"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_INSTITUTIONS__AGENCIES_AND_BODIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">UNION INSTITUTIONS, AGENCIES AND BODIES</rdfs:label>
    <skos:definition xml:lang="en">Entities falling within the scope of the Regulation for which the EDPS serves as market surveillance authority.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SERIOUS_INCIDENT_REPORTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SERIOUS INCIDENT REPORTING</rdfs:label>
    <skos:definition xml:lang="en">**SERIOUS INCIDENT REPORTING**

Serious incident reporting within the context of high-risk AI systems is a mandatory regulatory requirement designed to ensure transparency, accountability, and public safety. This process encompasses specific obligations for various stakeholders, including providers, deployers, importers, and distributors.

Under these regulations, duty holders are required to diligently track, document, and report any serious incidents to the appropriate bodies. Specifically, in</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_OFFICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_TRAVEL_INFORMATION_AND_AUTHORISATION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EUROPEAN TRAVEL INFORMATION AND AUTHORISATION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The European Travel Information and Authorisation System, commonly referred to as ETIAS, is a centralized IT system designed to manage travel information and authorization requests for third-country nationals. Established under the framework of Regulation (EU) 2018/1240 and Regulation (EU) 2018/1241, this system streamlines the processing of data for travelers who are not citizens of the European Union, ensuring effective oversight and security. By integrating these regulations, ETIAS serves as </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1240"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1241"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STANDARDISATION_REQUEST">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">STANDARDISATION REQUEST</rdfs:label>
    <skos:definition xml:lang="en">A **STANDARDISATION REQUEST** is a formal instrument issued by the European Commission to European standardisation organisations. Its primary purpose is to mandate and guide the development of harmonised standards that address specific requirements or obligations set forth under the AI Act.

Under the regulatory framework of the AI Act, specifically Article 40(2), it is the official duty of the Commission to issue such requests to ensure that standards are developed to cover the requirements out</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_1025_2012"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_10_OF_REGULATION__EU__NO_1025_2012"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_STANDARDISATION_ORGANISATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TESTING_DATA_SETS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TESTING DATA SETS</rdfs:label>
    <skos:definition xml:lang="en">The specific data scope to which obligations apply for high-risk AI systems that do not use model training techniques</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROJECT_SUMMARY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROJECT SUMMARY</rdfs:label>
    <skos:definition xml:lang="en">A short summary of the AI project developed in the sandbox, including objectives and results, which must be published by the competent authority</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_24">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 24</rdfs:label>
    <skos:definition xml:lang="en">Article defining obligations of distributors</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_1025_2012">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) NO 1025/2012</rdfs:label>
    <skos:definition xml:lang="en">**REGULATION (EU) NO 1025/2012** is the central legislative framework governing the European standardisation system. It serves as the definitive EU regulation that establishes the rules and procedures for the development of harmonised standards, which are critical for the functioning of the European Single Market. 

This regulation is fundamental to the standardisation process, as it mandates specific requirements regarding stakeholder representation, ensuring that the development of standards i</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPLAINT_HANDLING_AND_REDRESS_PROCEDURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">COMPLAINT HANDLING AND REDRESS PROCEDURES</rdfs:label>
    <skos:definition xml:lang="en">Specific operational procedures that deployers must establish to mitigate risks to fundamental rights when using high-risk AI systems per Recital 96</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_7">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 7</rdfs:label>
    <skos:definition xml:lang="en">Article 7 is the section of the regulation that governs the amendment of Annex III, specifically outlining the procedures and criteria that the Commission must follow when modifying the list of high-risk AI systems contained therein.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONTRACTING_OPERATOR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CONTRACTING OPERATOR</rdfs:label>
    <skos:definition xml:lang="en">An operator in the Union receiving outputs from an AI system used in a third country.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_I_SECTION_A">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX I SECTION A</rdfs:label>
    <skos:definition xml:lang="en">List of Union harmonisation legislation; high-risk AI systems falling under this legislation must follow specific assessment procedures</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_77">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 77</rdfs:label>
    <skos:definition xml:lang="en">Text describing the role of cybersecurity in AI systems and how high-risk systems can demonstrate compliance via horizontal cybersecurity regulations.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SINGLE_INFORMATION_PLATFORM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SINGLE INFORMATION PLATFORM</rdfs:label>
    <skos:definition xml:lang="en">The Single Information Platform is a digital tool developed and maintained by the AI Office to serve as a comprehensive resource for operators, providers, and deployers under the AI Act. Its primary purpose is to offer accessible, easy-to-use information regarding the Regulation.

Additionally, the Single Information Platform functions as a mechanism for transparency regarding sandbox projects. Under the provisions of the Article, it serves as a designated space where exit reports from these pro</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GUIDELINES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">GUIDELINES</rdfs:label>
    <skos:definition xml:lang="en">Documents developed by the Commission to assist with the practical implementation of the Regulation, including requirements, prohibited practices, and transparency obligations, as per Article 96</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_96"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_STANDARDS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMON_SPECIFICATIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_8_15"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_50"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPARTIALITY_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">IMPARTIALITY REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">The duty of notified bodies to document and implement structures and procedures to safeguard objective and impartial assessments throughout their organization and personnel, per Article 31(6).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PRODUCT_ORIENTED_RESEARCH__TESTING_AND_DEVELOPMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">PRODUCT-ORIENTED RESEARCH, TESTING AND DEVELOPMENT</rdfs:label>
    <skos:definition xml:lang="en">Activities regarding AI systems or models prior to those systems being put into service or placed on the market are excluded from the Regulation's provisions</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOXES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODELS_WITH_SYSTEMIC_RISK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#SystemicRisk"/>
    <rdfs:label xml:lang="en">GENERAL-PURPOSE AI MODELS WITH SYSTEMIC RISK</rdfs:label>
    <skos:definition xml:lang="en">GPAI models with systemic risk, criteria for which the Commission can amend via delegated acts</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IDENTIFICATION_NUMBER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">IDENTIFICATION NUMBER</rdfs:label>
    <skos:definition xml:lang="en">The specific number of the notified body that must follow the CE marking and appear in promotional material</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CE_MARKING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_90">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 90</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 90** serves as the regulatory provision that governs and establishes the formal procedure for the scientific panel to issue alerts regarding potential systemic risks associated with artificial intelligence. This article outlines the specific mechanisms through which the scientific panel communicates such concerns, ensuring that the AI Office is properly notified of any identified systemic risks. By codifying this reporting process, Article 90 provides a structured framework for oversig</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION_OF_FACIAL_RECOGNITION_SCRAPING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION OF FACIAL RECOGNITION SCRAPING</rdfs:label>
    <skos:definition xml:lang="en">Duty not to place on the market, put into service, or use AI systems that create facial recognition databases via untargeted scraping.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_167_2013">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) NO 167/2013</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) No 167/2013 serves as the primary legislative framework governing the approval and market surveillance of agricultural and forestry vehicles. This regulation establishes the essential requirements for ensuring that these vehicles meet safety, environmental, and performance standards before they can be placed on the market.

Beyond its foundational role, Regulation (EU) No 167/2013 is dynamic and subject to updates to align with evolving technological landscapes. Specifically, it </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LIABILITY_OF_PROVIDERS_OF_INTERMEDIARY_SERVICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">LIABILITY OF PROVIDERS OF INTERMEDIARY SERVICES</rdfs:label>
    <skos:definition xml:lang="en">Legal responsibility of providers of intermediary services as defined in Regulation (EU) 2022/2065, which remains unaffected by this Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_III">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER III</rdfs:label>
    <skos:definition xml:lang="en">Refers to the section of the Act setting out requirements for high-risk AI systems, conformity with which is a condition for source code access</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIGITAL_SERVICES_ACT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIGITAL SERVICES ACT</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2022/2065, establishing rules for the single market for digital services, referenced for interaction with the AI Act</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_AI_ACT"/>
    <euai:appliesThroughout rdf:resource="https://w3id.org/euaiact/ontology#AISYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LOGGING_MECHANISM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">LOGGING MECHANISM</rdfs:label>
    <skos:definition xml:lang="en">The **LOGGING MECHANISM** is a necessary technical feature designed to enable deployers to systematically collect, store, and interpret logs. Its primary function is to ensure that these logging activities are conducted in strict accordance with the requirements set forth in Article 12, thereby maintaining full regulatory compliance.</skos:definition>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_12"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADVISORY_FORUM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">ADVISORY FORUM</rdfs:label>
    <skos:definition xml:lang="en">The **Advisory Forum** is a dedicated advisory body established to provide technical expertise and strategic guidance to both the European AI Board and the European Commission.

Composed of a diverse group of stakeholders, the Advisory Forum includes representatives from industry, small and medium-sized enterprises (SMEs), academia, and civil society. It also incorporates participation from key organizations such as the European Union Agency for Fundamental Rights (FRA), the European Union Agenc</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_ARTIFICIAL_INTELLIGENCE_BOARD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_67"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BOARD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#ANNUAL_REPORT_PREPARATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2006_42_EC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2006/42/EC</rdfs:label>
    <skos:definition xml:lang="en">Union harmonisation legislation applicable to machinery (Recital 46)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_46"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_SPECIFICATIONS_AND_TESTING_STANDARDS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TECHNICAL SPECIFICATIONS AND TESTING STANDARDS</rdfs:label>
    <skos:definition xml:lang="en">Technical standards and specifications adopted by the Commission for AI systems, which must incorporate the requirements of Chapter III, Section 2 of the AI Act</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_OF_CHAPTER_III_SECTION_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AUTHORITIES_INVOLVED_IN_THE_APPLICATION_OF_THE_REGULATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">AUTHORITIES INVOLVED IN THE APPLICATION OF THE REGULATION</rdfs:label>
    <skos:definition xml:lang="en">Authorities (including national competent authorities, the Commission, and market surveillance authorities) tasked with enforcing the AI Act, mandated to protect confidential information and data obtained during their activities</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROTECTION_OF_CONFIDENTIAL_INFORMATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CYBERSECURITY_MEASURES_FOR_DATA_PROTECTION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMMON_AND_LEGITIMATE_COMMERCIAL_PRACTICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">COMMON AND LEGITIMATE COMMERCIAL PRACTICES</rdfs:label>
    <skos:definition xml:lang="en">Exemption for standard advertising practices that comply with applicable law.</skos:definition>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_MANIPULATIVE_AI_PRACTICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODELS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">GENERAL-PURPOSE AI MODELS</rdfs:label>
    <skos:definition xml:lang="en">**GENERAL-PURPOSE AI MODELS** are subject to specific monitoring activities conducted by the AI Office. These models may also be subject to qualified alerts, regarding which the Board is tasked with providing opinions to the Commission, in accordance with Article 66(n).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#APPLICATION_DATE_2_AUGUST_2025">
    <rdfs:label xml:lang="en">APPLICATION DATE 2 AUGUST 2025</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CREDIT_INSTITUTIONS_AND_INSURANCE_UNDERTAKINGS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CREDIT INSTITUTIONS AND INSURANCE UNDERTAKINGS</rdfs:label>
    <skos:definition xml:lang="en">Entities that use AI for prudential purposes and credit scoring</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_R23_OF_ANNEX_I_TO_DECISION_768_2008_EC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE R23 OF ANNEX I TO DECISION 768/2008/EC</rdfs:label>
    <skos:definition xml:lang="en">Reference to the legal basis for the electronic notification tool used by national competent authorities</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HEALTH_AND_LIFE_INSURANCE_RISK_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">HEALTH AND LIFE INSURANCE RISK AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems used for risk assessment and pricing in life and health insurance (Annex III 5(c))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_VALUE_CHAIN_PARTIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">AI VALUE CHAIN PARTIES</rdfs:label>
    <skos:definition xml:lang="en">Parties that supply AI systems, tools, services, or components incorporated by providers into high-risk AI systems</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#WRITTEN_AGREEMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INTELLECTUAL_PROPERTY_RIGHTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRADE_SECRETS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPORTER_OBLIGATION__IDENTIFICATION_LABELING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">IMPORTER OBLIGATION: IDENTIFICATION LABELING</rdfs:label>
    <skos:definition xml:lang="en">Importers must indicate their name, registered trade name/mark, and contact address on the high-risk AI system, packaging, or documentation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CYBERSECURITY_PROTECTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CYBERSECURITY PROTECTION</rdfs:label>
    <skos:definition xml:lang="en">**CYBERSECURITY PROTECTION**

CYBERSECURITY PROTECTION represents a mandatory obligation to ensure an adequate and robust level of security for AI models and their supporting physical infrastructure. As stipulated by Article 55(1)(d), this duty requires that rigorous security measures be implemented to safeguard the integrity and safety of the technology.

This protection extends to the entire operational ecosystem, encompassing critical components such as the models themselves, their specific w</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITALS_106_110">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITALS 106-110</rdfs:label>
    <skos:definition xml:lang="en">The section of the EU AI Act providing context and explanatory justification for transparency obligations for general-purpose AI models and systemic risk definitions</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMERGENCY_DISPATCH_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EMERGENCY DISPATCH AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems used to dispatch or establish priority in emergency first response services (Annex III 5(d))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK_CRITERIA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SYSTEMIC RISK CRITERIA</rdfs:label>
    <skos:definition xml:lang="en">Criteria used by the Commission to designate general-purpose AI models with systemic risk. Includes: number of parameters, dataset quality/size, computation amount (FLOPs/cost/time/energy), input/output modalities, and model benchmarks/evaluations, as specified in Annex XIII.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_XIII"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_29">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 29</rdfs:label>
    <skos:definition xml:lang="en">Article 29 outlines the comprehensive regulatory framework regarding the status of conformity assessment bodies. Specifically, it details the requirements and the formal application process that these bodies must undergo to achieve official notification. Furthermore, Article 29 addresses the procedural obligations necessary for an already notified body to request an extension to the scope of its existing notification. In essence, this article serves as the governing provision for both the initia</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTEGRATION_INTO_SOFTWARE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INTEGRATION INTO SOFTWARE</rdfs:label>
    <skos:definition xml:lang="en">An activity in the AI value chain for which providers require assistance from upstream suppliers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HIGH_RISK_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">HIGH-RISK AI</rdfs:label>
    <skos:definition xml:lang="en">The classification heading for Chapter III, implying the regulatory scope for systems under discussion.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_TO_FUNDAMENTAL_RIGHTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">RISK TO FUNDAMENTAL RIGHTS</rdfs:label>
    <skos:definition xml:lang="en">A specific risk classification used by authorities to determine enforcement actions when AI systems impact the rights of persons</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_34">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 34</rdfs:label>
    <skos:definition xml:lang="en">A section of the Regulation detailing the requirement for responsible, proportionate use, necessity, and the mandatory fundamental rights impact assessment for biometric identification systems.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK_THRESHOLD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#SystemicRisk"/>
    <rdfs:label xml:lang="en">SYSTEMIC RISK THRESHOLD</rdfs:label>
    <skos:definition xml:lang="en">A classification triggered by general-purpose AI models that meet specific criteria (such as 10^25 FLOPs or significant scale), resulting in additional obligations under Article 55</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_2_TEU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 2 TEU</rdfs:label>
    <skos:definition xml:lang="en">Reference to Union values upon which AI and its regulatory framework must be developed</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_III_POINT_1_A_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">ANNEX III POINT 1(A)</rdfs:label>
    <skos:definition xml:lang="en">A specific sub-category of high-risk AI systems identified in Annex III that triggers additional minimum logging requirements under Article 12(3)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_PHYSICAL_STATE_DETECTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION FOR PHYSICAL STATE DETECTION</rdfs:label>
    <skos:definition xml:lang="en">Condition under Recital 18 where systems detecting physical states like pain or fatigue are not considered emotion recognition systems, provided they are not used to infer emotions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_POLICY">
    <rdfs:label xml:lang="en">RISK MANAGEMENT POLICY</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HIGH_QUALITY_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">HIGH-QUALITY DATA</rdfs:label>
    <skos:definition xml:lang="en">A technical requirement for training AI systems to avoid discriminatory or incorrect outcomes</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERNAL_MARKET_INTEGRATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INTERNAL MARKET INTEGRATION</rdfs:label>
    <skos:definition xml:lang="en">The objective of ensuring the free movement of AI-based goods and services across borders within the Union</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_37_4_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 37(4)</rdfs:label>
    <skos:definition xml:lang="en">Specific provision detailing the Commission's power to intervene when notified bodies fail to meet requirements</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#deploysSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">deploys system</rdfs:label>
    <skos:definition xml:lang="en">Relates a deployer to an AI system they operate.</skos:definition>
    <rdfs:domain rdf:resource="https://w3id.org/euaiact/ontology#Deployer"/>
    <rdfs:range rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ACCURACY_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ACCURACY REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">Requirement for AI systems in migration, asylum, and border control to be accurate to guarantee fundamental rights.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSITIONAL_PERIOD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">TRANSITIONAL PERIOD</rdfs:label>
    <skos:definition xml:lang="en">The period during which voluntary compliance with obligations is encouraged, specifically for high-risk AI system providers (Recital 178)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINANCIAL_INTELLIGENCE_ADMINISTRATIVE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">FINANCIAL INTELLIGENCE ADMINISTRATIVE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems used by financial intelligence units carrying out administrative tasks analyzing information under anti-money laundering law</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FINANCIAL_INTELLIGENCE_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_AND_MIGRATION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">LAW ENFORCEMENT AND MIGRATION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">High-risk AI systems used in specific sensitive domains like law enforcement, migration, asylum, and border control management</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#ELECTRONIC_INSTRUCTIONS_FOR_USE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_50">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 50</rdfs:label>
    <skos:definition xml:lang="en">**RECITAL 50** of the AI Act serves as a foundational provision within the preamble, delineating the specific criteria used to classify certain artificial intelligence systems as high-risk. Specifically, RECITAL 50 establishes that AI systems functioning as safety components within products—or which are themselves products—must be designated as high-risk if those items are subject to a third-party conformity assessment under existing Union harmonisation legislation. By defining this classificati</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAWFUL_EVALUATION_PRACTICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">LAWFUL EVALUATION PRACTICES</rdfs:label>
    <skos:definition xml:lang="en">Evaluation practices of natural persons carried out for a specific purpose in accordance with Union and national law, which are not prohibited (Recital 31).</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#SOCIAL_SCORING_AI_SYSTEMS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MONITORING_MECHANISMS">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_35_OF_REGULATION__EU__2016_679"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_39_OF_REGULATION__EU__2018_1725"/>
    <rdfs:label xml:lang="en">MONITORING MECHANISMS</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PERFORMANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PERFORMANCE</rdfs:label>
    <skos:definition xml:lang="en">Technical requirement for AI systems to operate effectively and reliably</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DEVELOPMENT_OF_INFORMATION_PLATFORM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DEVELOPMENT OF INFORMATION PLATFORM</rdfs:label>
    <skos:definition xml:lang="en">Duty of the AI Office to develop and maintain a single information platform for all operators across the Union.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSPARENCY_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TRANSPARENCY REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">Requirement for AI systems in migration, asylum, and border control to be transparent to guarantee fundamental rights.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSPARENCY_RELATED_REQUIREMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TRANSPARENCY-RELATED REQUIREMENTS</rdfs:label>
    <skos:definition xml:lang="en">**TRANSPARENCY-RELATED REQUIREMENTS**

The transparency-related requirements for general-purpose AI (GPAI) models encompass a set of obligations designed to ensure accountability and regulatory compliance. Providers of GPAI models are mandated to adhere to specific documentation and information-provision standards. Central to these transparency obligations is the requirement for providers to generate and publish a comprehensive summary of the content used for training their models. Furthermore, </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_50">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 50</rdfs:label>
    <skos:definition xml:lang="en">**Article 50** serves as a critical regulatory framework dedicated to establishing specific transparency obligations for the providers and deployers of AI systems. The article outlines detailed requirements that ensure clarity and accountability regarding the operation and usage of these technologies. 

Central to its purpose, Article 50 defines the nature and scope of transparency measures applicable to certain AI systems that require heightened scrutiny or public disclosure. It delineates the </skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXPLOITATIVE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EXPLOITATIVE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">An AI system that exploits vulnerabilities of natural persons due to age, disability, or specific circumstances (Article 5(1)(b))</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_EXPLOITATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DelegatedAct">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">DelegatedAct</rdfs:label>
    <skos:definition xml:lang="en">A Commission act that modifies or extends classification rules or obligations.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_POLITICAL_CAMPAIGN_TOOLS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION FOR POLITICAL CAMPAIGN TOOLS</rdfs:label>
    <skos:definition xml:lang="en">The "EXCLUSION FOR POLITICAL CAMPAIGN TOOLS" acts as a specific regulatory provision that exempts certain AI systems from the high-risk classification typically applied to tools used for influencing elections. As outlined in the regulations—specifically within Annex III(8)(b) and clarified by Recital 62—this exception applies to AI tools utilized for the administrative and logistical optimization of political campaigns. 

The core criterion for this exclusion is the lack of direct exposure to na</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUSPENSION_OF_USE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SUSPENSION OF USE</rdfs:label>
    <skos:definition xml:lang="en">The requirement for a deployer to stop using a system if it presents a risk within the meaning of Article 79(1)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESOURCE_REPORTING_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">RESOURCE REPORTING OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Member States must report to the Commission every two years on the status of financial and human resources of national competent authorities</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_4_1__OF_DIRECTIVE__EU__2016_680">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 4(1) OF DIRECTIVE (EU) 2016/680</rdfs:label>
    <skos:definition xml:lang="en">Article setting principles for data processing including lawfulness, fairness, transparency, and purpose limitation (Recital 94)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GUIDELINES_ON_PRACTICAL_IMPLEMENTATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">GUIDELINES ON PRACTICAL IMPLEMENTATION</rdfs:label>
    <skos:definition xml:lang="en">Commission must provide guidelines specifying the practical implementation of Article 49 by 2 February 2026, including a list of examples of high-risk and non-high-risk AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WORKERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">WORKERS</rdfs:label>
    <skos:definition xml:lang="en">Employees whose rights, working conditions, and health and safety at work are protected by Union and national labour law, independent of this Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STRUCTURED_DIALOGUE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">STRUCTURED DIALOGUE</rdfs:label>
    <skos:definition xml:lang="en">**STRUCTURED DIALOGUE** refers to a voluntary and preliminary procedural step initiated by the AI Office. This dialogue takes place between the AI Office and a provider, serving as an initial engagement before any formal requests for information or formal access requests are issued. The primary purpose of this interaction is to gather comprehensive information regarding a provider's model testing methodologies and their strategies for risk mitigation, effectively laying the groundwork prior to p</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_6_4_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 6(4)</rdfs:label>
    <skos:definition xml:lang="en">ARTICLE 6(4) functions as a specific legal reference that governs the parameters surrounding the use of personal data. Furthermore, it establishes defined registration requirements applicable to systems categorized as non-high-risk. By integrating these provisions, ARTICLE 6(4) serves a dual purpose in regulatory compliance, ensuring that both data usage practices and the administrative obligations for lower-risk systems are clearly outlined and governed within the relevant legal framework.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_COMMITTEE_FOR_ELECTROTECHNICAL_STANDARDIZATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">EUROPEAN COMMITTEE FOR ELECTROTECHNICAL STANDARDIZATION</rdfs:label>
    <skos:definition xml:lang="en">Also known as CENELEC, a permanent member of the advisory forum (Article 67(5)).</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADVISORY_FORUM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CRIMINAL_OFFENCE_INVESTIGATION_EXCEPTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">CRIMINAL OFFENCE INVESTIGATION EXCEPTION</rdfs:label>
    <skos:definition xml:lang="en">An exclusion condition for transparency obligations regarding AI systems used by law enforcement to detect, prevent, investigate, or prosecute criminal offences, provided appropriate safeguards are in place</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTENDED_PURPOSE_MODIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">INTENDED PURPOSE MODIFICATION</rdfs:label>
    <skos:definition xml:lang="en">The act of changing the intended purpose of an AI system (including general-purpose AI) so it becomes a high-risk AI system; this triggers provider obligations for the modifying party per Recital 84.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_LAW">
    <rdfs:label xml:lang="en">UNION LAW</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SeriousIncident">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">SeriousIncident</rdfs:label>
    <skos:definition xml:lang="en">An event related to a GPAI model that must be reported.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PENALTIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PENALTIES</rdfs:label>
    <skos:definition xml:lang="en">Penalties serve as a critical enforcement mechanism designed to address non-compliance with the Regulation. To ensure their legitimacy and impact, these measures must be effective, proportionate, and dissuasive. 

Under the established framework, Member States are mandated to lay down, notify, and effectively implement rules regarding these penalties—which include administrative fines—by the deadline of 2 August 2025. Furthermore, the state and ongoing effectiveness of these penalties are subjec</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#APPLICATION_DATE_2_AUGUST_2025"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_92">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 92</rdfs:label>
    <skos:definition xml:lang="en">**Article 92** functions as the governing regulation concerning the evaluation of general-purpose AI (GPAI) models. It establishes the legal framework and authority for conducting these critical assessments. Furthermore, Article 92 outlines the enforcement mechanisms related to these evaluations, specifically mandating that GPAI providers grant necessary access for the assessment process; failure to provide such access can result in the imposition of financial penalties on the providers.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TAX_AND_CUSTOMS_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">TAX AND CUSTOMS AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">Authorities responsible for tax and customs, using AI for administrative proceedings</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TAX_AND_CUSTOMS_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_SOLUTIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TECHNICAL SOLUTIONS</rdfs:label>
    <skos:definition xml:lang="en">Mechanisms like fail-safe plans designed to enable systems to safely interrupt operations or prevent/minimize harmful behavior</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ROBUSTNESS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_2144">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2019/2144</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2019/2144, formally known as the regulation on type-approval requirements for motor vehicles and their trailers, is a critical legislative framework designed to enhance road safety and security. It establishes comprehensive safety and protection standards aimed at safeguarding both vehicle occupants and vulnerable road users. By setting these rigorous type-approval requirements, Regulation (EU) 2019/2144 ensures that motor vehicles and trailers manufactured for use in the Europea</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_52">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 52</rdfs:label>
    <skos:definition xml:lang="en">Article detailing the procedure for notifying, designating, and reassessing GPAI models with systemic risk</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LOG_KEEPING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">LOG KEEPING</rdfs:label>
    <skos:definition xml:lang="en">Regarding the log keeping requirements for high-risk AI systems, both providers and deployers have specific responsibilities to ensure accountability and traceability. 

Providers are mandated to retain automatically generated logs created by their high-risk AI systems, provided these systems remain under their control. This requirement is explicitly outlined under Article 16(e) and Article 19 of the relevant regulations. Furthermore, deployers are also required to maintain logs generated by the</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_19"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PERSONAL_DATA_PROCESSING_IN_SANDBOX">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PERSONAL DATA PROCESSING IN SANDBOX</rdfs:label>
    <skos:definition xml:lang="en">The requirement that personal data collected for other purposes may be processed in the sandbox only under specific, strictly defined conditions, including safety and public interest criteria</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_59"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AUTHORISED_REPRESENTATIVE_APPOINTMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">AUTHORISED REPRESENTATIVE APPOINTMENT</rdfs:label>
    <skos:definition xml:lang="en">Requirement to appoint an authorised representative where applicable; failure to do so is formal non-compliance under Article 83</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_83"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFIDENTIALITY_OBLIGATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CONFIDENTIALITY OBLIGATIONS</rdfs:label>
    <skos:definition xml:lang="en">Legal duties to protect information and documentation obtained under the Act, particularly trade secrets, in accordance with Article 78</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPETENT_PERSONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">COMPETENT PERSONS</rdfs:label>
    <skos:definition xml:lang="en">Persons within a notifying authority who make notification decisions, distinct from those who assessed the conformity assessment bodies</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADMINISTRATION_OF_JUSTICE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">ADMINISTRATION OF JUSTICE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">**ADMINISTRATION OF JUSTICE AI SYSTEM**

The "Administration of Justice AI System" refers to advanced artificial intelligence technologies designed specifically for use by, or on behalf of, judicial authorities. The primary purpose of these systems is to support the judiciary in the complex tasks inherent in legal proceedings. Specifically, these AI tools are intended to assist in the comprehensive processes of researching, interpreting, and analyzing both facts and the law, as well as applying </skos:definition>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATION_OF_JUSTICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_V">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX V</rdfs:label>
    <skos:definition xml:lang="en">ANNEX V serves as a formal section of regulatory documentation that outlines the specific content requirements for the EU declaration of conformity. This annex functions as a definitive guide for manufacturers and relevant parties, detailing exactly what information must be included in the declaration to ensure compliance with European Union standards. By specifying these content requirements, ANNEX V provides the necessary framework for drafting a complete and accurate EU declaration of conform</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MODEL_EVALUATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MODEL EVALUATION</rdfs:label>
    <skos:definition xml:lang="en">**Model Evaluation** refers to a critical and mandatory requirement for providers of General Purpose AI (GPAI) models that pose systemic risks. Under Article 55 of the relevant regulatory framework, these providers are legally obligated to conduct thorough assessments of their models prior to making them available on the market.

The primary purpose of this Model Evaluation process is to proactively identify, assess, and mitigate systemic risks associated with the AI technology. To ensure consis</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_55"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADVERSARIAL_TESTING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_29">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 29</rdfs:label>
    <skos:definition xml:lang="en">**RECITAL 29** is a critical section of the Act that establishes prohibitions concerning manipulative and exploitative artificial intelligence practices. Specifically, it outlines the prohibition of AI systems designed to materially distort human behavior through the use of manipulative techniques. By addressing these harmful applications, RECITAL 29 serves as a regulatory safeguard against AI deployments that aim to exploit users or undermine their autonomy.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_4_2__TEU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 4(2) TEU</rdfs:label>
    <skos:definition xml:lang="en">Article 4(2) of the Treaty on European Union (TEU) serves as a fundamental provision delineating the division of competence between the European Union and its Member States. This article establishes the principle that the responsibility for safeguarding national security rests solely with the individual Member States. Consequently, it functions as a critical legal justification for excluding national security, as well as military and defense-related activities, from the scope of various European</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ABSENCE_OF_CONFLICTS_OF_INTERESTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ABSENCE OF CONFLICTS OF INTERESTS</rdfs:label>
    <skos:definition xml:lang="en">Specific requirement for notified bodies to operate without bias or competing commercial interests</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STATE_OF_THE_ART_ON_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">STATE OF THE ART ON AI</rdfs:label>
    <skos:definition xml:lang="en">The baseline technological and safety standard that providers must take into account when adopting measures to comply with the mandatory requirements of the Regulation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_DATA_PROTECTION_LAW">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">UNION DATA PROTECTION LAW</rdfs:label>
    <skos:definition xml:lang="en">Refers to the existing legal framework including Regulation (EU) 2016/679 (GDPR), Regulation (EU) 2018/1725, and Directive (EU) 2016/680, which apply to personal data processing by AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_PROTECTION_LAW">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DATA PROTECTION LAW</rdfs:label>
    <skos:definition xml:lang="en">The requirement that data governance and management practices must comply with relevant Union law, such as Regulation (EU) 2016/679</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AnnexIIICategory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">AnnexIIICategory</rdfs:label>
    <skos:definition xml:lang="en">One of the 8 high-risk use case domains listed in Annex III.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CRITICAL_INFRASTRUCTURE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">CRITICAL INFRASTRUCTURE</rdfs:label>
    <skos:definition xml:lang="en">**Critical Infrastructure** refers to systems, assets, or domains whose disruption or failure would pose an imminent threat to life or physical safety. Due to the significant risks associated with their operation, they are frequently categorized as a high-risk domain for the deployment of artificial intelligence (AI) systems.

The scope of critical infrastructure encompasses vital societal functions, specifically those related to the safety components in the management and operation of critical </skos:definition>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_SETS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA SETS</rdfs:label>
    <skos:definition xml:lang="en">The training, validation, and testing data for high-risk AI systems which must be relevant, representative, complete, and free of errors</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PRIVACY_PRESERVING_TECHNIQUES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_GOVERNANCE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_PROTECTION_LAW"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_MANAGEMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA MANAGEMENT</rdfs:label>
    <skos:definition xml:lang="en">Procedures for data acquisition, collection, analysis, labelling, storage, filtration, mining, aggregation, and retention for high-risk AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OPERATOR_OBLIGATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">OPERATOR OBLIGATIONS</rdfs:label>
    <skos:definition xml:lang="en">Requirement for operators (importers, distributors, etc.) to fulfill obligations associated with their roles, which may be cumulative if acting in multiple roles.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECRUITMENT_AND_JOB_ADVERTISEMENT_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">RECRUITMENT AND JOB ADVERTISEMENT AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems used for recruitment, placement of targeted job advertisements, and filtering applications (Annex III 4(a))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EMPLOYMENT__WORKERS__MANAGEMENT_AND_ACCESS_TO_SELF_EMPLOYMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_28">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 28</rdfs:label>
    <skos:definition xml:lang="en">Reference to Recital 28, covering the prohibition of manipulative and exploitative AI practices due to contradictions with Union values</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EU_DECLARATION_OF_CONFORMITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EU DECLARATION OF CONFORMITY</rdfs:label>
    <skos:definition xml:lang="en">The **EU Declaration of Conformity** is a critical, formal document that serves as an official assertion by a provider that a high-risk AI system complies with the requirements set out in the AI Act—specifically those detailed in Section 2—as well as other relevant Union law. As mandated by Article 47 and Annex V of the AI Act, this declaration must be drawn up by the provider to attest that the AI system meets all necessary regulatory standards.

Functioning as a legal instrument of compliance,</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION_ON_HORIZONTAL_CYBERSECURITY_REQUIREMENTS_FOR_PRODUCTS_WITH_DIGITAL_ELEMENTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_47"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_V"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_OF_SECTION_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_HARMONISATION_LEGISLATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFIED_BODY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISED_REPRESENTATIVE"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITIES"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_83"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INPUT_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INPUT DATA</rdfs:label>
    <skos:definition xml:lang="en">Data provided to or acquired by an AI system, which serves as the basis for the system to produce an output.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_30">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 30</rdfs:label>
    <skos:definition xml:lang="en">**RECITAL 30** functions as a key provision within the Act, specifically addressing the regulatory framework surrounding biometric categorisation systems. Its primary purpose is to delineate the strict limitations imposed on these technologies. 

RECITAL 30 establishes a clear prohibition against the use of biometric categorisation systems that attempt to infer sensitive or protected attributes—such as race, political opinions, trade union membership, religious or philosophical beliefs, sex life</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LOGGING_CAPABILITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">LOGGING CAPABILITIES</rdfs:label>
    <skos:definition xml:lang="en">Technical functionality required by Article 12 to enable the recording of system events</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LOGS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MAKING_AVAILABLE_ON_THE_MARKET">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">MAKING AVAILABLE ON THE MARKET</rdfs:label>
    <skos:definition xml:lang="en">The supply of an AI system or a general-purpose AI model for distribution or use on the Union market in the course of a commercial activity, whether in return for payment or free of charge</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REVERSIBILITY_OF_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">REVERSIBILITY OF AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The requirement that predictions, recommendations, or decisions of the AI system can be effectively reversed and disregarded, per Article 60(k)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HighRisk">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">HighRisk</rdfs:label>
    <skos:definition xml:lang="en">Risk level triggering the full set of Chapter III obligations</skos:definition>
    <euai:articleReference>Article 6</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TESTING_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TESTING DATA</rdfs:label>
    <skos:definition xml:lang="en">Data used for providing an independent evaluation of an AI system to confirm expected performance before placing it on the market or putting it into service.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_COMMITTEE_FOR_STANDARDIZATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">EUROPEAN COMMITTEE FOR STANDARDIZATION</rdfs:label>
    <skos:definition xml:lang="en">Also known as CEN, a permanent member of the advisory forum (Article 67(5)).</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADVISORY_FORUM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MIGRATION_AND_BORDER_CONTROL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">MIGRATION AND BORDER CONTROL</rdfs:label>
    <skos:definition xml:lang="en">Domain involved in visa issuance and asylum procedures, referenced via Regulation (EC) No 810/2009 and Directive 2013/32/EU</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EC__NO_810_2009"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE_2013_32_EU"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_INFLUENCING_ELECTIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR INFLUENCING ELECTIONS</rdfs:label>
    <skos:definition xml:lang="en">System used to influence election/referendum outcomes or voting behavior, identified in Annex III(8)(b)</skos:definition>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_POLITICAL_CAMPAIGN_TOOLS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#QualityManagementSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Quality Management System</rdfs:label>
    <skos:definition xml:lang="en">A system providers must establish to ensure compliance. (Article 17)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2013_32_EU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2013/32/EU</rdfs:label>
    <skos:definition xml:lang="en">Directive 2013/32/EU, commonly known as the Asylum Procedures Directive, establishes a framework of common procedures for the granting and withdrawing of international protection within the European Union. This legislative instrument is designed to harmonize the processes Member States use to assess asylum claims, ensuring a consistent approach to the protection of individuals seeking refuge. 

Furthermore, Directive 2013/32/EU holds significant relevance within the context of emerging technolog</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION_OF_EXPLOITATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION OF EXPLOITATION</rdfs:label>
    <skos:definition xml:lang="en">Prohibition on placing, putting into service, or using AI systems that exploit vulnerabilities of natural persons (Article 5(1)(b))</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_7_2_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 7(2)</rdfs:label>
    <skos:definition xml:lang="en">**Article 7(2)** serves as a regulatory provision that establishes the essential criteria for evaluating risks associated with AI systems, specifically within the context of amending Annex III. This article outlines a framework for assessing potential risks to ensure that any adjustments to the classification or regulation of these systems are grounded in objective factors. Key elements considered in this evaluation include the intensity of the potential harm, the degree of dependency that indiv</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_FINES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ADMINISTRATIVE FINES</rdfs:label>
    <skos:definition xml:lang="en">Administrative fines serve as a critical enforcement measure designed to ensure compliance with the AI Act. These financial penalties are imposed upon various entities—including Member States, Union institutions, and providers of general-purpose AI (GPAI) models—in response to infringements of the Regulation.

The framework for these administrative fines establishes specific monetary limits based on the nature of the entity and the type of violation. For Union institutions, penalties are capped </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SME"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_INSTITUTION__BODY__OFFICE_OR_AGENCY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_101"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_99_1_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#Robustness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Accuracy, Robustness and Cybersecurity</rdfs:label>
    <skos:definition xml:lang="en">Requirements for AI system performance and resilience. (Article 15)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_38_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(38)</rdfs:label>
    <skos:definition xml:lang="en">Definition of sensitive operational data</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEMS_LIST_AMENDMENT_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">HIGH-RISK AI SYSTEMS LIST AMENDMENT ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">The Commission must assess the need to amend the list of high-risk AI systems and prohibited practices once a year (Recital 174).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2000_31_EC">
    <rdfs:label xml:lang="en">DIRECTIVE 2000 31 EC</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECIPIENT_NATIONAL_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">RECIPIENT NATIONAL AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">National authorities receiving outputs from third-country cooperation agreements; they remain accountable for compliance with Union law.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ACCOUNTABILITY_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUBJECT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">SUBJECT</rdfs:label>
    <skos:definition xml:lang="en">A natural person who participates in testing in real-world conditions, as defined in Article 3(58)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INFORMED_CONSENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_COMMON_DATA_SPACES">
    <rdfs:label xml:lang="en">EUROPEAN COMMON DATA SPACES</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NARROW_PROCEDURAL_TASK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">NARROW PROCEDURAL TASK</rdfs:label>
    <skos:definition xml:lang="en">Condition where an AI system performs a narrow procedural task and is therefore potentially not high-risk despite Annex III listing</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SERIOUS_CRIMINAL_OFFENCES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SERIOUS CRIMINAL OFFENCES</rdfs:label>
    <skos:definition xml:lang="en">Crimes punishable by a custodial sentence or detention order for at least four years, serving as a threshold to justify the use of real-time remote biometric identification (Recital 33).</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_EXCEPTIONS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1860">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2018/1860</rdfs:label>
    <skos:definition xml:lang="en">Legislation on the use of the Schengen Information System for the return of illegally staying third-country nationals</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMERGENCY_HEALTHCARE_TRIAGE_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EMERGENCY HEALTHCARE TRIAGE AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems used for emergency healthcare patient triage (Annex III 5(d))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CORRECTIVE_ACTIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CORRECTIVE ACTIONS</rdfs:label>
    <skos:definition xml:lang="en">Providers must take necessary measures to bring a non-conforming AI system into conformity, withdraw it, disable it, or recall it as per Article 20(1)</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_20"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_X">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX X</rdfs:label>
    <skos:definition xml:lang="en">**ANNEX X** refers to a specific section within the EU AI Act that serves to identify and list relevant Union legislative acts. This annex focuses exclusively on legislation pertaining to large-scale information technology (IT) systems within the domain of Freedom, Security, and Justice. The information contained in ANNEX X is particularly significant because it is often utilized to help determine the classification of AI systems, specifically when evaluating whether a system qualifies as a high</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#SCHENGEN_INFORMATION_SYSTEM"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#VISA_INFORMATION_SYSTEM"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EURODAC"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STAKEHOLDER_ORGANISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">STAKEHOLDER ORGANISATION</rdfs:label>
    <skos:definition xml:lang="en">Civil society or relevant bodies involved in the AI ecosystem</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2002_14_EC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2002/14/EC</rdfs:label>
    <skos:definition xml:lang="en">**DIRECTIVE 2002/14/EC** is a piece of European legislation that establishes a general framework for the information and consultation of employees within the European Community. This directive is designed to ensure that workers are properly informed and consulted by their employers regarding relevant workplace matters.

In the context of contemporary legal frameworks—specifically concerning the regulation of artificial intelligence—DIRECTIVE 2002/14/EC plays a significant role. It is explicitly </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM_NOT_USING_TRAINING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">HIGH-RISK AI SYSTEM NOT USING TRAINING</rdfs:label>
    <skos:definition xml:lang="en">A high-risk AI system that does not involve techniques using the training of AI models, for which obligations regarding data processing apply only to testing data sets</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_DATA_SETS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ECONOMIC_OPERATOR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">ECONOMIC OPERATOR</rdfs:label>
    <skos:definition xml:lang="en">Any person/organization subject to Regulation (EU) 2019/1020, understood to include operators identified in Article 2(1) of the AI Act</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_1020"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#modifies">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">modifies</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_82">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 82</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 82** concerns high-risk AI systems that, despite being formally compliant with the Regulation, still present significant risks. This article serves as a mechanism to address these exceptional cases, ensuring that compliance with standard regulatory requirements does not preclude the identification and mitigation of actual or potential dangers posed by these advanced technologies.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADVERSARIAL_TESTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ADVERSARIAL TESTING</rdfs:label>
    <skos:definition xml:lang="en">Adversarial testing is a specialized evaluation methodology utilized to assess the security and robustness of AI models. As defined by its inclusion in model evaluation frameworks, this process is essential for identifying and mitigating systemic risks, a requirement specifically mandated under Article 55(1)(a). 

This evaluation method functions by employing either internal testing or independent external assessments to rigorously probe the model for potential weaknesses. By simulating various </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MODEL_EVALUATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MICROENTERPRISE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">MICROENTERPRISE</rdfs:label>
    <skos:definition xml:lang="en">A **microenterprise** is a specific category of small business entity recognized for its size and operational scale. These businesses are eligible for simplified fulfillment procedures regarding their quality management systems. Specifically, under Article 63, a microenterprise is granted the ability to comply with quality management system obligations in a simplified manner. This regulatory approach is designed to ensure proportionality, particularly regarding the costs associated with innovati</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#QUALITY_MANAGEMENT_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AUTHORISATION_FOR_EXCEPTIONAL_USE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">AUTHORISATION FOR EXCEPTIONAL USE</rdfs:label>
    <skos:definition xml:lang="en">The process by which law enforcement or civil protection authorities may seek permission to use a high-risk AI system in emergencies; if refused, use must cease and results be discarded.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_49_2_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 49(2)</rdfs:label>
    <skos:definition xml:lang="en">Article 49(2) serves as a regulatory provision within the context of AI governance, specifically concerning the transparency and oversight obligations of AI system providers. This article encompasses three distinct but related requirements aimed at ensuring proper documentation and database registration for various AI systems.

First, Article 49(2) clarifies the registration obligations for providers of AI systems that, despite being listed in Annex III, have been assessed and deemed not to be h</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX__LIST_OF_CRIMINAL_OFFENCES_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX (LIST OF CRIMINAL OFFENCES)</rdfs:label>
    <skos:definition xml:lang="en">The annex containing the list of 32 criminal offences derived from Council Framework Decision 2002/584/JHA for which real-time remote biometric identification may be considered.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MinimalRisk">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">MinimalRisk</rdfs:label>
    <skos:definition xml:lang="en">Risk level with no mandatory obligations under the Act</skos:definition>
    <euai:articleReference>Recital 46</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PRIVATE_ENTITY_PROVIDING_PUBLIC_SERVICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PRIVATE ENTITY PROVIDING PUBLIC SERVICES</rdfs:label>
    <skos:definition xml:lang="en">Private organisations delivering services of public interest (e.g., education, healthcare, social services) that are treated as deployers of high-risk AI systems under Recital 96</skos:definition>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNUAL_NOTIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ANNUAL NOTIFICATION</rdfs:label>
    <skos:definition xml:lang="en">The duty of the European Data Protection Supervisor to provide an annual report to the Commission regarding administrative fines imposed and any initiated litigation or judicial proceedings.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TAX_AND_CUSTOMS_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">TAX AND CUSTOMS AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">Authorities carrying out administrative tasks whose AI tools for administrative proceedings are generally excluded from law enforcement high-risk classification.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_VIII">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX VIII</rdfs:label>
    <skos:definition xml:lang="en">Annex VIII serves as a critical regulatory component within the framework governing artificial intelligence, specifically outlining the mandatory information requirements for the registration of high-risk AI systems in the EU database. This annex ensures compliance and transparency by detailing the specific data that must be submitted under Article 49 of the relevant regulations. Furthermore, Annex VIII is structured into specific sections—designated as sections A, B, and C—which comprehensively</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DATABASE_FOR_HIGH_RISK_AI_SYSTEMS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFICATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NOTIFICATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The **NOTIFICATION OBLIGATION** encompasses a variety of reporting requirements mandated across different stakeholders involved in the regulatory frameworks for AI and legislative processes, ensuring transparency, safety, and oversight. These obligations apply differently depending on the role of the entity involved:

For the European Commission, a specific notification duty exists regarding delegated acts. Upon the adoption of any delegated act, the Commission is required to notify both the Eur</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_52"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_74_8_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 74(8)</rdfs:label>
    <skos:definition xml:lang="en">Article specifying the market surveillance authorities designated to access technical documentation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUPERVISORY_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">SUPERVISORY AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">Authorities competent for the supervision of law enforcement and judicial authorities; they assess whether international cooperation frameworks include adequate safeguards for fundamental rights.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PUBLIC_AUTHORITIES_OF_A_THIRD_COUNTRY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNATIONAL_ORGANISATIONS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MITIGATION_OF_SIGNIFICANT_RISKS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">MITIGATION OF SIGNIFICANT RISKS</rdfs:label>
    <skos:definition xml:lang="en">Duty of providers in sandboxes to act expeditiously and in good faith to mitigate risks to safety, health, and fundamental rights</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUBLIC_ENTITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PUBLIC ENTITY</rdfs:label>
    <skos:definition xml:lang="en">A body governed by public law that deploys high-risk AI systems and must perform fundamental rights impact assessments per Recital 96</skos:definition>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PENALTIES FOR GENERAL NON-COMPLIANCE</rdfs:label>
    <skos:definition xml:lang="en">Administrative fines for non-compliance with provisions other than Article 5 (e.g., obligations of providers, importers, distributors, notified bodies). Amount: up to EUR 15,000,000 or 3% of total worldwide annual turnover, whichever is higher</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_99"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERNAL_MARKET">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INTERNAL MARKET</rdfs:label>
    <skos:definition xml:lang="en">The economic area within the EU that the Regulation aims to improve and harmonize by preventing fragmentation and ensuring free movement of AI-based goods and services</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVIDER_CLASSIFICATION_RULE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">PROVIDER CLASSIFICATION RULE</rdfs:label>
    <skos:definition xml:lang="en">Rule stating that distributors, importers, or deployers become providers if they put their name on a system, make substantial modifications, or change the intended purpose of an AI system to become high-risk.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMOTION_RECOGNITION_AI_SYSTEM">
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_EMOTION_RECOGNITION_AI"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#WORKPLACE_CATEGORY"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EDUCATION_CATEGORY"/>
    <rdfs:label xml:lang="en">EMOTION RECOGNITION AI SYSTEM</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CIVIL_AVIATION_SECURITY_REGULATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CIVIL AVIATION SECURITY REGULATION</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EC) No 300/2008 establishes the common rules for civil aviation security, serving as the primary legal framework governing security protocols within the civil aviation sector. This regulation is designed to standardize and enhance security measures across the field of civil aviation, ensuring consistent safety standards for the protection of passengers, crew, and airport infrastructure.

Beyond its foundational role in aviation safety, Regulation (EC) No 300/2008 is also recognized f</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFIDENTIALITY_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CONFIDENTIALITY OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">**CONFIDENTIALITY OBLIGATION**

The Confidentiality Obligation serves as a critical regulatory requirement mandated for national competent authorities, notified bodies, and experts. This obligation dictates that all parties involved in the execution of their professional tasks must maintain strict confidentiality regarding the information and data obtained during their work.

This duty is primarily anchored to the standards set forth in Article 78, which governs the handling and protection of se</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_78"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_MITIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RISK MITIGATION</rdfs:label>
    <skos:definition xml:lang="en">**RISK MITIGATION** refers to the essential and mandatory protocols established to address significant risks identified throughout the development and testing phases of an AI system. These measures are not optional; they are critical safeguards designed to ensure the safety and reliability of the technology. The process emphasizes a strict adherence to these requirements: if the identified significant risks cannot be adequately addressed or mitigated, the development process must be suspended im</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RIGHT_TO_AN_EXPLANATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">RIGHT TO AN EXPLANATION</rdfs:label>
    <skos:definition xml:lang="en">The **Right to an Explanation** is a crucial protection afforded to individuals interacting with artificial intelligence systems. It establishes a clear obligation for the deployer—the entity utilizing the technology—to proactively inform natural persons of their specific entitlement to receive an explanation regarding decisions rendered by high-risk AI systems. 

Under this framework, affected individuals have the right to obtain a clear, meaningful, and understandable explanation when a decisi</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1240">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2018/1240</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2018/1240 is the legislative act and legal instrument that formally established the European Travel Information and Authorisation System (ETIAS).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_31">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 31</rdfs:label>
    <skos:definition xml:lang="en">**RECITAL 31** serves as a critical regulatory provision that addresses the significant risks associated with the use of artificial intelligence (AI) systems for the social scoring of natural persons. It specifically outlines the prohibition of such practices, establishing that AI systems designed or deployed to evaluate or classify individuals based on their social behavior or personal characteristics—often resulting in detrimental or unfavorable treatment—are deemed unacceptable. By providing </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AUTHORISATION_FOR_POST_REMOTE_BIOMETRIC_IDENTIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">AUTHORISATION FOR POST-REMOTE BIOMETRIC IDENTIFICATION</rdfs:label>
    <skos:definition xml:lang="en">Deployers must request ex-ante authorisation (or no later than 48 hours) from a judicial or administrative authority for the use of post-remote biometric identification systems, except in specific cases of initial identification.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_TO_HEALTH__SAFETY_OR_FUNDAMENTAL_RIGHTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">RISK TO HEALTH, SAFETY OR FUNDAMENTAL RIGHTS</rdfs:label>
    <skos:definition xml:lang="en">A threshold that triggers specific safeguard procedures for enforcement against AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REQUIREMENTS_OF_CHAPTER_III_SECTION_2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">REQUIREMENTS OF CHAPTER III SECTION 2</rdfs:label>
    <skos:definition xml:lang="en">A set of requirements from the EU AI Act (Regulation 2024/1689) which must be taken into account when specific EU acts (directives/regulations) are adopted or implemented regarding AI safety components</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INSTRUCTIONS_OF_USE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INSTRUCTIONS OF USE</rdfs:label>
    <skos:definition xml:lang="en">**INSTRUCTIONS OF USE** constitute essential documentation provided by the system provider for high-risk AI systems. These instructions are mandatory for ensuring the safe and compliant operation of the AI system by the deployer.

Under Article 15(3), a critical component of these instructions involves the transparent declaration of the system's accuracy levels and the relevant accuracy metrics used to measure them. Furthermore, as outlined in Recital 91, the deployer is obligated to adhere to t</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_INSTITUTION__BODY__OFFICE_OR_AGENCY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">UNION INSTITUTION, BODY, OFFICE OR AGENCY</rdfs:label>
    <skos:definition xml:lang="en">A Union institution, body, office, or agency refers to the organizational entities within the European Union that are subject to regulatory oversight regarding their use of artificial intelligence. These entities are accountable under specific regulations concerning non-compliance with established AI practices and obligations and may be subject to administrative fines should they fail to meet these standards.

Within this regulatory framework, such Union institutions, bodies, offices, and agenci</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_LAW_ENFORCEMENT_VICTIM_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TECHNICAL DOCUMENTATION ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">A conformity assessment procedure involving a notified body as described in Annex VII</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2024_1358">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2024/1358</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2024/1358 is a legislative act that serves as the legal instrument establishing the Eurodac system. This regulation is specifically designed to facilitate the comparison of biometric data as part of the European Union’s broader framework for managing asylum and migration.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING_PLAN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">POST-MARKET MONITORING PLAN</rdfs:label>
    <skos:definition xml:lang="en">The Post-Market Monitoring Plan is a critical component of the technical documentation, specifically outlined in Annex IV, which serves as the foundational framework for an AI system’s post-market monitoring system. As mandated by Article 72 and Article 72(3) of the relevant regulations, this plan is designed to continuously evaluate the performance of an AI system once it has been placed on the market. By establishing this systematic approach, the Post-Market Monitoring Plan ensures ongoing ove</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_72"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_74">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 74</rdfs:label>
    <skos:definition xml:lang="en">Article governing market surveillance and control of AI systems in the Union market</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESIDUAL_RISK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">RESIDUAL RISK</rdfs:label>
    <skos:definition xml:lang="en">The level of risk remaining after risk management measures have been applied, which must be judged to be acceptable under Article 9(5)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EssentialServicesAI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#HighRiskAISystem"/>
    <rdfs:label xml:lang="en">EssentialServicesAI</rdfs:label>
    <skos:definition xml:lang="en">AI for access to essential private and public services</skos:definition>
    <euai:articleReference>Annex III, 5</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFICATION_OF_NATIONAL_RULES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NOTIFICATION OF NATIONAL RULES</rdfs:label>
    <skos:definition xml:lang="en">Regarding the "NOTIFICATION OF NATIONAL RULES," Member States are required to notify the European Commission of any national regulations they adopt concerning the authorization and use of biometric identification systems. This mandate specifically pertains to remote biometric identification systems. Such notifications must be submitted to the Commission no later than 30 days following the formal adoption of these rules.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_LABOUR_LAW">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">NATIONAL LABOUR LAW</rdfs:label>
    <skos:definition xml:lang="en">National legal provisions concerning employment and working conditions that remain unaffected by the Regulation when pursuing legitimate public interest objectives other than those pursued by the AI Act</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESOURCE_PROVISION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">RESOURCE PROVISION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Member States must ensure national competent authorities have adequate technical, financial, and human resources.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">LAW ENFORCEMENT AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems used for prevention, detection, investigation, and prosecution of criminal offences, excluding specific administrative tasks in tax/customs/financial intelligence units.</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_PROCEEDING_EXCLUSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#SECURE_NON_PUBLIC_REGISTRATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#USER_FRIENDLY_EU_DATABASE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">USER-FRIENDLY EU DATABASE</rdfs:label>
    <skos:definition xml:lang="en">The EU database must be publicly accessible, free of charge, easy to navigate, understandable, machine-readable, and feature search functionalities</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SAFETY_COMPONENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">SAFETY COMPONENTS</rdfs:label>
    <skos:definition xml:lang="en">AI systems used as safety components, subject to specific requirements in Chapter III, Section 2, when referenced in other regulations like 167/2013 or 168/2013</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_III__SECTION_2"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_167_2013"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_168_2013"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE_2014_90_EU"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EC__NO_300_2008"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_39_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(39)</rdfs:label>
    <skos:definition xml:lang="en">Definition of emotion recognition system</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_26_5_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 26(5)</rdfs:label>
    <skos:definition xml:lang="en">Legal reference concerning monitoring the operation of specific high-risk AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERNAL_GOVERNANCE_AND_RISK_MANAGEMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INTERNAL GOVERNANCE AND RISK MANAGEMENT</rdfs:label>
    <skos:definition xml:lang="en">Rules applicable to financial institutions which the AI Act seeks to integrate with to ensure coherence</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXTENSION_OF_TESTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EXTENSION OF TESTING</rdfs:label>
    <skos:definition xml:lang="en">The ability to extend testing by six months, subject to prior notification to the market surveillance authority</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_16">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 16</rdfs:label>
    <skos:definition xml:lang="en">Article 16 serves as the section of the regulation that defines and specifies the obligations of providers of high-risk AI systems. It outlines the fundamental duties, general requirements, and specific responsibilities that these providers must adhere to in the context of high-risk AI system deployment.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#POST_MARKETING_MONITORING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">POST-MARKETING MONITORING</rdfs:label>
    <skos:definition xml:lang="en">A procedural obligation for providers to track the performance and risks of AI systems after they are placed on the market</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_43">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 43</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 43**

Article 43 within the AI Act serves as a foundational provision defining the specific conformity assessment procedures required for high-risk AI systems. As a critical regulatory component, it establishes the frameworks that both manufacturers and notified bodies must adhere to ensure compliance.

Specifically, Article 43 outlines the necessary conformity assessment procedures applicable to different categories of high-risk AI systems. This includes detailing the procedural requi</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_IN_CHAPTER_III_SECTION_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#IMPLEMENTING_ACTS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ENHANCED_HUMAN_OVERSIGHT_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ENHANCED HUMAN OVERSIGHT REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">The specific duty for certain biometric systems to require verification by at least two natural persons before any action or decision is taken by the deployer.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NARROW_PROCEDURAL_TASK_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">NARROW PROCEDURAL TASK EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">A condition where an AI system performs a narrow procedural task (e.g., transforming unstructured data, classifying documents), resulting in limited risks and potential exclusion from high-risk classification</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#MATERIAL_INFLUENCE_CRITERION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INVESTIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">INVESTIGATION</rdfs:label>
    <skos:definition xml:lang="en">The process by which the AI Office enforces compliance, involving requests for documentation, evaluations, and measures against non-compliant providers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK_ASSESSMENT_CRITERIA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SYSTEMIC RISK ASSESSMENT CRITERIA</rdfs:label>
    <skos:definition xml:lang="en">Factors used to designate a GPAI model as having systemic risk, including training data quality, user base size, autonomy, scalability, and modalities.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MONITORING_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">MONITORING OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The monitoring obligation for deployers of high-risk AI systems requires consistent oversight of the system's operation. This oversight must be conducted in accordance with the provided instructions for use. Specifically, for deployers operating within the financial sector, this obligation is satisfied through compliance with existing governance arrangements established under Union financial services law.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_79_1_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FATIGUE_DETECTION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">FATIGUE DETECTION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">An AI system used for detecting physical states like fatigue in professional contexts (e.g., pilots or drivers), excluded from the scope of emotion recognition systems per Recital 18.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PERFORMANCE_CHARACTERISTICS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PERFORMANCE CHARACTERISTICS</rdfs:label>
    <skos:definition xml:lang="en">Mandatory information regarding the AI system's intended purpose, accuracy, robustness, cybersecurity, and limitations that must be included in the instructions for use per Article 13(3)(b)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GUIDANCE_ON_REPORTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">GUIDANCE ON REPORTING</rdfs:label>
    <skos:definition xml:lang="en">Technical/organizational guidance developed by the Commission to facilitate compliance with reporting obligations, to be issued by 2 August 2025.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LimitedRisk">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">LimitedRisk</rdfs:label>
    <skos:definition xml:lang="en">Risk level triggering transparency obligations only</skos:definition>
    <euai:articleReference>Article 50</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DECLARATION_OF_INTERESTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DECLARATION OF INTERESTS</rdfs:label>
    <skos:definition xml:lang="en">A document each expert on the scientific panel must draw up, which shall be made publicly available</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CESSATION_OF_ACTIVITIES_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CESSATION OF ACTIVITIES OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">If a notified body ceases activities, it must inform the notifying authority and providers at least one year in advance for planned cessations</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUB_THRESHOLD_GPAI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">SUB-THRESHOLD GPAI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">An AI system based on a general-purpose AI model that does not carry systemic risk (Recital 66)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMOTION_RECOGNITION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EMOTION RECOGNITION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">An Emotion Recognition System is defined as an AI system specifically designed to identify or infer the emotions or intentions of natural persons by analyzing their biometric data. As specified in Article 3(39) and Recital 18 of the relevant regulatory framework, these systems operate by interpreting biometric inputs to discern a subject's internal states.

The scope of an Emotion Recognition System excludes technologies used solely for detecting physical states, such as fatigue or pain, unless </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_TIME_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_EXCEPTION"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_PHYSICAL_STATE_DETECTION"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_MERE_EXPRESSION_DETECTION"/>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AISYSTEM"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_39_"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#INFORMATION_OBLIGATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESTRICTED_ACCESS_SPACE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RESTRICTED ACCESS SPACE</rdfs:label>
    <skos:definition xml:lang="en">Spaces explicitly excluded from the definition of "publicly accessible space" per Recital 19, such as prisons, border control, or private workplaces/offices intended only for specific employees.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PUBLICLY_ACCESSIBLE_SPACE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2023_988">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2023/988</rdfs:label>
    <skos:definition xml:lang="en">REGULATION (EU) 2023/988 serves as a pivotal piece of legislation focused on general product safety. It functions as a critical safety net, specifically designed to address AI systems that do not fall under the "high-risk" classification outlined in the AI Act.

Furthermore, this Regulation interacts significantly with the broader market surveillance frameworks established by the AI Act, as noted in Recital 53. By bridging these regulatory gaps, REGULATION (EU) 2023/988 ensures that products—inc</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2019_1937"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DISTRIBUTOR_OBLIGATION__VERIFICATION_AND_CORRECTIVE_ACTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DISTRIBUTOR OBLIGATION: VERIFICATION AND CORRECTIVE ACTION</rdfs:label>
    <skos:definition xml:lang="en">Before making a system available, distributor must verify CE marking, EU declaration of conformity, instructions, and provider/importer compliance. Must take corrective action or withdraw/recall non-conforming systems</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_47"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_16"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_23_3_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SECTION_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_ANCILLARY_JUDICIAL_TASKS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION FOR ANCILLARY JUDICIAL TASKS</rdfs:label>
    <skos:definition xml:lang="en">Classification rule where AI systems for purely administrative tasks (e.g., anonymisation, document processing) that do not affect the administration of justice are not high-risk (Recital 61).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_49">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 49</rdfs:label>
    <skos:definition xml:lang="en">Article 49 serves as a key regulatory provision concerning the administrative management of artificial intelligence technologies within the European Union. Specifically, it establishes and outlines the registration obligations for high-risk AI systems. This article functions as the primary legal mandate governing the mandatory registration of these systems in the centralized EU database, thereby defining the specific requirements that must be met to ensure compliance and transparency for high-ri</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_91">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 91</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 91** acts as the governing provision regarding the authority of the Commission to request documentation and information from providers of general-purpose AI (GPAI) models. This article establishes the legal framework that empowers the Commission to obtain necessary materials from these providers. Furthermore, it explicitly links compliance with these requests to regulatory accountability, as failure to provide the requested documents or information may result in the imposition of fines</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SCIENTIFIC_COMMUNITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">SCIENTIFIC COMMUNITY</rdfs:label>
    <skos:definition xml:lang="en">External experts engaged by the AI Office to provide input on thresholds and benchmarks for systemic risk assessment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2014_31_EU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2014/31/EU</rdfs:label>
    <skos:definition xml:lang="en">Directive 2014/31/EU refers to the Non-automatic Weighing Instruments Directive. This European Union regulation is designed to govern the market availability and harmonization of laws across member states regarding non-automatic weighing instruments. By establishing uniform standards, the directive ensures that these instruments meet consistent requirements before being placed on the market.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_42_1__AND__2_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 42(1) AND (2)</rdfs:label>
    <skos:definition xml:lang="en">Specific clauses within Regulation (EU) 2018/1725 regarding consultation requirements</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_PROTECTION_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">DATA PROTECTION AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">National public authorities that supervise the application of Union law protecting fundamental rights, whose independence is preserved by this Regulation.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2024_1689"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_VERIFICATION_AI">
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRICS"/>
    <rdfs:label xml:lang="en">BIOMETRIC VERIFICATION AI</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINANCIAL_SERVICES_FRAUD_DETECTION_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">FINANCIAL SERVICES FRAUD DETECTION EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">Condition under which fraud detection AI systems are not classified as high-risk under this Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_95">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 95</rdfs:label>
    <skos:definition xml:lang="en">Recital addressing the use of post-remote biometric identification systems and associated safeguards</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_66_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(66)</rdfs:label>
    <skos:definition xml:lang="en">Reference defining general-purpose AI models, which form the basis for systemic risk assessment and other obligations.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CAPITAL_REQUIREMENT_CALCULATION_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">CAPITAL REQUIREMENT CALCULATION AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems used for prudential purposes to calculate credit institutions’ and insurance undertakings’ capital requirements</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CAPITAL_REQUIREMENT_CALCULATION_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REAL-WORLD TESTING OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Duty for providers to comply with specific conditions (e.g., registration, plan submission, EU establishment) when conducting real-world testing of high-risk AI systems. Includes time limits (6 months, extendable by 6 months) and specific registration requirements per Annex IX</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_71_4_"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_49_4_"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_49_5_"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ETHICAL_REVIEW"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#VULNERABLE_GROUPS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMOTION_INFERENCE_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EMOTION INFERENCE EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">The prohibition on emotion inference systems in workplace/education does not apply where the system is intended for medical or safety reasons.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ACCESS_TO_SOURCE_CODE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ACCESS TO SOURCE CODE</rdfs:label>
    <skos:definition xml:lang="en">Specific access right granted to market surveillance authorities under strict conditions: necessity for conformity assessment and exhaustion of other testing methods</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EDUCATION_ACCESS_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EDUCATION ACCESS AI</rdfs:label>
    <skos:definition xml:lang="en">AI system used to determine access or admission to educational or vocational training institutions.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EDUCATION_AND_VOCATIONAL_TRAINING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INCLUSIVE_AND_DIVERSE_DESIGN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INCLUSIVE AND DIVERSE DESIGN</rdfs:label>
    <skos:definition xml:lang="en">**INCLUSIVE AND DIVERSE DESIGN** encompasses a multifaceted approach to development practices that prioritizes accessibility and equity throughout the lifecycle of a project or system. This framework operates through both mandatory and voluntary guidelines aimed at fostering environments that are both representative and accessible to all users.

At its core, INCLUSIVE AND DIVERSE DESIGN is defined by a specific mandate within codes of conduct—referenced under Article 95(2)(d)—which requires the </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_CONDUCT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#cooperatesWith">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">cooperatesWith</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_33">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 33</rdfs:label>
    <skos:definition xml:lang="en">Article 33 establishes key regulatory obligations and operational requirements for notified bodies. Specifically, paragraphs 1, 3, and 4 of Article 33 outline the mandatory responsibilities that notified bodies must uphold in the performance of their duties. Furthermore, the article governs the framework under which these notified bodies may utilize subsidiaries and engage in subcontracting arrangements, ensuring that such practices remain within compliance guidelines. Together, these provisions</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFICATION_OF_AUTHORISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NOTIFICATION OF AUTHORISATION</rdfs:label>
    <skos:definition xml:lang="en">The duty of the market surveillance authority to inform the Commission and Member States of any issued authorization for the exceptional use of high-risk AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2017_745">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2017/745</rdfs:label>
    <skos:definition xml:lang="en">**REGULATION (EU) 2017/745**, also known as the Medical Device Regulation (MDR), serves as the primary piece of Union legislation governing medical devices. This regulation establishes a comprehensive framework for the safety and performance requirements of such devices within the European Union.

Crucially, **REGULATION (EU) 2017/745** functions as a key component of Union harmonisation legislation. It contains specific provisions that are designed to prevail over general modifications introduc</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER_CLASSIFICATION_RULE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVIDER_OF_INTERMEDIARY_SERVICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PROVIDER OF INTERMEDIARY SERVICES</rdfs:label>
    <skos:definition xml:lang="en">The term "provider of intermediary services" refers to market actors that operate under the framework established by Regulation (EU) 2022/2065 (the Digital Services Act). These entities are defined by the specific service roles outlined in that regulation and often incorporate AI systems or models into their platforms and operational workflows.

Within the regulatory landscape of the EU, these providers are not treated in isolation. As referenced in Recital 118 of the AI Act, providers of interm</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_FRAMEWORK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_VI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER VI</rdfs:label>
    <skos:definition xml:lang="en">Refers to the specific chapter in Regulation (EU) 2019/1020 regarding market surveillance procedures that applies mutatis mutandis</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#THIRD_PARTY_CONFORMITY_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">THIRD-PARTY CONFORMITY ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">A requirement for products or AI systems acting as safety components under Annex I to undergo assessment by a third party prior to market placement</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_I"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_4_3__OF_DIRECTIVE__EU__2019_790">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 4(3) OF DIRECTIVE (EU) 2019/790</rdfs:label>
    <skos:definition xml:lang="en">Article 4(3) of Directive (EU) 2019/790 serves as a critical legal provision concerning copyright protection, specifically addressing the reservation of rights by rightsholders. Under this article, service providers are required to adhere to specific rules regarding the use of protected content, particularly within the context of training artificial intelligence models or data mining.

The provision establishes a clear mechanism through which rightsholders can opt out of or restrict the use of t</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPETENT_MARKET_SURVEILLANCE_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">COMPETENT MARKET SURVEILLANCE AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">Specific authority to whom real-world testing plans must be submitted</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REPORTING OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The Reporting Obligations outlined within the regulatory framework impose significant transparency and accountability duties on Member States, providers, market surveillance authorities, and the European Commission. These obligations ensure rigorous oversight and compliance throughout the implementation of the regulations.

Regarding resource management, Member States are required to report to the European Commission on the status and adequacy of their national competent authorities' resources b</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SERIOUS_INCIDENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_49__C_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPETITION_AUTHORITIES"/>
    <euai:hasDeadline rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_49__B_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PRIOR_AUTHORISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PRIOR AUTHORISATION</rdfs:label>
    <skos:definition xml:lang="en">**PRIOR AUTHORISATION**

Prior authorisation is a mandatory legal requirement for law enforcement agencies seeking to deploy real-time remote biometric identification systems. Under this framework, authorities must obtain express, specific, and binding approval from a judicial or independent administrative body before such systems can be utilized.

This process ensures oversight and accountability in the application of biometric technologies. However, the framework includes specific provisions f</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADEQUATE_SAFEGUARDS_FOR_FUNDAMENTAL_RIGHTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ADEQUATE SAFEGUARDS FOR FUNDAMENTAL RIGHTS</rdfs:label>
    <skos:definition xml:lang="en">The requirement for third countries and international organisations to protect fundamental rights and freedoms of individuals to qualify for the exclusion from the Regulation's scope.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNATIONAL_COOPERATION_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROCEDURAL_REQUIREMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROCEDURAL REQUIREMENTS</rdfs:label>
    <skos:definition xml:lang="en">Mandatory compliance for migration AI systems with Regulation (EC) No 810/2009 and Directive 2013/32/EU.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXEMPTION_FROM_POST_MARKET_MONITORING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXEMPTION FROM POST-MARKET MONITORING</rdfs:label>
    <skos:definition xml:lang="en">An exemption applied to post-market monitoring activities, stating that monitoring should not cover sensitive operational data of deployers that are law enforcement authorities.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LIST_OF_GENERAL_PURPOSE_AI_MODELS_WITH_SYSTEMIC_RISK">
    <rdfs:label xml:lang="en">LIST OF GENERAL PURPOSE AI MODELS WITH SYSTEMIC RISK</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COUNCIL_DIRECTIVE_85_374_EEC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">COUNCIL DIRECTIVE 85/374/EEC</rdfs:label>
    <skos:definition xml:lang="en">**COUNCIL DIRECTIVE 85/374/EEC** serves as a foundational piece of legislation concerning liability for defective products. It establishes a comprehensive civil liability framework that provides individuals with rights to compensation for damages caused by such products. In the modern context, this directive is increasingly significant as it applies to damages potentially caused by AI systems, ensuring that there is an established legal structure to address accountability and consumer protection</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_52_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(52)</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 3(52)** serves as the authoritative definition and legal reference for the term "profiling." Within the context of the relevant regulatory framework, this provision formally establishes what constitutes profiling, ensuring a standardized understanding for its application in legal and compliance matters. By defining this concept, ARTICLE 3(52) provides the necessary foundation for organizations and entities to identify and regulate activities that involve the automated processing of per</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPLAINANT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">COMPLAINANT</rdfs:label>
    <skos:definition xml:lang="en">A person or entity that lodges a complaint and is associated with proceedings conducted by the European Data Protection Supervisor.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_DATA_PROTECTION_SUPERVISOR"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DETECTION_OF_PATTERNS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">DETECTION OF PATTERNS</rdfs:label>
    <skos:definition xml:lang="en">Condition where an AI system detects decision-making patterns without replacing/influencing human assessment, potentially exempting it from high-risk classification</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_IDENTIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">BIOMETRIC IDENTIFICATION</rdfs:label>
    <skos:definition xml:lang="en">**BIOMETRIC IDENTIFICATION** is defined as the automated recognition of specific human physical, physiological, or behavioral features—such as facial characteristics, gait patterns, or heart rate—for the purpose of establishing an individual's identity. This process functions by comparing collected biometric data against a reference database. Crucially, BIOMETRIC IDENTIFICATION encompasses these recognition activities in all instances, regardless of whether the individual has provided consent, a</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_DATA"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_15"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REASSESSMENT_OF_SYSTEMIC_RISK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REASSESSMENT OF SYSTEMIC RISK</rdfs:label>
    <skos:definition xml:lang="en">Duty/right involving a process where providers can request a review of their systemic risk designation at least six months after a decision, per Article 53 preamble context.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_STANDARDISATION_ORGANISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">EUROPEAN STANDARDISATION ORGANISATION</rdfs:label>
    <skos:definition xml:lang="en">European Standardisation Organisations (ESOs) are recognized as the key bodies responsible for the development and drafting of harmonised standards. Their function is formally triggered upon receiving a specific request from the European Commission, a role that is crucial within the context of European standardisation procedures. Furthermore, these organisations may be actively involved within the broader AI ecosystem, where they play a significant part in supporting the effective implementation</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_24_OF_REGULATION__EU__NO_1025_2012"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_MIGRATION_DETECTION_AND_IDENTIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR MIGRATION DETECTION AND IDENTIFICATION</rdfs:label>
    <skos:definition xml:lang="en">System used in migration/border control for detecting, recognizing, or identifying natural persons, identified in Annex III(7)(d)</skos:definition>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_TRAVEL_DOCUMENT_VERIFICATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INDEPENDENT_EXPERTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">INDEPENDENT EXPERTS</rdfs:label>
    <skos:definition xml:lang="en">**INDEPENDENT EXPERTS** are specialized individuals appointed by the European Commission to perform critical functions regarding the governance and evaluation of artificial intelligence. These experts are tasked with carrying out formal evaluations of general-purpose AI models, adhering strictly to the criteria defined in Article 68(2) of the applicable regulations. This evaluation process is conducted by the experts on behalf of the Commission and includes members of the scientific panel, ensur</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EVALUATION_OF_GPAI_MODEL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_92_EVALUATIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_68_2_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINANCIAL_SUPERVISOR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">FINANCIAL SUPERVISOR</rdfs:label>
    <skos:definition xml:lang="en">National authority responsible for financial supervision of institutions; acts as the market surveillance authority for AI systems used in financial services</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPETENT_NATIONAL_COURT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">COMPETENT NATIONAL COURT</rdfs:label>
    <skos:definition xml:lang="en">A **COMPETENT NATIONAL COURT** refers to the judicial bodies within Member States that are officially authorized to impose administrative fines. The specific authority and jurisdiction of these courts are determined by the respective national legal systems of each Member State. As outlined in Article 99(9), these courts play a critical role in the enforcement of administrative penalties, ensuring that such actions are carried out in strict accordance with the laws of their governing jurisdiction</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_FINE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_10_OF_REGULATION__EU__NO_1025_2012">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 10 OF REGULATION (EU) NO 1025/2012</rdfs:label>
    <skos:definition xml:lang="en">Specific provision detailing the Commission's power to issue standardisation requests.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_PROTECTION_BY_DESIGN_AND_BY_DEFAULT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA PROTECTION BY DESIGN AND BY DEFAULT</rdfs:label>
    <skos:definition xml:lang="en">A foundational data protection principle requiring privacy-preserving measures in the design and operation of AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VERY_LARGE_ONLINE_PLATFORMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">VERY LARGE ONLINE PLATFORMS</rdfs:label>
    <skos:definition xml:lang="en">Providers of platforms that must identify and mitigate systemic risks arising from artificially generated content, as per Regulation (EU) 2022/2065</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2022_2065"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DEEP_FAKE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">DEEP FAKE</rdfs:label>
    <skos:definition xml:lang="en">AI-generated or manipulated content (image, audio, video) that falsely appears authentic, as defined in Article 3(60)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DOCUMENTATION">
    <rdfs:label xml:lang="en">DOCUMENTATION</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label xml:lang="en">EU AI Act Ontology</rdfs:label>
    <dcterms:description xml:lang="en">An OWL ontology capturing the key concepts, actors, and obligations of Regulation (EU) 2024/1689 (EU Artificial Intelligence Act)</dcterms:description>
    <dcterms:source rdf:resource="https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=OJ:L_202401689"/>
    <owl:versionInfo>0.1.0</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_13_3_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 13(3)</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 13(3)** is a provision focused on the principles of transparency, specifically regarding the obligations to provide information to deployers. Within this article, point (d) plays a crucial role in ensuring that deployers are adequately equipped to understand and utilize the AI system effectively. Specifically, this provision mandates that deployers must be facilitated in the interpretation of the AI system's outputs, ensuring that the information provided is sufficient to enable a clea</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LEARNING_AFTER_DEPLOYMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">LEARNING AFTER DEPLOYMENT</rdfs:label>
    <skos:definition xml:lang="en">Changes to algorithm and performance of AI systems that are pre-determined by the provider and assessed at the moment of conformity assessment; these do not constitute a substantial modification</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#SUBSTANTIAL_MODIFICATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TFEU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">TFEU</rdfs:label>
    <skos:definition xml:lang="en">The Treaty on the Functioning of the European Union (TFEU) serves as a primary pillar of the European Union’s legal architecture. As a foundational document, it establishes the legal framework governing various critical functions of the EU, including the judicial review of decisions made by the European Commission. Specifically, the TFEU empowers the Court of Justice of the European Union to oversee and adjudicate upon these Commission decisions, ensuring legal compliance and institutional accou</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FLOATING_POINT_OPERATIONS_THRESHOLD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">FLOATING POINT OPERATIONS THRESHOLD</rdfs:label>
    <skos:definition xml:lang="en">The "FLOATING POINT OPERATIONS THRESHOLD" serves as a technical metric defined by the cumulative compute utilized during the training phase of an artificial intelligence model. This metric is employed as an initial approximation to evaluate and presume whether a General Purpose AI (GPAI) model possesses systemic risks, as explicitly referenced in Recital 111 of the relevant regulatory framework. By quantifying the computational power invested in training, this threshold acts as a foundational be</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISKS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPACT_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">IMPACT ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">Duty for deployers of high-risk AI systems to assess risks, potentially involving stakeholders such as civil society and independent experts</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_46">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 46</rdfs:label>
    <skos:definition xml:lang="en">Recital outlining mandatory requirements for high-risk AI systems and the relationship with Union harmonisation legislation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_18">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 18</rdfs:label>
    <skos:definition xml:lang="en">ARTICLE 18 establishes the regulatory framework regarding the documentation obligations for providers of high-risk AI systems. Specifically, this article mandates that these providers must maintain comprehensive technical documentation, ensuring that all necessary records related to the development, function, and compliance of their high-risk AI systems are properly preserved and accessible.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EVALUATION_AND_REVIEW_REPORT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EVALUATION AND REVIEW REPORT</rdfs:label>
    <skos:definition xml:lang="en">Duty of the Commission to submit reports every four years (or by specific deadlines like 2 August 2028) regarding the regulation, the AI Office, and standardization deliverables</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_FINES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_STANDARDS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMON_SPECIFICATIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SME"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_104">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_168_2013"/>
    <rdfs:label xml:lang="en">ARTICLE 104</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_REGISTRATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NATIONAL REGISTRATION</rdfs:label>
    <skos:definition xml:lang="en">Requirement for high-risk AI systems referred to in point 2 of Annex III to be registered at the national level instead of the EU database</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EVALUATION_OF_AI_SYSTEM_CLASSIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EVALUATION OF AI SYSTEM CLASSIFICATION</rdfs:label>
    <skos:definition xml:lang="en">The process by which a market surveillance authority determines if an AI system classified as non-high-risk should be classified as high-risk, based on Article 6(3) and Commission guidelines</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_80"/>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_6_3_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CLOSED_DATA_SET">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CLOSED DATA SET</rdfs:label>
    <skos:definition xml:lang="en">Constraint requiring post-remote biometric identification to be based on legally acquired video footage rather than indiscriminate surveillance (Recital 95)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#Requirement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Technical Requirement</rdfs:label>
    <skos:definition xml:lang="en">A technical or organisational requirement for high-risk AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFYING_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">NOTIFYING AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">Authorities responsible for the assessment and notification of notified bodies, cooperating within the Board's standing sub-groups as per Article 65(6).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_44">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 44</rdfs:label>
    <skos:definition xml:lang="en">Recital discussing the risks of emotion recognition AI and the prohibition in workplace and education contexts</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#APPLICATION_DATE_2_AUGUST_2026">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">APPLICATION DATE 2 AUGUST 2026</rdfs:label>
    <skos:definition xml:lang="en">The general date of application for the Regulation, except where specific provisions apply earlier (Recital 179)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPLIANCE_WITH_THE_REGULATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">COMPLIANCE WITH THE REGULATION</rdfs:label>
    <skos:definition xml:lang="en">Duty imposed on providers to adhere to the Act, enforceable by penalties and fines tailored to factors such as nature, gravity, duration, and provider size</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LEARNING_OUTCOME_EVALUATION_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">LEARNING OUTCOME EVALUATION AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems used to evaluate learning outcomes or steer the learning process (Annex III 3(b))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EDUCATION_AND_VOCATIONAL_TRAINING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPLIANCE_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">COMPLIANCE OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">**COMPLIANCE OBLIGATION**

The Compliance Obligation for AI systems entails a multi-faceted duty imposed on providers to ensure their technologies adhere to the requirements set forth by the Regulation and relevant Union harmonisation legislation. This obligation is designed to maintain consistency across the regulatory landscape while simultaneously avoiding the imposition of unnecessary administrative burdens on developers and operators.

Central to this mandate is the requirement that provide</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TechnicalDocumentation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Technical Documentation</rdfs:label>
    <skos:definition xml:lang="en">Documentation providers must maintain before placing on the market. (Article 11, Annex IV)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_46_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(46)</rdfs:label>
    <skos:definition xml:lang="en">Definition of law enforcement</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MITIGATION_OF_FORESEEABLE_MISUSE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MITIGATION OF FORESEEABLE MISUSE</rdfs:label>
    <skos:definition xml:lang="en">The process of identifying and addressing risks stemming from reasonably foreseeable misuse, distinct from, but related to, standard risk management</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_13_OF_DIRECTIVE__EU__2016_680">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 13 OF DIRECTIVE (EU) 2016/680</rdfs:label>
    <skos:definition xml:lang="en">Article governing the implementation of information obligations for law enforcement use of AI systems (Recital 93)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_39_OF_REGULATION__EU__2018_1725">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 39 OF REGULATION (EU) 2018/1725</rdfs:label>
    <skos:definition xml:lang="en">Article regarding data protection impact assessments referred to in the context of identifying sandbox risks</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NEW_LEGISLATIVE_FRAMEWORK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">NEW LEGISLATIVE FRAMEWORK</rdfs:label>
    <skos:definition xml:lang="en">The "New Legislative Framework" is a comprehensive regulatory structure designed to oversee Union harmonisation legislation. It serves as the foundational legal architecture upon which existing conformity assessments for various products are conducted, ensuring consistent safety standards across the Union. 

This framework encompasses several key legislative instruments, specifically including Regulation (EC) No 765/2008, Decision No 768/2008/EC, and Regulation (EU) 2019/1020. By aligning its pr</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#OPERATOR_OBLIGATIONS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PRODUCT_MANUFACTURER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PRODUCT MANUFACTURER</rdfs:label>
    <skos:definition xml:lang="en">A Product Manufacturer is defined as any natural or legal person who either manufactures a product themselves or arranges for a product to be designed or manufactured, ultimately marketing that product under their own name or trademark. This definition extends to entities that place a product on the market or put it into service, including those incorporating AI systems.

Within the specific context of AI regulation, a Product Manufacturer holds significant responsibilities. When a manufacturer </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_HARMONISATION_LEGISLATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_STANDARDS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMON_SPECIFICATIONS"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#NEW_LEGISLATIVE_FRAMEWORK"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_16"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSPARENCY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TRANSPARENCY</rdfs:label>
    <skos:definition xml:lang="en">In the context of the AI Act, "Transparency" serves as a fundamental requirement for AI systems, designed to ensure that their operations, outputs, and underlying processes are both understandable and well-documented. This core obligation mandates that AI systems must be explainable and transparent, a necessity for upholding accountability and protecting fundamental rights. 

By demanding clarity and openness, Transparency functions as a critical mechanism that allows stakeholders to comprehend </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_83">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 83</rdfs:label>
    <skos:definition xml:lang="en">Article defining the procedure for handling formal non-compliance of high-risk AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VOLUNTARY_CODES_OF_CONDUCT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#CodeOfPractice"/>
    <rdfs:label xml:lang="en">VOLUNTARY CODES OF CONDUCT</rdfs:label>
    <skos:definition xml:lang="en">Voluntary compliance instruments designed to be effective, inclusive, and based on clear objectives and key performance indicators as mentioned in Recital 166</skos:definition>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#KEY_PERFORMANCE_INDICATORS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_67">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 67</rdfs:label>
    <skos:definition xml:lang="en">Article 67 serves as the foundational provision that establishes the Advisory Forum. This article outlines the formal framework for the Forum, explicitly detailing its membership structure, core duties, term of office, and the operational rules that govern its conduct. 

In addition to defining its organizational structure, Article 67 mandates the Advisory Forum’s role in specific regulatory processes, stipulating that the Forum must be consulted regarding the development or implementation of co</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMMITTEE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">COMMITTEE</rdfs:label>
    <skos:definition xml:lang="en">A Committee is an entity established under the framework of Article 98, operating within the meaning of Regulation (EU) No 182/2011. Its primary purpose is to assist the European Commission in the process of implementing acts.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_98"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INDEPENDENCE">
    <rdfs:label xml:lang="en">INDEPENDENCE</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#POLYGRAPHS_AND_SIMILAR_TOOLS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">POLYGRAPHS AND SIMILAR TOOLS</rdfs:label>
    <skos:definition xml:lang="en">Specific AI-enabled devices used in migration and border control for assessing risks posed by natural persons.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNUAL_REPORTING_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ANNUAL REPORTING OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Requirement for deployers to submit annual reports to market surveillance and data protection authorities on the use of post-remote biometric identification systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ASSISTIVE_FUNCTION_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">ASSISTIVE FUNCTION AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems performing primarily assistive functions for standard editing, which are exempt from the marking obligation to remain proportionate.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKING_AND_DETECTION_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPUTE_THRESHOLD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">COMPUTE THRESHOLD</rdfs:label>
    <skos:definition xml:lang="en">A technical criterion (10^25 FLOPs) used to identify general-purpose AI models that are presumed to have systemic risks.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_107">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 107</rdfs:label>
    <skos:definition xml:lang="en">Article amending Regulation (EU) 2018/858 regarding AI safety components</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_858"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ONLINE_CHATBOT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">ONLINE CHATBOT</rdfs:label>
    <skos:definition xml:lang="en">Example of an AI system that performs web searches and generates combined outputs, often acting as an intermediary service</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WORKER_RIGHTS_PROTECTION_CLAUSE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">WORKER RIGHTS PROTECTION CLAUSE</rdfs:label>
    <skos:definition xml:lang="en">Regulation does not preclude the Union or Member States from maintaining/introducing laws more favourable to workers or allowing collective agreements that are more favourable. Defined in Article 2(11).</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OBLIGATION_TO_TEST">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">OBLIGATION TO TEST</rdfs:label>
    <skos:definition xml:lang="en">Duty of the provider to test high-risk AI systems for compliance and appropriate risk management measures prior to market placement per Article 9(6)-(8)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_102">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EC__NO_300_2008"/>
    <rdfs:label xml:lang="en">ARTICLE 102</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SECTION_2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">SECTION 2</rdfs:label>
    <skos:definition xml:lang="en">Refers to the section of the AI Act containing requirements that high-risk AI systems must meet</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CORRECTIVE_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CORRECTIVE MEASURES</rdfs:label>
    <skos:definition xml:lang="en">Actions required by the notifying Member State (including suspension or withdrawal of notification) when a notified body fails to meet requirements, per Article 37(4)</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_37_4_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STUDENT_PROHIBITED_BEHAVIOUR_MONITORING_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">STUDENT PROHIBITED BEHAVIOUR MONITORING AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems monitoring and detecting prohibited student behaviour during tests (Annex III 3(d))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EDUCATION_AND_VOCATIONAL_TRAINING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PENALTIES_IMPLEMENTATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PENALTIES IMPLEMENTATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Duty for Member States to lay down rules on penalties and enforcement measures, ensuring they are effective, proportionate, and dissuasive, and to notify the Commission</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WHISTLEBLOWERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">WHISTLEBLOWERS</rdfs:label>
    <skos:definition xml:lang="en">Persons reporting infringements of the AI Act, who are protected under Directive (EU) 2019/1937</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLAINT"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROTECTION_OF_WHISTLEBLOWERS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_53_1__A_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 53(1)(A)</rdfs:label>
    <skos:definition xml:lang="en">Article 53(1)(a) is a provision within the EU AI Act that establishes a specific regulatory obligation for providers of general-purpose AI models. Under this article, these providers are mandated to create, draw up, and maintain comprehensive technical documentation concerning their models. This requirement ensures that there is a documented record of the model's development, capabilities, and underlying technical framework, which is essential for compliance and oversight within the scope of the</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TEMPLATE_QUESTIONNAIRE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TEMPLATE QUESTIONNAIRE</rdfs:label>
    <skos:definition xml:lang="en">A tool/template developed by the AI Office to help deployers comply with fundamental rights impact assessment obligations</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CROSS_BORDER_COOPERATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CROSS-BORDER COOPERATION</rdfs:label>
    <skos:definition xml:lang="en">The design and implementation of AI regulatory sandboxes must facilitate cross-border cooperation between national competent authorities.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SystemicRiskGPAI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">General-Purpose AI Model with Systemic Risk</rdfs:label>
    <skos:definition xml:lang="en">A GPAI model designated as posing systemic risk, typically above 10^25 FLOPs. (Article 51)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#GeneralPurposeAIModel"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_MODEL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI MODEL</rdfs:label>
    <skos:definition xml:lang="en">The level at which marking techniques can be implemented, including general-purpose AI models generating content.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_SOLUTIONS_FOR_MARKING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WORKERS__REPRESENTATIVES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">WORKERS' REPRESENTATIVES</rdfs:label>
    <skos:definition xml:lang="en">Entities representing workers who must be informed by employers before the deployment of a high-risk AI system in the workplace per Article 26/requirements.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIGITAL_EUROPE_PROGRAMME">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">DIGITAL EUROPE PROGRAMME</rdfs:label>
    <skos:definition xml:lang="en">The DIGITAL EUROPE PROGRAMME is a European Union funding and support initiative designed to advance digital transformation across the region. As a comprehensive funding program and project, it is structured to actively contribute to the overarching objectives of the relevant Regulation. Central to its mission is the establishment and management of specialized infrastructure, specifically AI testing and experimentation facilities, which foster innovation and the practical application of artificia</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLIANCE_WITH_THIS_REGULATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INFORMATION_AND_CONSULTATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">INFORMATION AND CONSULTATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Duty for employers to inform or consult workers' representatives under Directive 2002/14/EC regarding the deployment of AI systems (Recital 92)</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE_2002_14_EC"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EDUCATION_AND_VOCATIONAL_TRAINING_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EDUCATION AND VOCATIONAL TRAINING AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems used in education or vocational training for determining access, assignment to institutions, evaluating learning outcomes, assessing education levels, or monitoring prohibited student behaviour (Recital 56)</skos:definition>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EDUCATION_AND_VOCATIONAL_TRAINING"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_56"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPORTER_OBLIGATION__DOCUMENTATION_AND_RECORDS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">IMPORTER OBLIGATION: DOCUMENTATION AND RECORDS</rdfs:label>
    <skos:definition xml:lang="en">Importer must keep copies of certificates, instructions for use, and declaration of conformity for 10 years; provide documentation to competent authorities upon request</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_47"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DESIGN_CONTROL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DESIGN CONTROL</rdfs:label>
    <skos:definition xml:lang="en">Techniques and procedures for design, verification, and control of the high-risk AI system (Article 17(2)(b)).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ECRIS_TCN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">ECRIS-TCN</rdfs:label>
    <skos:definition xml:lang="en">ECRIS-TCN is a centralised system designed to facilitate the identification of Member States that possess conviction information regarding third-country nationals and stateless persons. Established under Regulation (EU) 2019/816, the system serves as an essential mechanism for improving judicial cooperation and information exchange across the European Union, ensuring that authorities can efficiently determine where records of previous criminal convictions for these specific groups are held.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_816"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_27">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 27</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 27** is a regulatory provision that mandates the completion of a fundamental rights impact assessment. This requirement specifically applies to the deployers of certain high-risk AI systems. As a key component of the regulatory framework, Article 27 functions to ensure that organizations or entities utilizing these high-risk technologies rigorously evaluate and address the potential implications their systems may have on fundamental rights. By requiring this assessment, the article est</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_HARMONISATION_LEGISLATION_PRODUCTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">UNION HARMONISATION LEGISLATION PRODUCTS</rdfs:label>
    <skos:definition xml:lang="en">Specific product categories listed in Recital 50, including machinery, toys, lifts, and medical devices, which may contain high-risk AI safety components</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUBLIC_PROCUREMENT_PROCEDURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PUBLIC PROCUREMENT PROCEDURES</rdfs:label>
    <skos:definition xml:lang="en">Public procurement procedures represent a critical area where the Commission is tasked with evaluating and promoting the convergence of best practices concerning the implementation and use of AI systems. Specifically, under Article 62(3)(d), the AI Office is mandated to carry out this evaluation and promotion, ensuring that consistent and high-quality standards are applied when integrating artificial intelligence within public sector procurement.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECRUITMENT_AND_SELECTION_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">RECRUITMENT AND SELECTION AI</rdfs:label>
    <skos:definition xml:lang="en">AI system used for targeted job advertisements, filtering applications, and evaluating candidates.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EMPLOYMENT__WORKERS__MANAGEMENT_AND_ACCESS_TO_SELF_EMPLOYMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WORKPLACE_CATEGORY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">WORKPLACE CATEGORY</rdfs:label>
    <skos:definition xml:lang="en">Use case domain involving the management and monitoring of employees (Recital 44)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AGREEMENT_ON_ROLES_AND_RESPONSIBILITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">AGREEMENT ON ROLES AND RESPONSIBILITIES</rdfs:label>
    <skos:definition xml:lang="en">Written agreement between the provider/prospective provider and the deployer/prospective deployer specifying their roles and responsibilities, per Article 60(h)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ACCOUNTABILITY_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ACCOUNTABILITY OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The duty of recipient national authorities and Union institutions, bodies, offices, and agencies to ensure the use of outputs complies with Union law.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_48_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(48)</rdfs:label>
    <skos:definition xml:lang="en">Definition of national competent authority</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERNAL_MARKET_IMPACT_CRITERION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INTERNAL MARKET IMPACT CRITERION</rdfs:label>
    <skos:definition xml:lang="en">A criterion used to determine a model's impact, specifically presumed high when the model is made available to at least 10,000 registered business users established in the Union.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION_2024_1689"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MODEL_CAPABILITY_EVALUATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MODEL CAPABILITY EVALUATION</rdfs:label>
    <skos:definition xml:lang="en">Assessments including benchmarks, task adaptability, autonomy levels, scalability, and access to tools used to evaluate a general-purpose AI model.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CONFORMITY ASSESSMENT PROCEDURES</rdfs:label>
    <skos:definition xml:lang="en">Procedures that the Commission may amend via delegated acts, as per Recital 173</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#annexReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">annex reference</rdfs:label>
    <skos:definition xml:lang="en">Reference to a relevant Annex of the EU AI Act.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPORTER_OBLIGATION__STORAGE_AND_TRANSPORT">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SECTION_2"/>
    <rdfs:label xml:lang="en">IMPORTER OBLIGATION  STORAGE AND TRANSPORT</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_19_OF_REGULATION__EU__2019_1020">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 19 OF REGULATION (EU) 2019/1020</rdfs:label>
    <skos:definition xml:lang="en">Specific article governing appropriate measures to be taken by market surveillance authorities within seven days of a serious incident notification.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_9_OF_REGULATION__EU__2016_679">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 9 OF REGULATION (EU) 2016/679</rdfs:label>
    <skos:definition xml:lang="en">Regulation referenced regarding the processing of biometric data for purposes other than law enforcement</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_5_PROHIBITIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 5 PROHIBITIONS</rdfs:label>
    <skos:definition xml:lang="en">The section of the AI Act outlining prohibited AI practices due to unacceptable risk</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#Distributor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Distributor</rdfs:label>
    <skos:definition xml:lang="en">A person in the supply chain other than provider/importer. (Article 3(7))</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HUMAN_REVIEW_OR_EDITORIAL_CONTROL_EXCEPTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">HUMAN REVIEW OR EDITORIAL CONTROL EXCEPTION</rdfs:label>
    <skos:definition xml:lang="en">Transparency obligations for AI-generated text published in the public interest do not apply if the content has undergone human review or editorial control and a natural or legal person holds editorial responsibility, per Article 50(4)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESERVATION_OF_RIGHTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">RESERVATION OF RIGHTS</rdfs:label>
    <skos:definition xml:lang="en">Right exercised by rightsholders to prevent text and data mining of their works, which providers must respect pursuant to Article 4(3) of Directive (EU) 2019/790</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SOLELY_AUTOMATED_INDIVIDUAL_DECISION_MAKING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SOLELY AUTOMATED INDIVIDUAL DECISION-MAKING</rdfs:label>
    <skos:definition xml:lang="en">Rights of data subjects regarding profiling and automated decision-making as guaranteed under Union law, which are facilitated by the harmonised rules of the AI Act</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_28">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 28</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 28** serves as the regulatory framework establishing the duties, operational requirements, and specific roles of Notifying Authorities. This article defines the fundamental responsibilities that these authorities must uphold to ensure compliance and proper functioning within their designated regulatory scope. It outlines not only the obligations required of these entities but also sets the operational standards they must meet to effectively fulfill their oversight and notification mand</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFICATION_PROCESS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NOTIFICATION PROCESS</rdfs:label>
    <skos:definition xml:lang="en">The procedure by which a notifying authority informs the Commission and Member States about a conformity assessment body, triggering a two-week or two-month objection period depending on documentation.</skos:definition>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#OBJECTION_PERIOD"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_ON_DEMAND_PLATFORM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">AI-ON-DEMAND PLATFORM</rdfs:label>
    <skos:definition xml:lang="en">A platform supported by the Commission and Member States to provide technical and scientific support to providers and notified bodies to facilitate compliance</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFIED_BODY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_VI_OF_REGULATION__EU__2019_1020">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER VI OF REGULATION (EU) 2019/1020</rdfs:label>
    <skos:definition xml:lang="en">Legal reference for mutual assistance procedures in cross-border cases involving high-risk AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STANDARDISATION_ORGANISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">STANDARDISATION ORGANISATION</rdfs:label>
    <skos:definition xml:lang="en">Standardisation organisations comprise national or European-level bodies tasked with the development of technical standards. Within the framework of the AI regulatory sandbox, as outlined in Article 58(2)(f), these organisations play a crucial role by cooperating with sandbox participants. Their primary function in this context is to provide expert assistance, helping entities navigate compliance requirements and effectively integrate relevant standards into their development processes.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_CONTROLLER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">DATA CONTROLLER</rdfs:label>
    <skos:definition xml:lang="en">A Data Controller is a specific role defined under the General Data Protection Regulation (GDPR) (Regulation (EU) 2016/679), as well as the Law Enforcement Directive (LED). An entity assumes the status of a Data Controller when it determines the purposes and means of the processing of personal data. 

This role carries significant legal responsibilities and obligations regarding how data is handled, stored, and protected. Furthermore, the concept of a Data Controller is applicable to both provid</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AFFECTED_PERSON">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">AFFECTED PERSON</rdfs:label>
    <skos:definition xml:lang="en">An "Affected Person" is defined as any natural person whose rights, health, or safety may be impacted by the output or operation of an AI system. This designation encompasses individuals located within the Union who are subject to or influenced by these technologies.

Within the regulatory framework, an Affected Person is recognized as a subject of decisions made by a deployer based on the outputs generated by a high-risk AI system. In such instances, this individual possesses the specific right</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_LITERACY"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_ANALYTICS_AI_SYSTEMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">RISK ANALYTICS AI SYSTEMS</rdfs:label>
    <skos:definition xml:lang="en">Systems using risk analytics not based on individual profiling (e.g., financial fraud detection or narcotics trafficking prediction), which are permitted under Recital 42.</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_RISK_ANALYTICS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INITIAL_CONFORMITY_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">INITIAL CONFORMITY ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">The assessment process where the provider pre-determines changes to the AI system and its performance, referenced in Article 13(3)(c)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INSTRUCTIONS_FOR_USE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HEALTH_AND_LIFE_INSURANCE_RISK_ASSESSMENT_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">HEALTH AND LIFE INSURANCE RISK ASSESSMENT AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems used for risk assessment and pricing for natural persons regarding health and life insurance</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MICRO__SMALL_AND_MEDIUM_SIZED_ENTERPRISES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">MICRO, SMALL AND MEDIUM-SIZED ENTERPRISES</rdfs:label>
    <skos:definition xml:lang="en">Categories of enterprises defined by Commission Recommendation 2003/361/EC (Recital 44), which may have reduced obligations or support measures under the AI Act</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFIDENTIAL_INFORMATION_EXCHANGE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CONFIDENTIAL INFORMATION EXCHANGE</rdfs:label>
    <skos:definition xml:lang="en">Duty to protect confidential information, with specific disclosure prohibitions for information exchanged between competent authorities</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#grants">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">grants</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STAKEHOLDER_AND_CIVIL_SOCIETY_ORGANISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">STAKEHOLDER AND CIVIL SOCIETY ORGANISATION</rdfs:label>
    <skos:definition xml:lang="en">Groups that may be involved in the AI regulatory sandbox to provide input and oversight</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMMON_RULES_FOR_AI_REGULATORY_SANDBOXES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">COMMON RULES FOR AI REGULATORY SANDBOXES</rdfs:label>
    <skos:definition xml:lang="en">A unified framework for the implementation and operation of sandboxes across the Union</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TEXT_AND_DATA_MINING">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2019_790"/>
    <rdfs:label xml:lang="en">TEXT AND DATA MINING</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROFESSIONAL_SECRECY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROFESSIONAL SECRECY</rdfs:label>
    <skos:definition xml:lang="en">The binding duty for staff of notified bodies to observe secrecy regarding information obtained during their tasks, with exceptions only for notifying authorities, per Article 31(7).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FRAUD_DETECTION_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">FRAUD DETECTION AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems provided for by Union law for the purpose of detecting fraud in the offering of financial services</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FINANCIAL_SERVICES_FRAUD_DETECTION_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_48">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 48</rdfs:label>
    <skos:definition xml:lang="en">**RECITAL 48**

RECITAL 48 serves as a critical component of the AI Act’s preamble, establishing the foundational principles that govern the assessment and classification of artificial intelligence systems. This section emphasizes the paramount importance of fundamental rights, mandating that the potential impact of AI systems on these rights be carefully considered during the risk assessment process. Furthermore, RECITAL 48 specifically highlights the necessity of safeguarding children's rights</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSPARENCY_RULES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TRANSPARENCY RULES</rdfs:label>
    <skos:definition xml:lang="en">Harmonised obligations regarding the transparency of certain AI systems as defined in Article 1(2)(d)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUBCONTRACTOR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">SUBCONTRACTOR</rdfs:label>
    <skos:definition xml:lang="en">A third party hired by a notified body to perform specific tasks connected with the conformity assessment; must meet Article 31 requirements</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_31"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFIED_BODIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">NOTIFIED BODIES</rdfs:label>
    <skos:definition xml:lang="en">Notified Bodies are professional third-party certifiers that play a critical role in the regulatory framework established by the AI Act. Specifically, these entities serve as conformity assessment bodies tasked with evaluating high-risk AI systems to ensure they meet established safety and performance standards. In this capacity, Notified Bodies are subject to a strict set of obligations and regulatory requirements, ensuring that their oversight procedures remain rigorous, transparent, and compl</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_MISLEADING_INFORMATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MANDATE_OF_AUTHORISED_REPRESENTATIVE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">MANDATE OF AUTHORISED REPRESENTATIVE</rdfs:label>
    <skos:definition xml:lang="en">Third-country providers must appoint an authorised representative via written mandate and empower them to perform tasks like verifying conformity as per Article 22</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_22"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_31">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 31</rdfs:label>
    <skos:definition xml:lang="en">**Article 31** serves as a critical regulatory provision establishing the comprehensive requirements that must be met by conformity assessment bodies to achieve the status of a "notified body." Under this article, these entities are subjected to rigorous standards to ensure they are qualified, impartial, and capable of performing their designated oversight functions.

Specifically, Article 31 outlines the operational and organizational obligations necessary for a body to be authorized to control</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_261_TFEU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 261 TFEU</rdfs:label>
    <skos:definition xml:lang="en">Specific legal provision granting the Court of Justice unlimited jurisdiction with regard to penalties</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_MANAGEMENT_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA MANAGEMENT SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">Procedures including data acquisition, collection, labelling, storage, and mining, performed before placing on the market (Article 17(2)(f)).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ETHICAL_REVIEW">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ETHICAL REVIEW</rdfs:label>
    <skos:definition xml:lang="en">Mandatory ethical assessment required by Union or national law that must be respected during real-world testing</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CAPITAL_REQUIREMENT_CALCULATION_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">CAPITAL REQUIREMENT CALCULATION EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">Condition under which capital requirement calculation systems are not classified as high-risk under this Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_POLITICAL_CAMPAIGN_ADMINISTRATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR POLITICAL CAMPAIGN ADMINISTRATION</rdfs:label>
    <skos:definition xml:lang="en">Tools used to organise, optimise, and structure political campaigns from an administrative and logistical point of view. Specifically excepted from high-risk classification if natural persons are not directly exposed to the output (Recital 62).</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1725">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2018/1725</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2018/1725 serves as the primary legal framework concerning the protection of natural persons with regard to the processing of personal data by European Union institutions, bodies, offices, and agencies. It establishes the standards for how these entities must manage and safeguard personal information.

Beyond its general mandate on data protection, the regulation is instrumental in specific regulatory and operational contexts. It serves as the reference regulation for the consult</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AISystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">AI System</rdfs:label>
    <skos:definition xml:lang="en">A machine-based system designed to operate with varying levels of autonomy and that may exhibit adaptiveness after deployment. (Article 3(1))</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_54">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 54</rdfs:label>
    <skos:definition xml:lang="en">Recital regarding classification of biometric systems as high-risk or excluded (Recital 54)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_112">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 112</rdfs:label>
    <skos:definition xml:lang="en">**Article 112** serves as a critical component of the AI Act, specifically functioning as a provision that mandates the evaluation and review of the legislation itself. In this capacity, Article 112 establishes a framework for ongoing oversight, wherein the AI Board is tasked with providing essential assistance. Furthermore, Article 112 includes provisions related to the necessary revision of Article 5, ensuring that the legal requirements concerning prohibited AI practices remain dynamic and re</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RIGHT_TO_EXPLANATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">RIGHT TO EXPLANATION</rdfs:label>
    <skos:definition xml:lang="en">The "Right to Explanation" is a key provision, specifically detailed in Article 86, that centers on the transparency and accountability of artificial intelligence systems. This right ensures that individuals who are impacted by decisions made by AI systems are entitled to receive a clear and meaningful explanation regarding the role the AI played in that individual decision-making process.

Essentially, Article 86 establishes a corresponding obligation for deployers of these AI systems. These de</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_86"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TESTING_DURATION_LIMIT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TESTING DURATION LIMIT</rdfs:label>
    <skos:definition xml:lang="en">Testing in real world conditions must not exceed six months, extendable for another six months upon notification, per Article 60(f)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#JusticeAI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#HighRiskAISystem"/>
    <rdfs:label xml:lang="en">JusticeAI</rdfs:label>
    <skos:definition xml:lang="en">AI assisting judicial authorities in legal research and decisions</skos:definition>
    <euai:articleReference>Annex III, 8</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_24_OF_REGULATION__EU__NO_1025_2012">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 24 OF REGULATION (EU) NO 1025/2012</rdfs:label>
    <skos:definition xml:lang="en">Provision requiring European standardisation organisations to provide evidence of best efforts in fulfilling standardisation requests.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2022_2065">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2022/2065</rdfs:label>
    <skos:definition xml:lang="en">**REGULATION (EU) 2022/2065**, formally known as the **Regulation on a Single Market for Digital Services** and commonly referred to as the **Digital Services Act (DSA)**, serves as a pivotal piece of legislation governing the digital ecosystem within the European Union.

This regulation establishes a comprehensive framework for online platforms and search engines, focusing on their responsibilities regarding content moderation and the mitigation of systemic risks. Specifically, it provides crit</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#VERY_LARGE_ONLINE_PLATFORMS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INVESTIGATIVE_AND_CORRECTIVE_POWERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">INVESTIGATIVE AND CORRECTIVE POWERS</rdfs:label>
    <skos:definition xml:lang="en">**INVESTIGATIVE AND CORRECTIVE POWERS** refer to the essential authorities and mandates granted to oversight bodies, regulators, and enforcement agencies, enabling them to effectively carry out their official duties. These powers allow authorities to access necessary personal data and specific information required to perform their prescribed tasks and functions.

In the context of law enforcement and the justice domain, these powers are critical, as they provide the legal framework for authoriti</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CRIMINAL_RISK_ASSESSMENT_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">CRIMINAL RISK ASSESSMENT AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI system assessing/predicting criminal risk based solely on profiling or personality traits; prohibited unless supporting human assessment of criminal activity based on objective facts</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICE"/>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#CRIMINAL_RISK_ASSESSMENT_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#APPLICATION_DATE_2_FEBRUARY_2025">
    <rdfs:label xml:lang="en">APPLICATION DATE 2 FEBRUARY 2025</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXPERT_PANELS__EXPERT_LABORATORIES_AND_REFERENCE_LABORATORIES">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2017_745"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2017_746"/>
    <rdfs:label xml:lang="en">EXPERT PANELS  EXPERT LABORATORIES AND REFERENCE LABORATORIES</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_XI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX XI</rdfs:label>
    <skos:definition xml:lang="en">**ANNEX XI** is a specific and essential component of the EU AI Act. It serves as the formal section that outlines the comprehensive requirements for the technical documentation of general-purpose AI models. By detailing the specific content that must be included within these documents, ANNEX XI ensures transparency and regulatory compliance for developers working with these advanced systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AUTHORISATION_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">AUTHORISATION REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">Requirement for competent authorities to obtain authorization before deploying certain biometric systems, which does not apply to non-law enforcement uses</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LIABILITY_INSURANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">LIABILITY INSURANCE</rdfs:label>
    <skos:definition xml:lang="en">Notified bodies must have appropriate liability insurance for conformity assessment activities, unless liability is assumed by the Member State</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_IX">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX IX</rdfs:label>
    <skos:definition xml:lang="en">Annex IX serves as a regulatory component outlining the specific information required for the registration of high-risk AI systems within the EU database. It functions as a definitive guide for the necessary documentation and data points that must be provided when registering these systems. Furthermore, Annex IX extends its scope beyond standard registration, as it also specifies the information requirements pertaining to the real-world testing of high-risk AI systems. Consequently, it acts as a</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_BODY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CONFORMITY ASSESSMENT BODY</rdfs:label>
    <skos:definition xml:lang="en">A Conformity Assessment Body is a designated third-party organization responsible for performing conformity assessment activities, which include testing, certification, and inspection. These bodies play a critical role under Union harmonization legislation, where their involvement in certain contexts, such as the evaluation of Artificial Intelligence systems, can determine high-risk classifications.

To operate in this capacity, a Conformity Assessment Body must first apply for notification to a</skos:definition>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#SAFETY_COMPONENT_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFIED_BODY"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#APPLICATION_FOR_NOTIFICATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_31"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MODEL_MODIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">MODEL MODIFICATION</rdfs:label>
    <skos:definition xml:lang="en">Requirement for providers to update technical documentation and disclose new training data sources when a model is fine-tuned or modified</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_AND_COMPLIANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RISK MANAGEMENT AND COMPLIANCE</rdfs:label>
    <skos:definition xml:lang="en">Mandatory requirements for high-risk AI systems laid down in the Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_VALUE_CHAIN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">AI VALUE CHAIN</rdfs:label>
    <skos:definition xml:lang="en">Various operators involved in the design, development, deployment, or use of AI systems, subject to obligations under this Regulation</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECORD_KEEPING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REMOTE_BIOMETRIC_IDENTIFICATION_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">REMOTE BIOMETRIC IDENTIFICATION AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI system used for remote biometric identification, subject to specific data processing rules under the AI Act</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_RULES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2022_2065__DIGITAL_SERVICES_ACT_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2022/2065 (DIGITAL SERVICES ACT)</rdfs:label>
    <skos:definition xml:lang="en">Regulation on a Single Market For Digital Services, which intersects with the EU AI Act regarding online platform regulation and transparency</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE_2000_31_EC"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADMINISTRATION_OF_JUSTICE_AND_DEMOCRATIC_PROCESSES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">ADMINISTRATION OF JUSTICE AND DEMOCRATIC PROCESSES</rdfs:label>
    <skos:definition xml:lang="en">The "Administration of Justice and Democratic Processes" encompasses high-risk artificial intelligence use case domains that are integral to the functioning of critical public sectors. Specifically, this area pertains to AI systems utilized to assist judicial authorities in performing legal tasks, as well as systems that have the potential to influence the outcomes of elections or referenda. These applications are formally categorized as high-risk within the framework of AI regulations, such as </skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_JUDICIAL_ASSISTANCE"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_INFLUENCING_ELECTIONS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WRITTEN_AGREEMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">WRITTEN AGREEMENT</rdfs:label>
    <skos:definition xml:lang="en">A Written Agreement is a mandatory formal contract established between a provider and a third party within the AI value chain. This agreement functions as a critical requirement, ensuring that all relevant parties involved in the AI value chain are obligated to furnish the provider with necessary technical assistance and information access. By formalizing these obligations, the Written Agreement ensures seamless cooperation and the provision of essential resources required for the effective func</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INFORMATION_OR_DOCUMENTATION">
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CONFIDENTIALITY_OBLIGATIONS"/>
    <rdfs:label xml:lang="en">INFORMATION OR DOCUMENTATION</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TESTING_AND_EXPERIMENTATION_FACILITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">TESTING AND EXPERIMENTATION FACILITY</rdfs:label>
    <skos:definition xml:lang="en">The TESTING AND EXPERIMENTATION FACILITY represents a critical component of the broader artificial intelligence ecosystem. These organizations provide the essential infrastructure and environments necessary to support the ongoing development and experimentation of AI technologies. 

Functioning as a resource for prospective AI providers, a TESTING AND EXPERIMENTATION FACILITY offers a secure, controlled environment—often referred to as a sandbox—where developers can build, refine, and rigorously</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_881">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2019/881</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2019/881, widely known as the Cybersecurity Act, is a pivotal piece of European Union legislation that addresses the safety and resilience of digital infrastructure. Its primary function is to establish a comprehensive framework for the cybersecurity certification of information and communications technology (ICT) products, services, and processes.

Central to this regulation is the formal establishment and reinforcement of ENISA, the European Union Agency for Cybersecurity. Regu</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_OBJECTIVES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">LAW ENFORCEMENT OBJECTIVES</rdfs:label>
    <skos:definition xml:lang="en">Specific objectives allowing the use of real-time remote biometric identification systems, including searching for victims of abduction/trafficking, preventing imminent threats to life, or preventing terrorist attacks.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FEES_FOR_CONFORMITY_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">FEES FOR CONFORMITY ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">Financial costs for conformity assessments which must be reduced for SME providers under Article 62(2)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_18_REGULATION_2019_1020">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 18 REGULATION 2019/1020</rdfs:label>
    <skos:definition xml:lang="en">Article regarding procedural rights of economic operators, applied mutatis mutandis to GPAI model providers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_48">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 48</rdfs:label>
    <skos:definition xml:lang="en">Article defining the requirements for affixing the CE marking.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_78">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 78</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 78** is a provision within the relevant Regulation that establishes comprehensive confidentiality obligations. It serves to define the requirements for maintaining the secrecy and protection of information or documentation obtained during the course of official duties.

Specifically, **ARTICLE 78** applies to various entities, including national competent authorities, authorities, and other persons involved in the execution of the Regulation. It governs the handling of information obta</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_113"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TRANSPARENCY OBLIGATIONS</rdfs:label>
    <skos:definition xml:lang="en">**Transparency Obligations**

Transparency Obligations under the current AI regulatory framework refer to a set of binding rules designed to ensure accountability and clarity regarding the use of specific artificial intelligence systems. These obligations are implemented as a core component of the Regulation's overarching risk-based approach, which categorizes AI systems based on their potential impact and risks.

At the heart of these requirements is the duty to inform both users and deployers </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NEGATIVE_IMPACT_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">NEGATIVE IMPACT ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">A specific requirement for codes of conduct focused on assessing and preventing negative impacts on vulnerable persons, including accessibility and gender equality, as per Article 95(2)(e)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNUAL_REPORT_ON_AI_REGULATORY_SANDBOXES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ANNUAL REPORT ON AI REGULATORY SANDBOXES</rdfs:label>
    <skos:definition xml:lang="en">A mandatory report submitted by national competent authorities to the AI Office and the Board regarding the progress, results, best practices, and incidents within the sandboxes (Recital 16).</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_OFFICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_ARTIFICIAL_INTELLIGENCE_BOARD"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VALIDATION_AND_TESTING_PROCEDURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">VALIDATION AND TESTING PROCEDURES</rdfs:label>
    <skos:definition xml:lang="en">Processes to measure accuracy, robustness, and compliance, including test logs and reports</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSPARENCY_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TRANSPARENCY MEASURES</rdfs:label>
    <skos:definition xml:lang="en">Requirement for general-purpose AI model providers to draw up, keep up to date, and provide documentation and information regarding the model for downstream users, as described in Recital 101</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_50"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#hasException">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasException</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CRIMINAL_VICTIMISATION_RISK_ASSESSMENT_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">CRIMINAL VICTIMISATION RISK ASSESSMENT AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems used by law enforcement to assess the risk of a natural person becoming a victim of criminal offences (Annex III 6(a))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TERMINATE_MANDATE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TERMINATE MANDATE</rdfs:label>
    <skos:definition xml:lang="en">The requirement for an authorised representative to formally end their mandate if they have reason to believe the provider is acting contrary to the Regulation, including notifying the AI Office</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MODEL_TRAINING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MODEL TRAINING</rdfs:label>
    <skos:definition xml:lang="en">An activity in the AI value chain for which providers require assistance from upstream suppliers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_65">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 65</rdfs:label>
    <skos:definition xml:lang="en">Article establishing and defining the structure of the European Artificial Intelligence Board</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_16_6_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 16(6)</rdfs:label>
    <skos:definition xml:lang="en">Provision in Regulation (EU) 2022/2065 requiring hosting services to process notices on illegal content (Recital 136)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINANCIAL_INTELLIGENCE_UNITS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">FINANCIAL INTELLIGENCE UNITS</rdfs:label>
    <skos:definition xml:lang="en">Bodies carrying out administrative tasks under anti-money laundering law, whose AI tools are generally excluded from law enforcement high-risk classification.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITED_PRACTICES_LIST">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">PROHIBITED PRACTICES LIST</rdfs:label>
    <skos:definition xml:lang="en">The list of prohibited AI practices which the Commission must assess for potential amendment annually, as per Recital 174</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK_DESIGNATION_CRITERIA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SYSTEMIC RISK DESIGNATION CRITERIA</rdfs:label>
    <skos:definition xml:lang="en">Specific benchmarks used for the designation of a GPAI model as having systemic risk, including training data quality, user base size, autonomy, scalability, and modalities.</skos:definition>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISKS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CRITICAL_SITUATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">CRITICAL SITUATIONS</rdfs:label>
    <skos:definition xml:lang="en">Criterion regarding decisions made in critical situations for life, health, and property, used to justify high-risk classification</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EMERGENCY_SERVICE_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_61">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 61</rdfs:label>
    <skos:definition xml:lang="en">Article 61 establishes the regulatory framework governing the testing of AI systems in real-world conditions. This article outlines the specific requirements and conditions that must be met to ensure that such testing is conducted safely, ethically, and in accordance with legal standards. A central component of Article 61 is the definition of informed consent, which mandates that participants must be fully informed and provide their consent before their involvement in real-world AI testing can p</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2008_48_EC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2008/48/EC</rdfs:label>
    <skos:definition xml:lang="en">Directive 2008/48/EC, specifically referencing its Recital 47, is a piece of European Union legislation that acts as a directive on credit agreements for consumers. This directive is significant for establishing critical legal standards for financial services within the consumer credit market. By setting these standards, Directive 2008/48/EC aims to provide a harmonized framework that ensures consumer protection and promotes transparency in credit agreements across member states.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE_2014_17_EU"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_PUBLIC_AUTHORITY_PROTECTING_FUNDAMENTAL_RIGHTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">NATIONAL PUBLIC AUTHORITY PROTECTING FUNDAMENTAL RIGHTS</rdfs:label>
    <skos:definition xml:lang="en">Bodies supervising or enforcing Union law on fundamental rights, authorized to request documentation and testing of high-risk AI systems.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DOCUMENTATION"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CONFIDENTIALITY_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OF_LIST_OF_AUTHORITIES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_V__SECTIONS_2_AND_3">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER V, SECTIONS 2 AND 3</rdfs:label>
    <skos:definition xml:lang="en">The specific sections of the AI Act setting out obligations for general-purpose AI models.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMPLOYERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">EMPLOYERS</rdfs:label>
    <skos:definition xml:lang="en">Entities involved in the employment relationship, whose industrial relations and collective bargaining rights remain unaffected by this Regulation</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#WORKERS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_47">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 47</rdfs:label>
    <skos:definition xml:lang="en">Recital addressing safety risks of AI systems acting as safety components in products</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_35_GDPR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 35 GDPR</rdfs:label>
    <skos:definition xml:lang="en">Article regarding data protection impact assessments.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#Importer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Importer</rdfs:label>
    <skos:definition xml:lang="en">A person in the Union who places an AI system from a third country on the market. (Article 3(6))</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_5__6__AND_7_OF_REGULATION__EU__NO_1025_2012">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 5, 6, AND 7 OF REGULATION (EU) NO 1025/2012</rdfs:label>
    <skos:definition xml:lang="en">Provisions governing the multi-stakeholder governance and participation of stakeholders in the standardisation process.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#POOL_OF_EXPERTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">POOL OF EXPERTS</rdfs:label>
    <skos:definition xml:lang="en">A collective body of expertise available to Member States under Article 69</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_73">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 73</rdfs:label>
    <skos:definition xml:lang="en">**RECITAL 73**

RECITAL 73 of the EU AI Act serves as a critical provision regarding the governance of high-risk artificial intelligence systems. It establishes fundamental requirements for transparency, operational functionality, and human oversight, ensuring that these systems are deployed safely and ethically.

Central to RECITAL 73 is the requirement for comprehensive transparency. This necessitates that providers of high-risk AI systems furnish clear, accessible, and detailed instructions f</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION_2017_745">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION 2017/745</rdfs:label>
    <skos:definition xml:lang="en">Union harmonisation legislation applicable to medical devices that may apply to products with high-risk AI (Recital 46)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_46"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MigrationAsylumAI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#HighRiskAISystem"/>
    <rdfs:label xml:lang="en">MigrationAsylumAI</rdfs:label>
    <skos:definition xml:lang="en">AI for migration, asylum and border control</skos:definition>
    <euai:articleReference>Annex III, 7</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SubliminaltechniquesAI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ProhibitedAIPractice"/>
    <rdfs:label xml:lang="en">SubliminaltechniquesAI</rdfs:label>
    <skos:definition xml:lang="en">AI using subliminal techniques to distort behaviour causing harm</skos:definition>
    <euai:articleReference>Article 5(1)(a)</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 2</rdfs:label>
    <skos:definition xml:lang="en">**Article 2** serves as a foundational provision within the EU AI Act, primarily dedicated to defining the regulation’s scope and establishing its jurisdictional boundaries. By delineating who is subject to the Act, Article 2 ensures clarity regarding the obligations of various stakeholders within the AI ecosystem.

At its core, Article 2 specifies the scope of the Regulation by identifying the key entities it governs, including providers, deployers, importers, and distributors of AI systems. It</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#IMPORTER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DISTRIBUTOR"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SCIENTIFIC_RESEARCH_AND_DEVELOPMENT_ACTIVITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">SCIENTIFIC RESEARCH AND DEVELOPMENT ACTIVITY</rdfs:label>
    <skos:definition xml:lang="en">AI systems and models specifically developed and put into service for the sole purpose of scientific research and development are excluded from the scope of this Regulation prior to being placed on the market or put into service</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_13">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 13</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 13**

Article 13 serves as a pivotal legal provision focused on the requirements for transparency and the provision of information. It specifically mandates that transparency obligations and information-sharing protocols be extended to both users and deployers. Furthermore, the significance of Article 13 is underscored by its formal linkage to other parts of the regulatory framework, as it is explicitly referenced in Article 9(5)(c).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OFFICIAL_JOURNAL_OF_THE_EUROPEAN_UNION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">OFFICIAL JOURNAL OF THE EUROPEAN UNION</rdfs:label>
    <skos:definition xml:lang="en">The Official Journal of the European Union serves as the official publication medium for references to harmonised standards and common specifications. Its role is pivotal in the regulatory framework of the European Union, as the publication of these references within the Journal is the required mechanism to trigger specific legal effects. Notably, this publication is the formal step necessary to establish the presumption of conformity for products or services adhering to these standards.</skos:definition>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_STANDARD"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SERIOUS_RISK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">SERIOUS RISK</rdfs:label>
    <skos:definition xml:lang="en">"SERIOUS RISK" refers to a classification assigned to high-risk AI systems that have been identified as presenting a significant level of danger across two or more Member States. This designation serves as a formal trigger for regulatory action, specifically enabling authorities to initiate and propose joint investigations into the system in question to address the widespread threat.</skos:definition>
    <euai:triggers rdf:resource="https://w3id.org/euaiact/ontology#JOINT_INVESTIGATIONS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_182_2011">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) NO 182/2011</rdfs:label>
    <skos:definition xml:lang="en">Reference to the regulation governing the exercise of implementing powers conferred on the Commission (Recital 175)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EmploymentAI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#HighRiskAISystem"/>
    <rdfs:label xml:lang="en">EmploymentAI</rdfs:label>
    <skos:definition xml:lang="en">AI for recruitment and employment decisions</skos:definition>
    <euai:articleReference>Annex III, 4</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__167_2013">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <rdfs:label xml:lang="en">REGULATION  EU  167 2013</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#METROLOGY_AND_BENCHMARKING_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">METROLOGY AND BENCHMARKING AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">**METROLOGY AND BENCHMARKING AUTHORITIES**

Metrology and benchmarking authorities serve as critical stakeholders and expert organizations that collaborate directly with the Commission. Their primary mandate involves cooperating with the Commission to establish and refine rigorous benchmarks and measurement methodologies. Specifically, these authorities focus on evaluating the accuracy and robustness of artificial intelligence systems, ensuring that AI technologies meet established standards thr</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">BIOMETRIC DATA</rdfs:label>
    <skos:definition xml:lang="en">Biometric data refers to personal information that is derived from the specific technical processing of a natural person's physical, physiological, or behavioural characteristics, such as facial images. This classification of data is officially defined and governed by Regulation (EU) 2016/679, Regulation (EU) 2018/1725, and Directive (EU) 2016/680. As outlined in Recital 14 of these legal frameworks, biometric data is utilized for the purposes of authentication, identification, categorisation, o</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_14"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REQUIREMENTS_IN_CHAPTER_III_SECTION_2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">REQUIREMENTS IN CHAPTER III SECTION 2</rdfs:label>
    <skos:definition xml:lang="en">Technical and organizational requirements set out in the AI Act (Regulation 2024/1689) that must be considered when other regulations adopt delegated or implementing acts concerning AI safety components.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAW_ON_THE_PROTECTION_OF_MINORS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">LAW ON THE PROTECTION OF MINORS</rdfs:label>
    <skos:definition xml:lang="en">National legal provisions for the protection of persons below the age of 18, which remain unaffected by this Regulation insofar as they are not specific to AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ACCURACY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ACCURACY</rdfs:label>
    <skos:definition xml:lang="en">**ACCURACY** is a critical technical requirement for artificial intelligence systems, particularly those classified as high-risk. It refers to the fundamental capability of an AI system to produce correct, reliable, and consistent outputs throughout its entire lifecycle while actively minimizing errors and bias. 

As a prerequisite for regulatory compliance, **ACCURACY** is not merely a technical performance metric but an essential quality for ensuring that high-risk AI systems function reliably</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_74"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_XII">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX XII</rdfs:label>
    <skos:definition xml:lang="en">**ANNEX XII** outlines the specific transparency requirements regarding information and documentation that must be provided by providers of general-purpose AI models to downstream AI system providers. This annex serves to ensure that those developing systems further down the AI value chain have access to the necessary data to operate, integrate, and manage these models effectively. Specifically, it details the transparency obligations referenced in Article 53(1)(b) of the applicable regulations,</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EU_DATABASE_REGISTRATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EU DATABASE REGISTRATION</rdfs:label>
    <skos:definition xml:lang="en">The EU Database Registration process is a critical regulatory obligation for providers of AI systems. According to the governing regulations, providers are required to register their AI systems in the designated EU database before the systems are deployed for use.

While Article 49 mandates this registration prior to use, there is a specific exception for urgent situations. In such cases, an AI system may be utilized before the registration process is finalized, provided that the registration is</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_49"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_83"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_20">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 20</rdfs:label>
    <skos:definition xml:lang="en">Article 20 serves as a regulatory provision focused on the management of high-risk AI systems, specifically addressing the requirements for corrective actions and the duty to provide information. It mandates that when an AI system is identified as non-conforming or posing risks, specific measures must be taken to rectify the situation. Furthermore, Article 20 outlines the obligations of relevant parties to ensure transparency and accountability by providing necessary information regarding these </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2019_882">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE (EU) 2019/882</rdfs:label>
    <skos:definition xml:lang="en">**Directive (EU) 2019/882**, commonly referred to as the European Accessibility Act, is a critical legislative framework establishing mandatory accessibility requirements for a wide range of products and services within the European Union. Its primary objective is to harmonize accessibility standards, ensuring that digital and physical environments are inclusive, available, and usable by the public, including persons with disabilities and those belonging to vulnerable groups.

This directive pla</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ACCESSIBILITY_REQUIREMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#presumesConformity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">presumesConformity</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AWARENESS_RAISING_AND_TRAINING_ACTIVITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">AWARENESS RAISING AND TRAINING ACTIVITIES</rdfs:label>
    <skos:definition xml:lang="en">Requirement for Member States to organize specific education for SMEs, deployers, and local public authorities on the AI Act under Article 62(1)(b)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STANDING_SUBGROUP_FOR_MARKET_SURVEILLANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">STANDING SUBGROUP FOR MARKET SURVEILLANCE</rdfs:label>
    <skos:definition xml:lang="en">A subgroup responsible for market surveillance activities whose activities the Commission should support.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INDEPENDENT_SUPERVISORY_AUTHORITIES">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2016_679__GDPR_"/>
    <rdfs:label xml:lang="en">INDEPENDENT SUPERVISORY AUTHORITIES</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CERTIFICATE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CERTIFICATE</rdfs:label>
    <skos:definition xml:lang="en">A document issued by a notified body confirming conformity of an AI system; subject to validity periods and revocation/suspension clauses</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_44"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_VII"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_I"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_4">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 4</rdfs:label>
    <skos:definition xml:lang="en">Article addressing AI literacy requirements</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#definedInArticle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">definedInArticle</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUBLIC_SECTOR_BODIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PUBLIC SECTOR BODIES</rdfs:label>
    <skos:definition xml:lang="en">Entities subject to Directive (EU) 2016/2102 regarding accessibility of websites and mobile applications (Recital 38)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_168_2013">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) NO 168/2013</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) No 168/2013 is a significant legislative act established to govern the approval and market surveillance of two- or three-wheel vehicles and quadricycles within the European Union. This regulation sets the framework for the type-approval requirements, ensuring that these vehicles meet necessary safety, environmental, and functional standards before they can be placed on the market.

Beyond its foundational role, the regulation has evolved to address contemporary technological adva</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STAND_ALONE_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">STAND-ALONE AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">High-risk AI systems that are not safety components of products and are not products themselves</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_CLASSIFICATION_RULE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ENTRY_EXIT_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">ENTRY/EXIT SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The Entry/Exit System (EES) is an automated IT system established by Regulation (EU) 2017/2226. Its primary purpose is to register the entry and exit data, as well as the refusal of entry data, of third-country nationals crossing the external borders of the European Union. In addition to serving as a record-keeping mechanism for border crossings, the system also incorporates specific conditions and frameworks allowing for access to this data for law enforcement purposes.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2017_2226"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION_OF_ENTRY_AND_EXIT_DATA"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INFORMATION_OBLIGATION_FOR_WORKERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">INFORMATION OBLIGATION FOR WORKERS</rdfs:label>
    <skos:definition xml:lang="en">Duty for deployers to inform workers or their representatives about the planned deployment of high-risk AI systems at the workplace (Recital 92)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WORKERS_AND_PLATFORM_SERVICE_PROVIDERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">WORKERS AND PLATFORM SERVICE PROVIDERS</rdfs:label>
    <skos:definition xml:lang="en">Individuals in work-related contractual relationships who are subject to AI-based monitoring, evaluation, or management</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#EMPLOYMENT_AND_WORKERS_MANAGEMENT_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LIABILITY_FOR_DEFECTIVE_PRODUCTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">LIABILITY FOR DEFECTIVE PRODUCTS</rdfs:label>
    <skos:definition xml:lang="en">The legal duty to compensate for damages caused by defective products, as outlined in Council Directive 85/374/EEC</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#COUNCIL_DIRECTIVE_85_374_EEC"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EURODAC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EURODAC</rdfs:label>
    <skos:definition xml:lang="en">EURODAC is a large-scale information technology system designed for the comparison of biometric data, primarily fingerprints. Established under Regulation (EU) 2024/1358, which also identifies the system as a relevant Union legislative act listed in Annex X, EURODAC serves a critical function in managing migration and security within the European Union.

The primary purpose of EURODAC is to facilitate the identification of third-country nationals and stateless persons who are staying in the EU i</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2024_1358"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPARISON_OF_BIOMETRIC_DATA"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#providesInstructionsTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">providesInstructionsTo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_40">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 40</rdfs:label>
    <skos:definition xml:lang="en">**Article 40** serves as a regulatory provision that addresses the critical role of harmonised standards and standardisation deliverables within a legal or technical framework. Its primary function is to define and regulate the application of these standards, establishing them as an essential mechanism for ensuring compliance. Specifically, Article 40 designates harmonised standards as the foundational basis for the presumption of conformity, meaning that products or processes adhering to these </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK_CLASSIFICATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SYSTEMIC RISK CLASSIFICATION</rdfs:label>
    <skos:definition xml:lang="en">The process by which a GPAI model is designated as having systemic risk, either by meeting the compute threshold or through Commission decision.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_PUBLIC_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">NATIONAL PUBLIC AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">Bodies referred to in Article 77(1) that cooperate with market surveillance authorities, particularly regarding risks to fundamental rights</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EVALUATION_AND_REVIEW">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EVALUATION AND REVIEW</rdfs:label>
    <skos:definition xml:lang="en">Duty of the Commission to assess the Regulation, Annex III, and Article 5, and report findings to the Parliament and Council (Article 112)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_46">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 46</rdfs:label>
    <skos:definition xml:lang="en">Defines the derogation from conformity assessment procedures for high-risk AI systems under exceptional circumstances of public security or life/health protection.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_80">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 80</rdfs:label>
    <skos:definition xml:lang="en">Article detailing the procedure for dealing with AI systems misclassified by the provider as non-high-risk</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_79"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PERSONAL_DATA_PROTECTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PERSONAL DATA PROTECTION</rdfs:label>
    <skos:definition xml:lang="en">**PERSONAL DATA PROTECTION** is a mandatory regulatory standard that safeguards the privacy and rights of natural persons concerning the processing of their personal information. This framework is anchored in legal requirements, most notably the General Data Protection Regulation (GDPR) (Regulation 2016/679), which establishes the protocols for how personal data must be handled, stored, and managed. 

Furthermore, PERSONAL DATA PROTECTION extends to modern technological landscapes, serving as a </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_816">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2019/816</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2019/816 is a legislative act and legal instrument that established the European Criminal Records Information System for Third-Country Nationals (ECRIS-TCN system). This legislation serves as the foundational framework for the creation and implementation of the ECRIS-TCN, a centralized system designed to facilitate the exchange of criminal record information regarding non-EU citizens within the European Union.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OBLIGATION_TO_COMPLY_WITH_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">OBLIGATION TO COMPLY WITH MEASURES</rdfs:label>
    <skos:definition xml:lang="en">Provider must comply with measures requested under Article 93 and requests for documents/information under Article 91</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRAINING_CONTENT_SUMMARY_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TRAINING CONTENT SUMMARY OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Duty to draw up and make publicly available a detailed summary about content used for training per Article 53(1)(d).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#reducedObligationsApplyTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">reducedObligationsApplyTo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEMS_LIST">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">HIGH-RISK AI SYSTEMS LIST</rdfs:label>
    <skos:definition xml:lang="en">The list of high-risk AI systems which the Commission is empowered to amend via delegated acts, as per Recital 173</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ProhibitedAIPractice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Prohibited AI Practice</rdfs:label>
    <skos:definition xml:lang="en">An AI practice that is banned under Article 5 due to unacceptable risk.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CRITICAL_DIGITAL_INFRASTRUCTURE_SAFETY_COMPONENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">CRITICAL DIGITAL INFRASTRUCTURE SAFETY COMPONENT</rdfs:label>
    <skos:definition xml:lang="en">AI systems used as safety components in the management and operation of critical digital infrastructure (Annex III 2)</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#CRITICAL_INFRASTRUCTURE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_41_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(41)</rdfs:label>
    <skos:definition xml:lang="en">Definition of remote biometric identification system</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_26_10_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 26(10)</rdfs:label>
    <skos:definition xml:lang="en">**Article 26(10)** is a specific provision within the AI Act that governs the processing of personal data by Member States. This article is particularly significant because it concerns processing activities that occur within the specific legislative contexts of Chapter 4 or 5 of Title V of the Treaty on the Functioning of the European Union (TFEU). Furthermore, Article 26(10) is notable for the unique legal status afforded to Ireland, which holds a specific opt-out or positioning status regardin</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_99">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 99</rdfs:label>
    <skos:definition xml:lang="en">Article 99 functions as the definitive framework within the AI Act governing the imposition of penalties for non-compliance and circumvention of its requirements. It establishes the legal basis for regulatory enforcement, detailing the structure for fines and penalties applicable to operators. Specifically, Article 99 outlines the mechanisms for calculating administrative fines, including the relevant circumstances and factors that authorities must consider when determining the appropriate sanct</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_96"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STANDARDISATION_DEVELOPMENT_PROCESSES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">STANDARDISATION DEVELOPMENT PROCESSES</rdfs:label>
    <skos:definition xml:lang="en">Member States are required to facilitate the participation of SMEs and other relevant stakeholders in these processes</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_VERIFICATION_PURPOSE">
    <rdfs:label xml:lang="en">BIOMETRIC VERIFICATION PURPOSE</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROCESSING_OF_SPECIAL_CATEGORIES_OF_PERSONAL_DATA">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIAS_DETECTION_AND_CORRECTION"/>
    <rdfs:label xml:lang="en">PROCESSING OF SPECIAL CATEGORIES OF PERSONAL DATA</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ETSI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">ETSI</rdfs:label>
    <skos:definition xml:lang="en">European Telecommunications Standards Institute, a permanent member of the advisory forum</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADVISORY_FORUM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REPORTING_SERIOUS_INCIDENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REPORTING SERIOUS INCIDENTS</rdfs:label>
    <skos:definition xml:lang="en">Providers are required to have a system to report serious incidents resulting from the use of their AI systems to relevant authorities.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TAX_AND_CUSTOMS_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">TAX AND CUSTOMS EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">Condition under which AI systems used for tax/customs administrative proceedings are not classified as high-risk</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONSULTATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CONSULTATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Requirement for national competent authorities to consult relevant authorities under other Union law when providing guidance on AI systems in areas covered by that other law.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_EVIDENCE_EVALUATION_IN_LAW_ENFORCEMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR EVIDENCE EVALUATION IN LAW ENFORCEMENT</rdfs:label>
    <skos:definition xml:lang="en">System used to evaluate the reliability of evidence in the investigation or prosecution of criminal offences, identified in Annex III(6)(c)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONSULTATION_OF_EXPERTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CONSULTATION OF EXPERTS</rdfs:label>
    <skos:definition xml:lang="en">Before adopting a delegated act, the Commission must consult experts designated by each Member State in accordance with the principles of the Interinstitutional Agreement of 13 April 2016 per Article 97(4)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LABELING_OBLIGATION_FOR_TEXT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">LABELING OBLIGATION FOR TEXT</rdfs:label>
    <skos:definition xml:lang="en">Requirement to disclose AI-generated or manipulated text published to inform the public on matters of public interest; has exception if content underwent human review/editorial control or a legal person holds editorial responsibility (Recital 134)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LABELING_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HOSTING_SERVICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_RISK_ANALYTICS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION FOR RISK ANALYTICS</rdfs:label>
    <skos:definition xml:lang="en">Exemption for AI systems assessing likelihood of financial fraud or narcotics trafficking, provided they are not based on personal profiling.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#THIRD_PARTIES">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CERTIFIED_COMPLIANCE_SERVICES"/>
    <rdfs:label xml:lang="en">THIRD PARTIES</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_INTENDED_FOR_ELECTION_OR_REFERENDUM">
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#EXCLUSION_CONDITION__NON_EXPOSURE_TO_OUTPUT"/>
    <rdfs:label xml:lang="en">AI SYSTEM INTENDED FOR ELECTION OR REFERENDUM</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUSPECTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">SUSPECTS</rdfs:label>
    <skos:definition xml:lang="en">Natural persons under investigation whose defence rights may be impacted by AI tool use and opacity.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NotifiedBody">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Notified Body</rdfs:label>
    <skos:definition xml:lang="en">A conformity assessment body designated by a Member State. (Article 3(22))</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NON_DISCRIMINATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">NON-DISCRIMINATION</rdfs:label>
    <skos:definition xml:lang="en">In the context of artificial intelligence, Non-Discrimination is both an essential quality and a mandatory requirement designed to ensure fairness and equity. It serves as a critical safeguard to prevent AI systems from perpetuating or amplifying historical patterns of prejudice, bias, or exclusion.

To be effective, Non-Discrimination must be deeply integrated into the development and deployment of AI technologies to protect individuals against discrimination based on protected characteristics,</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EVALUATION_OF_GPAI_MODEL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">EVALUATION OF GPAI MODEL</rdfs:label>
    <skos:definition xml:lang="en">Assessment procedure conducted by the AI Office (or appointed independent experts) to determine compliance or investigate systemic risks when information requests are insufficient</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_92"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2016_97">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE (EU) 2016/97</rdfs:label>
    <skos:definition xml:lang="en">Directive (EU) 2016/97, commonly known as the Directive on Insurance Distribution, establishes a regulatory framework governing the distribution of insurance products within the European Union. Central to this directive is Recital 51, which plays a critical role in shaping the compliance landscape for the insurance sector.

Recital 51 is significant because it highlights the necessity of addressing the implications of technological advancements, specifically identifying its relevance to the requ</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SAFETY_NET">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SAFETY NET</rdfs:label>
    <skos:definition xml:lang="en">The application of Regulation (EU) 2023/988 as a mechanism to ensure AI systems not classified as high-risk remain safe</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WITHDRAWAL_OF_AUTHORISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">WITHDRAWAL OF AUTHORISATION</rdfs:label>
    <skos:definition xml:lang="en">The duty of a market surveillance authority to revoke an authorization if the Commission deems said authorization unjustified.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTIFICIAL_CONTENT_DISCLOSURE_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ARTIFICIAL CONTENT DISCLOSURE OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Requirement for providers and deployers to enable detection and disclosure that outputs are artificially generated or manipulated</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ISOLATED_DATA_PROCESSING_ENVIRONMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ISOLATED DATA PROCESSING ENVIRONMENT</rdfs:label>
    <skos:definition xml:lang="en">A protected environment under the control of the prospective provider where personal data must be kept during sandbox experimentation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_I_AI_SYSTEM">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CERTIFICATE_EXTENSION"/>
    <rdfs:label xml:lang="en">ANNEX I AI SYSTEM</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION_">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADVISORY_FORUM"/>
    <rdfs:label xml:lang="en">EUROPEAN COMMISSION</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERNATIONAL_COOPERATION_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">INTERNATIONAL COOPERATION EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">The exclusion from the Regulation for public authorities of third countries and international organisations when acting in the framework of law enforcement or judicial cooperation agreements.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PRODUCT_COMPLIANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PRODUCT COMPLIANCE</rdfs:label>
    <skos:definition xml:lang="en">The obligation for products placed on the market to meet specific safety, accreditation, and harmonized standards, as referenced in Regulation (EC) No 765/2008 and Decision No 768/2008/EC</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EC__NO_765_2008"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_12">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 12</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 12** functions as the critical legal provision governing the mandatory record-keeping and logging obligations for high-risk AI systems. As a specific regulatory requirement, Article 12 mandates that providers of such systems implement robust mechanisms for the automatic recording of events, commonly referred to as logs, throughout the lifecycle of the AI system. By defining these essential record-keeping duties, Article 12 ensures transparency, accountability, and traceability, thereby</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FULL_ASSESSMENT_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">FULL ASSESSMENT OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Requirement for a successor notified body to complete a full assessment of affected high-risk AI systems within nine months following the cessation of the previous notified body's activities</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_8_15">
    <rdfs:label xml:lang="en">ARTICLE 8 15</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_TELECOMMUNICATIONS_STANDARDS_INSTITUTE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">EUROPEAN TELECOMMUNICATIONS STANDARDS INSTITUTE</rdfs:label>
    <skos:definition xml:lang="en">The European Telecommunications Standards Institute, commonly referred to as ETSI, is formally recognized as a permanent member of the advisory forum, a designation specifically cited under Article 67(5). As an organization, it maintains this established role within the advisory framework.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADVISORY_FORUM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ACCESS_TO_TECHNICAL_DOCUMENTATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ACCESS TO TECHNICAL DOCUMENTATION</rdfs:label>
    <skos:definition xml:lang="en">Requirement for law enforcement, immigration, or asylum authorities (when acting as providers) to ensure market surveillance authorities have immediate access to technical documentation (Annex IV) on their premises</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HOSTING_SERVICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">HOSTING SERVICES</rdfs:label>
    <skos:definition xml:lang="en">Service providers subject to obligations under Article 16 of Regulation (EU) 2022/2065 regarding illegal content notices, which remains independent of transparency labeling obligations (Recital 136)</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_16_6_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_16_1_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SMALL_AND_MEDIUM_ENTERPRISES__SMES_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">SMALL AND MEDIUM ENTERPRISES (SMES)</rdfs:label>
    <skos:definition xml:lang="en">Specific group of economic operators, including startups, receiving supportive measures under the Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#THIRD_COUNTRY_PUBLIC_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">THIRD COUNTRY PUBLIC AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">Third country public authorities, as well as international organizations operating in third countries, may be subject to exemptions under Article 2(4). These entities are potentially exempted from certain regulatory requirements, provided that the specific conditions related to law enforcement and judicial cooperation are fully satisfied as outlined in the referenced article.</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_76">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 76</rdfs:label>
    <skos:definition xml:lang="en">Article establishing supervision of testing in real-world conditions by market surveillance authorities</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REQUIREMENTS_FOR_HIGH_RISK_AI_SYSTEMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REQUIREMENTS FOR HIGH-RISK AI SYSTEMS</rdfs:label>
    <skos:definition xml:lang="en">Mandatory duties imposed on high-risk AI systems to ensure safety and compliance, derived from the risk-based approach of the Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_PROCEEDING_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">ADMINISTRATIVE PROCEEDING EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">**ADMINISTRATIVE PROCEEDING EXCLUSION**

AI systems utilized for administrative proceedings within tax, customs, and financial intelligence units are expressly excluded from the high-risk classification that is otherwise applied to artificial intelligence systems used in the context of law enforcement. This specific exclusion ensures that these financial and regulatory administrative processes are not subject to the same regulatory requirements mandated for high-risk law enforcement AI.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MODEL_RETRAINING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MODEL RETRAINING</rdfs:label>
    <skos:definition xml:lang="en">An activity in the AI value chain for which providers require assistance from upstream suppliers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#Complaint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Complaint</rdfs:label>
    <skos:definition xml:lang="en">A formal instrument for downstream providers to report upstream infringements.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_55">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 55</rdfs:label>
    <skos:definition xml:lang="en">Recital regarding classification of critical infrastructure safety components as high-risk (Recital 55)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OTHER_COMPETENT_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">OTHER COMPETENT AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">Any national or Union authority with supervisory powers over aspects of an AI system (e.g., data protection or product safety) that are involved in the sandbox operation alongside national competent authorities.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EXEMPTION_FROM_FINES_FOR_OTHER_LAW"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_5_TEU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 5 TEU</rdfs:label>
    <skos:definition xml:lang="en">Reference to the Treaty on European Union regarding the principle of subsidiarity and proportionality (Recital 176)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_114">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 114</rdfs:label>
    <skos:definition xml:lang="en">The article of the Treaty on the Functioning of the European Union (TFEU) providing the legal basis for ensuring a high level of protection and preventing market divergences</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OBLIGATION_TO_COMPLY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">OBLIGATION TO COMPLY</rdfs:label>
    <skos:definition xml:lang="en">The requirement for entities using AI systems originally intended for military, defence, or national security purposes to ensure compliance with the Regulation if those systems are subsequently used for other purposes (e.g., civilian, humanitarian, law enforcement).</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROPORTIONALITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PROPORTIONALITY</rdfs:label>
    <skos:definition xml:lang="en">Requirement for the use of post-remote biometric identification systems to be targeted and strictly necessary to the goal (Recital 95)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CRIMINAL_OFFENCE_THRESHOLD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">CRIMINAL OFFENCE THRESHOLD</rdfs:label>
    <skos:definition xml:lang="en">The criterion requiring that criminal offences for which biometric identification is used must be punishable by a custodial sentence or detention order of a maximum period of at least four years.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONSUMERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CONSUMERS</rdfs:label>
    <skos:definition xml:lang="en">Natural persons who may be negatively impacted by AI systems and for whom rights and remedies are preserved under Union law, including under Council Directive 85/374/EEC</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COUNCIL_DIRECTIVE_85_374_EEC"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STANDARDISED_TEMPLATES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">STANDARDISED TEMPLATES</rdfs:label>
    <skos:definition xml:lang="en">STANDARDISED TEMPLATES are essential documentation aids designed to streamline regulatory adherence. These documents are provided by the Commission with the specific objective of addressing the unique needs of small and medium-sized enterprises (SMEs), thereby facilitating their compliance efforts. Furthermore, these templates are furnished by the AI Office, in accordance with specifications set forth by the Board, to assist organizations in meeting the compliance requirements mandated under Art</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AUTOMATIC_RECORDING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">AUTOMATIC RECORDING</rdfs:label>
    <skos:definition xml:lang="en">A technical capability that high-risk AI systems must possess to allow for traceability and post-market monitoring of their operations.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#hasDeadline">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasDeadline</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_77">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 77</rdfs:label>
    <skos:definition xml:lang="en">Article defining the powers of authorities protecting fundamental rights regarding high-risk AI systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_VERIFICATION_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">BIOMETRIC VERIFICATION EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">The **BIOMETRIC VERIFICATION EXCLUSION** refers to specific regulatory conditions under which an AI-driven biometric system is exempt from certain requirements or oversight. This exclusion applies to biometric systems whose sole and exclusive function is biometric verification—often referred to as authentication—designed to confirm that a natural person is indeed the individual they claim to be. 

Such systems are typically utilized for straightforward access control, such as logging into a devi</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REQUIREMENTS_SET_OUT_IN_CHAPTER_III__SECTION_2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">REQUIREMENTS SET OUT IN CHAPTER III, SECTION 2</rdfs:label>
    <skos:definition xml:lang="en">The specific technical and organisational requirements (such as risk management, data governance, etc.) that the technical documentation must demonstrate compliance with.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AIOffice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">AI Office</rdfs:label>
    <skos:definition xml:lang="en">The Commission body responsible for GPAI model oversight and coordination. (Article 64)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_44_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(44)</rdfs:label>
    <skos:definition xml:lang="en">Definition of publicly accessible space</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSITION_TO_HIGH_RISK_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TRANSITION TO HIGH-RISK AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">Duty for the former provider to cooperate and provide technical access and information when an AI system changes classification to high-risk, provided they have not expressly excluded this possibility</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">NATIONAL COMPETENT AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">National Competent Authorities serve as key regulatory bodies tasked with the oversight and supervision of artificial intelligence systems. Operating in conjunction with the European Commission, these authorities hold significant responsibilities regarding both high-risk AI systems and General Purpose AI (GPAI) models. 

Specifically, regarding high-risk AI systems, National Competent Authorities are responsible for overseeing their placement on the market. In this capacity, they are empowered t</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LOCAL_PUBLIC_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">LOCAL PUBLIC AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">Authorities whose needs must be paid special attention to by the Commission when issuing guidelines, as per Article 96(1)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AWARENESS_RAISING_AND_TRAINING_ACTIVITIES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CUSTOMS_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CUSTOMS AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">Public authorities that use risk analytic tools for predicting the localisation of narcotics or illicit goods, which are excluded from the general prohibition on risk assessment systems.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_ANALYTICS_AI_SYSTEMS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DOWNSTREAM_PROVIDERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">DOWNSTREAM PROVIDERS</rdfs:label>
    <skos:definition xml:lang="en">**DOWNSTREAM PROVIDERS** are defined as stakeholders—specifically entities that utilize General Purpose AI (GPAI) models—who are invited to play an active role in the regulatory process. Under Article 56(3), these providers are encouraged to contribute to and support the collaborative development of codes of practice. By leveraging their practical experience in utilizing GPAI models, they help ensure that the resulting codes are comprehensive, informed, and effective.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2017_2226">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2017/2226</rdfs:label>
    <skos:definition xml:lang="en">Regulation (EU) 2017/2226 is the legislative act and legal instrument that formally establishes the Entry/Exit System (EES) of the European Union.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AUTONOMOUS_ROBOTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AUTONOMOUS ROBOTS</rdfs:label>
    <skos:definition xml:lang="en">Robots operating in complex environments (manufacturing, personal assistance) which, due to their autonomy, are considered significant AI systems requiring safety and reliability.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROTOCOL_NO_22">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">PROTOCOL NO 22</rdfs:label>
    <skos:definition xml:lang="en">Protocol attached to the TEU and TFEU regarding the position of Denmark, which creates an exclusion condition for the application of specific AI Act provisions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OFFENDING_RISK_ASSESSMENT_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">OFFENDING RISK ASSESSMENT AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems used by law enforcement to assess the risk of a natural person offending or reoffending</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_PROTECTION_AND_PRIVACY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA PROTECTION AND PRIVACY</rdfs:label>
    <skos:definition xml:lang="en">Mandatory requirement to protect the rights of persons monitored by AI systems in work-related contexts</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SYSTEM_REGISTRATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SYSTEM REGISTRATION</rdfs:label>
    <skos:definition xml:lang="en">Requirement for law enforcement authorities to register the AI system in the relevant database as set out in the Regulation before use.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_LITERACY_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">AI LITERACY MEASURES</rdfs:label>
    <skos:definition xml:lang="en">Voluntary organizational requirement focusing on education and awareness regarding AI systems</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_CONDUCT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MANDATORY_REQUIREMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MANDATORY REQUIREMENTS</rdfs:label>
    <skos:definition xml:lang="en">**MANDATORY REQUIREMENTS** constitute a comprehensive set of obligations and standards established by the AI Act to ensure the safe and ethical deployment of artificial intelligence. These measures are designed to guide providers in ensuring compliance, with a core focus on balancing strict adherence with the state of the art and the principle of proportionality, as highlighted in Recital 64.

At their core, these requirements serve as the fundamental framework for high-risk AI systems. They enc</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNUAL_REPORT_PREPARATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ANNUAL REPORT PREPARATION</rdfs:label>
    <skos:definition xml:lang="en">The advisory forum is required to prepare an annual report on its activities and make it publicly available</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:label xml:lang="en">HIGH-RISK AI SYSTEMS</rdfs:label>
    <skos:definition xml:lang="en">High-risk AI systems are classified as AI systems for which relevant regulations establish specific requirements and obligations for their operators. These systems are subject to strict regulatory oversight, necessitating that operators adhere to defined standards and responsibilities to ensure the systems are developed and deployed safely, transparently, and in compliance with the law.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_STANDARDISATION_ORGANISATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">EUROPEAN STANDARDISATION ORGANISATIONS</rdfs:label>
    <skos:definition xml:lang="en">European Standardisation Organisations (ESOs) are crucial entities operating within the framework of Regulation (EU) No 1025/2012. These organisations have been tasked by the European Commission with the critical responsibility of drafting harmonised standards specifically for high-risk AI systems and general-purpose AI models. Furthermore, European Standardisation Organisations serve as essential forums for engagement, as notified bodies are required to participate in or be represented within t</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STANDARDISATION_REQUEST"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_STANDARDS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROSPECTIVE_DEPLOYER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PROSPECTIVE DEPLOYER</rdfs:label>
    <skos:definition xml:lang="en">A natural or legal person intending to use an AI system under their authority.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EU_AI_ACT">
    <rdfs:label xml:lang="en">EU AI ACT</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING_REGISTRATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REAL-WORLD TESTING REGISTRATION</rdfs:label>
    <skos:definition xml:lang="en">Duty to register real-world testing in the EU database or according to Art 71(4), with exceptions for specific Annex III high-risk systems</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_49_4_"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_49_5_"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_71_4_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AWARENESS_COMMUNICATION_CAMPAIGNS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">AWARENESS COMMUNICATION CAMPAIGNS</rdfs:label>
    <skos:definition xml:lang="en">Duty of the AI Office to organize communication campaigns to raise awareness about obligations arising from the Regulation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CERTIFICATE_SUSPENSION_OR_WITHDRAWAL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CERTIFICATE SUSPENSION OR WITHDRAWAL</rdfs:label>
    <skos:definition xml:lang="en">A duty of a notified body to suspend or withdraw a certificate if requirements are not met, unless corrective action is taken.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STANDING_SUB_GROUPS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">STANDING SUB-GROUPS</rdfs:label>
    <skos:definition xml:lang="en">Internal bodies established by the Board (including ADCO) to facilitate cooperation among market surveillance and notifying authorities per Article 65(6)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TACIT_APPROVAL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">TACIT APPROVAL</rdfs:label>
    <skos:definition xml:lang="en">The condition where a testing plan is deemed approved if the market surveillance authority does not respond within 30 days</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SCHENGEN_INFORMATION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">SCHENGEN INFORMATION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The Schengen Information System (SIS) is a large-scale IT system dedicated to the management of security and borders. It is formally recognized as a relevant Union legislative act, specifically listed under Annex X of the applicable regulations governing its operation.</skos:definition>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1860"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1861"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1862"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFIDENTIALITY_RULES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CONFIDENTIALITY RULES</rdfs:label>
    <skos:definition xml:lang="en">Obligation for members of national competent authorities to refrain from actions incompatible with their duties and protect sensitive information.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CERTIFIED_COMPLIANCE_SERVICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CERTIFIED COMPLIANCE SERVICES</rdfs:label>
    <skos:definition xml:lang="en">Services provided by third parties to assist providers in meeting data governance obligations, including data training, validation, and testing verification.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION__PRE_MARKET_ACTIVITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION: PRE-MARKET ACTIVITIES</rdfs:label>
    <skos:definition xml:lang="en">"EXCLUSION: PRE-MARKET ACTIVITIES" refers to specific categories of work that fall outside the scope of the relevant regulations. According to Article 2(8), any research, testing, or development activities conducted prior to placing a product or service on the market or putting it into service are excluded from regulation. This encompasses the entirety of the pre-market phase, ensuring that the necessary preliminary work remains exempt.</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPORTER_OBLIGATION__INFORMATION_PROVISION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">IMPORTER OBLIGATION: INFORMATION PROVISION</rdfs:label>
    <skos:definition xml:lang="en">Importers must provide relevant competent authorities with necessary documentation (certificate, instructions, declaration) in a language easily understood by them</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__168_2013">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <rdfs:label xml:lang="en">REGULATION  EU  168 2013</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_35_OF_REGULATION__EU__2016_679">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 35 OF REGULATION (EU) 2016/679</rdfs:label>
    <skos:definition xml:lang="en">Article 35 of Regulation (EU) 2016/679, commonly known as the General Data Protection Regulation (GDPR), serves as the foundational provision governing Data Protection Impact Assessments (DPIAs). This article outlines the requirements and procedures for controllers to assess the impact of envisaged processing operations on the protection of personal data. By mandating DPIAs, the regulation ensures that organizations proactively identify and mitigate risks associated with data processing activiti</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_43_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(43)</rdfs:label>
    <skos:definition xml:lang="en">Definition of post-remote biometric identification system</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_MINIMISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">DATA MINIMISATION</rdfs:label>
    <skos:definition xml:lang="en">A principle of data protection requiring that only necessary personal data is processed, applicable throughout the AI system lifecycle.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFICATION_OF_LIST_OF_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NOTIFICATION OF LIST OF AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">Member States must notify the Commission and other Member States of the list of public authorities protecting fundamental rights by 2 November 2024</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRAINING_DATA_SUMMARY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TRAINING DATA SUMMARY</rdfs:label>
    <skos:definition xml:lang="en">Requirement for providers to draw up and make publicly available a sufficiently detailed summary of the content used for training a general-purpose AI model</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SIMPLIFIED_TECHNICAL_DOCUMENTATION_FORM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SIMPLIFIED TECHNICAL DOCUMENTATION FORM</rdfs:label>
    <skos:definition xml:lang="en">The Simplified Technical Documentation Form is a specific template established by the Commission for use by small and medium-sized enterprises (SMEs). This form is designed to facilitate the provision of technical documentation in a simplified format, as permitted under Article 11(1). By utilizing this standardized template, SMEs can streamline the process of submitting the necessary technical information required for regulatory compliance.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGISTRATION_IN_EU_DATABASE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REGISTRATION IN EU DATABASE</rdfs:label>
    <skos:definition xml:lang="en">The registration process within the EU database involves specific obligations for different stakeholders regarding AI systems.

Regarding providers of AI systems, there is a duty to register a system in the EU database if the provider has formally determined that the system is non-high-risk based on established exclusion conditions.

Additionally, the EU database serves as a platform for public authority deployers. Under Article 71, these deployers are required to register themselves, select the</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_71"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#JUDICIAL_OR_ADMINISTRATIVE_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">JUDICIAL OR ADMINISTRATIVE AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">An authority whose decision is binding and subject to judicial review, responsible for granting or rejecting authorisations for the use of post-remote biometric identification systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_9">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 9</rdfs:label>
    <skos:definition xml:lang="en">Article 9 outlines the mandatory requirements regarding risk management systems specifically designed for high-risk AI systems. This article establishes a regulatory framework that mandates the creation, implementation, documentation, and ongoing maintenance of a comprehensive risk management system. By requiring these processes, Article 9 ensures that organizations developing or operating high-risk AI systems have structured protocols in place to identify, assess, and mitigate potential risks t</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_26_8_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 26(8)</rdfs:label>
    <skos:definition xml:lang="en">Provision requiring data protection impact assessments to be summarized during registration</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_817">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2019/817</rdfs:label>
    <skos:definition xml:lang="en">Legislation establishing the interoperability framework for borders and visa systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PENALTIES_FOR_PROHIBITED_PRACTICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PENALTIES FOR PROHIBITED PRACTICES</rdfs:label>
    <skos:definition xml:lang="en">Administrative fines for non-compliance with prohibited AI practices under Article 5. Amount: up to EUR 35,000,000 or 7% of total worldwide annual turnover, whichever is higher</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_99"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NON_DISCRIMINATION_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">NON-DISCRIMINATION REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">The Non-Discrimination Requirement mandates that AI systems deployed within the domains of migration, asylum, and border control must operate without bias to ensure the protection and guarantee of fundamental human rights. This obligation necessitates proactive measures to ensure that these technologies do not perpetuate, amplify, or solidify historical patterns of discrimination. Consequently, the Non-Discrimination Requirement strictly prohibits the unfair treatment of individuals based on pro</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_7_3_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 7(3)</rdfs:label>
    <skos:definition xml:lang="en">Article 7(3) is a provision that empowers the European Commission to adopt delegated acts for the purpose of removing specific high-risk AI systems from the scope of Annex III, provided that certain conditions are met. This mechanism allows for the flexibility to adjust the classification of high-risk AI systems as the regulatory landscape and technology evolve.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_LITERACY_TRAINING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">AI LITERACY TRAINING</rdfs:label>
    <skos:definition xml:lang="en">Specific training required for persons responsible for human oversight to ensure they can adequately perform their tasks (Recital 91)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DEMONSTRATION_OF_CONFORMITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DEMONSTRATION OF CONFORMITY</rdfs:label>
    <skos:definition xml:lang="en">Upon reasoned request of a national competent authority, providers must demonstrate conformity of the system (Article 16(k)).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STANDING_SUB_GROUP_FOR_MARKET_SURVEILLANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">STANDING SUB-GROUP FOR MARKET SURVEILLANCE</rdfs:label>
    <skos:definition xml:lang="en">A sub-group of the Board acting as the administrative cooperation group (ADCO) for the Regulation, as per Article 30 of Regulation (EU) 2019/1020.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_30_OF_REGULATION__EU__2019_1020"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#APPOINTMENT_OF_AUTHORISED_REPRESENTATIVE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">APPOINTMENT OF AUTHORISED REPRESENTATIVE</rdfs:label>
    <skos:definition xml:lang="en">Providers established in third countries must, by written mandate, appoint an authorised representative established in the Union before making systems available.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FORMER_PROVIDER">
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TRANSITION_TO_HIGH_RISK_AI_SYSTEM"/>
    <rdfs:label xml:lang="en">FORMER PROVIDER</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_30_OF_REGULATION__EU__2019_1020">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 30 OF REGULATION (EU) 2019/1020</rdfs:label>
    <skos:definition xml:lang="en">Legal basis defining the administrative cooperation group (ADCO) which the standing sub-group for market surveillance acts as.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_COUNCIL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">EUROPEAN COUNCIL</rdfs:label>
    <skos:definition xml:lang="en">EU institution that has stated the objective of promoting a human-centric approach to AI and global leadership in ethical AI</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WRITTEN_PROOF">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">WRITTEN PROOF</rdfs:label>
    <skos:definition xml:lang="en">Documentation provided by the competent authority upon request, verifying the successful activities carried out by a provider or prospective provider in the sandbox</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_10_1__REGULATION__EU__NO_1025_2012">
    <rdfs:label xml:lang="en">ARTICLE 10 1  REGULATION  EU  NO 1025 2012</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WORKERS_CONTRACTUAL_RELATIONSHIP_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">WORKERS CONTRACTUAL RELATIONSHIP AI</rdfs:label>
    <skos:definition xml:lang="en">AI systems making decisions affecting terms of work-related relationships, promotion, or termination (Annex III 4(b))</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EMPLOYMENT__WORKERS__MANAGEMENT_AND_ACCESS_TO_SELF_EMPLOYMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_PROTECTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">FUNDAMENTAL RIGHTS PROTECTION</rdfs:label>
    <skos:definition xml:lang="en">The underlying objective of the AI Act requiring deployers to actively protect fundamental rights when using high-risk AI systems (Recital 92, 93)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_COPYRIGHT_LAW">
    <rdfs:label xml:lang="en">UNION COPYRIGHT LAW</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMPLOYMENT__WORKERS__MANAGEMENT_AND_ACCESS_TO_SELF_EMPLOYMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">EMPLOYMENT, WORKERS’ MANAGEMENT AND ACCESS TO SELF-EMPLOYMENT</rdfs:label>
    <skos:definition xml:lang="en">High-risk domain covering recruitment, selection, and performance evaluation in work-related relationships.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_ECOSYSTEM">
    <rdfs:label xml:lang="en">AI ECOSYSTEM</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_96">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 96</rdfs:label>
    <skos:definition xml:lang="en">Recital mandating fundamental rights impact assessments for deployers of high-risk AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_III_POINTS_6__7_AND_8">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">ANNEX III POINTS 6, 7 AND 8</rdfs:label>
    <skos:definition xml:lang="en">Specific categories of high-risk AI systems subject to designation of data protection authorities as market surveillance authorities</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VULNERABILITY_EXPLOITATION_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">VULNERABILITY EXPLOITATION AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI system exploiting vulnerabilities of persons due to age, disability, or social/economic situation to distort behavior and cause significant harm</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_CATEGORISATION_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">BIOMETRIC CATEGORISATION EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">The prohibition on biometric categorisation does not cover labelling or filtering of lawfully acquired biometric datasets or categorising biometric data in the area of law enforcement.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONCRETE_AND_IDENTIFIABLE_RISK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#SystemicRisk"/>
    <rdfs:label xml:lang="en">CONCRETE AND IDENTIFIABLE RISK</rdfs:label>
    <skos:definition xml:lang="en">Specific risk classification for general-purpose AI models that triggers the Scientific Panel to provide qualified alerts to the AI Office</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNACCEPTABLE_RISK_PROHIBITIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">UNACCEPTABLE RISK PROHIBITIONS</rdfs:label>
    <skos:definition xml:lang="en">Prohibitions of certain AI practices deemed to carry an unacceptable risk, applicable from 2 February 2025</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_1"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#articleReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">article reference</rdfs:label>
    <skos:definition xml:lang="en">The article number(s) in the EU AI Act where this concept is defined.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HumanOversight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Human Oversight</rdfs:label>
    <skos:definition xml:lang="en">Measures enabling humans to oversee and intervene in AI system operation. (Article 14)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OBJECTION_PERIOD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">OBJECTION PERIOD</rdfs:label>
    <skos:definition xml:lang="en">The term "OBJECTION PERIOD" refers to specific, defined timeframes during which authorized bodies—such as the Commission, Member States, the European Parliament, or the Council—may challenge or halt proposed actions or regulations. While the duration and purpose of these periods vary depending on the specific regulatory context, they all serve as a mechanism to pause implementation until concerns are addressed.

In the context of notified bodies, the objection period acts as a regulatory safegua</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURE_BASED_ON_INTERNAL_CONTROL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CONFORMITY ASSESSMENT PROCEDURE BASED ON INTERNAL CONTROL</rdfs:label>
    <skos:definition xml:lang="en">A specific conformity assessment procedure (Annex VI) involving verification of the quality management system, technical documentation, and post-market monitoring</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_VI"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_109">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 109</rdfs:label>
    <skos:definition xml:lang="en">Article 109 of the AI Act, which provides the amendment to Regulation (EU) 2019/2144 regarding the consideration of requirements for safety component AI systems.</skos:definition>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#REGULATION_2019_2144"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EFFECTIVE_OVERSIGHT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">EFFECTIVE OVERSIGHT</rdfs:label>
    <skos:definition xml:lang="en">A mandatory requirement for competent personnel to be involved in real-world testing to ensure proper supervision</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PRACTICAL_IMPLEMENTATION_GUIDELINES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PRACTICAL IMPLEMENTATION GUIDELINES</rdfs:label>
    <skos:definition xml:lang="en">Commission-issued guidance intended to provide further clarity on the practical implementation of exclusion conditions, including a comprehensive list of high-risk vs. non-high-risk use cases.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#meetsSystemicRiskThreshold">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">meetsSystemicRiskThreshold</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EARLY_APPLICATION_DATE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">EARLY APPLICATION DATE</rdfs:label>
    <skos:definition xml:lang="en">The date of 2 February 2025, when prohibitions and general provisions apply (Recital 179).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_17">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 17</rdfs:label>
    <skos:definition xml:lang="en">Recital defining 'remote biometric identification system', its variants (real-time/post), and exclusions for biometric verification.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REFERENCE_DATABASE_OF_PERSONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">REFERENCE DATABASE OF PERSONS</rdfs:label>
    <skos:definition xml:lang="en">The specific database of persons that must be appropriate for each use case in the context of remote biometric identification.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVIDER_OF_AI_SYSTEMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PROVIDER OF AI SYSTEMS</rdfs:label>
    <skos:definition xml:lang="en">An entity that intends to integrate a general-purpose AI model into their own AI systems, receiving documentation from the GPAI model provider.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK_THRESHOLD_RULE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">SYSTEMIC RISK THRESHOLD RULE</rdfs:label>
    <skos:definition xml:lang="en">Criterion under Article 51 defining the classification of GPAI models based on high impact capabilities or compute thresholds (10^25 FLOPs)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#belongsToCategory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">belongsToCategory</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OBLIGATION_TO_UPDATE_GUIDELINES">
    <rdfs:label xml:lang="en">OBLIGATION TO UPDATE GUIDELINES</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_40_AND_41">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 40 AND 41</rdfs:label>
    <skos:definition xml:lang="en">References to harmonised standards or common specifications conferring a presumption of conformity</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_SECURITY_AND_MILITARY_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">NATIONAL SECURITY AND MILITARY EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">AI systems developed and used solely for military, defence, or national security purposes are excluded from the scope of the Regulation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_IIICATEGORY">
    <rdfs:label xml:lang="en">ANNEX IIICATEGORY</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSLATION_COSTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TRANSLATION COSTS</rdfs:label>
    <skos:definition xml:lang="en">A significant cost factor for operators; Member States should facilitate the use of widely understood languages for documentation and communication to mitigate this</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_MIGRATION_POLYGRAPHS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR MIGRATION POLYGRAPHS</rdfs:label>
    <skos:definition xml:lang="en">Polygraph or similar tool used for migration, asylum, and border control management, identified in Annex III(7)(a)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_AI_TESTING_SUPPORT_STRUCTURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">UNION AI TESTING SUPPORT STRUCTURES</rdfs:label>
    <skos:definition xml:lang="en">Union AI Testing Support Structures are specialized entities designated by the European Commission. Their primary mandate is to perform essential testing tasks in accordance with Regulation (EU) 2019/1020. Beyond their testing responsibilities, these structures are tasked with providing independent, expert technical and scientific advice. Furthermore, these structures are established to support the enforcement of AI regulations and to reinforce the overall capacities of Member States concerning </skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_84"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GOVERNANCE_AND_ENFORCEMENT_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">GOVERNANCE AND ENFORCEMENT SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The system of supervision and governance that the Commission must evaluate (Recital 174)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION_OF_AI_PRACTICES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION OF AI PRACTICES</rdfs:label>
    <skos:definition xml:lang="en">The Prohibition of AI Practices encompasses a critical regulatory framework designed to safeguard individuals and society from harmful artificial intelligence technologies. At its core, this framework establishes an overarching requirement to ban specific AI systems deemed to violate human rights, undermine dignity, or pose excessive risks to fundamental freedoms, as detailed in Recitals 30, 31, and 33. To enforce these protections, Article 5 explicitly outlines a set of specific prohibitions re</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SYNTHETIC_CONTENT_GENERATOR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">SYNTHETIC CONTENT GENERATOR</rdfs:label>
    <skos:definition xml:lang="en">AI systems (including general-purpose AI systems) that generate synthetic audio, image, video, or text content, subject to marking obligations</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#MARKING_OF_SYNTHETIC_CONTENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AND_CONTROL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">MARKET SURVEILLANCE AND CONTROL</rdfs:label>
    <skos:definition xml:lang="en">The application of Regulation (EU) 2019/1020 to AI systems, including annual reporting to the Commission regarding prohibited practices and competition law interests</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROCEDURE_FOR_PROMPT_RECALL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROCEDURE FOR PROMPT RECALL</rdfs:label>
    <skos:definition xml:lang="en">The provider must establish a procedure to promptly recall the AI system if the testing is terminated or a serious incident occurs, per Article 60(7)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BENCHMARKS_AND_MEASUREMENT_METHODOLOGIES">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#METROLOGY_AND_BENCHMARKING_AUTHORITIES"/>
    <rdfs:label xml:lang="en">BENCHMARKS AND MEASUREMENT METHODOLOGIES</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_94">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 94</rdfs:label>
    <skos:definition xml:lang="en">Article 94 serves as a critical component within the legal framework governing AI regulation. It establishes essential procedural guarantees that are specifically referenced in Article 88, ensuring that these protections are upheld during the execution of enforcement actions. Furthermore, Article 94 is identified as a key element concerning the enforcement powers about which the AI Office is obligated to inform the Board, thereby playing a foundational role in both the procedural safeguards of e</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_70">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 70</rdfs:label>
    <skos:definition xml:lang="en">Article 70 serves as the regulatory provision governing the designation and operational framework of national competent authorities and single points of contact. This article establishes the legal requirements for appointing these entities, defining their roles and outlining the specific operational mandates they must fulfill to ensure effective compliance and coordination.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INFORMATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">INFORMATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The "INFORMATION OBLIGATION" encompasses specific transparency requirements aimed at both providers and deployers of regulated systems to ensure clarity and accountability.

For providers, the obligation mandates the clear disclosure of their identity. Specifically, providers are required to prominently indicate their name, their registered trade name or trademark, and a valid contact address. This information must be made available directly on the system itself, on its packaging, or within the </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EC__NO_300_2008">
    <rdfs:label xml:lang="en">REGULATION  EC  NO 300 2008</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PRODUCT_BASED_HIGH_RISK_CLASSIFICATION_RULE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">PRODUCT-BASED HIGH-RISK CLASSIFICATION RULE</rdfs:label>
    <skos:definition xml:lang="en">The criterion stating that if a product (e.g., machinery, toys, lifts) is a safety component and undergoes third-party conformity assessment, the AI within it is classified as high-risk.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_50"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_56">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 56</rdfs:label>
    <skos:definition xml:lang="en">Recital regarding classification of AI systems in education and vocational training as high-risk (Recital 56)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_50_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(50)</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 3(50)** serves as the formal definition and regulatory reference point for the term "Personal Data." It establishes the foundational legal meaning of what constitutes personal data within the relevant framework, ensuring that the term is clearly defined and consistently applicable. By acting as the definitive source for this terminology, Article 3(50) provides the necessary guidance and clarity for interpreting how personal information is categorized and handled under the applicable re</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION_ON_HORIZONTAL_CYBERSECURITY_REQUIREMENTS_FOR_PRODUCTS_WITH_DIGITAL_ELEMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION ON HORIZONTAL CYBERSECURITY REQUIREMENTS FOR PRODUCTS WITH DIGITAL ELEMENTS</rdfs:label>
    <skos:definition xml:lang="en">A legislative framework that defines essential cybersecurity requirements for products with digital elements, which high-risk AI systems may leverage for compliance.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#relatedTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">relatedTo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VOLUNTARY_COMPLIANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">VOLUNTARY COMPLIANCE</rdfs:label>
    <skos:definition xml:lang="en">Providers of high-risk AI systems are encouraged to start complying with obligations voluntarily during the transitional period (Recital 178).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUB_THRESHOLD_GPAI_MODEL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">SUB-THRESHOLD GPAI MODEL</rdfs:label>
    <skos:definition xml:lang="en">A general-purpose AI model that does not meet the high-impact capabilities threshold (Recital 63-64)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CYBERSECURITY_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CYBERSECURITY MEASURES</rdfs:label>
    <skos:definition xml:lang="en">Security protocols and measures implemented to protect the AI system, mandated as part of the technical documentation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGISTRATION_OBLIGATIONS">
    <rdfs:label xml:lang="en">REGISTRATION OBLIGATIONS</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#enforces">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">enforces</rdfs:label>
    <skos:definition xml:lang="en">Relates an authority to the obligations it enforces.</skos:definition>
    <rdfs:domain rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:range rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EMPLOYMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">EMPLOYMENT</rdfs:label>
    <skos:definition xml:lang="en">**EMPLOYMENT** is classified as one of the eight high-risk use case domains under the regulatory framework, specifically as defined in Annex III. This category encompasses a range of artificial intelligence systems designed to facilitate various professional processes. Specifically, these systems are utilized for recruitment procedures, the monitoring of employee performance, broader worker management, and the management of access to self-employment opportunities. As a high-risk domain, AI appli</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DOCUMENTATION_PRESERVATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DOCUMENTATION PRESERVATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The notifying authority's duty to take steps to ensure that the files of a notified body are kept and made available in the event of a suspension, restriction, or withdrawal of designation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RISK ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">A technical/organizational requirement to evaluate the risks associated with the serious incident as part of the investigation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OTHER_NOTIFIED_BODIES">
    <rdfs:label xml:lang="en">OTHER NOTIFIED BODIES</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_6_2_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 6(2)</rdfs:label>
    <skos:definition xml:lang="en">Article 6(2) serves as a critical provision within the regulatory framework for artificial intelligence, specifically regarding the categorization of high-risk AI systems. This article defines the scope and criteria used to identify these systems, directly referencing the list provided in Annex III of the regulation. By establishing these parameters, Article 6(2) plays a foundational role in determining which AI applications are subject to specific regulatory obligations, including the requireme</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_STANDARDISATION_ORGANISATION">
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
    <rdfs:label xml:lang="en">NATIONAL STANDARDISATION ORGANISATION</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPLIANCE_WITH_SECTION_2_REQUIREMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">COMPLIANCE WITH SECTION 2 REQUIREMENTS</rdfs:label>
    <skos:definition xml:lang="en">Providers must ensure their high-risk AI systems comply with the requirements set out in Section 2 of the AI Act (Article 16(a)).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AISYSTEM">
    <rdfs:label xml:lang="en">AISYSTEM</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CERTIFICATE_OF_CONFORMITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CERTIFICATE OF CONFORMITY</rdfs:label>
    <skos:definition xml:lang="en">A document issued by a notified body attesting to a system's conformity; its validity status is subject to specific conditions when the issuing body's designation is changed.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT__MIGRATION__ASYLUM_AND_BORDER_CONTROL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">LAW ENFORCEMENT, MIGRATION, ASYLUM AND BORDER CONTROL</rdfs:label>
    <skos:definition xml:lang="en">High-risk AI use case domains involving sensitive public sector activities</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_39">
    <rdfs:label xml:lang="en">ARTICLE 39</rdfs:label>
  </rdf:Description>
