    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SCIENTIFIC_PANEL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2019_1020"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STRUCTURED_DIALOGUE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_93"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_94"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_95_CODES_OF_CONDUCT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_CONDUCT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SME"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_LEVEL_EVALUATION_METHODOLOGY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_50"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#SCIENTIFIC_COMMUNITY"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#CIVIL_SOCIETY"/>
