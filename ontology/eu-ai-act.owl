    <rdfs:label xml:lang="en">COMPETENCE AND RESOURCE REQUIREMENTS</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXEMPTION_FOR_ARTISTIC_CREATIVE_WORK">
    <rdfs:label xml:lang="en">EXEMPTION FOR ARTISTIC CREATIVE WORK</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CONFLICT_OF_INTEREST_PREVENTION">
    <rdfs:label xml:lang="en">CONFLICT OF INTEREST PREVENTION</rdfs:label>
  </rdf:Description>
