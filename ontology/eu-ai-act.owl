   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GUIDELINES_FOR_QUALITY_MANAGEMENT_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">GUIDELINES FOR QUALITY MANAGEMENT SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The obligation for the Commission to develop specific guidelines detailing how microenterprises can fulfill quality management system requirements in a simplified manner</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PRODUCT_SAFETY_AND_CONSUMER_PROTECTION_RULES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PRODUCT SAFETY AND CONSUMER PROTECTION RULES</rdfs:label>
    <skos:definition xml:lang="en">Regulation is without prejudice to the rules laid down by other Union legal acts related to consumer protection and product safety. Defined in Article 2(9).</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_UNION_AVIATION_SAFETY_AGENCY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">EUROPEAN UNION AVIATION SAFETY AGENCY</rdfs:label>
    <skos:definition xml:lang="en">The European Union Aviation Safety Agency (EASA) is a regulatory body established by Regulation (EU) 2018/1139. It serves as the primary authority responsible for developing and implementing common rules and standards in the field of civil aviation across the European Union.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_ELECTION_OR_REFERENDUM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR ELECTION OR REFERENDUM</rdfs:label>
    <skos:definition xml:lang="en">AI systems intended to influence the outcome of an election or referendum or voting behaviour, typically classified as high-risk under Annex III</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#EXCLUSION_CONDITION__NON_EXPOSURE_TO_OUTPUT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CYBERSECURITY_BIOMETRIC_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">CYBERSECURITY BIOMETRIC SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">Biometric systems intended solely for enabling cybersecurity and personal data protection measures, explicitly excluded from high-risk classification (Recital 54)</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_19">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 19</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 19**

ARTICLE 19, within the context of the AI Act, serves as a provision with distinct functional responsibilities concerning the regulation of artificial intelligence systems.

Primarily, ARTICLE 19 acts as an amendment to an existing regulation. As amended, it mandates that when the European Commission adopts delegated acts concerning AI systems classified as safety components, it must explicitly take into account the requirements outlined in Chapter III, Section 2 of the AI Act. Th</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_IN_CHAPTER_III_SECTION_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DELEGATED_ACTS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_VI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ANNEX VI</rdfs:label>
    <skos:definition xml:lang="en">Annex VI serves as a foundational regulatory component that details the conformity assessment procedure based on internal control. This specific procedure is established as a critical mechanism for demonstrating compliance with the requirements set forth for high-risk AI systems. By outlining this internal control-based approach, Annex VI provides the necessary framework for organizations to verify that their high-risk AI systems meet the mandated standards.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">AI REGULATORY SANDBOX</rdfs:label>
    <skos:definition xml:lang="en">An **AI Regulatory Sandbox** is a controlled environment established by national competent authorities designed to foster innovation by facilitating the development, testing, training, and validation of innovative AI systems. Governed by provisions such as Article 3(55), Article 57, and Article 58, this framework provides a structured space for providers to refine their systems under regulatory oversight and supervision before they are placed on the market.

The primary objective of the AI Regul</skos:definition>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#COMMON_RULES_FOR_AI_REGULATORY_SANDBOXES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPETENT_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SANDBOX_PLAN"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_57"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INNOVATIVE_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SME"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROSPECTIVE_PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_CONDUCT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFIED_BODY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STANDARDISATION_ORGANISATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_DATA_PROTECTION_SUPERVISOR"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_IN_REAL_WORLD_CONDITIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_58"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_III_SECTION_2_REQUIREMENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">CHAPTER III SECTION 2 REQUIREMENTS</rdfs:label>
    <skos:definition xml:lang="en">Technical and organisational requirements for AI systems, the voluntary application of which is encouraged by codes of conduct</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVIDER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PROVIDER</rdfs:label>
    <skos:definition xml:lang="en">A "Provider" is defined as any natural or legal person, public authority, agency, or other body that develops an AI system or a general-purpose AI (GPAI) model—or has one developed—and subsequently places it on the market or puts it into service under its own name or trademark. This definition encompasses entities regardless of whether the system is provided for payment or free of charge. Furthermore, the definition includes entities established in third countries if the output of their system i</skos:definition>
