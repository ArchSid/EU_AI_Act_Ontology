  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NON_HIGH_RISK_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">NON-HIGH-RISK AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">Any AI system not classified as high-risk, for which providers are encouraged to voluntarily create and adhere to codes of conduct</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2016_680">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE (EU) 2016/680</rdfs:label>
    <skos:definition xml:lang="en">**Directive (EU) 2016/680**, often referred to as the Law Enforcement Directive (LED), is a critical legal instrument of the European Parliament and of the Council established to govern the protection of natural persons regarding the processing of personal data. Specifically, it concerns the processing of such data by competent authorities for the purposes of the prevention, investigation, detection, or prosecution of criminal offences, or the execution of criminal penalties, including the safeg</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INVESTIGATIVE_AND_CORRECTIVE_POWERS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VERY_LARGE_ONLINE_SEARCH_ENGINE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">VERY LARGE ONLINE SEARCH ENGINE</rdfs:label>
    <skos:definition xml:lang="en">Service provider regulated under Regulation (EU) 2022/2065, subject to specific risk-management frameworks when embedding AI systems or models</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_FRAMEWORK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">FINES</rdfs:label>
    <skos:definition xml:lang="en">Fines are financial penalties imposed on providers to ensure accountability and compliance within the regulatory framework. These penalties are enforced under two primary provisions:

*   **Article 99:** Fines are levied against providers for failure to comply with established regulatory requirements. Furthermore, these penalties specifically target providers that engage in the deliberate misclassification of systems or attempt to circumvent high-risk classification protocols.
*   **Article 101:</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_99"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_101"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ELECTRONIC_INSTRUCTIONS_FOR_USE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ELECTRONIC INSTRUCTIONS FOR USE</rdfs:label>
    <skos:definition xml:lang="en">**ELECTRONIC INSTRUCTIONS FOR USE** serve as a mandatory documentation requirement for high-risk AI systems, ensuring that users are provided with necessary information regarding the system's operation and usage. However, this requirement is not universal; specific exemptions exist for AI systems deployed within the sectors of law enforcement, migration, asylum, and border control. In particular, these systems, often categorized under Annex III of relevant AI regulations, are relieved from the o</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HUMAN_OVERSIGHT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">HUMAN OVERSIGHT</rdfs:label>
    <skos:definition xml:lang="en">**Human Oversight**

Human oversight acts as a fundamental governance arrangement and mandatory mitigation measure, primarily concerning the deployment of high-risk AI systems. As established under Article 14, it is a core requirement that mandates AI systems be designed to ensure that natural persons can effectively monitor, understand, intervene in, and override system outputs. The overarching goal of these measures is to mitigate risks to health, safety, and fundamental rights, and to prevent</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_73"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_14"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#THIRD_PARTY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">THIRD PARTY</rdfs:label>
    <skos:definition xml:lang="en">Entity that supplies tools, services, components, or processes integrated into a high-risk AI system</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINANCIAL_INTELLIGENCE_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">FINANCIAL INTELLIGENCE EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">Condition under which AI systems used by financial intelligence units for administrative tasks are not classified as high-risk</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#subjectTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">subject to</rdfs:label>
    <skos:definition xml:lang="en">Relates an AI system to an applicable obligation.</skos:definition>
    <rdfs:domain rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:range rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_42_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(42)</rdfs:label>
    <skos:definition xml:lang="en">Definition of real-time remote biometric identification system</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#POST_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">POST REMOTE BIOMETRIC IDENTIFICATION SYSTEM</rdfs:label>
    <rdfs:label xml:lang="en">POST-REMOTE BIOMETRIC IDENTIFICATION SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">A remote biometric identification system where the biometric data has already been captured prior to identification.</skos:definition>
    <skos:definition xml:lang="en">A "Post-Remote Biometric Identification System" is classified as a high-risk AI system designed to identify individuals after an event has occurred, as opposed to real-time systems. As defined in Article 3(43) and Recital 17, these systems operate by capturing, comparing, and identifying biometric data after a significant delay. This process utilizes pre-existing material, such as pictures or video footage generated prior to the system's use, rather than live streams.

These systems serve specif</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_17"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_95"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_43_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_DATA_PROCESSING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INDISCRIMINATE_SURVEILLANCE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_TIME_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROPORTIONALITY"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CLOSED_DATA_SET"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISATION_FOR_POST_REMOTE_BIOMETRIC_IDENTIFICATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISATION_OBLIGATION"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATED_FINANCIAL_INSTITUTIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">REGULATED FINANCIAL INSTITUTIONS</rdfs:label>
    <skos:definition xml:lang="en">Entities such as credit institutions, insurance and re-insurance undertakings, and insurance intermediaries subject to Union financial services law, which may use AI systems</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNAL_GOVERNANCE_AND_RISK_MANAGEMENT"/>
    <euai:reducedObligationsApplyTo rdf:resource="https://w3id.org/euaiact/ontology#QUALITY_MANAGEMENT_SYSTEM"/>
    <euai:reducedObligationsApplyTo rdf:resource="https://w3id.org/euaiact/ontology#POST_MARKETING_MONITORING"/>
    <euai:reducedObligationsApplyTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DELEGATED_ACTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#DelegatedAct"/>
    <rdfs:label xml:lang="en">DELEGATED ACTS</rdfs:label>
    <skos:definition xml:lang="en">Delegated Acts refer to specific legislative instruments adopted by the European Commission within the framework of the AI Act. These acts serve two critical functions regarding the regulation of artificial intelligence. First, they provide the Commission with the authority to amend and update the classification conditions for high-risk AI systems, specifically those outlined in Article 6(3) of the AI Act. This ensures that the categorization of high-risk systems remains current and adaptable to</skos:definition>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_6"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_IN_CHAPTER_III_SECTION_2"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADOPTION_OF_TECHNICAL_SPECIFICATIONS_AND_STANDARDS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ADOPTION OF TECHNICAL SPECIFICATIONS AND STANDARDS</rdfs:label>
    <skos:definition xml:lang="en">The European Commission must take into account Chapter III Section 2 requirements when adopting technical specifications and standards</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_105"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_10">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 10</rdfs:label>
    <skos:definition xml:lang="en">Article 10 pertains to the establishment of regulations concerning data and data governance specifically for high-risk artificial intelligence (AI) systems. As a governing provision, this article outlines the necessary standards and requirements that must be adhered to regarding the management, quality, and oversight of data used within the development and operation of high-risk AI technologies.</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INPUT_DATA_RELEVANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INPUT DATA RELEVANCE</rdfs:label>
    <skos:definition xml:lang="en">The "INPUT DATA RELEVANCE" requirement establishes a specific responsibility for AI deployers. Under this obligation, deployers are mandated to ensure that the input data utilized by an AI system is both relevant and representative of the context in which the AI is intended to operate. This requirement, however, is conditional: it applies specifically to those instances where the deployer exercises control over the selection or processing of the input data. In essence, whenever a deployer has th</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LARGE_SCALE_IT_SYSTEMS">
    <rdfs:label xml:lang="en">LARGE SCALE IT SYSTEMS</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ACCESSIBILITY_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ACCESSIBILITY REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">**ACCESSIBILITY REQUIREMENT**

An Accessibility Requirement represents a set of mandatory standards established to ensure that products and services remain fully accessible to all individuals, with a specific focus on promoting equal access for persons with disabilities. These requirements are formalized through key legal frameworks, most notably Directive (EU) 2016/2102 and Directive (EU) 2019/882. Under these mandates, providers are under a strict obligation to ensure full compliance, thereby </skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2019_882"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VIRTUAL_REALITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">VIRTUAL REALITY</rdfs:label>
    <skos:definition xml:lang="en">Technology that facilitates manipulative AI practices by controlling stimuli presented to persons.</skos:definition>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#MANIPULATIVE_OR_DECEPTIVE_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ETHICAL_PRINCIPLES_FOR_TRUSTWORTHY_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ETHICAL PRINCIPLES FOR TRUSTWORTHY AI</rdfs:label>
    <skos:definition xml:lang="en">The Ethical Principles for Trustworthy AI consist of a set of seven non-binding guidelines designed to steer the development, drafting of codes of practice, and overall design of coherent artificial intelligence systems. These principles act as a foundational framework for ensuring AI technologies are developed and deployed responsibly.

The seven core principles are as follows:

1.  **Human Agency and Oversight:** AI systems should support human autonomy and decision-making, ensuring appropriat</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_98_2_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 98(2)</rdfs:label>
    <skos:definition xml:lang="en">Article 98(2) serves as the legal provision that establishes and governs the examination procedure used by the European Commission for the adoption of implementing acts. This mechanism is central to the regulatory framework, ensuring a consistent approach when the Commission is tasked with finalizing technical or administrative details.

The scope of Article 98(2) is broad and encompasses various specific applications across different regulatory contexts. It is explicitly identified as the gover</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MODEL_WEIGHTS_AND_ARCHITECTURE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MODEL WEIGHTS AND ARCHITECTURE</rdfs:label>
    <skos:definition xml:lang="en">Specific information about model parameters and usage that must be publicly available for a model to be considered transparent under an open-source licence, as described in Recital 102 and 104</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPLAINT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Complaint"/>
    <rdfs:label xml:lang="en">COMPLAINT</rdfs:label>
    <skos:definition xml:lang="en">A **COMPLAINT** acts as a formal procedural instrument used to report alleged infringements of the AI Act. This mechanism is utilized by natural or legal persons, including downstream providers and other relevant stakeholders, to seek recourse or initiate oversight regarding regulatory violations.

The **COMPLAINT** functions through two primary channels depending on the nature of the alleged infringement:

1.  **General Infringements:** Any natural or legal person with sufficient grounds may su</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_85"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER_OF_GENERAL_PURPOSE_AI_MODEL"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_74_9_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 74(9)</rdfs:label>
    <skos:definition xml:lang="en">Article specifying the market surveillance authorities designated to access technical documentation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COPYRIGHT_COMPLIANCE_POLICY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">COPYRIGHT COMPLIANCE POLICY</rdfs:label>
    <skos:definition xml:lang="en">The **COPYRIGHT COMPLIANCE POLICY** represents a mandatory obligation for providers of General-Purpose AI (GPAI) models. This policy requires providers to establish and implement internal procedures ensuring full adherence to Union copyright law and related rights throughout the entire training process of their AI models. 

Central to this policy is the necessity to respect and comply with specific legal frameworks regarding the reservation of rights. Specifically, providers must align their pra</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2019_790"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_4_3__OF_DIRECTIVE__EU__2019_790"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#hasObligation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has obligation</rdfs:label>
    <skos:definition xml:lang="en">Relates an actor to an obligation they must fulfil.</skos:definition>
    <rdfs:domain rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:range rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_95_CODES_OF_CONDUCT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#CodeOfPractice"/>
    <rdfs:label xml:lang="en">ARTICLE 95 CODES OF CONDUCT</rdfs:label>
    <skos:definition xml:lang="en">Voluntary instruments encouraged by the AI Office and Member States for non-high-risk AI systems to adopt requirements from Chapter III, Section 2</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_III_SECTION_2_REQUIREMENTS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPORTER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">IMPORTER</rdfs:label>
    <skos:definition xml:lang="en">An **IMPORTER** is defined as any natural or legal person established or located within the European Union that introduces AI systems from a third country (a country outside the Union) onto the Union market.

In the context of the AI regulatory framework, an **IMPORTER** fulfills a crucial role in the value chain by bridging the gap between foreign providers and the Union market. Specifically, the designation applies to entities that perform one of the following actions:

*   Placing a high-risk</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER_CLASSIFICATION_RULE"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DECLARATION_OF_CONFORMITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CE_MARKING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INSTRUCTIONS_FOR_USE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_43"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_11"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_IV"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_47"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_22_1_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#IMPORTER_OBLIGATION__VERIFICATION_AND_NON_CONFORMITY_REPORTING"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#IMPORTER_OBLIGATION__DOCUMENTATION_AND_RECORDS"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#IMPORTER_OBLIGATION__STORAGE_AND_TRANSPORT"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#IMPORTER_OBLIGATION__INFORMATION_PROVISION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#IMPORTER_OBLIGATION__IDENTIFICATION_LABELING"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#COMPETENT_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SME">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">SME</rdfs:label>
    <skos:definition xml:lang="en">Small and medium-sized enterprises (SMEs), including start-ups, are central to the regulatory framework surrounding artificial intelligence. Recognizing their limited legal and administrative capacities, the AI Act mandates that the specific needs of these entities be considered by the AI Office and Member States, as outlined in Articles 95 and 96. To prevent excessive burdens and high compliance costs, the regulation provides various support mechanisms and relief measures designed to ensure SME</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER_OF_GENERAL_PURPOSE_AI_MODELS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MODEL_MODIFICATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_STANDARDS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOXES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SIMPLIFIED_TECHNICAL_DOCUMENTATION_FORM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_FINE"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_STANDARD"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#FEES_FOR_CONFORMITY_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SANDBOX_REPORTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SANDBOX REPORTING</rdfs:label>
    <skos:definition xml:lang="en">National competent authorities must submit annual and final reports to the AI Office and the Board regarding sandbox progress, results, best practices, and lessons learned.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TECHNICAL DOCUMENTATION</rdfs:label>
    <skos:definition xml:lang="en">**TECHNICAL DOCUMENTATION** refers to a comprehensive and mandatory set of records that providers must create and maintain to demonstrate that an AI system complies with the requirements set forth in the AI Act. This documentation serves as a critical tool for regulatory oversight, conformity assessment, and post-market monitoring, allowing competent authorities to evaluate the system’s design, development, and overall safety.

For high-risk AI systems, as mandated by Article 11(1) and detailed </skos:definition>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_OFFICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_11"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_IV"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFIED_BODY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_HARMONISATION_LEGISLATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_11_1_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_III__SECTION_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_14"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_13_3_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_SET_OUT_IN_CHAPTER_III__SECTION_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HUMAN_OVERSIGHT_MEASURES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_GOVERNANCE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HUMAN_OVERSIGHT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CYBERSECURITY_MEASURES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#VALIDATION_AND_TESTING_PROCEDURES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING_PLAN"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_53_1__A_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_XI"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_72"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ANNEXES"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_83"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DEPLOYER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">DEPLOYER</rdfs:label>
    <skos:definition xml:lang="en">A "DEPLOYER" is defined as any natural or legal person—including public authorities, agencies, or other bodies—that operates an AI system under their authority. This definition expressly excludes instances where an AI system is used in the course of a personal, non-professional activity. The classification of a DEPLOYER applies to entities established within the European Union, as well as those established in third countries, provided the output of the AI system they operate is intended for use </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_CONTROLLER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_LITERACY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MANIPULATIVE_OR_DECEPTIVE_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INSTRUCTIONS_FOR_USE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_IDENTIFICATION_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ENHANCED_HUMAN_OVERSIGHT_REQUIREMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HUMAN_OVERSIGHT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECORD_KEEPING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DATABASE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#WRITTEN_AGREEMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PERSONAL_NON_PROFESSIONAL_ACTIVITY_EXCLUSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STOP_BUTTON"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MONITORING_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SERIOUS_INCIDENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INPUT_DATA_RELEVANCE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SUSPENSION_OF_USE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_PROTECTION_IMPACT_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#IMPORTER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DISTRIBUTOR"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2016_680"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INFORMATION_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2016_679"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1725"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AGREEMENT_ON_ROLES_AND_RESPONSIBILITIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DATABASE_DATA_ENTRY_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_IN_REAL_WORLD_CONDITIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_CONDUCT"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_13"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_MANIPULATIVE_AI_PRACTICES"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER_CLASSIFICATION_RULE"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_73"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#MONITORING_OF_THE_PERFORMANCE"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#INFORMATION_OBLIGATION_FOR_WORKERS"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OBLIGATION_TO_NATURAL_PERSONS"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#RIGHT_TO_AN_EXPLANATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#MONITORING_OF_THE_FUNCTIONING"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#INSTRUCTIONS_OF_USE"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#AI_LITERACY_TRAINING"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#INFORMATION_AND_CONSULTATION_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#IMPACT_ASSESSMENT"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#ARTIFICIAL_CONTENT_DISCLOSURE_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION_IN_EU_DATABASE"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#DEEPFAKE_DISCLOSURE_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#MONITORING_OF_SYSTEM_OPERATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION__RISK_"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION__SERIOUS_INCIDENT_"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#SERIOUS_INCIDENT_REPORTING"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#LOG_KEEPING"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#WORKER_INFORMATION_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISATION_FOR_POST_REMOTE_BIOMETRIC_IDENTIFICATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#WORKERS__REPRESENTATIVES"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#AFFECTED_WORKERS"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#ANNUAL_REPORTING_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_TO_MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#RIGHT_TO_EXPLANATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION_OF_TESTING"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_DATA_PROTECTION_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CERTIFICATE_TRANSFER_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">CERTIFICATE TRANSFER OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">When a notified body ceases activity, certificates may remain valid for nine months if another notified body assumes responsibility and completes a full assessment</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_36"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_35">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 35</rdfs:label>
    <skos:definition xml:lang="en">A section of the Regulation addressing the general application and use of real-time remote biometric identification systems.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_TIME_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RiskCategory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Risk Category</rdfs:label>
    <skos:definition xml:lang="en">A level of risk under the EU AI Act classification framework.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFIED_BODY_STAFF">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">NOTIFIED BODY STAFF</rdfs:label>
    <skos:definition xml:lang="en">Personnel employed by or working for notified bodies, bound by professional secrecy obligations regarding information obtained during their tasks</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROFESSIONAL_SECRECY_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNUAL_REPORTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ANNUAL REPORTING</rdfs:label>
    <skos:definition xml:lang="en">Requirement for national authorities to submit reports to the Commission regarding the use of biometric systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINANCIAL_AND_HUMAN_RESOURCES_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">FINANCIAL AND HUMAN RESOURCES ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">The duty of Member States to report to the Commission on the status and adequacy of the financial and human resources of national competent authorities every two years.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RIGHTSHOLDER">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">RIGHTSHOLDER</rdfs:label>
    <skos:definition xml:lang="en">Entity or person holding copyright and related rights over works, authorized to reserve rights against text and data mining under Directive (EU) 2019/790</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RESERVATION_OF_RIGHTS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADMINISTRATION_OF_JUSTICE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">ADMINISTRATION OF JUSTICE</rdfs:label>
    <skos:definition xml:lang="en">The Administration of Justice is classified as a high-risk domain regarding the implementation of artificial intelligence. In this context, AI systems utilized by judicial authorities are subject to strict scrutiny because of their significant potential impact on fundamental rights, specifically the right to a fair trial and the provision of an effective remedy. This high-risk classification encompasses a broad spectrum of applications, including the use of AI for legal research, the interpretat</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_108">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 108</rdfs:label>
    <skos:definition xml:lang="en">Article amending Regulation (EU) 2018/1139 regarding AI safety components</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1139"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DOCUMENTATION_KEEPING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DOCUMENTATION KEEPING</rdfs:label>
    <skos:definition xml:lang="en">Under the framework of "DOCUMENTATION KEEPING," providers are subject to specific obligations regarding the retention of essential records as stipulated in Article 18. This requirement mandates that providers maintain comprehensive technical documentation, as well as quality management records and conformity declarations. These materials must be kept at the disposal of relevant authorities for a period of 10 years following the product's placement on the market to ensure ongoing regulatory compl</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_18"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REPORTING_DEADLINE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REPORTING DEADLINE</rdfs:label>
    <skos:definition xml:lang="en">The requirement to report serious incidents not later than 15 days after the provider or deployer becomes aware of the incident (Article 73(2)).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_15">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 15</rdfs:label>
    <skos:definition xml:lang="en">Article 15 establishes mandatory requirements concerning the accuracy, robustness, and cybersecurity of high-risk AI systems. This article serves as a key reference for ensuring that such systems meet necessary standards in these three critical areas to maintain safety, reliability, and security throughout their operational lifecycle.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TransparencyObligation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Transparency Obligation</rdfs:label>
    <skos:definition xml:lang="en">Obligations to inform users that they are interacting with an AI system. (Article 50)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_75_3_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 75(3)</rdfs:label>
    <skos:definition xml:lang="en">Article regarding the powers of the AI Office and national competent authorities, referenced in Article 88(2)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SECURE_NON_PUBLIC_REGISTRATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SECURE NON-PUBLIC REGISTRATION</rdfs:label>
    <skos:definition xml:lang="en">Specific obligation for certain high-risk AI systems (law enforcement, migration, etc.) to be registered in a secure, non-public section of the EU database rather than the public section</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_VIII"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_IX"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_71"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HUMAN_AGENCY_AND_OVERSIGHT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">HUMAN AGENCY AND OVERSIGHT</rdfs:label>
    <skos:definition xml:lang="en">The requirement that AI systems act as tools that respect human dignity, autonomy, and function under human control</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ETHICAL_PRINCIPLES_FOR_TRUSTWORTHY_AI"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRICS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">BIOMETRICS</rdfs:label>
    <skos:definition xml:lang="en">**BIOMETRICS** are classified as a high-risk AI system domain under Annex III of the EU AI Act. This domain encompasses AI systems designed for remote biometric identification, biometric categorisation, and emotion recognition. As a high-risk area, these technologies are subject to stringent oversight and specific market surveillance powers, as highlighted in Recital 54.

Due to their classification as high-risk, AI systems used for biometrics are subject to rigorous regulatory standards. Unlike</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_RULES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_III"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_CATEGORISATION_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSPARENCY_DOCUMENTATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TRANSPARENCY DOCUMENTATION</rdfs:label>
    <skos:definition xml:lang="en">Transparency Documentation refers to the essential information that general-purpose AI model providers are legally obligated to supply to downstream providers who integrate these models into their own AI systems. As outlined in Article 53(1)(b) of the applicable regulations and detailed in Annex XII, this documentation serves as a critical bridge of information between the original developers and those applying the technology in various use cases.

This documentation is comprehensive in scope, e</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_XII"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFYING_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">NOTIFYING AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">The **Notifying Authority** is a designated national competent authority established by each European Union Member State, playing a critical role in the oversight of conformity assessment procedures under the AI Act. Specifically mandated by Article 70(1) and Article 28 of the Regulation, the **Notifying Authority** is responsible for the assessment, designation, notification, and continuous monitoring of conformity assessment bodies, often referred to as "notified bodies."

To ensure the integr</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MEMBER_STATES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_BODY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFIED_BODY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_28"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_ACCREDITATION_BODY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPETENT_PERSONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#APPLICATION_FOR_NOTIFICATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFLICT_OF_INTEREST_PREVENTION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SEGREGATION_OF_DUTIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFIDENTIALITY_REQUIREMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPETENCE_EVIDENCE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ELECTRONIC_NOTIFICATION_TOOL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DESIGNATION_MANAGEMENT_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_30"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_CONSULTANCY"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#COMPETENT_PERSONNEL_REQUIREMENT"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#INVESTIGATION_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#DOCUMENTATION_PRESERVATION_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EU_DATABASE_FOR_HIGH_RISK_AI_SYSTEMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EU DATABASE FOR HIGH-RISK AI SYSTEMS</rdfs:label>
    <skos:definition xml:lang="en">A database set up and maintained by the Commission containing information on high-risk AI systems and specific other AI systems as required by the Act</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_71"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INFORMED_CONSENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">INFORMED CONSENT</rdfs:label>
    <skos:definition xml:lang="en">Informed Consent is a critical regulatory requirement mandated for individuals participating in real-world testing. Defined under Article 3(59) as a subject's voluntary and unambiguous expression of willingness to participate, Informed Consent ensures that subjects are fully aware of all relevant aspects before agreeing to take part.

Prospective providers are obligated to obtain this consent from natural persons prior to their participation in testing under real-world conditions. This process m</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_61"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">MARKET SURVEILLANCE AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">Market Surveillance Authorities are national bodies tasked with the responsibility of overseeing and enforcing market regulations. These authorities play a critical role in cross-border market surveillance, a process in which they receive essential support from a dedicated scientific panel to enhance the effectiveness of their operations.

Furthermore, Market Surveillance Authorities are empowered with specific access rights to information that is registered within the European Union database, a</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_COOPERATION_GROUP"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DATABASE_FOR_HIGH_RISK_AI_SYSTEMS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2016_797">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE (EU) 2016/797</rdfs:label>
    <skos:definition xml:lang="en">Directive (EU) 2016/797 is a legislative act focused on the interoperability of the rail system within the European Union. Its primary objective is to harmonize and streamline technical and operational standards across member states to ensure that rail systems can function seamlessly together.

In addition to its foundational purpose regarding railway interoperability, Directive (EU) 2016/797 has been subject to updates to reflect modern technological advancements. Specifically, the directive wa</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_58">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 58</rdfs:label>
    <skos:definition xml:lang="en">Article 58 of the AI Act is a regulatory provision that serves two primary functions: establishing the framework for AI regulatory sandboxes and dictating specific considerations for safety-critical AI systems.

First, Article 58 acts as the governing provision for AI regulatory sandboxes. It outlines the detailed arrangements and procedures required for their operation, ensuring that these sandboxes function effectively within the broader AI regulatory framework.

Second, Article 58 has been am</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_IN_CHAPTER_III_SECTION_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DELEGATED_ACTS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">NATIONAL COMPETENT AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">A National Competent Authority (NCA) is a regulatory or enforcement body designated by a Member State to oversee the application, implementation, and enforcement of the AI Act at the national level. These entities act as the primary interface between national jurisdictions and the European Union’s regulatory framework for artificial intelligence.

The scope of a National Competent Authority is broad and multifaceted. Primarily, they are responsible for ensuring compliance with the AI Act, which </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFIED_BODY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_MITIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MEMBER_STATES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_AND_EXPERIMENTATION_FACILITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_DIGITAL_INNOVATION_HUB"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STANDARDISATION_ORGANISATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_DATA_PROTECTION_SUPERVISOR"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DESIGNATION_MANAGEMENT_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CERTIFICATE_OF_CONFORMITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_OFFICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BOARD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_PROTECTION_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SUSPENSION_OF_TESTING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CROSS_BORDER_COOPERATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#OTHER_COMPETENT_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ANNUAL_REPORT_ON_AI_REGULATORY_SANDBOXES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TESTING_IN_REAL_WORLD_CONDITIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFIDENTIALITY_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CYBERSECURITY_REQUIREMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPETENCE_AND_RESOURCE_REQUIREMENTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GUIDANCE_AND_ADVICE_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONSULTATION_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SME"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_20_OF_REGULATION__EU__2019_1020"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OF_SERIOUS_INCIDENTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SERIOUS_INCIDENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_CENTRAL_BANK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INFORMATION_PROVISION"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_R23_OF_ANNEX_I_TO_DECISION_768_2008_EC"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_70"/>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#DEMONSTRATION_OF_CONFORMITY"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#SANDBOX_REPORTING"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#OVERSIGHT_OF_SIGNIFICANT_RISKS"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#NOTIFYING_AUTHORITY"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CONFIDENTIAL_INFORMATION_EXCHANGE"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_MISLEADING_INFORMATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EDUCATION_AND_TRAINING_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EDUCATION AND TRAINING AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">**EDUCATION AND TRAINING AI SYSTEM**

An Education and Training AI System encompasses various technological tools designed to evaluate learning outcomes, assess educational levels, and monitor student behavior during testing environments. Due to their significant potential to influence an individual's academic progress and overall life trajectory, these systems are classified as high-risk. This classification reflects the critical nature of the decisions they facilitate, such as grading, admissi</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EDUCATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NON_DISCRIMINATION_REQUIREMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NON_DISCRIMINATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_MEDICAL_OR_SAFETY_PURPOSES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">EXCLUSION FOR MEDICAL OR SAFETY PURPOSES</rdfs:label>
    <skos:definition xml:lang="en">The "EXCLUSION FOR MEDICAL OR SAFETY PURPOSES" refers to a specific exception within regulatory frameworks concerning the use of emotion recognition AI. Under this provision, systems that are placed on the market strictly for medical or safety reasons are exempt from the general prohibition against emotion recognition AI. One prominent example of a permissible application under this exclusion is the use of such technology for therapeutic purposes, as outlined in Recital 44. Consequently, while e</skos:definition>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_EMOTION_RECOGNITION_AI"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERNATIONAL_ORGANISATIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">INTERNATIONAL ORGANISATIONS</rdfs:label>
    <skos:definition xml:lang="en">**INTERNATIONAL ORGANISATIONS**

International organisations are excluded from the scope of the Regulation when they are operating within the framework of cooperation or international agreements specifically related to law enforcement and judicial cooperation. This exclusion is conditional, applying only when these foreign organisations demonstrate that they provide adequate safeguards during their operations.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EXCLUSION_FOR_MILITARY__DEFENCE_AND_NATIONAL_SECURITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNATIONAL_COOPERATION_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_55">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 55</rdfs:label>
    <skos:definition xml:lang="en">Article 55 establishes the regulatory framework and specific requirements for providers of general-purpose AI (GPAI) models that are classified as presenting systemic risks. This article outlines the obligations these providers must adhere to, ensuring that models with significant impact or potential for systemic disruption are managed responsibly and safely within the regulatory landscape.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AUTOMATICALLY_GENERATED_LOGS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">AUTOMATICALLY GENERATED LOGS</rdfs:label>
    <skos:definition xml:lang="en">Logs generated by high-risk AI systems that providers must keep for at least six months, governed by Article 19.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_19"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VOLUNTARY_MODEL_CONTRACTUAL_TERMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">VOLUNTARY MODEL CONTRACTUAL TERMS</rdfs:label>
    <skos:definition xml:lang="en">Non-mandatory contractual clauses developed by the Commission to facilitate cooperation between providers and third-party suppliers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ANNEX_III_USE_CASE_RULE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">ANNEX III USE CASE RULE</rdfs:label>
    <skos:definition xml:lang="en">The **ANNEX III USE CASE RULE** functions as a regulatory classification mechanism within the context of AI governance. This rule serves as the criterion for identifying and categorizing Artificial Intelligence systems as "high-risk" by default, provided they fall within the specific domains enumerated in Annex III of the relevant regulatory framework.

These high-stakes domains encompass critical areas of societal importance, including but not limited to education, employment, and the provision</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#EDUCATION_AND_TRAINING_AI_SYSTEM"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#EMPLOYMENT_AND_WORKERS_MANAGEMENT_AI_SYSTEM"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#ESSENTIAL_PUBLIC_SERVICES_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NON_BINDING_GUIDANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">NON-BINDING GUIDANCE</rdfs:label>
    <skos:definition xml:lang="en">Advice sought by stakeholders via the interface regarding the conformity of innovative products, services, or business models (Article 58(1)).</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SINGLE_DEDICATED_INTERFACE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSPARENCY_INFORMATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TRANSPARENCY INFORMATION</rdfs:label>
    <skos:definition xml:lang="en">Information that providers of general-purpose AI models must provide, which may be modified by delegated acts, as per Recital 173</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_ESTIMATION_AND_EVALUATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RISK ESTIMATION AND EVALUATION</rdfs:label>
    <skos:definition xml:lang="en">The process of estimating and evaluating risks when the system is used as intended or under reasonably foreseeable misuse, as required by Article 9(2)(b)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_10_5_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 10(5)</rdfs:label>
    <skos:definition xml:lang="en">Specific legal reference mentioned as an exception to other legal act interactions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TRANSPARENCY_AND_PROVISION_OF_INFORMATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TRANSPARENCY AND PROVISION OF INFORMATION</rdfs:label>
    <skos:definition xml:lang="en">Duty of the provider to ensure the AI system's operation is transparent and accompanied by clear instructions for the deployer per Article 13</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_13"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNION_INSTITUTIONS__BODIES__OFFICES_OR_AGENCIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">UNION INSTITUTIONS, BODIES, OFFICES OR AGENCIES</rdfs:label>
    <skos:definition xml:lang="en">UNION INSTITUTIONS, BODIES, OFFICES OR AGENCIES comprise those European Union organizations that are subject to the requirements of the Regulation and fall under the supervision of the European Data Protection Supervisor. This group specifically encompasses EU bodies tasked with responsibilities related to migration, asylum, and border control management, particularly those that deploy artificial intelligence systems in the execution of these duties.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MIGRATION__ASYLUM_AND_BORDER_CONTROL_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_DATA_PROTECTION_SUPERVISOR"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#riskLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">risk level</rdfs:label>
    <skos:definition xml:lang="en">The risk level designation (unacceptable/high/limited/minimal).</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROHIBITION</rdfs:label>
    <skos:definition xml:lang="en">The legal duty to not place on the market, put into service, or use specific AI systems classified as unacceptable risk under Article 5.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HARMONISED_STANDARDS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">HARMONISED STANDARDS</rdfs:label>
    <skos:definition xml:lang="en">Technical specifications adopted by European standardisation organisations that, when followed, allow providers to presume compliance with the requirements of this Regulation</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PRESUMPTION_OF_CONFORMITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__NO_1025_2012"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#OFFICIAL_JOURNAL_OF_THE_EUROPEAN_UNION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:presumesConformity rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_31"/>
    <euai:presumesConformity rdf:resource="https://w3id.org/euaiact/ontology#SECTION_2_OF_CHAPTER_II"/>
    <euai:presumesConformity rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_V__SECTIONS_2_AND_3"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_40_AND_41"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_40"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ESSENTIAL_SERVICES_SUPPLY_SAFETY_COMPONENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">ESSENTIAL SERVICES SUPPLY SAFETY COMPONENT</rdfs:label>
    <skos:definition xml:lang="en">AI systems used as safety components in the supply of water, gas, heating or electricity (Annex III 2)</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#CRITICAL_INFRASTRUCTURE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PRIVACY_PRESERVING_TECHNIQUES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PRIVACY-PRESERVING TECHNIQUES</rdfs:label>
    <skos:definition xml:lang="en">Techniques used during development and testing of AI systems to protect personal data while meeting data set requirements</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_69">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 69</rdfs:label>
    <skos:definition xml:lang="en">Article 69 addresses the protocols and regulations concerning access to the pool of experts for Member States. This article establishes the framework through which Member States may engage with and utilize this specific body of specialized professionals.</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#MEMBER_STATES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">POST-MARKET MONITORING OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The duty for all providers of high-risk AI systems to maintain a post-market monitoring system to allow for system improvement and corrective action.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SOCIAL_SCORING_AI_SYSTEMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">SOCIAL SCORING AI SYSTEMS</rdfs:label>
    <skos:definition xml:lang="en">Social scoring AI systems are technologies designed to evaluate, classify, or rank natural persons or groups based on their social behavior, personality traits, or personal characteristics over a period of time. Because these systems often result in discriminatory or detrimental outcomes for the individuals or groups being assessed, they are subject to strict regulatory prohibition. Specifically, as outlined in Recital 31, these systems are banned due to the risks they pose in unfairly categoriz</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_31"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_AI_PRACTICES"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OPERATOR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">OPERATOR</rdfs:label>
    <skos:definition xml:lang="en">The term "OPERATOR" functions as a collective, comprehensive designation for any natural or legal person involved in the lifecycle of an AI system who bears specific obligations under the AI Act. This umbrella term encompasses a range of entities along the value chain, specifically including providers, product manufacturers, deployers, authorised representatives, importers, and distributors. As defined in Article 3(8) and referenced in Recital 83 of the New Legislative Framework, these entities </skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_RULES"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CONSULTATION_PROCEDURE"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_AND_ORGANISATIONAL_MEASURES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISED_REPRESENTATIVE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#IMPORTER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DISTRIBUTOR"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PRODUCT_MANUFACTURER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CORRECTIVE_ACTION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION_OF_AI_PRACTICES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_FINE"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#STAND_ALONE_AI_SYSTEM_RULE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">STAND-ALONE AI SYSTEM RULE</rdfs:label>
    <skos:definition xml:lang="en">The rule determining high-risk status for systems that are not safety components, based on intended purpose and risk of harm to health, safety, or fundamental rights (Recital 52)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COUNCIL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">COUNCIL</rdfs:label>
    <skos:definition xml:lang="en">The Council is an EU legislative body that plays a crucial role in the oversight, evaluation, and regulatory implementation of European Union law, including the AI Act. Functioning as a central point for administrative review, the Council receives various critical documents from the Commission, including enforcement assessment reports, as well as comprehensive reports concerning the evaluation and review of the AI Act and other regulations.

Beyond its role as a recipient of these reports, the C</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DELEGATED_ACT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECALL_OF_AN_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">RECALL OF AN AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">Measure aiming to achieve the return to the provider, taking out of service, or disabling the use of an AI system made available to deployers</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PostMarketMonitoring">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Post-Market Monitoring</rdfs:label>
    <skos:definition xml:lang="en">Systematic collection and review of experience with deployed AI systems. (Article 72)</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUPPORT_FOR_INNOVATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SUPPORT FOR INNOVATION</rdfs:label>
    <skos:definition xml:lang="en">Measures intended to support innovation, focusing on SMEs and start-ups, as defined in Article 1(2)(g)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_16_TFEU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 16 TFEU</rdfs:label>
    <skos:definition xml:lang="en">Article 16 of the Treaty on the Functioning of the European Union (TFEU) serves as a fundamental legal basis within the European Union's regulatory framework, particularly concerning the governance of Artificial Intelligence. It provides the essential treaty-based authorization for the rules established under the AI Act, which govern the processing of personal data and dictate the limitations on specific technologies. 

Specifically, Article 16 TFEU provides the necessary authority to enact legi</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVIDER_OF_GPAI_MODELS_WITH_SYSTEMIC_RISK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">PROVIDER OF GPAI MODELS WITH SYSTEMIC RISK</rdfs:label>
    <skos:definition xml:lang="en">Legal person or entity responsible for the development and placing on the market of general-purpose AI models that carry systemic risks</skos:definition>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#MODEL_EVALUATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK_MITIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#SERIOUS_INCIDENT_REPORTING"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#CYBERSECURITY_PROTECTION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_53"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_54"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_56"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CONFIDENTIALITY_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BIOMETRIC_CATEGORISATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">BIOMETRIC CATEGORISATION</rdfs:label>
    <skos:definition xml:lang="en">The process of assigning natural persons to specific categories (sex, age, hair colour, eye colour, tattoos, behavioural or personality traits, language, religion, membership of a national minority, sexual or political orientation) based on biometric data.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#isBasedOn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">isBasedOn</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ROBUSTNESS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">ROBUSTNESS</rdfs:label>
    <skos:definition xml:lang="en">**Robustness**, in the context of artificial intelligence, refers to a critical technical requirement for AI systems to maintain stable, reliable, and consistent performance under varying conditions, adverse circumstances, and unforeseen situations. Specifically, for high-risk AI systems, robustness is a fundamental prerequisite for regulatory compliance.

This characteristic demands that systems remain resilient against errors, faults, inconsistencies, and harmful or undesirable behaviors. To a</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_75"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ASSISTIVE_FUNCTION_EXCEPTION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">ASSISTIVE FUNCTION EXCEPTION</rdfs:label>
    <skos:definition xml:lang="en">An exclusion condition for transparency/marking obligations where AI systems perform an assistive function for standard editing or do not substantially alter input data or semantics</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#MARKING_OF_SYNTHETIC_CONTENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EVIDENCE_RELIABILITY_EVALUATION_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">EVIDENCE RELIABILITY EVALUATION AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI systems used for the evaluation of the reliability of evidence in the course of investigation or prosecution of criminal offences</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ONLINE_MARKETPLACE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">ONLINE MARKETPLACE</rdfs:label>
    <skos:definition xml:lang="en">Commercial service provider, such as an online platform, where ancillary features (e.g., facial filters) are used to support principal services like product sales.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SENSITIVE_OPERATIONAL_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SENSITIVE OPERATIONAL DATA</rdfs:label>
    <skos:definition xml:lang="en">Operational data related to the prevention, detection, investigation, or prosecution of criminal offences, where disclosure could harm criminal proceedings.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_38_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_105">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 105</rdfs:label>
    <skos:definition xml:lang="en">Article amending Directive 2014/90/EU regarding AI safety components</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE_2014_90_EU"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#triggers">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">triggers</rdfs:label>
    <skos:definition xml:lang="en">Relates a risk category to the obligations it activates.</skos:definition>
    <rdfs:domain rdf:resource="https://w3id.org/euaiact/ontology#RiskCategory"/>
    <rdfs:range rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUSPENSION_OF_TESTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SUSPENSION OF TESTING</rdfs:label>
    <skos:definition xml:lang="en">Power held by national competent authorities to temporarily or permanently suspend testing or participation in the sandbox if risks cannot be effectively mitigated.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#JUDICIAL_OR_INDEPENDENT_ADMINISTRATIVE_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">JUDICIAL OR INDEPENDENT ADMINISTRATIVE AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">Bodies responsible for granting or rejecting prior authorisation for the use of real-time remote biometric identification systems</skos:definition>
    <euai:grants rdf:resource="https://w3id.org/euaiact/ontology#PRIOR_AUTHORISATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AUTHORISED_REPRESENTATIVE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">AUTHORISED REPRESENTATIVE</rdfs:label>
    <skos:definition xml:lang="en">An **Authorised Representative** is defined as any natural or legal person established within the European Union who has received and accepted a formal, written mandate from an AI system provider. This role is primarily essential for providers who are based in a third country (i.e., outside the Union) and wish to place AI systems or general-purpose AI models on the market or put them into service within the Union. By acting on behalf of the provider, the Authorised Representative ensures that th</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#WRITTEN_MANDATE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DOCUMENTATION_KEEPING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MANDATE_OF_AUTHORISED_REPRESENTATIVE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DECLARATION_OF_CONFORMITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MANDATE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFIED_BODY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_12_1_"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_47"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_11"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DATABASE_DATA_ENTRY_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#QUALITY_MANAGEMENT_SYSTEM"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_54"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION_OBLIGATIONS"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TERMINATE_MANDATE"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#COMPETENT_AUTHORITY"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#AI_OFFICE"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RECITAL_13">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">RECITAL 13</rdfs:label>
    <skos:definition xml:lang="en">RECITAL 13 serves to define the notion of a "deployer" specifically within the context and regulatory framework of the AI Act.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_22">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 22</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 22** outlines the regulatory framework and specific obligations pertaining to authorised representatives. Primarily, this article defines the responsibilities that authorised representatives must uphold within their professional capacity. Additionally, it specifies the necessary requirements for the appointment of these representatives, particularly for providers based in third countries, ensuring that proper representation is established in compliance with relevant regulations.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VALIDATION_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">VALIDATION DATA</rdfs:label>
    <skos:definition xml:lang="en">Data used for evaluating the trained AI system, tuning non-learnable parameters, and optimizing the learning process to prevent underfitting or overfitting.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MEMBER_STATES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">MEMBER STATES</rdfs:label>
    <skos:definition xml:lang="en">**MEMBER STATES** play a pivotal role in the implementation and enforcement of the AI Regulation. As the national authorities of EU countries, they bear the primary responsibility for ensuring compliance with the Regulation within their respective jurisdictions. This encompasses the critical task of establishing and enforcing rules on penalties, while ensuring that the internal market remains functional; consequently, they are prohibited from imposing unjustified restrictions on AI systems that </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_RULES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_CONDUCT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#VOLUNTARY_CODE_OF_CONDUCT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CE_MARKING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SME"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STANDARDISATION_DEVELOPMENT_PROCESSES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSLATION_COSTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_OFFICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFYING_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_AI_TESTING_SUPPORT_STRUCTURES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NE_BIS_IN_IDEM_PRINCIPLE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLIANCE_WITH_THE_REGULATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONSULTATION_PROCEDURE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOXES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AWARENESS_RAISING_AND_TRAINING_ACTIVITIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STANDARDISATION_DEVELOPMENT_PROCESS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_ARTIFICIAL_INTELLIGENCE_BOARD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODELS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#POOL_OF_EXPERTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SCIENTIFIC_PANEL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RESOURCE_PROVISION_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FEE_PAYMENT_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RESOURCE_REPORTING_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FINANCIAL_AND_HUMAN_RESOURCES_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_95_CODES_OF_CONDUCT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_PROHIBITED_PRACTICES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_MISLEADING_INFORMATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_IMPLEMENTATION_OBLIGATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_26_10_"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#RESOURCE_PROVISION_REQUIREMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIGITAL_CE_MARKING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DIGITAL CE MARKING</rdfs:label>
    <skos:definition xml:lang="en">A digital representation of the CE marking used for high-risk AI systems provided digitally or as a supplement to physical marking</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UNFAIR_COMMERCIAL_PRACTICES_DIRECTIVE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">UNFAIR COMMERCIAL PRACTICES DIRECTIVE</rdfs:label>
    <skos:definition xml:lang="en">The Unfair Commercial Practices Directive, formally known as Directive 2005/29/EC, establishes a comprehensive framework designed to regulate business-to-consumer commercial practices across the European Union. Its primary objective is to prevent businesses from engaging in misleading or aggressive tactics that could distort the economic behavior of consumers, thereby ensuring a fair marketplace and high level of consumer protection.

In the contemporary digital landscape, the Unfair Commercial </skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#AISYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NON_PERSONAL_DATA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">NON-PERSONAL DATA</rdfs:label>
    <skos:definition xml:lang="en">Non-personal data refers to any information that does not qualify as personal data as defined under Regulation (EU) 2016/679, commonly known as the General Data Protection Regulation (GDPR). This category of information is explicitly defined in Article 3(51) of the relevant legislative framework, which distinguishes it from data that relates to an identified or identifiable natural person. Essentially, non-personal data encompasses all datasets that fall outside the scope of personal privacy pro</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_51_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_33_OF_REGULATION__EU__2019_1020">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 33 OF REGULATION (EU) 2019/1020</rdfs:label>
    <skos:definition xml:lang="en">Article requiring the Commission to support the activities of the standing subgroup for market surveillance through evaluations or studies</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_DATA_PROTECTION_BOARD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">EUROPEAN DATA PROTECTION BOARD</rdfs:label>
    <skos:definition xml:lang="en">The European Data Protection Board (EDPB) is an independent European body with a mandate to ensure the consistent application of data protection rules throughout the European Union. In its advisory and regulatory capacity, the European Data Protection Board is consulted during the process of adopting new regulations. Furthermore, it serves as a critical regulatory body that must be consulted regarding the establishment of specific rules governing the processing of personal data in relation to ar</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2018_1725"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_ACCREDITATION_BODY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">NATIONAL ACCREDITATION BODY</rdfs:label>
    <skos:definition xml:lang="en">A body capable of carrying out assessment and monitoring of conformity assessment bodies, as defined under Regulation (EC) No 765/2008</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_BODY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OPERATORS_OF_AI_SYSTEMS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">OPERATORS OF AI SYSTEMS</rdfs:label>
    <skos:definition xml:lang="en">Entities responsible for AI systems, including those operating components of large-scale IT systems and high-risk AI systems used by public authorities (Recital 177)</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LARGE_SCALE_IT_SYSTEMS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_III__SECTION_2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER III, SECTION 2</rdfs:label>
    <skos:definition xml:lang="en">**CHAPTER III, SECTION 2**

CHAPTER III, SECTION 2 is a critical component of the EU AI Act, specifically designed to establish the regulatory framework for high-risk AI systems. This section delineates the essential technical and organizational requirements that providers must adhere to in order to ensure their systems are safe, transparent, and accountable. 

Compliance with the mandates set forth in this section is a necessary precursor for market access, as it dictates the standards to which</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESEARCH_AND_PROTOTYPING_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">RESEARCH AND PROTOTYPING EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">**RESEARCH AND PROTOTYPING EXCLUSION** refers to a regulatory provision that exempts certain AI models from specific definitions and obligations established under the Regulation. This exclusion applies exclusively to AI models that are utilized solely for the purposes of research, development, and prototyping activities. The exemption is time-bound, remaining valid only for the duration of these activities before the AI model is officially placed on the market. Consequently, as long as these mod</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TESTING_PLAN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TESTING PLAN</rdfs:label>
    <skos:definition xml:lang="en">The plan governing the testing of an AI system in real world conditions, against which market surveillance authorities evaluate compliance</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DISTRIBUTOR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">DISTRIBUTOR</rdfs:label>
    <skos:definition xml:lang="en">A **Distributor** is defined as any natural or legal person operating within the supply chain who makes an AI system available on the Union market. Crucially, this definition excludes the provider or the importer of the AI system.

While some descriptions suggest the exclusion of the deployer, the prevailing consensus within the provided regulatory context—specifically referencing Article 3(7) and Article 2(1)(d)—establishes that a Distributor is distinct from the provider and the importer. As a</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER_CLASSIFICATION_RULE"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_16"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_25"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPETENT_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CORRECTIVE_ACTION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_REQUIREMENTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_79_1_"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#DISTRIBUTOR_OBLIGATION__VERIFICATION_AND_CORRECTIVE_ACTION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#DISTRIBUTOR_OBLIGATION__STORAGE_AND_TRANSPORT"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REASSESSMENT_PROCEDURE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REASSESSMENT PROCEDURE</rdfs:label>
    <skos:definition xml:lang="en">A process where a provider, upon reasoned request, can ask the Commission to re-evaluate whether a model designated as having systemic risk still presents such risks.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION_EVALUATION_AND_REVIEW">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REGULATION EVALUATION AND REVIEW</rdfs:label>
    <skos:definition xml:lang="en">The Commission must evaluate and review the Regulation by 2 August 2029 and every four years thereafter (Recital 174).</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_PARLIAMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COUNCIL"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFICATION_OF_SERIOUS_INCIDENTS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">NOTIFICATION OF SERIOUS INCIDENTS</rdfs:label>
    <skos:definition xml:lang="en">Duty to report serious incidents for high-risk AI systems (medical devices) to the chosen national competent authority</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_REDUNDANCY_SOLUTIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TECHNICAL REDUNDANCY SOLUTIONS</rdfs:label>
    <skos:definition xml:lang="en">Measures such as backup or fail-safe plans used to achieve the robustness of high-risk AI systems, as per Article 15(4)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATURAL_PERSON">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">NATURAL PERSON</rdfs:label>
    <skos:definition xml:lang="en">The individual who is the subject of biometric identification or verification (Recital 14, 15).</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#BIOMETRIC_DATA"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY_OBLIGATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#IMPORTER_OBLIGATION__VERIFICATION_AND_NON_CONFORMITY_REPORTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">IMPORTER OBLIGATION: VERIFICATION AND NON-CONFORMITY REPORTING</rdfs:label>
    <skos:definition xml:lang="en">Importer must check for conformity, report risks under Article 79(1) to provider/rep/authorities, and refrain from placing non-conforming systems on the market</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_79_1_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MATERIAL_INFLUENCE_CRITERION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">MATERIAL INFLUENCE CRITERION</rdfs:label>
    <skos:definition xml:lang="en">The criterion that an AI system must materially influence the outcome of decision-making to be considered high-risk; systems that do not are potentially exempt (Recital 53)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPUTE_METRIC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">COMPUTE METRIC</rdfs:label>
    <skos:definition xml:lang="en">The amount of computation used for training the model, measured in floating point operations or via proxies like cost, time, and energy consumption.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION_2024_1689"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_HARMONISED_STANDARD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">EUROPEAN HARMONISED STANDARD</rdfs:label>
    <skos:definition xml:lang="en">Technical standards whose compliance grants presumption of conformity for GPAI model obligations</skos:definition>
    <euai:grants rdf:resource="https://w3id.org/euaiact/ontology#PRESUMPTION_OF_CONFORMITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RealTimeBiometricSurveillance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ProhibitedAIPractice"/>
    <rdfs:label xml:lang="en">RealTimeBiometricSurveillance</rdfs:label>
    <skos:definition xml:lang="en">Real-time remote biometric identification in publicly accessible spaces (with narrow exceptions)</skos:definition>
    <euai:articleReference>Article 5(1)(h)</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERNAL_MARKET_IMPACT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">INTERNAL MARKET IMPACT</rdfs:label>
    <skos:definition xml:lang="en">A criterion for assessing a model's significance, specifically presumed when the model is available to at least 10,000 registered business users in the Union.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINANCIAL_INTELLIGENCE_UNIT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">FINANCIAL INTELLIGENCE UNIT</rdfs:label>
    <skos:definition xml:lang="en">Units carrying out administrative tasks analyzing information pursuant to Union anti-money laundering law</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FINANCIAL_INTELLIGENCE_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HIGH_RISK_USE_CASE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AnnexIIICategory"/>
    <rdfs:label xml:lang="en">HIGH-RISK USE CASE</rdfs:label>
    <skos:definition xml:lang="en">Specific domains listed in an Annex to the Regulation where AI systems are presumed to be high-risk, unless exclusion conditions apply.</skos:definition>
    <euai:alwaysClassifiedAs rdf:resource="https://w3id.org/euaiact/ontology#PROFILING"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2005_29_EC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2005/29/EC</rdfs:label>
    <skos:definition xml:lang="en">Directive concerning unfair commercial practices, complementary to the AI Act's prohibitions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NATIONAL_MARKET_SURVEILLANCE_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">NATIONAL MARKET SURVEILLANCE AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">The **National Market Surveillance Authority** serves as a vital regulatory body within a Member State, tasked with the essential dual responsibility of overseeing market surveillance and ensuring data protection compliance. As part of its regulatory mandate, the authority plays a central role in monitoring the implementation of advanced technologies, specifically receiving comprehensive reports regarding the usage of real-time biometric identification systems.

Furthermore, the National Market </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HUMAN_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">HUMAN ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">Essential requirement for risk assessments involving natural persons to ensure they are not judged solely on AI-predicted behavior.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_III_SECTION_4">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER III SECTION 4</rdfs:label>
    <skos:definition xml:lang="en">A section of the Regulation that applies from 2 August 2025 according to Article 113.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_113"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#UN_CONVENTION_RELATING_TO_THE_STATUS_OF_REFUGEES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">UN CONVENTION RELATING TO THE STATUS OF REFUGEES</rdfs:label>
    <skos:definition xml:lang="en">International obligation that must not be circumvented by the use of AI systems in migration management.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_49__B_">
    <rdfs:label xml:lang="en">ARTICLE 3 49  B</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMMISSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">COMMISSION</rdfs:label>
    <skos:definition xml:lang="en">The European Commission serves as the central regulatory and executive authority under the EU AI Act, wielding extensive powers to oversee, enforce, and adapt the Regulation to evolving technological landscapes. As the EU executive body, the European Commission is responsible for the overall implementation of the Regulation, which includes establishing the AI Office, appointing the AI High-Level Expert Group (HLEG), and maintaining the European Artificial Intelligence Board. It acts as the contr</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_HLEG"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DELEGATED_ACT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_ARTIFICIAL_INTELLIGENCE_BOARD"/>
