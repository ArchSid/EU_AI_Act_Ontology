    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_64"/>
    <euai:providesInstructionsTo rdf:resource="https://w3id.org/euaiact/ontology#FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT"/>
