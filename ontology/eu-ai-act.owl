    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_94"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CONSULTATION_OF_EXPERTS"/>
    <euai:conductsEvaluationOf rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_BODY"/>
    <euai:conductsEvaluationOf rdf:resource="https://w3id.org/euaiact/ontology#NOTIFIED_BODY"/>
    <euai:conductsEvaluationOf rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_92_EVALUATIONS"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_67"/>
