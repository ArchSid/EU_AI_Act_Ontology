    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GUIDANCE_ON_REPORTING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OF_LIST_OF_AUTHORITIES"/>
