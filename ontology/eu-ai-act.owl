    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_75_3_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#VERY_LARGE_ONLINE_PLATFORM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">VERY LARGE ONLINE PLATFORM</rdfs:label>
    <skos:definition xml:lang="en">Service provider regulated under Regulation (EU) 2022/2065, subject to specific risk-management frameworks when embedding AI systems or models</skos:definition>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_FRAMEWORK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SYSTEMIC_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LAW_ENFORCEMENT_AUTHORITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">LAW ENFORCEMENT AUTHORITIES</rdfs:label>
    <skos:definition xml:lang="en">**Law Enforcement Authorities** are designated national bodies within Member States that have been granted authorized access to key security and migration systems, such as Eurodac and the Entry/Exit System (EES). These authorities are specifically empowered to request and utilize data from these systems exclusively for the purposes of preventing, detecting, or investigating terrorist activities and other serious criminal offenses.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EURODAC"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ENTRY_EXIT_SYSTEM"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HIGH_RISK_CLASSIFICATION_RULE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ClassificationRule"/>
    <rdfs:label xml:lang="en">HIGH-RISK CLASSIFICATION RULE</rdfs:label>
    <skos:definition xml:lang="en">Criteria for classifying an AI system as high-risk, including being a safety component of products subject to third-party assessment or operating in pre-defined high-risk areas</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INTERNAL_CONTROL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">INTERNAL CONTROL</rdfs:label>
    <skos:definition xml:lang="en">A conformity assessment procedure based on internal checks. For high-risk AI systems that are also important and critical products with digital elements, this procedure is subject to specific derogations defined in Recital 78.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_78"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_LAW_ENFORCEMENT_VICTIM_ASSESSMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR LAW ENFORCEMENT VICTIM ASSESSMENT</rdfs:label>
    <skos:definition xml:lang="en">System used to assess the risk of a natural person becoming the victim of criminal offences, identified in Annex III(6)(a)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FINANCIAL_FRAUD_DETECTION_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">FINANCIAL FRAUD DETECTION AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">**FINANCIAL FRAUD DETECTION AI SYSTEMS** are advanced technological tools designed to enhance security and regulatory compliance within the financial sector. Specifically, these systems are utilized to identify fraudulent activities in the provision of financial services and to assist financial institutions in accurately calculating their required capital reserves. Due to their specific function and regulatory context, these AI systems are explicitly excluded from high-risk classification, disti</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#FINANCIAL_FRAUD_DETECTION_EXCLUSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SUBJECTS_OF_TESTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">SUBJECTS OF TESTING</rdfs:label>
    <skos:definition xml:lang="en">Individuals participating in testing in real-world conditions whose informed consent must be obtained</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RIGHT_TO_WITHDRAW"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SANDBOX_PLAN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">SANDBOX PLAN</rdfs:label>
    <skos:definition xml:lang="en">The **SANDBOX PLAN** is a formal, mandatory document established as a prerequisite for participation in an AI regulatory sandbox. Defined in Article 3(54) of the relevant regulations, it functions as a specific agreement between a provider (or a prospective provider) and the competent authority overseeing the sandbox.

This document serves as the structural framework for testing activities, outlining the necessary scope, objectives, conditions, timeframe, and specific requirements for the sandbo</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPETENT_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESEARCHERS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">RESEARCHERS</rdfs:label>
    <skos:definition xml:lang="en">Individuals or groups engaged in research, who may access data for the development and assessment of high-risk AI systems</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_4_4_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 4(4)</rdfs:label>
    <skos:definition xml:lang="en">Reference for Profiling definition in GDPR</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#COMPETENT_PERSONNEL_REQUIREMENT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">COMPETENT PERSONNEL REQUIREMENT</rdfs:label>
    <skos:definition xml:lang="en">Requirement for notifying authorities to maintain an adequate number of competent personnel with expertise in information technologies, AI, law, and fundamental rights, as per Article 29(7)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CIVIL_PROTECTION_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CIVIL PROTECTION AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">The Civil Protection Authority is a governmental body tasked with the oversight and management of civil protection measures. In performing its duties, the Civil Protection Authority possesses the specific mandate to deploy high-risk AI systems without obtaining prior authorization from market surveillance authorities. This ability to bypass standard authorization procedures is strictly limited to exceptional, urgent, or justified situations, ensuring that the Authority can effectively respond to</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#URGENT_DEPLOYMENT_EXCEPTION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#URGENT_DEPLOYMENT_AUTHORISATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">ADMINISTRATIVE AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">The ADMINISTRATIVE AUTHORITY functions as a regulatory body tasked with the oversight and governance of post-remote biometric identification systems. As an administrative entity, it holds the power to issue binding decisions regarding the authorization of these systems. Furthermore, the actions and decisions made by the ADMINISTRATIVE AUTHORITY are subject to judicial review, ensuring that its regulatory processes remain accountable and legally compliant.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_MILITARY__DEFENCE_OR_NATIONAL_SECURITY_PURPOSES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">AI SYSTEM FOR MILITARY, DEFENCE OR NATIONAL SECURITY PURPOSES</rdfs:label>
    <skos:definition xml:lang="en">An AI system developed, placed on the market, or used for military, defence, or national security purposes, which is excluded from the Regulation unless used for other purposes.</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#MILITARY__DEFENCE_OR_NATIONAL_SECURITY_EXCLUSION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#OBLIGATION_TO_ENSURE_COMPLIANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">POST-MARKET MONITORING SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The Post-Market Monitoring System is a mandatory technical and organizational structure that providers of high-risk AI systems must establish, implement, and maintain. As outlined in Article 72 of the relevant regulatory framework (and supported by Recital 81), this system is essential for the continuous oversight of AI systems once they have been placed on the market or put into service.

The primary function of the Post-Market Monitoring System is to facilitate the active and systematic collec</skos:definition>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#EXEMPTION_FROM_POST_MARKET_MONITORING"/>
    <euai:hasException rdf:resource="https://w3id.org/euaiact/ontology#DEPLOYER"/>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING_PLAN"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_HARMONISATION_LEGISLATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TESTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">TESTING</rdfs:label>
    <skos:definition xml:lang="en">The process of ensuring high-risk AI systems perform consistently for their intended purpose and comply with legal requirements, performed prior to market placement, as per Article 9(6)-(8)</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_9"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_60"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EC__NO_765_2008">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EC) NO 765/2008</rdfs:label>
    <skos:definition xml:lang="en">**REGULATION (EC) NO 765/2008** serves as a foundational component of the European Union’s New Legislative Framework. It is the primary regulation that establishes the general principles and requirements for CE marking, which signifies that a product conforms to EU health, safety, and environmental protection standards. Furthermore, REGULATION (EC) NO 765/2008 provides essential rules to ensure consistency regarding the placing of products on the market, including those categorized as high-risk </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#NOTIFIED_BODY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">NOTIFIED BODY</rdfs:label>
    <skos:definition xml:lang="en">A Notified Body is an independent, authorized organization designated by Member States to perform critical third-party conformity assessment procedures for high-risk AI systems under the AI Act. These bodies serve a central role in the AI regulatory ecosystem, ensuring that AI systems comply with all relevant legal requirements before they enter the market.

To operate as a Notified Body, an organization must successfully complete a formal notification process, demonstrating that it meets strict</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SME"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_FEES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GOVERNANCE_AND_ENFORCEMENT_STRUCTURE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_BODY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SIMPLIFIED_TECHNICAL_DOCUMENTATION_FORM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFIDENTIALITY_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_31"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#LIABILITY_INSURANCE_REQUIREMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#IMPARTIALITY_REQUIREMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROFESSIONAL_SECRECY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SUBCONTRACTOR"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SUBSIDIARY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFYING_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNAL_COMPETENCES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER_NOTIFICATION_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CERTIFICATE_OF_CONFORMITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SECTORAL_GROUP_OF_NOTIFIED_BODIES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CERTIFICATE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#APPEAL_PROCEDURE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CE_MARKING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EXIT_REPORT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DECLARATION_OF_CONFORMITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#QUALITY_MANAGEMENT_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISED_REPRESENTATIVE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION_ASSESSMENT_CERTIFICATE"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#INDEPENDENCE"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#COMPETENCE"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#ABSENCE_OF_CONFLICTS_OF_INTERESTS"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CYBERSECURITY"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#INDEPENDENCE_REQUIREMENT"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#QUALITY_MANAGEMENT_REQUIREMENT"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#CYBERSECURITY_REQUIREMENT"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROFESSIONAL_SECRECY_OBLIGATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#COORDINATION_ACTIVITIES"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#DOCUMENTATION_KEEPING"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#LIABILITY_INSURANCE"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#DOCUMENTATION_SUBMISSION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#DOCUMENTATION_PROVISION_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#CESSATION_OF_ACTIVITIES_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OF_CHANGE_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#FULL_ASSESSMENT_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#CERTIFICATE_SUSPENSION_OR_WITHDRAWAL"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_38"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_34"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_45"/>
    <euai:conductsEvaluationOf rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_43"/>
    <euai:conductsEvaluationOf rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_OF_SECTION_2"/>
    <euai:conductsEvaluationOf rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNAL_PROCEDURES"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_STANDARDISATION_ORGANISATIONS"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#OTHER_NOTIFIED_BODIES"/>
    <euai:regulatedBy rdf:resource="https://w3id.org/euaiact/ontology#NATIONAL_COMPETENT_AUTHORITY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TESTING_AND_EXPERIMENTATION_FACILITIES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">TESTING AND EXPERIMENTATION FACILITIES</rdfs:label>
    <skos:definition xml:lang="en">Facilities supported by the Commission/Member States to provide technical and scientific support for compliance and testing</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">PROHIBITED AI PRACTICE</rdfs:label>
    <skos:definition xml:lang="en">**PROHIBITED AI PRACTICE** refers to any artificial intelligence system or practice that is strictly forbidden from being placed on the market, put into service, or utilized. These prohibitions, primarily outlined in Article 5 of the relevant Regulation, are established because such systems pose unacceptable risks to fundamental rights and safety.

A core category of these prohibited AI systems includes those that employ manipulative, exploitative, or social control techniques. Such practices ar</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_28"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_29"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NATURAL_PERSONS"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITALS_29_30"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5_PROHIBITIONS"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_5"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#SAFEGUARD_PROCEDURE"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITION"/>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#UNACCEPTABLE_RISK"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_3_19__OF_REGULATION_2019_1020">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 3(19) OF REGULATION 2019/1020</rdfs:label>
    <skos:definition xml:lang="en">Definition reference for 'product presenting a risk'</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#LawEnforcementAI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#HighRiskAISystem"/>
    <rdfs:label xml:lang="en">LawEnforcementAI</rdfs:label>
    <skos:definition xml:lang="en">AI used by law enforcement authorities</skos:definition>
    <euai:articleReference>Annex III, 6</euai:articleReference>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#OPERATORS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">OPERATORS</rdfs:label>
    <skos:definition xml:lang="en">The term "OPERATORS" refers to a diverse group of commercial and legal entities involved across the AI value chain. This category encompasses providers, importers, distributors, deployers, and authorized representatives. These entities are subject to specific obligations, requirements, and potential penalties for non-compliance under the AI Act. Furthermore, the regulation aims to minimize the duplication of conformity assessment procedures for these economic operators to ensure a more efficient</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_RULES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INTERNAL_MARKET_INTEGRATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TRANSPARENCY"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#RECORD_KEEPING"/>
    <euai:subjectTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DELEGATED_ACTS_MODIFYING_CONDITIONS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#DelegatedAct"/>
    <rdfs:label xml:lang="en">DELEGATED ACTS MODIFYING CONDITIONS</rdfs:label>
    <skos:definition xml:lang="en">Delegated acts modifying conditions refer to regulatory measures adopted by the European Commission designed to amend specific criteria related to the high-risk classification of AI systems. These acts provide the Commission with the authority to update and refine the regulatory framework established under Article 49 of the relevant AI legislation.

Specifically, these delegated acts serve two primary functions: first, they allow the Commission to amend the conditions outlined in Article 49(3) r</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_49"/>
    <euai:modifies rdf:resource="https://w3id.org/euaiact/ontology#EXCLUSION_CONDITIONS"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">TECHNICAL DOCUMENTATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">Duty to draw up and keep up-to-date technical documentation of the model (including training/testing process and results) per Article 53(1)(a).</skos:definition>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#ANNEX_XI"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_CENTRAL_BANK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">EUROPEAN CENTRAL BANK</rdfs:label>
    <skos:definition xml:lang="en">The European Central Bank (ECB) serves as the central banking institution for the European Union. Beyond its monetary policy functions, it acts as a key EU institution responsible for executing prudential supervisory tasks. Within this supervisory framework, the ECB oversees credit institutions that participate in the Single Supervisory Mechanism (SSM). To facilitate this oversight, the ECB receives critical reports from national market surveillance authorities regarding these financial institut</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REASSESSMENT_REQUEST">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REASSESSMENT REQUEST</rdfs:label>
    <skos:definition xml:lang="en">Providers designated with systemic risk can request a reassessment of their model's status based on new, objective, and detailed reasons, subject to a minimum six-month interval between requests (Article 52(5))</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAIR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">CHAIR</rdfs:label>
    <skos:definition xml:lang="en">The individual leading the Board, whose tasks, selection, and mandate duration are defined in the Board's rules of procedure as per Article 65(5).</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_ARTIFICIAL_INTELLIGENCE_BOARD"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">REAL-WORLD TESTING</rdfs:label>
    <skos:definition xml:lang="en">The process of testing AI systems in real-world conditions, subject to specific guarantees, consent requirements, and registration obligations</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMPETENT_MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EU_DATABASE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#WRITTEN_AGREEMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING_PLAN"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EFFECTIVE_OVERSIGHT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_TRANSFER_SAFEGUARDS"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2016_679"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#QUALITY_MANAGEMENT_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">QUALITY MANAGEMENT SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">A Quality Management System (QMS) is a mandatory organizational requirement that providers of high-risk AI systems must establish to ensure compliance with the relevant AI regulations. As detailed in Article 17, this system functions as a framework for documented policies and procedures, encompassing critical areas such as strategy, design control, verification, data management, risk management, post-market monitoring, incident reporting, and accountability. The QMS serves as a comprehensive sys</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#SERIOUS_INCIDENT_REPORTING"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STRATEGY_FOR_REGULATORY_COMPLIANCE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DESIGN_CONTROL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DEVELOPMENT_AND_QUALITY_CONTROL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EXAMINATION_AND_VALIDATION_PROCEDURES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_SPECIFICATIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_MANAGEMENT_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_MANAGEMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_17"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_63"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RESTRICTIVE_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">RESTRICTIVE MEASURES</rdfs:label>
    <skos:definition xml:lang="en">RESTRICTIVE MEASURES refer to regulatory actions, such as the withdrawal of an AI system from the market or the prohibition of its use, which are mandated when a national measure regarding that system is determined to be justified under Article 81. These measures serve as an enforcement mechanism to ensure compliance and safety, necessitating that specific AI systems be removed from availability or halted in operation once the legal grounds for such intervention have been established.</skos:definition>
    <euai:enforces rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_SAFEGUARD_PROCEDURE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_81"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SME_PENALTY_PROVISION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">SME PENALTY PROVISION</rdfs:label>
    <skos:definition xml:lang="en">A provision ensuring penalties for SMEs and start-ups do not exceed the specified percentages or amounts if they are lower than the standard fines</skos:definition>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_PROHIBITED_PRACTICES"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_GENERAL_NON_COMPLIANCE"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#PENALTIES_FOR_MISLEADING_INFORMATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PRESUMPTION_OF_CONFORMITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PRESUMPTION OF CONFORMITY</rdfs:label>
    <skos:definition xml:lang="en">**PRESUMPTION OF CONFORMITY** is a legal status granted to AI systems and, in certain contexts, conformity assessment bodies, which significantly simplifies the process of demonstrating adherence to regulatory requirements. This status is primarily conferred upon AI systems that meet established benchmarks, such as European harmonised standards, common specifications, cybersecurity standards, or specific training data and certification criteria.

By achieving this status, providers are effective</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_40"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_42"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#GeneralPurposeAIModel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">General-Purpose AI Model</rdfs:label>
    <skos:definition xml:lang="en">An AI model trained on large data that can perform a wide range of tasks. (Article 3(63))</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_11_1_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 11(1)</rdfs:label>
    <skos:definition xml:lang="en">**Article 11(1)** mandates that providers of high-risk AI systems are responsible for the creation and ongoing maintenance of comprehensive technical documentation. This documentation must be drafted in accordance with the specifications outlined in Annex IV of the regulation. Crucially, Article 11(1) requires that this documentation be fully prepared before the high-risk AI system is placed on the market.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#FREE_AND_OPEN_SOURCE_LICENCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">FREE AND OPEN-SOURCE LICENCE</rdfs:label>
    <skos:definition xml:lang="en">A "free and open-source licence" functions as a regulatory exemption framework within specific legal contexts, notably concerning the obligations of third parties and the classification of General Purpose AI (GPAI) models. 

Under this licensing condition, third parties providing tools, services, or components—excluding GPAI models—are granted an exemption from value-chain compliance requirements. In the specific context of GPAI models, the licence serves as a qualifying condition for an exempti</skos:definition>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#AI_VALUE_CHAIN_PARTIES"/>
    <euai:isExemptFromHighRisk rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_54"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MODEL_CARDS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DATA_SHEETS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MODEL_WEIGHTS_AND_ARCHITECTURE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">EUROPEAN COMMISSION</rdfs:label>
    <skos:definition xml:lang="en">The European Commission functions as the central executive institution of the European Union, playing a comprehensive and multifaceted role in the implementation, oversight, and enforcement of the AI Act. As the body responsible for proposing the legislation, the European Commission is tasked with the ongoing evaluation and review of the Regulation, including a formal assessment of its enforcement by August 2031, which it reports to the European Parliament and the Council.

A primary responsibil</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REGULATION__EU__2024_1689"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_CONDUCT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#VOLUNTARY_CODE_OF_CONDUCT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_HARMONISATION_LEGISLATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION_DELEGATED_ACT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ACCURACY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ENISA"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#VOLUNTARY_MODEL_CONTRACTUAL_TERMS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISKS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#IMPLEMENTING_ACTS"/>
