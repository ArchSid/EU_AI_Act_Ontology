  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUBLICLY_ACCESSIBLE_SPACE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PUBLICLY ACCESSIBLE SPACE</rdfs:label>
    <skos:definition xml:lang="en">A "Publicly Accessible Space" is defined as any physical location—whether publicly or privately owned—that is open to an undetermined number of natural persons. As detailed in the provided references, this category encompasses a wide range of environments, including but not limited to commercial, service, transport, sport, and entertainment areas.

The designation of a Publicly Accessible Space is largely independent of ownership, specific activities, or minor entry requirements. For instance, t</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3_44_"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ADMINISTRATIVE_FINE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">ADMINISTRATIVE FINE</rdfs:label>
    <skos:definition xml:lang="en">Monetary penalty imposed for infringements of the AI Act. The amount depends on specific criteria like nature/gravity of infringement, SME status, and operator size. Regulated by Article 99 and Article 100</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_99"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_100"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PRIVACY_AND_DATA_GOVERNANCE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PRIVACY AND DATA GOVERNANCE</rdfs:label>
    <skos:definition xml:lang="en">The requirement that AI systems are developed in accordance with privacy rules and process high-quality, high-integrity data</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ETHICAL_PRINCIPLES_FOR_TRUSTWORTHY_AI"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#SOCIAL_SCORING_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">SOCIAL SCORING AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">AI system evaluating or classifying persons based on social behavior or personality traits leading to detrimental or unjustified treatment</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#PROHIBITED_AI_PRACTICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DIRECTIVE_2020_1828">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">DIRECTIVE 2020/1828</rdfs:label>
    <skos:definition xml:lang="en">Directive (EU) 2020/1828 is a legislative act of the European Union that has been amended by Article 110 of the Artificial Intelligence (AI) Act. This directive serves as an important component of the EU regulatory framework, and its modification through the AI Act ensures its alignment with updated legal standards regarding the governance and regulation of artificial intelligence technologies.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_110"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MARKET_MONITORING">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">MARKET MONITORING</rdfs:label>
    <skos:definition xml:lang="en">The set of rules and measures for overseeing AI systems once placed on the market as defined in Article 1(2)(f)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">HIGH-RISK AI SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">A **HIGH-RISK AI SYSTEM** is defined under the EU AI Act as a system that poses significant risks to health, safety, or fundamental rights. These systems are subject to a robust, stringent regulatory framework designed to mitigate these risks while allowing for beneficial innovation.

**Classification and Scope**
A HIGH-RISK AI SYSTEM is typically identified through specific criteria:
*   **Article 6 Classification:** Systems classified under Article 6(1) or (2), including those listed in Annex </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HARMONISED_RULES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NEW_LEGISLATIVE_FRAMEWORK"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REQUIREMENTS_FOR_HIGH_RISK_AI_SYSTEMS"/>
