    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#MANDATE_OF_AUTHORISED_REPRESENTATIVE"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#CONFORMITY_ASSESSMENT_PROCEDURE"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REASSESSMENT_REQUEST"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#PROJECT_SUMMARY"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#EXTENSION_OF_TESTING"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#INFORMED_CONSENT"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#PROTECTION_OF_VULNERABLE_GROUPS"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#AGREEMENT_ON_ROLES_AND_RESPONSIBILITIES"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#RIGHT_TO_WITHDRAW"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#PROCEDURE_FOR_PROMPT_RECALL"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_OF_SERIOUS_INCIDENTS"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REPORTING_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#INVESTIGATION_OBLIGATION"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#REGISTRATION_OF_TESTING"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#RECITAL_68"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_2"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_3"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_16"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#THIRD_PARTIES"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:cooperatesWith rdf:resource="https://w3id.org/euaiact/ontology#NOTIFIED_BODY"/>
    <euai:meetsSystemicRiskThreshold rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#MILITARY__DEFENCE_OR_NATIONAL_SECURITY_EXCLUSION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#ExclusionCondition"/>
    <rdfs:label xml:lang="en">MILITARY, DEFENCE OR NATIONAL SECURITY EXCLUSION</rdfs:label>
    <skos:definition xml:lang="en">The exclusion of AI systems from the Regulation when used for military, defence, or national security purposes, pursuant to Article 4(2) TEU.</skos:definition>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_4_2__TEU"/>
    <euai:isBasedOn rdf:resource="https://w3id.org/euaiact/ontology#CHAPTER_2_OF_TITLE_V_TEU"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#EUROPEAN_ARTIFICIAL_INTELLIGENCE_OFFICE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">EUROPEAN ARTIFICIAL INTELLIGENCE OFFICE</rdfs:label>
    <skos:definition xml:lang="en">The European Artificial Intelligence Office is an EU-level body established by Commission Decision C(2024) 390 (Recital 45). Its primary mandate is to oversee the implementation and enforcement of the AI Act. Beyond this broad oversight, the European Artificial Intelligence Office is also tasked with developing practical tools, such as templates and questionnaires, designed to facilitate compliance and reduce the administrative burden for AI deployers.</skos:definition>
    <euai:providesInstructionsTo rdf:resource="https://w3id.org/euaiact/ontology#COMPLIANCE_QUESTIONNAIRE_TEMPLATE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#COMMISSION_DECISION_C_2024__390"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DIRECTIVE__EU__2019_1937"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_60">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 60</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 60**

Article 60 serves as a critical regulatory provision governing the testing of AI systems in real-world conditions. Specifically, it establishes the necessary conditions, requirements, and procedures for such testing, particularly for high-risk AI systems operating outside of dedicated AI regulatory sandboxes. 

The article delineates the registration obligations and transparency requirements that developers must adhere to when conducting these real-world tests. It functions as a </skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#REAL_WORLD_TESTING_PLAN"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_4_1_">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 4(1)</rdfs:label>
    <skos:definition xml:lang="en">Reference for Personal Data definition in GDPR</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PUBLICLY_ACCESSIBLE_SPACES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">PUBLICLY ACCESSIBLE SPACES</rdfs:label>
    <skos:definition xml:lang="en">Environmental context where the use of real-time remote biometric identification systems is strictly regulated</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#REGULATION__EU__2021_1133">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">REGULATION (EU) 2021/1133</rdfs:label>
    <skos:definition xml:lang="en">Legislation amending conditions for accessing EU information systems for the purposes of the Visa Information System</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#CHAPTER_V">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">CHAPTER V</rdfs:label>
    <skos:definition xml:lang="en">CHAPTER V of the AI Act establishes critical obligations for providers of general-purpose AI models. This section specifically addresses the requirements related to transparency and systemic risk, as outlined in its second and third sections. 

Enforcement of these provisions falls under the jurisdiction of the European Commission, as stipulated by Article 88. According to Article 113 of the regulation, CHAPTER V is set to become applicable on 2 August 2025.</skos:definition>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_113"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#PROVISIONAL_MEASURES">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">PROVISIONAL MEASURES</rdfs:label>
    <skos:definition xml:lang="en">Measures taken by market surveillance authorities (prohibit, restrict, withdraw, recall) if an operator fails to take adequate corrective action</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#EUROPEAN_COMMISSION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ARTICLE_97">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Article"/>
    <rdfs:label xml:lang="en">ARTICLE 97</rdfs:label>
    <skos:definition xml:lang="en">**ARTICLE 97** serves as the pivotal legal provision governing the European Commission's authority to adopt delegated acts within the framework of the regulation. It establishes the procedural rules for the exercise of this power, ensuring that the Commission operates within the scope and duration specified by the regulation.

Functionally, **ARTICLE 97** provides the necessary legal basis for the Commission to update, amend, or adjust specific annexes, articles, and rules. This includes, notabl</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DELEGATED_ACTS_AMENDING_ANNEX_III"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DELEGATED_ACTS_MODIFYING_CONDITIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DELEGATED_ACT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#JUDICIAL_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">JUDICIAL AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">The **JUDICIAL AUTHORITY** is an independent judicial body mandated with the critical responsibility of overseeing the deployment of biometric identification systems. This entity is exclusively empowered to grant or reject binding, express, and specific authorizations regarding the use of both real-time and post-remote biometric identification systems. By serving as the gatekeeper for these technologies, the **JUDICIAL AUTHORITY** ensures that the application of such invasive identification tool</skos:definition>
    <euai:grants rdf:resource="https://w3id.org/euaiact/ontology#PRIOR_AUTHORISATION"/>
    <euai:grants rdf:resource="https://w3id.org/euaiact/ontology#AUTHORISATION_FOR_POST_REMOTE_BIOMETRIC_IDENTIFICATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ADMINISTRATION_OF_JUSTICE_AI_SYSTEM"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#AI_SYSTEM_FOR_JUDICIAL_ASSISTANCE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#ALTERNATIVE_DISPUTE_RESOLUTION_BODY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">ALTERNATIVE DISPUTE RESOLUTION BODY</rdfs:label>
    <skos:definition xml:lang="en">A body that settles disputes outside of court, which may use AI systems that have legal effects on parties (Recital 61).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#DATA_DELETION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">DATA DELETION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">If an authorisation for the use of a real-time remote biometric identification system is rejected, all data, results, and outputs must be immediately discarded and deleted.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#BORDER_CONTROL_AUTHORITY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Actor"/>
    <rdfs:label xml:lang="en">BORDER CONTROL AUTHORITY</rdfs:label>
    <skos:definition xml:lang="en">The **BORDER CONTROL AUTHORITY** is an organization tasked with overseeing and managing border control operations. Within the scope of its duties, the **BORDER CONTROL AUTHORITY** is legally authorized to conduct identity checks, provided these actions are performed in accordance with both applicable Union and national laws. 

Furthermore, when the **BORDER CONTROL AUTHORITY** functions as a provider of high-risk AI systems, it is mandated to ensure that it maintains and provides access to the n</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#IDENTITY_CHECK"/>
    <euai:hasObligation rdf:resource="https://w3id.org/euaiact/ontology#TECHNICAL_DOCUMENTATION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_SYSTEM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Requirement"/>
    <rdfs:label xml:lang="en">RISK MANAGEMENT SYSTEM</rdfs:label>
    <rdfs:label xml:lang="en">RISK-MANAGEMENT SYSTEM</rdfs:label>
    <skos:definition xml:lang="en">The **Risk Management System** is a mandatory, continuous, and iterative component of the quality management system for high-risk AI systems, as required by Article 9. It serves as a vital framework that providers must establish to ensure the trustworthiness of their AI systems by identifying, analyzing, estimating, evaluating, and mitigating foreseeable risks and unintended outcomes.

At its core, the **Risk Management System** is designed to protect health, safety, and fundamental rights throu</skos:definition>
    <skos:definition xml:lang="en">A risk-management system is a mandatory, systematic process designed for implementation throughout the entire lifecycle of a high-risk AI system. This framework functions as a continuous and iterative operation that is both carefully planned and actively executed to ensure ongoing oversight. The primary objective of the risk-management system is to proactively identify and mitigate potential hazards that could compromise health, safety, and the protection of fundamental rights.</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#UNION_HARMONISATION_LEGISLATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#HEALTH__SAFETY_AND_FUNDAMENTAL_RIGHTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#STATE_OF_THE_ART_ON_AI"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_9"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_MANAGEMENT_MEASURES"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#POST_MARKET_MONITORING_SYSTEM"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_IDENTIFICATION_AND_ANALYSIS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_ESTIMATION_AND_EVALUATION"/>
    <euai:appliesTo rdf:resource="https://w3id.org/euaiact/ontology#HIGH_RISK_AI_SYSTEM"/>
    <euai:definedInArticle rdf:resource="https://w3id.org/euaiact/ontology#ARTICLE_72"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#INVESTIGATION_OBLIGATION">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Obligation"/>
    <rdfs:label xml:lang="en">INVESTIGATION OBLIGATION</rdfs:label>
    <skos:definition xml:lang="en">The "INVESTIGATION OBLIGATION" represents a multifaceted requirement ensuring accountability and oversight within regulatory frameworks. This obligation mandates distinct duties for different stakeholders involved in compliance and safety management.

Primarily, the "INVESTIGATION OBLIGATION" imposes a duty on the provider to proactively manage safety. Following a serious incident, the provider is required to conduct thorough investigations, perform necessary risk assessments, and implement appr</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#RISK_ASSESSMENT"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CORRECTIVE_ACTION"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#WORKERS_MANAGEMENT_AI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#AISystem"/>
    <rdfs:label xml:lang="en">WORKERS MANAGEMENT AI</rdfs:label>
    <skos:definition xml:lang="en">AI system used for decisions affecting terms of work-related relationships, promotions, terminations, task allocation, or performance monitoring.</skos:definition>
    <euai:belongsToCategory rdf:resource="https://w3id.org/euaiact/ontology#EMPLOYMENT__WORKERS__MANAGEMENT_AND_ACCESS_TO_SELF_EMPLOYMENT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/euaiact/ontology#AI_OFFICE">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/euaiact/ontology#Authority"/>
    <rdfs:label xml:lang="en">AI OFFICE</rdfs:label>
    <skos:definition xml:lang="en">The **AI Office** is an EU-level body established by the Commission to serve as a central authority for the implementation, supervision, and enforcement of the EU AI Act. Functioning as the Commission’s primary enforcement arm—and effectively synonymous with the Commission’s administrative role in this context—the AI Office is dedicated to developing Union-level expertise in artificial intelligence and ensuring consistent application of AI law.

The core mission of the AI Office centers on the s</skos:definition>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#QUESTIONNAIRE_TEMPLATE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#PROVIDER_OF_GENERAL_PURPOSE_AI_MODELS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TRAINING_DATA_SUMMARY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#FLOATING_POINT_OPERATIONS_THRESHOLD"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INDUSTRY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#NOTIFICATION_OBLIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CODE_OF_PRACTICE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CIVIL_SOCIETY_ORGANISATIONS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODELS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#MARKET_SURVEILLANCE_AUTHORITY"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#GENERAL_PURPOSE_AI_MODEL"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INVESTIGATION"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#CLASSIFICATION_RULE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#VOLUNTARY_MODEL_TERMS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#TEMPLATE_QUESTIONNAIRE"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#ACADEMIA"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#DOWNSTREAM_PROVIDERS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#INDEPENDENT_EXPERTS"/>
    <euai:relatedTo rdf:resource="https://w3id.org/euaiact/ontology#AI_REGULATORY_SANDBOX"/>
