        euai:TRAINING_DATA_SUMMARY,
        euai:VOLUNTARY_MODEL_TERMS ;
    euai:subjectTo euai:ARTICLE_75_3_ .

euai:NOTIFIED_BODY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "NOTIFIED BODY"@en ;
    skos:definition """A Notified Body is an independent, authorized organization designated by Member States to perform critical third-party conformity assessment procedures for high-risk AI systems under the AI Act. These bodies serve a central role in the AI regulatory ecosystem, ensuring that AI systems comply with all relevant legal requirements before they enter the market.

To operate as a Notified Body, an organization must successfully complete a formal notification process, demonstrating that it meets strict"""@en ;
    euai:appliesTo euai:INTERNAL_PROCEDURES ;
    euai:conductsEvaluationOf euai:ARTICLE_43,
