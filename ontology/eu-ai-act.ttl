        euai:DOWNSTREAM_PROVIDERS,
        euai:EUROPEAN_ARTIFICIAL_INTELLIGENCE_BOARD,
        euai:FLOATING_POINT_OPERATIONS_THRESHOLD,
        euai:GENERAL_PURPOSE_AI_MODEL,
        euai:GENERAL_PURPOSE_AI_MODELS,
        euai:INDEPENDENT_EXPERTS,
        euai:INDUSTRY,
        euai:INVESTIGATION,
        euai:MARKET_SURVEILLANCE_AUTHORITY,
        euai:NOTIFICATION_OBLIGATION,
        euai:PROVIDER_OF_GENERAL_PURPOSE_AI_MODELS,
