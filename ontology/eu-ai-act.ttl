@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix euai: <https://w3id.org/euaiact/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/euaiact/ontology> a owl:Ontology ;
    rdfs:label "EU AI Act Ontology"@en ;
    dcterms:description "An OWL ontology capturing the key concepts, actors, and obligations of Regulation (EU) 2024/1689 (EU Artificial Intelligence Act)"@en ;
    dcterms:source <https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=OJ:L_202401689> ;
    owl:versionInfo "0.1.0" .

euai:ACCESSIBILITY_REQUIREMENTS_DIRECTIVE a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ACCESSIBILITY REQUIREMENTS DIRECTIVE"@en ;
    skos:definition """The Accessibility Requirements Directive, formally known as Directive (EU) 2019/882, establishes a comprehensive legal framework concerning the accessibility requirements for products and services within the European Union. Its primary objective is to harmonize accessibility standards across member states to ensure that essential products and services are usable by persons with disabilities, thereby promoting greater inclusivity and removing barriers within the internal market.

Furthermore, the"""@en .

euai:ACCESS_TO_DOCUMENTATION_AND_DATA a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "ACCESS TO DOCUMENTATION AND DATA"@en ;
    skos:definition "Obligation for providers to grant market surveillance authorities full access to documentation, training, validation, and testing datasets for high-risk AI systems"@en ;
    euai:relatedTo euai:HIGH_RISK_AI_SYSTEM .

euai:ADEQUATE_SAFEGUARDS_FOR_FUNDAMENTAL_RIGHTS a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "ADEQUATE SAFEGUARDS FOR FUNDAMENTAL RIGHTS"@en ;
    skos:definition "The requirement for third countries and international organisations to protect fundamental rights and freedoms of individuals to qualify for the exclusion from the Regulation's scope."@en ;
    euai:relatedTo euai:INTERNATIONAL_COOPERATION_EXCLUSION .

euai:ADOPTION_OF_DELEGATED_AND_IMPLEMENTING_ACTS a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "ADOPTION OF DELEGATED AND IMPLEMENTING ACTS"@en ;
    skos:definition "The European Commission must take into account Chapter III Section 2 requirements when adopting delegated or implementing acts involving AI safety components"@en ;
    euai:relatedTo euai:ARTICLE_106,
        euai:ARTICLE_107,
        euai:ARTICLE_108 .

euai:ADOPTION_OF_TECHNICAL_SPECIFICATIONS_AND_STANDARDS a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "ADOPTION OF TECHNICAL SPECIFICATIONS AND STANDARDS"@en ;
    skos:definition "The European Commission must take into account Chapter III Section 2 requirements when adopting technical specifications and standards"@en ;
    euai:relatedTo euai:ARTICLE_105 .

euai:AFFECTED_PERSONS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "AFFECTED PERSONS"@en ;
    skos:definition "**AFFECTED PERSONS** are defined as individuals or entities whose interests, rights, and freedoms are impacted by artificial intelligence systems. This group comprises natural or legal persons whose rights and freedoms are adversely impacted by the use of AI systems, as well as those who are directly affected by decisions made by a deployer based on the output of high-risk AI. Furthermore, AFFECTED PERSONS include those whose specific interests and needs must be taken into account by the AI Offi"@en ;
    euai:relatedTo euai:CODE_OF_PRACTICE,
        euai:COMPLAINT,
        euai:EXPLANATION_OF_DECISION,
        euai:RIGHT_TO_AN_EXPLANATION .

euai:AGRICULTURAL_AND_FORESTRY_VEHICLES_REGULATION a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "AGRICULTURAL AND FORESTRY VEHICLES REGULATION"@en ;
    skos:definition "Regulation (EU) No 167/2013 is a key piece of European Union legislation established to govern the approval and market surveillance of agricultural and forestry vehicles. This regulation plays a critical role in standardizing the safety and operational requirements for these specific vehicle types. Beyond its primary function in ensuring compliance and market safety within the agricultural and forestry sectors, the regulation is also highly relevant to the evolving field of artificial intelligen"@en .

euai:AIOffice a owl:Class ;
    rdfs:label "AI Office"@en ;
    rdfs:subClassOf euai:Authority ;
    skos:definition "The Commission body responsible for GPAI model oversight and coordination. (Article 64)"@en .

euai:AI_LITERACY_MEASURES a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "AI LITERACY MEASURES"@en ;
    skos:definition "Voluntary organizational requirement focusing on education and awareness regarding AI systems"@en ;
    euai:relatedTo euai:CODE_OF_CONDUCT .

euai:AI_MODEL a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI MODEL"@en ;
    skos:definition "The level at which marking techniques can be implemented, including general-purpose AI models generating content."@en ;
    euai:relatedTo euai:TECHNICAL_SOLUTIONS_FOR_MARKING .

euai:AI_ON_DEMAND_PLATFORM a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "AI-ON-DEMAND PLATFORM"@en ;
    skos:definition "A platform supported by the Commission and Member States to provide technical and scientific support to providers and notified bodies to facilitate compliance"@en ;
    euai:relatedTo euai:NOTIFIED_BODY,
        euai:PROVIDER .

euai:AI_SYSTEMS_CREATING_FACIAL_RECOGNITION_DATABASES a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEMS CREATING FACIAL RECOGNITION DATABASES"@en ;
    skos:definition "Systems that create or expand databases through untargeted scraping of facial images from the internet or CCTV, prohibited under Recital 43."@en ;
    euai:subjectTo euai:PROHIBITION_OF_FACIAL_RECOGNITION_SCRAPING .

euai:AI_SYSTEMS_FOR_PREDICTING_CRIMINAL_BEHAVIOUR a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEMS FOR PREDICTING CRIMINAL BEHAVIOUR"@en ;
    skos:definition "Systems that assess the likelihood of offending based solely on profiling, personality traits, or characteristics, which are prohibited under Recital 42."@en ;
    euai:subjectTo euai:HUMAN_ASSESSMENT,
        euai:PROHIBITION_OF_PREDICTIVE_RISK_ASSESSMENTS .

euai:AI_SYSTEM_AS_SAFETY_COMPONENT a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM AS SAFETY COMPONENT"@en ;
    skos:definition """An AI system as a safety component refers to artificial intelligence technology designed to function as a critical safety element within a larger product. These systems are defined specifically under Regulation (EU) 2024/1689 and encompass any AI software or hardware intended to perform safety functions where failure or malfunction could result in adverse impacts on human health or safety.

Because of the potential risks these systems pose, an AI system classified as a safety component is subjec"""@en ;
    euai:relatedTo euai:DELEGATED_ACT,
        euai:IMPLEMENTING_ACT,
        euai:RECITAL_47,
        euai:REQUIREMENTS_OF_CHAPTER_III_SECTION_2 ;
    euai:subjectTo euai:REQUIREMENTS_IN_CHAPTER_III_SECTION_2 .

euai:AI_SYSTEM_FOR_ADMINISTRATION_OF_JUSTICE a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM FOR ADMINISTRATION OF JUSTICE"@en ;
    skos:definition "An AI system intended to be used by a judicial authority or on its behalf to assist in researching and interpreting facts and the law, or applying the law to a concrete set of facts. Considered high-risk per Recital 61."@en ;
    euai:alwaysClassifiedAs euai:HIGH_RISK ;
    euai:relatedTo euai:JUDICIAL_AUTHORITY ;
    euai:subjectTo euai:HUMAN_OVERSIGHT .

euai:AI_SYSTEM_FOR_ALTERNATIVE_DISPUTE_RESOLUTION a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM FOR ALTERNATIVE DISPUTE RESOLUTION"@en ;
    skos:definition "An AI system used by alternative dispute resolution bodies to research and interpret facts and law, considered high-risk when outcomes produce legal effects for parties (Recital 61)."@en ;
    euai:alwaysClassifiedAs euai:HIGH_RISK ;
    euai:relatedTo euai:ALTERNATIVE_DISPUTE_RESOLUTION_BODY .

euai:AI_SYSTEM_FOR_ANCILLARY_ADMINISTRATIVE_ACTIVITIES a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM FOR ANCILLARY ADMINISTRATIVE ACTIVITIES"@en ;
    skos:definition "An AI system used for tasks like anonymisation/pseudonymisation or administrative tasks that do not affect the actual administration of justice. These are excluded from high-risk classification (Recital 61)."@en ;
    euai:isExemptFromHighRisk euai:HIGH_RISK .

euai:AI_SYSTEM_FOR_ELECTION_OR_REFERENDUM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM FOR ELECTION OR REFERENDUM"@en ;
    skos:definition "AI systems intended to influence the outcome of an election or referendum or voting behaviour, typically classified as high-risk under Annex III"@en ;
    euai:subjectTo euai:EXCLUSION_CONDITION__NON_EXPOSURE_TO_OUTPUT .

euai:AI_SYSTEM_FOR_ELECTION_OR_REFERENDUM_INFLUENCE a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM FOR ELECTION OR REFERENDUM INFLUENCE"@en ;
    skos:definition "An AI system intended to be used to influence the outcome of an election or referendum or voting behaviour of natural persons. Classified as high-risk (Recital 62)."@en ;
    euai:alwaysClassifiedAs euai:HIGH_RISK ;
    euai:definedInArticle euai:ARTICLE_39_OF_THE_CHARTER ;
    euai:subjectTo euai:REGULATION__EU__2024_900 .

euai:AI_SYSTEM_FOR_EMOTION_RECOGNITION a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM FOR EMOTION RECOGNITION"@en ;
    skos:definition "AI systems intended to identify or infer emotions or intentions of natural persons on the basis of biometric data, specifically in the workplace or education sectors"@en ;
    euai:subjectTo euai:PROHIBITION_OF_EMOTION_RECOGNITION_AI .

euai:AI_SYSTEM_FOR_MILITARY__DEFENCE_OR_NATIONAL_SECURITY_PURPOSES a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM FOR MILITARY, DEFENCE OR NATIONAL SECURITY PURPOSES"@en ;
    skos:definition "An AI system developed, placed on the market, or used for military, defence, or national security purposes, which is excluded from the Regulation unless used for other purposes."@en ;
    euai:isExemptFromHighRisk euai:MILITARY__DEFENCE_OR_NATIONAL_SECURITY_EXCLUSION ;
    euai:subjectTo euai:OBLIGATION_TO_ENSURE_COMPLIANCE .

euai:AI_SYSTEM_FOR_POLITICAL_CAMPAIGN_ADMINISTRATION a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM FOR POLITICAL CAMPAIGN ADMINISTRATION"@en ;
    skos:definition "Tools used to organise, optimise, and structure political campaigns from an administrative and logistical point of view. Specifically excepted from high-risk classification if natural persons are not directly exposed to the output (Recital 62)."@en ;
    euai:isExemptFromHighRisk euai:HIGH_RISK .

euai:AI_SYSTEM_INTENDED_FOR_ELECTION_OR_REFERENDUM rdfs:label "AI SYSTEM INTENDED FOR ELECTION OR REFERENDUM"@en ;
    euai:subjectTo euai:EXCLUSION_CONDITION__NON_EXPOSURE_TO_OUTPUT .

euai:AI_SYSTEM_INTERACTING_WITH_NATURAL_PERSONS a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM INTERACTING WITH NATURAL PERSONS"@en ;
    skos:definition "AI systems interacting with natural persons are defined as technologies engineered to engage directly with human users or to generate content for their consumption. Due to the inherent potential for impersonation or deception, these systems are subject to strict transparency obligations. Specifically, such AI systems must clearly disclose their identity, ensuring that natural persons are fully aware they are interacting with an artificial intelligence rather than another human being. These requi"@en ;
    euai:subjectTo euai:TRANSPARENCY_OBLIGATION .

euai:AI_SYSTEM_PRESENTING_A_RISK a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM PRESENTING A RISK"@en ;
    skos:definition "An \"AI system presenting a risk\" is defined as an artificial intelligence system that poses threats to the health, safety, or fundamental rights of individuals. This classification aligns directly with the criteria established in Regulation (EU) 2019/1020, which outlines the parameters for \"products presenting a risk.\" Consequently, an AI system is categorized as presenting a risk if it meets these defined standards, essentially functioning as an equivalent to the \"product presenting a risk\" des"@en ;
    euai:definedInArticle euai:ARTICLE_3_19__OF_REGULATION_2019_1020 ;
    euai:regulatedBy euai:ARTICLE_79 ;
    euai:subjectTo euai:EVALUATION_OF_AI_SYSTEM .

euai:AI_VALUE_CHAIN a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "AI VALUE CHAIN"@en ;
    skos:definition "Various operators involved in the design, development, deployment, or use of AI systems, subject to obligations under this Regulation"@en ;
    euai:relatedTo euai:RECORD_KEEPING,
        euai:TECHNICAL_DOCUMENTATION,
        euai:TRANSPARENCY .

euai:ANNEX_III_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "ANNEX III AI SYSTEM"@en ;
    skos:definition "AI systems covered by Annex III, subject to specific certificate validity periods as defined in the introductory text."@en ;
    euai:relatedTo euai:CERTIFICATE_EXTENSION .

euai:ANNEX_III_CATEGORIES_1__6__OR_7 a owl:NamedIndividual,
        euai:AnnexIIICategory ;
    rdfs:label "ANNEX III CATEGORIES 1, 6, OR 7"@en ;
    skos:definition "Specific high-risk use case categories (e.g., law enforcement, migration, asylum) where specific information handling and access restrictions apply"@en ;
    euai:relatedTo euai:ACCESS_TO_TECHNICAL_DOCUMENTATION .

euai:ANNEX_III_POINTS_6__7_AND_8 a owl:NamedIndividual,
        euai:AnnexIIICategory ;
    rdfs:label "ANNEX III POINTS 6, 7 AND 8"@en ;
    skos:definition "Specific categories of high-risk AI systems subject to designation of data protection authorities as market surveillance authorities"@en ;
    euai:relatedTo euai:MARKET_SURVEILLANCE_AUTHORITY .

euai:ANNEX_III_POINT_1 rdfs:label "ANNEX III POINT 1"@en ;
    euai:relatedTo euai:MARKET_SURVEILLANCE_AUTHORITY .

euai:ANNEX_I_AI_SYSTEM rdfs:label "ANNEX I AI SYSTEM"@en ;
    euai:relatedTo euai:CERTIFICATE_EXTENSION .

euai:ANNEX_I_SECTION_A a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ANNEX I SECTION A"@en ;
    skos:definition "List of Union harmonisation legislation; high-risk AI systems falling under this legislation must follow specific assessment procedures"@en ;
    euai:subjectTo euai:HIGH_RISK_AI_SYSTEM .

euai:APPLICATION_DATE_2_AUGUST_2026 a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "APPLICATION DATE 2 AUGUST 2026"@en ;
    skos:definition "The general date of application for the Regulation, except where specific provisions apply earlier (Recital 179)"@en .

euai:ARTICLE_102 rdfs:label "ARTICLE 102"@en ;
    euai:relatedTo euai:REGULATION__EC__NO_300_2008 .

euai:ARTICLE_103 rdfs:label "ARTICLE 103"@en ;
    euai:relatedTo euai:REGULATION__EU__NO_167_2013 .

euai:ARTICLE_104 rdfs:label "ARTICLE 104"@en ;
    euai:relatedTo euai:REGULATION__EU__NO_168_2013 .

euai:ARTICLE_10_5_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 10(5)"@en ;
    skos:definition "Specific legal reference mentioned as an exception to other legal act interactions."@en .

euai:ARTICLE_111 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 111"@en ;
    skos:definition "Article 111 of the AI Act, dealing with AI systems and general-purpose AI models already placed on the market or put into service."@en .

euai:ARTICLE_14_5_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 14(5)"@en ;
    skos:definition "Reference for the natural persons involved in the verification of results"@en .

euai:ARTICLE_23 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 23"@en ;
    skos:definition "**ARTICLE 23** serves as a regulatory provision that outlines and defines the specific obligations required of importers. It establishes the mandatory responsibilities and duties that importers must adhere to within the context of the relevant framework."@en ;
    euai:definedInArticle euai:PENALTIES_FOR_GENERAL_NON_COMPLIANCE .

euai:ARTICLE_24 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 24"@en ;
    skos:definition "Article defining obligations of distributors"@en ;
    euai:definedInArticle euai:PENALTIES_FOR_GENERAL_NON_COMPLIANCE .

euai:ARTICLE_26 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 26"@en ;
    skos:definition "Article 26 defines the specific obligations for deployers of high-risk AI systems. As a regulatory provision, it outlines the requirements and responsibilities that entities or individuals must adhere to when utilizing AI systems that have been classified as high-risk. By specifying these duties, the article ensures that deployers operate within a defined framework of accountability and compliance when implementing such technologies."@en ;
    euai:definedInArticle euai:PENALTIES_FOR_GENERAL_NON_COMPLIANCE ;
    euai:relatedTo euai:DEPLOYER .

euai:ARTICLE_26_5_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 26(5)"@en ;
    skos:definition "Legal reference concerning monitoring the operation of specific high-risk AI systems"@en .

euai:ARTICLE_290_TFEU a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 290 TFEU"@en ;
    skos:definition "The article providing the legal basis for the Commission to adopt delegated acts to adapt the regulatory framework, as per Recital 173"@en ;
    euai:definedInArticle euai:DELEGATED_ACT .

euai:ARTICLE_32 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 32"@en ;
    skos:definition "Article defining the presumption of conformity for notified bodies"@en .

euai:ARTICLE_33 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 33"@en ;
    skos:definition "Article 33 establishes key regulatory obligations and operational requirements for notified bodies. Specifically, paragraphs 1, 3, and 4 of Article 33 outline the mandatory responsibilities that notified bodies must uphold in the performance of their duties. Furthermore, the article governs the framework under which these notified bodies may utilize subsidiaries and engage in subcontracting arrangements, ensuring that such practices remain within compliance guidelines. Together, these provisions"@en ;
    euai:definedInArticle euai:PENALTIES_FOR_GENERAL_NON_COMPLIANCE .

euai:ARTICLE_35 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 35"@en ;
    skos:definition "Article concerning identification numbers and lists of notified bodies"@en .

euai:ARTICLE_35_GDPR a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 35 GDPR"@en ;
    skos:definition "Article regarding data protection impact assessments."@en .

euai:ARTICLE_3_48_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 3(48)"@en ;
    skos:definition "Definition of national competent authority"@en .

euai:ARTICLE_3_66_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 3(66)"@en ;
    skos:definition "Reference defining general-purpose AI models, which form the basis for systemic risk assessment and other obligations."@en .

euai:ARTICLE_42_1__AND__2_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 42(1) AND (2)"@en ;
    skos:definition "Specific clauses within Regulation (EU) 2018/1725 regarding consultation requirements"@en .

euai:ARTICLE_49_6_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 49(6)"@en ;
    skos:definition "Provision empowering the Commission to adopt delegated acts to amend conditions for high-risk classification exclusion"@en .

euai:ARTICLE_49_7_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 49(7)"@en ;
    skos:definition "Provision empowering the Commission to adopt delegated acts to delete conditions for high-risk classification exclusion"@en .

euai:ARTICLE_54_3__OF_REGULATION__EU__2019_881 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 54(3) OF REGULATION (EU) 2019/881"@en ;
    skos:definition "Article referenced regarding the cybersecurity certification of products"@en .

euai:ARTICLE_5__6__AND_7_OF_REGULATION__EU__NO_1025_2012 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 5, 6, AND 7 OF REGULATION (EU) NO 1025/2012"@en ;
    skos:definition "Provisions governing the multi-stakeholder governance and participation of stakeholders in the standardisation process."@en .

euai:ARTICLE_68_1_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 68(1)"@en ;
    skos:definition "Article referencing the implementing act that sets out fee structures and procedures for the scientific panel."@en .

euai:ARTICLE_69 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 69"@en ;
    skos:definition "Article 69 addresses the protocols and regulations concerning access to the pool of experts for Member States. This article establishes the framework through which Member States may engage with and utilize this specific body of specialized professionals."@en ;
    euai:appliesTo euai:MEMBER_STATES .

euai:ARTICLE_6_4_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 6(4)"@en ;
    skos:definition "ARTICLE 6(4) functions as a specific legal reference that governs the parameters surrounding the use of personal data. Furthermore, it establishes defined registration requirements applicable to systems categorized as non-high-risk. By integrating these provisions, ARTICLE 6(4) serves a dual purpose in regulatory compliance, ensuring that both data usage practices and the administrative obligations for lower-risk systems are clearly outlined and governed within the relevant legal framework."@en .

euai:ARTICLE_74_10_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 74(10)"@en ;
    skos:definition "Article referencing specific national authorities or bodies that the authorised representative must provide documentation to."@en .

euai:ARTICLE_75 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 75"@en ;
    skos:definition "**ARTICLE 75** serves as the regulatory framework governing mutual assistance, market surveillance, and the control of general-purpose AI systems. Within this scope, the article explicitly defines the powers and authority granted to market surveillance authorities, specifically regarding their capacity to conduct testing, perform inspections, and carry out enforcement actions to ensure compliance within the AI ecosystem."@en ;
    euai:relatedTo euai:AI_OFFICE,
        euai:MARKET_SURVEILLANCE_AUTHORITY .

euai:ARTICLE_88 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 88"@en ;
    skos:definition "Article governing the enforcement of obligations of providers of general-purpose AI models"@en .

euai:ARTICLE_89 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 89"@en ;
    skos:definition "Article governing monitoring actions, including the rights of downstream providers to lodge complaints"@en .

euai:ASSISTIVE_FUNCTION_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "ASSISTIVE FUNCTION AI"@en ;
    skos:definition "AI systems performing primarily assistive functions for standard editing, which are exempt from the marking obligation to remain proportionate."@en ;
    euai:relatedTo euai:MARKING_AND_DETECTION_OBLIGATION .

euai:ASSISTIVE_FUNCTION_EXCEPTION a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "ASSISTIVE FUNCTION EXCEPTION"@en ;
    skos:definition "An exclusion condition for transparency/marking obligations where AI systems perform an assistive function for standard editing or do not substantially alter input data or semantics"@en ;
    euai:appliesTo euai:MARKING_OF_SYNTHETIC_CONTENT .

euai:ASYLUM_AUTHORITY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "ASYLUM AUTHORITY"@en ;
    skos:definition "The **ASYLUM AUTHORITY** is an organization tasked with managing asylum applications and processes. Within the scope of its duties, the **ASYLUM AUTHORITY** is legally permitted to perform identity checks, provided these actions are conducted in compliance with both Union and national laws. Furthermore, when the **ASYLUM AUTHORITY** operates in the capacity of a provider of high-risk AI systems, it is mandated to ensure that it maintains and provides access to all necessary technical documentati"@en ;
    euai:grants euai:IDENTITY_CHECK ;
    euai:hasObligation euai:TECHNICAL_DOCUMENTATION .

euai:AUTHORISED_REPRESENTATIVE_APPOINTMENT a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "AUTHORISED REPRESENTATIVE APPOINTMENT"@en ;
    skos:definition "Requirement to appoint an authorised representative where applicable; failure to do so is formal non-compliance under Article 83"@en ;
    euai:definedInArticle euai:ARTICLE_83 .

euai:AUTHORITIES_INVOLVED_IN_THE_APPLICATION_OF_THE_REGULATION a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "AUTHORITIES INVOLVED IN THE APPLICATION OF THE REGULATION"@en ;
    skos:definition "Authorities (including national competent authorities, the Commission, and market surveillance authorities) tasked with enforcing the AI Act, mandated to protect confidential information and data obtained during their activities"@en ;
    euai:relatedTo euai:PROTECTION_OF_CONFIDENTIAL_INFORMATION ;
    euai:subjectTo euai:CYBERSECURITY_MEASURES_FOR_DATA_PROTECTION .

euai:AUTOMATIC_LOGGING a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "AUTOMATIC LOGGING"@en ;
    skos:definition "**AUTOMATIC LOGGING** refers to the essential technical capability integrated into high-risk AI systems to systematically record events throughout the entire duration of the system's operational lifetime. As mandated by Article 12(1), this feature is a critical compliance requirement designed to ensure comprehensive traceability, allowing for the auditing and monitoring of the system's performance and decision-making processes over time."@en ;
    euai:relatedTo euai:RECORD_KEEPING .

euai:AUTONOMOUS_ROBOTS a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AUTONOMOUS ROBOTS"@en ;
    skos:definition "Robots operating in complex environments (manufacturing, personal assistance) which, due to their autonomy, are considered significant AI systems requiring safety and reliability."@en .

euai:AuthorisedRepresentative a owl:Class ;
    rdfs:label "Authorised Representative"@en ;
    rdfs:subClassOf euai:Actor ;
    skos:definition "A person in the Union mandated by a provider established outside the Union. (Article 3(5))"@en .

euai:BIOMETRIC_CATEGORISATION_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "BIOMETRIC CATEGORISATION AI"@en ;
    skos:definition "BIOMETRIC CATEGORISATION AI refers to an artificial intelligence system designed to perform biometric categorisation by analyzing sensitive or protected attributes of individuals. These systems are specifically classified under Annex III 1(b) of the relevant regulatory framework, which highlights their high-risk nature due to their use of personal and sensitive data for classification purposes. By processing biometric information to categorize individuals based on protected characteristics, thes"@en ;
    euai:belongsToCategory euai:BIOMETRICS .

euai:BIOMETRIC_CATEGORISATION_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "BIOMETRIC CATEGORISATION AI SYSTEM"@en ;
    skos:definition "AI system used for biometric categorisation for law enforcement purposes, subject to specific data processing rules"@en ;
    euai:subjectTo euai:HARMONISED_RULES .

euai:BIOMETRIC_DATA_PROCESSING_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "BIOMETRIC DATA PROCESSING AI"@en ;
    skos:definition "AI systems that process biometric data to identify/infer emotions, intentions, or specific categories (sex, age, etc.) of natural persons, triggering notification obligations."@en ;
    euai:relatedTo euai:TRANSPARENCY_OBLIGATION .

euai:BIOMETRIC_VERIFICATION a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "BIOMETRIC VERIFICATION"@en ;
    skos:definition "Systems used to confirm that a specific person is who they claim to be for access to services, devices, or premises. Sole purpose is authentication (Recital 15)"@en ;
    euai:isBasedOn euai:BIOMETRIC_DATA ;
    euai:relatedTo euai:BIOMETRIC_IDENTIFICATION,
        euai:REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM .

euai:BIOMETRIC_VERIFICATION_AI rdfs:label "BIOMETRIC VERIFICATION AI"@en ;
    euai:belongsToCategory euai:BIOMETRICS .

euai:BIOMETRIC_VERIFICATION_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "BIOMETRIC VERIFICATION SYSTEM"@en ;
    skos:definition """**BIOMETRIC VERIFICATION SYSTEM** refers to AI-based systems specifically designed and utilized for authentication purposes. The primary function of a **BIOMETRIC VERIFICATION SYSTEM** is to confirm an individual's identity to grant them access to specific services, devices, or premises.

Under current regulatory frameworks, such as Recital 54, these systems are explicitly categorized as distinct from broader biometric identification categories. Specifically, a **BIOMETRIC VERIFICATION SYSTEM** """@en ;
    euai:relatedTo euai:BIOMETRIC_VERIFICATION_EXCLUSION,
        euai:REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM .

euai:BORDER_CONTROL_AUTHORITY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "BORDER CONTROL AUTHORITY"@en ;
    skos:definition """The **BORDER CONTROL AUTHORITY** is an organization tasked with overseeing and managing border control operations. Within the scope of its duties, the **BORDER CONTROL AUTHORITY** is legally authorized to conduct identity checks, provided these actions are performed in accordance with both applicable Union and national laws. 

Furthermore, when the **BORDER CONTROL AUTHORITY** functions as a provider of high-risk AI systems, it is mandated to ensure that it maintains and provides access to the n"""@en ;
    euai:hasObligation euai:TECHNICAL_DOCUMENTATION ;
    euai:relatedTo euai:IDENTITY_CHECK .

euai:BiometricIdentificationSystem a owl:NamedIndividual,
        euai:HighRiskAISystem ;
    rdfs:label "BiometricIdentificationSystem"@en ;
    skos:definition "AI systems for biometric identification of persons"@en ;
    euai:articleReference "Annex III, 1" .

euai:CAPITAL_REQUIREMENT_CALCULATION_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "CAPITAL REQUIREMENT CALCULATION AI SYSTEM"@en ;
    skos:definition "AI systems used for prudential purposes to calculate credit institutions’ and insurance undertakings’ capital requirements"@en ;
    euai:relatedTo euai:CAPITAL_REQUIREMENT_CALCULATION_EXCLUSION .

euai:CENELEC a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "CENELEC"@en ;
    skos:definition "European Committee for Electrotechnical Standardization, a permanent member of the advisory forum"@en ;
    euai:relatedTo euai:ADVISORY_FORUM .

euai:CERTIFICATE_TRANSFER_OBLIGATION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "CERTIFICATE TRANSFER OBLIGATION"@en ;
    skos:definition "When a notified body ceases activity, certificates may remain valid for nine months if another notified body assumes responsibility and completes a full assessment"@en ;
    euai:definedInArticle euai:ARTICLE_36 .

euai:CE_MARKING_OBLIGATION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "CE MARKING OBLIGATION"@en ;
    skos:definition "Requirement to affix CE marking correctly per Article 48, missing or incorrectly affixed marking constitutes formal non-compliance under Article 83"@en ;
    euai:definedInArticle euai:ARTICLE_83 .

euai:CHAIR a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "CHAIR"@en ;
    skos:definition "The individual leading the Board, whose tasks, selection, and mandate duration are defined in the Board's rules of procedure as per Article 65(5)."@en ;
    euai:relatedTo euai:EUROPEAN_ARTIFICIAL_INTELLIGENCE_BOARD .

euai:CHAPTER_I a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "CHAPTER I"@en ;
    skos:definition "A section of the Regulation that applies from 2 February 2025 according to Article 113."@en ;
    euai:definedInArticle euai:ARTICLE_113 .

euai:CHAPTER_II a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "CHAPTER II"@en ;
    skos:definition "A section of the Regulation that applies from 2 February 2025 according to Article 113."@en ;
    euai:definedInArticle euai:ARTICLE_113 .

euai:CHAPTER_III_SECTION_4 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "CHAPTER III SECTION 4"@en ;
    skos:definition "A section of the Regulation that applies from 2 August 2025 according to Article 113."@en ;
    euai:definedInArticle euai:ARTICLE_113 .

euai:CHAPTER_VII a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "CHAPTER VII"@en ;
    skos:definition "A section of the Regulation that applies from 2 August 2025 according to Article 113."@en ;
    euai:definedInArticle euai:ARTICLE_113 .

euai:CHAPTER_VI_OF_REGULATION__EU__2019_1020 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "CHAPTER VI OF REGULATION (EU) 2019/1020"@en ;
    skos:definition "Legal reference for mutual assistance procedures in cross-border cases involving high-risk AI systems"@en .

euai:CHAPTER_XII a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "CHAPTER XII"@en ;
    skos:definition "A section of the Regulation that applies from 2 August 2025 according to Article 113."@en ;
    euai:definedInArticle euai:ARTICLE_113 .

euai:CIRCUMVENTION_PROHIBITION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "CIRCUMVENTION PROHIBITION"@en ;
    skos:definition "Requirement that integration of features or functionality must not be a means to circumvent the applicability of the rules of the AI Act."@en ;
    euai:relatedTo euai:ANCILLARY_FEATURE_EXCLUSION .

euai:CIVIL_AVIATION_SECURITY_REGULATION a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "CIVIL AVIATION SECURITY REGULATION"@en ;
    skos:definition """Regulation (EC) No 300/2008 establishes the common rules for civil aviation security, serving as the primary legal framework governing security protocols within the civil aviation sector. This regulation is designed to standardize and enhance security measures across the field of civil aviation, ensuring consistent safety standards for the protection of passengers, crew, and airport infrastructure.

Beyond its foundational role in aviation safety, Regulation (EC) No 300/2008 is also recognized f"""@en ;
    euai:subjectTo euai:HIGH_RISK_AI_SYSTEM .

euai:CIVIL_PROTECTION_AUTHORITY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "CIVIL PROTECTION AUTHORITY"@en ;
    skos:definition "The Civil Protection Authority is a governmental body tasked with the oversight and management of civil protection measures. In performing its duties, the Civil Protection Authority possesses the specific mandate to deploy high-risk AI systems without obtaining prior authorization from market surveillance authorities. This ability to bypass standard authorization procedures is strictly limited to exceptional, urgent, or justified situations, ensuring that the Authority can effectively respond to"@en ;
    euai:appliesTo euai:HIGH_RISK_AI_SYSTEM ;
    euai:hasException euai:URGENT_DEPLOYMENT_EXCEPTION ;
    euai:relatedTo euai:URGENT_DEPLOYMENT_AUTHORISATION .

euai:COMMISSION_RECOMMENDATION_2003_361_EC a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "COMMISSION RECOMMENDATION 2003/361/EC"@en ;
    skos:definition """Commission Recommendation 2003/361/EC is the official European Commission document that establishes the standardized criteria for defining micro, small, and medium-sized enterprises (SMEs). This classification is critical for regulatory and policy contexts, as it provides a clear framework for distinguishing smaller businesses from larger entities.

Notably, Commission Recommendation 2003/361/EC is referenced in Recital 44 of the Artificial Intelligence Act (AI Act). In this context, the definit"""@en .

euai:COMMON_AND_LEGITIMATE_COMMERCIAL_PRACTICES a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "COMMON AND LEGITIMATE COMMERCIAL PRACTICES"@en ;
    skos:definition "Exemption for standard advertising practices that comply with applicable law."@en ;
    euai:hasException euai:PROHIBITION_OF_MANIPULATIVE_AI_PRACTICES .

euai:COMPETENT_AUTHORITIES_FOR_FINANCIAL_SERVICES a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "COMPETENT AUTHORITIES FOR FINANCIAL SERVICES"@en ;
    skos:definition """The Competent Authorities for Financial Services are the regulatory and supervisory bodies specifically mandated to oversee and enforce financial services law within the European Union. These authorities are formally defined under Regulation (EU) No 575/2013, as well as Directives 2008/48/EC, 2009/138/EC, and 2013/36/EU.

Beyond their established duties in the financial sector, these Competent Authorities for Financial Services have been designated to supervise the implementation and enforcement"""@en ;
    euai:relatedTo euai:EUROPEAN_CENTRAL_BANK,
        euai:MARKET_SURVEILLANCE,
        euai:REGULATION__EU__NO_575_2013 .

euai:COMPETENT_AUTHORITY_FOR_CRIMINAL_OFFENCES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "COMPETENT AUTHORITY FOR CRIMINAL OFFENCES"@en ;
    skos:definition "Authorities responsible for the prevention, investigation, detection, or prosecution of criminal offences, subject to specific data processing rules under Directive (EU) 2016/680"@en ;
    euai:relatedTo euai:PERSONAL_DATA_PROTECTION .

euai:COMPETENT_JUDICIAL_AUTHORITY a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "COMPETENT JUDICIAL AUTHORITY"@en ;
    skos:definition "A judicial or independent administrative body that issues binding decisions, grants/rejects authorisations, and supervises the use of real-time remote biometric identification systems."@en ;
    euai:definedInArticle euai:ARTICLE_5 ;
    euai:grants euai:PRIOR_AUTHORISATION .

euai:COMPETENT_NATIONAL_COURT a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "COMPETENT NATIONAL COURT"@en ;
    skos:definition "A **COMPETENT NATIONAL COURT** refers to the judicial bodies within Member States that are officially authorized to impose administrative fines. The specific authority and jurisdiction of these courts are determined by the respective national legal systems of each Member State. As outlined in Article 99(9), these courts play a critical role in the enforcement of administrative penalties, ensuring that such actions are carried out in strict accordance with the laws of their governing jurisdiction"@en ;
    euai:relatedTo euai:ADMINISTRATIVE_FINE .

euai:COMPETENT_PUBLIC_AUTHORITY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "COMPETENT PUBLIC AUTHORITY"@en ;
    skos:definition "A Competent Public Authority is defined as any public authority, including relevant Union institutions, bodies, or agencies, that is mandated to perform essential duties related to migration, asylum, and border control management. These entities hold responsibilities that extend to administrative and law enforcement enforcement tasks within these domains. Furthermore, in the context of technological oversight and governance, the term specifically encompasses those authorities that are actively i"@en ;
    euai:appliesTo euai:AI_SYSTEM_FOR_ASYLUM_AND_VISA_PROCESSING,
        euai:AI_SYSTEM_FOR_MIGRATION_POLYGRAPHS,
        euai:AI_SYSTEM_FOR_MIGRATION_RISK_ASSESSMENT ;
    euai:relatedTo euai:MIGRATION__ASYLUM_AND_BORDER_CONTROL_AI_SYSTEM .

euai:COMPLAINANT a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "COMPLAINANT"@en ;
    skos:definition "A person or entity that lodges a complaint and is associated with proceedings conducted by the European Data Protection Supervisor."@en ;
    euai:relatedTo euai:EUROPEAN_DATA_PROTECTION_SUPERVISOR .

euai:COMPLAINT_HANDLING_AND_REDRESS_PROCEDURES a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "COMPLAINT HANDLING AND REDRESS PROCEDURES"@en ;
    skos:definition "Specific operational procedures that deployers must establish to mitigate risks to fundamental rights when using high-risk AI systems per Recital 96"@en ;
    euai:relatedTo euai:FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT .

euai:CONFIDENTIALITY_RULES a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "CONFIDENTIALITY RULES"@en ;
    skos:definition "Obligation for members of national competent authorities to refrain from actions incompatible with their duties and protect sensitive information."@en .

euai:CONFORMITY_ASSESSMENT_BODY_OF_THIRD_COUNTRY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "CONFORMITY ASSESSMENT BODY OF THIRD COUNTRY"@en ;
    skos:definition "Bodies established in non-EU countries that may be authorised to act as notified bodies if they meet Article 31 requirements or equivalent compliance standards, per Article 39"@en ;
    euai:regulatedBy euai:ARTICLE_39 .

euai:CONFORMITY_ASSESSMENT_PROCEDURE_BASED_ON_INTERNAL_CONTROL a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "CONFORMITY ASSESSMENT PROCEDURE BASED ON INTERNAL CONTROL"@en ;
    skos:definition "A specific conformity assessment procedure (Annex VI) involving verification of the quality management system, technical documentation, and post-market monitoring"@en ;
    euai:definedInArticle euai:ANNEX_VI .

euai:CONFORMITY_BASED_ON_ASSESSMENT_OF_QUALITY_MANAGEMENT_SYSTEM_AND_TECHNICAL_DOCUMENTATION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "CONFORMITY BASED ON ASSESSMENT OF QUALITY MANAGEMENT SYSTEM AND TECHNICAL DOCUMENTATION"@en ;
    skos:definition "A specific conformity assessment procedure (Annex VII) involving formal assessment of the quality management system and technical documentation"@en ;
    euai:definedInArticle euai:ANNEX_VII .

euai:CONSUMERS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "CONSUMERS"@en ;
    skos:definition "Natural persons who may be negatively impacted by AI systems and for whom rights and remedies are preserved under Union law, including under Council Directive 85/374/EEC"@en ;
    euai:relatedTo euai:COUNCIL_DIRECTIVE_85_374_EEC .

euai:CONSUMER_ORGANISATIONS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "CONSUMER ORGANISATIONS"@en ;
    skos:definition "Consumer organisations are essential stakeholder groups that represent the interests of consumers. Their active participation and representation are highly encouraged in the development of standards, as their inclusion ensures that consumer needs and perspectives are properly integrated into the standard-setting process."@en ;
    euai:relatedTo euai:HARMONISED_STANDARD,
        euai:HARMONISED_STANDARDS .

euai:CONTRACTING_OPERATOR a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "CONTRACTING OPERATOR"@en ;
    skos:definition "An operator in the Union receiving outputs from an AI system used in a third country."@en .

euai:COUNCIL_OF_THE_EUROPEAN_UNION a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "COUNCIL OF THE EUROPEAN UNION"@en ;
    skos:definition "One of the co-legislating bodies that adopted Regulation (EU) 2024/1689"@en ;
    euai:relatedTo euai:REGULATION__EU__2024_1689 .

euai:CREDITWORTHINESS_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "CREDITWORTHINESS AI"@en ;
    skos:definition "AI system used to evaluate the creditworthiness of natural persons or establish their credit score."@en ;
    euai:belongsToCategory euai:ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES ;
    euai:hasException euai:FINANCIAL_FRAUD_DETECTION_EXCLUSION .

euai:CREDIT_INSTITUTIONS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "CREDIT INSTITUTIONS"@en ;
    skos:definition "Entities subject to prudential requirements under Regulation (EU) No 575/2013 (Recital 46)"@en ;
    euai:relatedTo euai:REGULATION__EU__NO_575_2013 .

euai:CREDIT_INSTITUTIONS_AND_INSURANCE_UNDERTAKINGS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "CREDIT INSTITUTIONS AND INSURANCE UNDERTAKINGS"@en ;
    skos:definition "Entities that use AI for prudential purposes and credit scoring"@en .

euai:CREDIT_SCORING_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "CREDIT SCORING AI SYSTEM"@en ;
    skos:definition "**CREDIT SCORING AI SYSTEMS** are automated technologies designed to evaluate the credit scores or creditworthiness of natural persons. These systems play a critical role in the financial ecosystem, as the assessments they generate directly influence an individual's access to vital financial resources and essential services. Due to this significant impact on people's lives and economic opportunities, these systems are formally classified as high-risk."@en ;
    euai:relatedTo euai:ESSENTIAL_SERVICES,
        euai:HIGH_RISK .

euai:CRIMINAL_OFFENCE_INVESTIGATION_EXCEPTION a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "CRIMINAL OFFENCE INVESTIGATION EXCEPTION"@en ;
    skos:definition "An exclusion condition for transparency obligations regarding AI systems used by law enforcement to detect, prevent, investigate, or prosecute criminal offences, provided appropriate safeguards are in place"@en ;
    euai:appliesTo euai:TRANSPARENCY_OBLIGATION .

euai:CRIMINAL_RISK_ASSESSMENT_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "CRIMINAL RISK ASSESSMENT AI SYSTEM"@en ;
    skos:definition "AI system assessing/predicting criminal risk based solely on profiling or personality traits; prohibited unless supporting human assessment of criminal activity based on objective facts"@en ;
    euai:belongsToCategory euai:PROHIBITED_AI_PRACTICE ;
    euai:hasException euai:CRIMINAL_RISK_ASSESSMENT_EXCLUSION .

euai:CRIMINAL_VICTIMISATION_RISK_ASSESSMENT_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "CRIMINAL VICTIMISATION RISK ASSESSMENT AI"@en ;
    skos:definition "AI systems used by law enforcement to assess the risk of a natural person becoming a victim of criminal offences (Annex III 6(a))"@en ;
    euai:belongsToCategory euai:LAW_ENFORCEMENT .

euai:CRITICAL_DIGITAL_INFRASTRUCTURE_SAFETY_COMPONENT a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "CRITICAL DIGITAL INFRASTRUCTURE SAFETY COMPONENT"@en ;
    skos:definition "AI systems used as safety components in the management and operation of critical digital infrastructure (Annex III 2)"@en ;
    euai:belongsToCategory euai:CRITICAL_INFRASTRUCTURE .

euai:CRITICAL_INFRASTRUCTURE_SAFETY_COMPONENT a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "CRITICAL INFRASTRUCTURE SAFETY COMPONENT"@en ;
    skos:definition """The term "CRITICAL INFRASTRUCTURE SAFETY COMPONENT" refers to AI systems that are specifically intended to function as safety components within the management and operation of critical infrastructure. These systems play a vital role in ensuring the reliability and security of essential services and systems that support society.

Specifically, these AI systems are utilized in the management and operation of critical digital infrastructure, as well as in the oversight of critical public services s"""@en ;
    euai:alwaysClassifiedAs euai:HIGH_RISK_AI_SYSTEM ;
    euai:definedInArticle euai:RECITAL_55 ;
    euai:isBasedOn euai:SAFETY_COMPONENT_DEFINITION ;
    euai:relatedTo euai:CRITICAL_INFRASTRUCTURE,
        euai:CYBERSECURITY_PURPOSE .

euai:CRITICAL_SITUATIONS a owl:NamedIndividual,
        euai:ClassificationRule ;
    rdfs:label "CRITICAL SITUATIONS"@en ;
    skos:definition "Criterion regarding decisions made in critical situations for life, health, and property, used to justify high-risk classification"@en ;
    euai:relatedTo euai:EMERGENCY_SERVICE_AI_SYSTEM .

euai:CUSTOMS_AUTHORITIES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "CUSTOMS AUTHORITIES"@en ;
    skos:definition "Public authorities that use risk analytic tools for predicting the localisation of narcotics or illicit goods, which are excluded from the general prohibition on risk assessment systems."@en ;
    euai:relatedTo euai:RISK_ANALYTICS_AI_SYSTEMS .

euai:CYBERSECURITY_BIOMETRIC_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "CYBERSECURITY BIOMETRIC SYSTEM"@en ;
    skos:definition "Biometric systems intended solely for enabling cybersecurity and personal data protection measures, explicitly excluded from high-risk classification (Recital 54)"@en ;
    euai:isExemptFromHighRisk euai:HIGH_RISK_AI_SYSTEM .

euai:CYBERSECURITY_SCHEME a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "CYBERSECURITY SCHEME"@en ;
    skos:definition "The \"CYBERSECURITY SCHEME\" is a certification framework established pursuant to Regulation (EU) 2019/881, commonly known as the Cybersecurity Act. This scheme is designed to play a critical role in the regulatory landscape for high-risk AI systems. When a system meets the requirements set forth by this scheme, it benefits from a presumption of conformity with the cybersecurity standards mandated by the relevant legal framework. Specifically, this certification is utilized to establish a presumpt"@en ;
    euai:relatedTo euai:HIGH_RISK_AI_SYSTEM .

euai:CriticalInfrastructureAI a owl:NamedIndividual,
        euai:HighRiskAISystem ;
    rdfs:label "CriticalInfrastructureAI"@en ;
    skos:definition "AI for management and operation of critical infrastructure"@en ;
    euai:articleReference "Annex III, 2" .

euai:DATA_PROCESSOR a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "DATA PROCESSOR"@en ;
    skos:definition "A role under GDPR (Regulation (EU) 2016/679) where an entity processes personal data on behalf of a controller, applicable to providers and deployers of AI systems"@en .

euai:DATA_PROTECTION_AUTHORITIES a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "DATA PROTECTION AUTHORITIES"@en ;
    skos:definition "National public authorities that supervise the application of Union law protecting fundamental rights, whose independence is preserved by this Regulation."@en ;
    euai:relatedTo euai:REGULATION__EU__2024_1689 .

euai:DATA_PROTECTION_BY_DESIGN_AND_BY_DEFAULT a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "DATA PROTECTION BY DESIGN AND BY DEFAULT"@en ;
    skos:definition "A foundational data protection principle requiring privacy-preserving measures in the design and operation of AI systems."@en .

euai:DATA_PROTECTION_SUPERVISORY_AUTHORITY a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "DATA PROTECTION SUPERVISORY AUTHORITY"@en ;
    skos:definition "Competent authority under Regulation (EU) 2016/679 or Directive (EU) 2016/680, designated by Member States as market surveillance authority for specific high-risk AI systems in law enforcement, border management, justice, and democracy"@en ;
    euai:relatedTo euai:MARKET_SURVEILLANCE_AUTHORITY .

euai:DATA_QUALITY_REQUIREMENT a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "DATA QUALITY REQUIREMENT"@en ;
    skos:definition "Requirement for AI systems to be trained and tested on data reflecting the specific geographical, behavioural, contextual, or functional setting of intended use, linked to Article 10(4)"@en .

euai:DATA_SUBJECT a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "DATA SUBJECT"@en ;
    skos:definition "A **DATA SUBJECT** is defined as a natural person whose personal data is processed, including instances where this processing is carried out by AI systems. Regardless of the context in which their data is handled, the **DATA SUBJECT** retains the full scope of rights and guarantees afforded to them under Union data protection law, such as the General Data Protection Regulation (GDPR) and the Law Enforcement Directive (LED). These protections include, but are not limited to, the right to withdraw"@en ;
    euai:relatedTo euai:AI_SYSTEM,
        euai:PROVIDER,
        euai:REAL_WORLD_TESTING,
        euai:SOLELY_AUTOMATED_INDIVIDUAL_DECISION_MAKING .

euai:DATA_TRAINING_REQUIREMENT a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "DATA TRAINING REQUIREMENT"@en ;
    skos:definition "Technical requirement for data used to train AI systems; non-compliance triggers mandatory re-training prior to new conformity assessment"@en ;
    euai:subjectTo euai:CHAPTER_III__SECTION_2 .

euai:DEEP_FAKE a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "DEEP FAKE"@en ;
    skos:definition "AI-generated or manipulated content (image, audio, video) that falsely appears authentic, as defined in Article 3(60)"@en .

euai:DEEP_FAKES a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "DEEP FAKES"@en ;
    skos:definition "Content generated or manipulated by AI that appreciably resembles existing persons, objects, places, entities or events, falsely appearing authentic"@en ;
    euai:subjectTo euai:TRANSPARENCY_OBLIGATION .

euai:DEEP_FAKE_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "DEEP FAKE AI SYSTEM"@en ;
    skos:definition "An AI system that generates or manipulates image, audio or video content constituting a deep fake"@en ;
    euai:hasException euai:EXEMPTION_FOR_ARTISTIC_CREATIVE_WORK ;
    euai:relatedTo euai:LAW_ENFORCEMENT_EXCEPTION ;
    euai:subjectTo euai:TRANSPARENCY_OBLIGATION .

euai:DEMOCRATIC_PROCESSES a owl:NamedIndividual,
        euai:AnnexIIICategory ;
    rdfs:label "DEMOCRATIC PROCESSES"@en ;
    skos:definition "High-risk domain encompassing AI systems intended to influence the outcome of elections, referenda, or voting behaviour (Recital 62)."@en ;
    euai:belongsToCategory euai:HIGH_RISK .

euai:DENMARK rdfs:label "DENMARK"@en ;
    euai:definedInArticle euai:PROTOCOL_NO_22 ;
    euai:isExemptFromHighRisk euai:ARTICLE_5 .

euai:DETECTION_OF_PATTERNS a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "DETECTION OF PATTERNS"@en ;
    skos:definition "Condition where an AI system detects decision-making patterns without replacing/influencing human assessment, potentially exempting it from high-risk classification"@en ;
    euai:isExemptFromHighRisk euai:HIGH_RISK_AI_SYSTEM .

euai:DIGITAL_SERVICES_ACT a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "DIGITAL SERVICES ACT"@en ;
    skos:definition "Regulation (EU) 2022/2065, establishing rules for the single market for digital services, referenced for interaction with the AI Act"@en ;
    euai:appliesThroughout euai:AISYSTEM ;
    euai:relatedTo euai:EU_AI_ACT .

euai:DIRECTIVE_2005_29_EC a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "DIRECTIVE 2005/29/EC"@en ;
    skos:definition "Directive concerning unfair commercial practices, complementary to the AI Act's prohibitions."@en .

euai:DIRECTIVE_2006_42_EC a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "DIRECTIVE 2006/42/EC"@en ;
    skos:definition "Union harmonisation legislation applicable to machinery (Recital 46)"@en ;
    euai:relatedTo euai:RECITAL_46 .

euai:DIRECTIVE_2008_48_EC a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "DIRECTIVE 2008/48/EC"@en ;
    skos:definition "Directive 2008/48/EC, specifically referencing its Recital 47, is a piece of European Union legislation that acts as a directive on credit agreements for consumers. This directive is significant for establishing critical legal standards for financial services within the consumer credit market. By setting these standards, Directive 2008/48/EC aims to provide a harmonized framework that ensures consumer protection and promotes transparency in credit agreements across member states."@en ;
    euai:relatedTo euai:DIRECTIVE_2014_17_EU .

euai:DIRECTIVE_2009_138_EC a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "DIRECTIVE 2009/138/EC"@en ;
    skos:definition "Directive on the taking-up and pursuit of the business of Insurance and Reinsurance (Solvency II) (Recital 48)"@en ;
    euai:relatedTo euai:DIRECTIVE__EU__2016_97 .

euai:DIRECTIVE_2013_36_EU a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "DIRECTIVE 2013/36/EU"@en ;
    skos:definition """Directive 2013/36/EU, also known as the Capital Requirements Directive (CRD IV), is a key piece of European Union legislation that governs the access to the activity of credit institutions and the prudential supervision of both credit institutions and investment firms. Specifically, Recital 49 of the directive emphasizes the fundamental importance of robust supervisory frameworks to maintain financial stability and market integrity.

In the contemporary regulatory landscape, Directive 2013/36/EU"""@en ;
    euai:relatedTo euai:COUNCIL_REGULATION__EU__NO_1024_2013 .

euai:DIRECTIVE_2014_31_EU a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "DIRECTIVE 2014/31/EU"@en ;
    skos:definition "Directive 2014/31/EU refers to the Non-automatic Weighing Instruments Directive. This European Union regulation is designed to govern the market availability and harmonization of laws across member states regarding non-automatic weighing instruments. By establishing uniform standards, the directive ensures that these instruments meet consistent requirements before being placed on the market."@en .

euai:DIRECTIVE_2014_32_EU a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "DIRECTIVE 2014/32/EU"@en ;
    skos:definition "DIRECTIVE 2014/32/EU, commonly known as the Measuring Instruments Directive (MID), is a European Union legislative act designed to regulate the market availability and harmonization of laws for measuring instruments within the EU. It establishes a unified regulatory framework that ensures measuring devices meet consistent standards, thereby facilitating the free movement and trade of these instruments across member states. By harmonizing national laws, the directive aims to maintain high levels "@en .

euai:DIRECTIVE__EU__2016_2102 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "DIRECTIVE (EU) 2016/2102"@en ;
    skos:definition """**DIRECTIVE (EU) 2016/2102** is the European Union legislation governing the accessibility of websites and mobile applications managed by public sector bodies. This directive establishes a legal framework aimed at ensuring that digital content provided by public authorities is inclusive and accessible to all users, including those with disabilities.

The directive is referenced across various parts of the legislative text, appearing in both Recital 38 and Recital 80. By standardizing accessibili"""@en ;
    euai:relatedTo euai:ACCESSIBILITY_REQUIREMENT .

euai:DataGovernance a owl:Class ;
    rdfs:label "Data Governance"@en ;
    rdfs:subClassOf euai:Requirement ;
    skos:definition "Requirements on training, validation and testing data. (Article 10)"@en .

euai:Distributor a owl:Class ;
    rdfs:label "Distributor"@en ;
    rdfs:subClassOf euai:Actor ;
    skos:definition "A person in the supply chain other than provider/importer. (Article 3(7))"@en .

euai:ECONOMIC_OPERATOR a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "ECONOMIC OPERATOR"@en ;
    skos:definition "Any person/organization subject to Regulation (EU) 2019/1020, understood to include operators identified in Article 2(1) of the AI Act"@en ;
    euai:subjectTo euai:REGULATION__EU__2019_1020 .

euai:ECRIS_TCN a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "ECRIS-TCN"@en ;
    skos:definition "ECRIS-TCN is a centralised system designed to facilitate the identification of Member States that possess conviction information regarding third-country nationals and stateless persons. Established under Regulation (EU) 2019/816, the system serves as an essential mechanism for improving judicial cooperation and information exchange across the European Union, ensuring that authorities can efficiently determine where records of previous criminal convictions for these specific groups are held."@en ;
    euai:relatedTo euai:REGULATION__EU__2019_816 .

euai:EDUCATIONAL_ADMISSION_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EDUCATIONAL ADMISSION AI"@en ;
    skos:definition "AI systems determining access or admission to educational and vocational training institutions (Annex III 3(a))"@en ;
    euai:belongsToCategory euai:EDUCATION_AND_VOCATIONAL_TRAINING .

euai:EDUCATION_ACCESS_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EDUCATION ACCESS AI"@en ;
    skos:definition "AI system used to determine access or admission to educational or vocational training institutions."@en ;
    euai:belongsToCategory euai:EDUCATION_AND_VOCATIONAL_TRAINING .

euai:EDUCATION_AND_VOCATIONAL_TRAINING_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EDUCATION AND VOCATIONAL TRAINING AI SYSTEM"@en ;
    skos:definition "AI systems used in education or vocational training for determining access, assignment to institutions, evaluating learning outcomes, assessing education levels, or monitoring prohibited student behaviour (Recital 56)"@en ;
    euai:alwaysClassifiedAs euai:HIGH_RISK_AI_SYSTEM ;
    euai:belongsToCategory euai:EDUCATION_AND_VOCATIONAL_TRAINING ;
    euai:definedInArticle euai:RECITAL_56 .

euai:EDUCATION_EVALUATION_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EDUCATION EVALUATION AI"@en ;
    skos:definition "AI system used to evaluate learning outcomes or steer the learning process."@en ;
    euai:belongsToCategory euai:EDUCATION_AND_VOCATIONAL_TRAINING .

euai:EDUCATION_LEVEL_ASSESSMENT_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EDUCATION LEVEL ASSESSMENT AI"@en ;
    skos:definition "AI systems assessing appropriate level of education individuals will receive or access (Annex III 3(c))"@en ;
    euai:belongsToCategory euai:EDUCATION_AND_VOCATIONAL_TRAINING .

euai:EMERGENCY_CALL_CLASSIFICATION_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EMERGENCY CALL CLASSIFICATION AI"@en ;
    skos:definition "AI systems used to evaluate and classify emergency calls (Annex III 5(d))"@en ;
    euai:belongsToCategory euai:ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES .

euai:EMERGENCY_DISPATCH_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EMERGENCY DISPATCH AI"@en ;
    skos:definition "AI systems used to dispatch or establish priority in emergency first response services (Annex III 5(d))"@en ;
    euai:belongsToCategory euai:ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES .

euai:EMERGENCY_HEALTHCARE_TRIAGE_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EMERGENCY HEALTHCARE TRIAGE AI"@en ;
    skos:definition "AI systems used for emergency healthcare patient triage (Annex III 5(d))"@en ;
    euai:belongsToCategory euai:ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES .

euai:EMERGENCY_RESPONSE_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EMERGENCY RESPONSE AI"@en ;
    skos:definition "AI system used to evaluate/classify emergency calls or dispatch emergency first response services."@en ;
    euai:belongsToCategory euai:ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES .

euai:EMOTION_INFERENCE_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EMOTION INFERENCE AI SYSTEM"@en ;
    skos:definition "AI system inferring emotions in workplace or education contexts; prohibited unless for medical or safety reasons"@en ;
    euai:belongsToCategory euai:PROHIBITED_AI_PRACTICE ;
    euai:hasException euai:EMOTION_INFERENCE_EXCLUSION .

euai:EMOTION_RECOGNITION_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EMOTION RECOGNITION AI"@en ;
    skos:definition "Emotion recognition AI encompasses artificial intelligence systems specifically designed and intended to identify, analyze, and interpret human emotions. These technologies are categorized under Annex III 1(c) of regulatory frameworks, such as the EU AI Act, which classifies them as high-risk systems due to their capacity to influence and interpret sensitive human behavioral and psychological data."@en ;
    euai:belongsToCategory euai:BIOMETRICS .

euai:EMOTION_RECOGNITION_AI_SYSTEM rdfs:label "EMOTION RECOGNITION AI SYSTEM"@en ;
    euai:belongsToCategory euai:EDUCATION_CATEGORY,
        euai:WORKPLACE_CATEGORY ;
    euai:subjectTo euai:PROHIBITION_OF_EMOTION_RECOGNITION_AI .

euai:EMOTION_RECOGNITION_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EMOTION RECOGNITION SYSTEM"@en ;
    skos:definition """An Emotion Recognition System is defined as an AI system specifically designed to identify or infer the emotions or intentions of natural persons by analyzing their biometric data. As specified in Article 3(39) and Recital 18 of the relevant regulatory framework, these systems operate by interpreting biometric inputs to discern a subject's internal states.

The scope of an Emotion Recognition System excludes technologies used solely for detecting physical states, such as fatigue or pain, unless """@en ;
    euai:alwaysClassifiedAs euai:HIGH_RISK_AI_SYSTEM ;
    euai:belongsToCategory euai:AISYSTEM ;
    euai:definedInArticle euai:ARTICLE_3_39_ ;
    euai:isExemptFromHighRisk euai:EXCLUSION_FOR_MERE_EXPRESSION_DETECTION,
        euai:EXCLUSION_FOR_PHYSICAL_STATE_DETECTION ;
    euai:relatedTo euai:AI_SYSTEM,
        euai:LAW_ENFORCEMENT_EXCEPTION,
        euai:REAL_TIME_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM ;
    euai:subjectTo euai:INFORMATION_OBLIGATION,
        euai:TRANSPARENCY_OBLIGATION .

euai:EMPLOYERS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "EMPLOYERS"@en ;
    skos:definition "Entities involved in the employment relationship, whose industrial relations and collective bargaining rights remain unaffected by this Regulation"@en ;
    euai:relatedTo euai:WORKERS .

euai:ENVIRONMENTAL_AND_SOCIAL_STAKEHOLDERS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "ENVIRONMENTAL AND SOCIAL STAKEHOLDERS"@en ;
    skos:definition "Relevant groups whose representation is encouraged in the development of standards"@en ;
    euai:relatedTo euai:HARMONISED_STANDARDS .

euai:EQUALITY_BODIES a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "EQUALITY BODIES"@en ;
    skos:definition "National public authorities that supervise the application of Union law protecting fundamental rights, whose independence is preserved by this Regulation."@en ;
    euai:relatedTo euai:REGULATION__EU__2024_1689 .

euai:ESSENTIAL_SERVICES_SUPPLY_SAFETY_COMPONENT a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "ESSENTIAL SERVICES SUPPLY SAFETY COMPONENT"@en ;
    skos:definition "AI systems used as safety components in the supply of water, gas, heating or electricity (Annex III 2)"@en ;
    euai:belongsToCategory euai:CRITICAL_INFRASTRUCTURE .

euai:ETSI a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "ETSI"@en ;
    skos:definition "European Telecommunications Standards Institute, a permanent member of the advisory forum"@en ;
    euai:relatedTo euai:ADVISORY_FORUM .

euai:EUROPEAN_ARREST_WARRANT_DECISION a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "EUROPEAN ARREST WARRANT DECISION"@en ;
    skos:definition """The **European Arrest Warrant Decision** is formally established by Council Framework Decision 2002/584/JHA. This legal instrument serves as the foundation for surrender procedures between Member States of the European Union, facilitating the efficient extradition of individuals to face prosecution or serve custodial sentences.

Beyond its primary function as a mechanism for judicial cooperation and the surrender of persons across borders, the European Arrest Warrant Decision is increasingly sig"""@en .

euai:EUROPEAN_ARTIFICIAL_INTELLIGENCE_OFFICE a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "EUROPEAN ARTIFICIAL INTELLIGENCE OFFICE"@en ;
    skos:definition "The European Artificial Intelligence Office is an EU-level body established by Commission Decision C(2024) 390 (Recital 45). Its primary mandate is to oversee the implementation and enforcement of the AI Act. Beyond this broad oversight, the European Artificial Intelligence Office is also tasked with developing practical tools, such as templates and questionnaires, designed to facilitate compliance and reduce the administrative burden for AI deployers."@en ;
    euai:providesInstructionsTo euai:COMPLIANCE_QUESTIONNAIRE_TEMPLATE ;
    euai:relatedTo euai:COMMISSION_DECISION_C_2024__390,
        euai:DIRECTIVE__EU__2019_1937 .

euai:EUROPEAN_COMMISSION_ rdfs:label "EUROPEAN COMMISSION"@en ;
    euai:relatedTo euai:ADVISORY_FORUM .

euai:EUROPEAN_COMMITTEE_FOR_ELECTROTECHNICAL_STANDARDIZATION a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "EUROPEAN COMMITTEE FOR ELECTROTECHNICAL STANDARDIZATION"@en ;
    skos:definition "Also known as CENELEC, a permanent member of the advisory forum (Article 67(5))."@en ;
    euai:relatedTo euai:ADVISORY_FORUM .

euai:EUROPEAN_COMMITTEE_FOR_STANDARDIZATION a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "EUROPEAN COMMITTEE FOR STANDARDIZATION"@en ;
    skos:definition "Also known as CEN, a permanent member of the advisory forum (Article 67(5))."@en ;
    euai:relatedTo euai:ADVISORY_FORUM .

euai:EUROPEAN_COUNCIL a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "EUROPEAN COUNCIL"@en ;
    skos:definition "EU institution that has stated the objective of promoting a human-centric approach to AI and global leadership in ethical AI"@en ;
    euai:relatedTo euai:AI_SYSTEM .

euai:EUROPEAN_TELECOMMUNICATIONS_STANDARDS_INSTITUTE a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "EUROPEAN TELECOMMUNICATIONS STANDARDS INSTITUTE"@en ;
    skos:definition "The European Telecommunications Standards Institute, commonly referred to as ETSI, is formally recognized as a permanent member of the advisory forum, a designation specifically cited under Article 67(5). As an organization, it maintains this established role within the advisory framework."@en ;
    euai:relatedTo euai:ADVISORY_FORUM .

euai:EUROPEAN_TRAVEL_INFORMATION_AND_AUTHORISATION_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EUROPEAN TRAVEL INFORMATION AND AUTHORISATION SYSTEM"@en ;
    skos:definition "The European Travel Information and Authorisation System, commonly referred to as ETIAS, is a centralized IT system designed to manage travel information and authorization requests for third-country nationals. Established under the framework of Regulation (EU) 2018/1240 and Regulation (EU) 2018/1241, this system streamlines the processing of data for travelers who are not citizens of the European Union, ensuring effective oversight and security. By integrating these regulations, ETIAS serves as "@en ;
    euai:definedInArticle euai:REGULATION__EU__2018_1241 ;
    euai:relatedTo euai:REGULATION__EU__2018_1240 .

euai:EUROPOL a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "EUROPOL"@en ;
    skos:definition "EUROPOL, formally known as the European Union Agency for Law Enforcement Cooperation, is the primary body responsible for supporting law enforcement activities across the European Union. As part of its operational mandate, EUROPOL is officially authorised to request and obtain access to Eurodac data, a critical resource utilized for the purposes of law enforcement to assist in maintaining security and combating crime within the region."@en ;
    euai:relatedTo euai:EURODAC .

euai:EU_INTEROPERABILITY_FRAMEWORK a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EU INTEROPERABILITY FRAMEWORK"@en ;
    skos:definition "A framework establishing interoperability between various EU information systems in the fields of borders, visa, police, judicial cooperation, asylum, and migration"@en ;
    euai:definedInArticle euai:REGULATION__EU__2019_817,
        euai:REGULATION__EU__2019_818 .

euai:EVALUATION_AND_REVIEW a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "EVALUATION AND REVIEW"@en ;
    skos:definition "Duty of the Commission to assess the Regulation, Annex III, and Article 5, and report findings to the Parliament and Council (Article 112)"@en .

euai:EVALUATION_OF_AI_SYSTEM_CLASSIFICATION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "EVALUATION OF AI SYSTEM CLASSIFICATION"@en ;
    skos:definition "The process by which a market surveillance authority determines if an AI system classified as non-high-risk should be classified as high-risk, based on Article 6(3) and Commission guidelines"@en ;
    euai:definedInArticle euai:ARTICLE_80 ;
    euai:isBasedOn euai:ARTICLE_6_3_ .

euai:EVENT_RECORDING a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "EVENT RECORDING"@en ;
    skos:definition "The specific duty to capture start and end dates/times, input data, and search results for high-risk AI systems under Article 12(3)"@en .

euai:EVIDENCE_RELIABILITY_EVALUATION_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EVIDENCE RELIABILITY EVALUATION AI SYSTEM"@en ;
    skos:definition "AI systems used for the evaluation of the reliability of evidence in the course of investigation or prosecution of criminal offences"@en ;
    euai:relatedTo euai:HIGH_RISK .

euai:EXCLUSION_CONDITION a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "EXCLUSION CONDITION"@en ;
    skos:definition "Four specific criteria under which an AI system, otherwise listed as high-risk under Annex III, may be considered non-high-risk: 1) narrow and limited nature/limited risk, 2) improves the result of a previously completed human activity, 3) detects decision-making patterns or deviations, or 4) performs a task preparatory to an assessment."@en ;
    euai:relatedTo euai:NON_HIGH_RISK .

euai:EXCLUSION_FOR_ANCILLARY_JUDICIAL_TASKS a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "EXCLUSION FOR ANCILLARY JUDICIAL TASKS"@en ;
    skos:definition "Classification rule where AI systems for purely administrative tasks (e.g., anonymisation, document processing) that do not affect the administration of justice are not high-risk (Recital 61)."@en .

euai:EXCLUSION_FOR_MEDICAL_OR_SAFETY_PURPOSES a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "EXCLUSION FOR MEDICAL OR SAFETY PURPOSES"@en ;
    skos:definition "The \"EXCLUSION FOR MEDICAL OR SAFETY PURPOSES\" refers to a specific exception within regulatory frameworks concerning the use of emotion recognition AI. Under this provision, systems that are placed on the market strictly for medical or safety reasons are exempt from the general prohibition against emotion recognition AI. One prominent example of a permissible application under this exclusion is the use of such technology for therapeutic purposes, as outlined in Recital 44. Consequently, while e"@en ;
    euai:hasException euai:PROHIBITION_OF_EMOTION_RECOGNITION_AI .

euai:EXCLUSION_FROM_HIGH_RISK_CLASSIFICATION a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "EXCLUSION FROM HIGH-RISK CLASSIFICATION"@en ;
    skos:definition "The principle that AI systems which do not materially influence decision-making outcomes (e.g., narrow procedural tasks, improvement of human activity) may not be considered high-risk (Recital 53)"@en ;
    euai:isExemptFromHighRisk euai:HIGH_RISK_AI_SYSTEM .

euai:EXCLUSION__NATIONAL_SECURITY a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "EXCLUSION: NATIONAL SECURITY"@en ;
    skos:definition "AI systems used exclusively for military, defence, or national security purposes are outside the scope of the Regulation, per Article 2(3)"@en ;
    euai:isExemptFromHighRisk euai:AI_SYSTEM .

euai:EXCLUSION__PRE_MARKET_ACTIVITIES a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "EXCLUSION: PRE-MARKET ACTIVITIES"@en ;
    skos:definition "\"EXCLUSION: PRE-MARKET ACTIVITIES\" refers to specific categories of work that fall outside the scope of the relevant regulations. According to Article 2(8), any research, testing, or development activities conducted prior to placing a product or service on the market or putting it into service are excluded from regulation. This encompasses the entirety of the pre-market phase, ensuring that the necessary preliminary work remains exempt."@en ;
    euai:isExemptFromHighRisk euai:AI_SYSTEM .

euai:EXCLUSION__SCIENTIFIC_RESEARCH a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "EXCLUSION: SCIENTIFIC RESEARCH"@en ;
    skos:definition "AI systems developed solely for scientific research and development are excluded from the scope, per Article 2(6)"@en ;
    euai:isExemptFromHighRisk euai:AI_SYSTEM .

euai:EXCLUSION__THIRD_COUNTRY_COOPERATION a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "EXCLUSION: THIRD COUNTRY COOPERATION"@en ;
    skos:definition "Exemption for public authorities in third countries under international law enforcement/judicial cooperation agreements, per Article 2(4)"@en ;
    euai:isExemptFromHighRisk euai:THIRD_COUNTRY_PUBLIC_AUTHORITY .

euai:EXEMPTION_FOR_POINT_2_OF_ANNEX_III a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "EXEMPTION FOR POINT 2 OF ANNEX III"@en ;
    skos:definition "A specific condition exempting certain high-risk AI systems from the registration obligation under Article 49(1) and 49(3)"@en ;
    euai:relatedTo euai:REGISTRATION .

euai:EXPERT_PANELS__EXPERT_LABORATORIES_AND_REFERENCE_LABORATORIES rdfs:label "EXPERT PANELS  EXPERT LABORATORIES AND REFERENCE LABORATORIES"@en ;
    euai:relatedTo euai:REGULATION__EU__2017_745,
        euai:REGULATION__EU__2017_746 .

euai:EXPLOITATIVE_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "EXPLOITATIVE AI SYSTEM"@en ;
    skos:definition "An AI system that exploits vulnerabilities of natural persons due to age, disability, or specific circumstances (Article 5(1)(b))"@en ;
    euai:subjectTo euai:PROHIBITION_OF_EXPLOITATION .

euai:EducationAdmissionAI a owl:NamedIndividual,
        euai:HighRiskAISystem ;
    rdfs:label "EducationAdmissionAI"@en ;
    skos:definition "AI determining access to educational institutions"@en ;
    euai:articleReference "Annex III, 3" .

euai:EmploymentAI a owl:NamedIndividual,
        euai:HighRiskAISystem ;
    rdfs:label "EmploymentAI"@en ;
    skos:definition "AI for recruitment and employment decisions"@en ;
    euai:articleReference "Annex III, 4" .

euai:EssentialServicesAI a owl:NamedIndividual,
        euai:HighRiskAISystem ;
    rdfs:label "EssentialServicesAI"@en ;
    skos:definition "AI for access to essential private and public services"@en ;
    euai:articleReference "Annex III, 5" .

euai:EuropeanAIBoard a owl:Class ;
    rdfs:label "European AI Board"@en ;
    rdfs:subClassOf euai:Authority ;
    skos:definition "Advisory body composed of Member State representatives. (Article 65)"@en .

euai:ExploitativeAI a owl:NamedIndividual,
        euai:ProhibitedAIPractice ;
    rdfs:label "ExploitativeAI"@en ;
    skos:definition "AI exploiting vulnerabilities of specific groups"@en ;
    euai:articleReference "Article 5(1)(b)" .

euai:FACIAL_RECOGNITION_DATABASE_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "FACIAL RECOGNITION DATABASE AI SYSTEM"@en ;
    skos:definition "AI system creating or expanding facial recognition databases through untargeted scraping of internet or CCTV images"@en ;
    euai:belongsToCategory euai:PROHIBITED_AI_PRACTICE .

euai:FATIGUE_DETECTION_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "FATIGUE DETECTION SYSTEM"@en ;
    skos:definition "An AI system used for detecting physical states like fatigue in professional contexts (e.g., pilots or drivers), excluded from the scope of emotion recognition systems per Recital 18."@en .

euai:FINANCIAL_FRAUD_DETECTION_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "FINANCIAL FRAUD DETECTION AI"@en ;
    skos:definition "AI systems used for detecting financial fraud (Annex III 5(b))"@en ;
    euai:belongsToCategory euai:ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES .

euai:FINANCIAL_FRAUD_DETECTION_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "FINANCIAL FRAUD DETECTION AI SYSTEM"@en ;
    skos:definition "**FINANCIAL FRAUD DETECTION AI SYSTEMS** are advanced technological tools designed to enhance security and regulatory compliance within the financial sector. Specifically, these systems are utilized to identify fraudulent activities in the provision of financial services and to assist financial institutions in accurately calculating their required capital reserves. Due to their specific function and regulatory context, these AI systems are explicitly excluded from high-risk classification, disti"@en ;
    euai:isExemptFromHighRisk euai:FINANCIAL_FRAUD_DETECTION_EXCLUSION .

euai:FINANCIAL_INSTITUTION a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "FINANCIAL INSTITUTION"@en ;
    skos:definition """A Financial Institution is defined as a provider regulated under Union financial services law that utilizes high-risk AI systems. As entities operating within this specific regulatory framework, these institutions are subject to distinct compliance and oversight protocols designed to integrate with existing financial sector mandates.

Under these regulations, Financial Institutions are overseen by national financial authorities rather than general AI regulatory bodies, ensuring that the supervis"""@en ;
    euai:reducedObligationsApplyTo euai:POST_MARKET_MONITORING_SYSTEM,
        euai:QUALITY_MANAGEMENT_SYSTEM ;
    euai:relatedTo euai:FINANCIAL_SUPERVISOR,
        euai:INTERNAL_GOVERNANCE_ARRANGEMENTS,
        euai:MARKET_SURVEILLANCE_AUTHORITY,
        euai:NATIONAL_COMPETENT_AUTHORITY ;
    euai:subjectTo euai:LOG_KEEPING .

euai:FINANCIAL_INTELLIGENCE_ADMINISTRATIVE_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "FINANCIAL INTELLIGENCE ADMINISTRATIVE AI SYSTEM"@en ;
    skos:definition "AI systems used by financial intelligence units carrying out administrative tasks analyzing information under anti-money laundering law"@en ;
    euai:relatedTo euai:FINANCIAL_INTELLIGENCE_EXCLUSION .

euai:FINANCIAL_INTELLIGENCE_UNIT a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "FINANCIAL INTELLIGENCE UNIT"@en ;
    skos:definition "Units carrying out administrative tasks analyzing information pursuant to Union anti-money laundering law"@en ;
    euai:relatedTo euai:FINANCIAL_INTELLIGENCE_EXCLUSION .

euai:FINANCIAL_INTELLIGENCE_UNITS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "FINANCIAL INTELLIGENCE UNITS"@en ;
    skos:definition "Bodies carrying out administrative tasks under anti-money laundering law, whose AI tools are generally excluded from law enforcement high-risk classification."@en .

euai:FORMER_PROVIDER rdfs:label "FORMER PROVIDER"@en ;
    euai:hasObligation euai:TRANSITION_TO_HIGH_RISK_AI_SYSTEM .

euai:FORMER_PROVIDER_COOPERATION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "FORMER PROVIDER COOPERATION"@en ;
    skos:definition "Former providers must provide information, technical access, and assistance to new providers to enable compliance, especially for conformity assessments."@en ;
    euai:hasObligation euai:HIGH_RISK_AI_SYSTEM ;
    euai:relatedTo euai:CONFORMITY_ASSESSMENT .

euai:FRAUD_DETECTION_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "FRAUD DETECTION AI SYSTEM"@en ;
    skos:definition "AI systems provided for by Union law for the purpose of detecting fraud in the offering of financial services"@en ;
    euai:relatedTo euai:FINANCIAL_SERVICES_FRAUD_DETECTION_EXCLUSION .

euai:FREE_AND_OPEN_SOURCE_AI_COMPONENT a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "FREE AND OPEN-SOURCE AI COMPONENT"@en ;
    skos:definition "AI components released under free and open-source licenses, which may benefit from exceptions regarding transparency-related requirements unless they present systemic risk"@en ;
    euai:relatedTo euai:OPEN_SOURCE_EXCEPTION .

euai:FREE_AND_OPEN_SOURCE_LICENCE a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "FREE AND OPEN-SOURCE LICENCE"@en ;
    skos:definition """A "free and open-source licence" functions as a regulatory exemption framework within specific legal contexts, notably concerning the obligations of third parties and the classification of General Purpose AI (GPAI) models. 

Under this licensing condition, third parties providing tools, services, or components—excluding GPAI models—are granted an exemption from value-chain compliance requirements. In the specific context of GPAI models, the licence serves as a qualifying condition for an exempti"""@en ;
    euai:isExemptFromHighRisk euai:AI_VALUE_CHAIN_PARTIES,
        euai:ARTICLE_54 ;
    euai:relatedTo euai:DATA_SHEETS,
        euai:MODEL_CARDS,
        euai:MODEL_WEIGHTS_AND_ARCHITECTURE .

euai:FUNDAMENTAL_RIGHTS_AGENCY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "FUNDAMENTAL RIGHTS AGENCY"@en ;
    skos:definition "EU agency and a permanent member of the advisory forum (Article 67(5))."@en ;
    euai:relatedTo euai:ADVISORY_FORUM .

euai:GENERAL_DATE_OF_APPLICATION a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "GENERAL DATE OF APPLICATION"@en ;
    skos:definition "The date of 2 August 2026, when the Regulation generally applies (Recital 179)."@en .

euai:GENERAL_PENALTY_RULES a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "GENERAL PENALTY RULES"@en ;
    skos:definition "Obligation for Member States to lay down and notify the Commission of rules on penalties, including administrative fines, applicable from 2 August 2025"@en .

euai:GENERAL_PURPOSE_AI_MODEL_PROVIDER a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "GENERAL-PURPOSE AI MODEL PROVIDER"@en ;
    skos:definition "General-purpose AI model providers are entities responsible for the development and provision of general-purpose AI models. As key actors within the AI value chain, these providers bear specific obligations regarding documentation and transparency, as detailed in Recital 101. Furthermore, general-purpose AI model providers are invited to participate in the development and implementation of codes of practice to ensure responsible deployment and alignment with regulatory standards."@en ;
    euai:hasObligation euai:TECHNICAL_DOCUMENTATION ;
    euai:relatedTo euai:CODE_OF_PRACTICE,
        euai:DOWNSTREAM_PROVIDER,
        euai:SYSTEMIC_RISK ;
    euai:subjectTo euai:TRANSPARENCY_RELATED_REQUIREMENTS .

euai:GOVERNANCE_AND_ENFORCEMENT_SYSTEM a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "GOVERNANCE AND ENFORCEMENT SYSTEM"@en ;
    skos:definition "The system of supervision and governance that the Commission must evaluate (Recital 174)"@en .

euai:GPAI_PROVIDER a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "GPAI PROVIDER"@en ;
    skos:definition "The entity responsible for placing general-purpose AI models on the market, subject to specific regulatory obligations"@en ;
    euai:relatedTo euai:GENERAL_PURPOSE_AI_MODEL,
        euai:INTERNAL_PROCESS_EXCLUSION,
        euai:RESEARCH_AND_PROTOTYPING_EXCLUSION .

euai:HEALTH_AND_LIFE_INSURANCE_RISK_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "HEALTH AND LIFE INSURANCE RISK AI"@en ;
    skos:definition "AI systems used for risk assessment and pricing in life and health insurance (Annex III 5(c))"@en ;
    euai:belongsToCategory euai:ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES .

euai:HEALTH_AND_LIFE_INSURANCE_RISK_ASSESSMENT_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "HEALTH AND LIFE INSURANCE RISK ASSESSMENT AI SYSTEM"@en ;
    skos:definition "AI systems used for risk assessment and pricing for natural persons regarding health and life insurance"@en .

euai:HIGH_RISK_AI a owl:NamedIndividual,
        euai:RiskCategory ;
    rdfs:label "HIGH-RISK AI"@en ;
    skos:definition "The classification heading for Chapter III, implying the regulatory scope for systems under discussion."@en .

euai:HIGH_RISK_AI_SYSTEM_NOT_USING_TRAINING a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "HIGH-RISK AI SYSTEM NOT USING TRAINING"@en ;
    skos:definition "A high-risk AI system that does not involve techniques using the training of AI models, for which obligations regarding data processing apply only to testing data sets"@en ;
    euai:relatedTo euai:TESTING_DATA_SETS .

euai:HIGH_RISK_USE_CASE a owl:NamedIndividual,
        euai:AnnexIIICategory ;
    rdfs:label "HIGH-RISK USE CASE"@en ;
    skos:definition "Specific domains listed in an Annex to the Regulation where AI systems are presumed to be high-risk, unless exclusion conditions apply."@en ;
    euai:alwaysClassifiedAs euai:PROFILING .

euai:HORIZON_EUROPE a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "HORIZON EUROPE"@en ;
    skos:definition "A Union funding programme and project that should contribute to the objectives of this Regulation"@en ;
    euai:relatedTo euai:COMPLIANCE_WITH_THIS_REGULATION .

euai:HUMAN_AGENCY_AND_OVERSIGHT a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "HUMAN AGENCY AND OVERSIGHT"@en ;
    skos:definition "The requirement that AI systems act as tools that respect human dignity, autonomy, and function under human control"@en ;
    euai:relatedTo euai:ETHICAL_PRINCIPLES_FOR_TRUSTWORTHY_AI .

euai:HighRisk a owl:NamedIndividual,
        euai:RiskCategory ;
    rdfs:label "HighRisk"@en ;
    skos:definition "Risk level triggering the full set of Chapter III obligations"@en ;
    euai:articleReference "Article 6" .

euai:HumanOversight a owl:Class ;
    rdfs:label "Human Oversight"@en ;
    rdfs:subClassOf euai:Requirement ;
    skos:definition "Measures enabling humans to oversee and intervene in AI system operation. (Article 14)"@en .

euai:IDENTIFICATION_NUMBER a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "IDENTIFICATION NUMBER"@en ;
    skos:definition "The specific number of the notified body that must follow the CE marking and appear in promotional material"@en ;
    euai:relatedTo euai:CE_MARKING .

euai:IMMIGRATION_AUTHORITY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "IMMIGRATION AUTHORITY"@en ;
    skos:definition "The **IMMIGRATION AUTHORITY** is an organization tasked with overseeing immigration processes. Within its mandate, the **IMMIGRATION AUTHORITY** is permitted to conduct identity checks, provided that these actions strictly adhere to the conditions established by both Union and national law. Furthermore, in instances where the **IMMIGRATION AUTHORITY** acts as a provider of high-risk AI systems, it is mandated to ensure that it maintains and provides access to the necessary technical documentatio"@en ;
    euai:hasObligation euai:TECHNICAL_DOCUMENTATION ;
    euai:relatedTo euai:IDENTITY_CHECK .

euai:IMPORTANT_AND_CRITICAL_PRODUCTS_WITH_DIGITAL_ELEMENTS a owl:NamedIndividual,
        euai:ClassificationRule ;
    rdfs:label "IMPORTANT AND CRITICAL PRODUCTS WITH DIGITAL ELEMENTS"@en ;
    skos:definition "A specific category of products with digital elements that, when also classified as high-risk AI systems, trigger specific conformity assessment derogations as per Recital 78."@en ;
    euai:subjectTo euai:INTERNAL_CONTROL .

euai:IMPROVEMENT_OF_HUMAN_ACTIVITY_EXCLUSION a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "IMPROVEMENT OF HUMAN ACTIVITY EXCLUSION"@en ;
    skos:definition "A condition where an AI system is intended to improve the result of a previously completed human activity, thereby resulting in lowered risk and potential exclusion from high-risk classification"@en ;
    euai:isExemptFromHighRisk euai:MATERIAL_INFLUENCE_CRITERION ;
    euai:relatedTo euai:HIGH_RISK_AI_SYSTEM .

euai:IMPROVEMENT_OF_PREVIOUS_HUMAN_ACTIVITY a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "IMPROVEMENT OF PREVIOUS HUMAN ACTIVITY"@en ;
    skos:definition "Condition where an AI system is intended to improve the result of a previously completed human activity, potentially exempting it from high-risk classification"@en ;
    euai:isExemptFromHighRisk euai:HIGH_RISK_AI_SYSTEM .

euai:INDEPENDENT_ADMINISTRATIVE_AUTHORITY a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "INDEPENDENT ADMINISTRATIVE AUTHORITY"@en ;
    skos:definition "An independent administrative body empowered to grant or reject express and specific authorisation for the use of real-time remote biometric identification systems."@en ;
    euai:grants euai:PRIOR_AUTHORISATION .

euai:INDEPENDENT_SUPERVISORY_AUTHORITIES rdfs:label "INDEPENDENT SUPERVISORY AUTHORITIES"@en ;
    euai:relatedTo euai:REGULATION__EU__2016_679__GDPR_ .

euai:INFORMATION_OR_DOCUMENTATION rdfs:label "INFORMATION OR DOCUMENTATION"@en ;
    euai:subjectTo euai:CONFIDENTIALITY_OBLIGATIONS .

euai:INITIAL_PROVIDER a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "INITIAL PROVIDER"@en ;
    skos:definition "The original provider of an AI system who is no longer considered the provider when a distributor/importer/third party takes over responsibility via substantial modification or other means)"@en ;
    euai:hasObligation euai:COOPERATION_OBLIGATION ;
    euai:relatedTo euai:CONFORMITY_ASSESSMENT .

euai:INPUT_DATA a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "INPUT DATA"@en ;
    skos:definition "Data provided to or acquired by an AI system, which serves as the basis for the system to produce an output."@en .

euai:INSURANCE_RISK_ASSESSMENT_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "INSURANCE RISK ASSESSMENT AI"@en ;
    skos:definition "AI system used for risk assessment and pricing for life and health insurance."@en ;
    euai:belongsToCategory euai:ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES .

euai:INTEGRATION_INTO_SOFTWARE a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "INTEGRATION INTO SOFTWARE"@en ;
    skos:definition "An activity in the AI value chain for which providers require assistance from upstream suppliers"@en .

euai:INTENDED_PURPOSE a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "INTENDED PURPOSE"@en ;
    skos:definition "The use for which an AI system is intended by the provider, specified in instructions for use, promotional materials, and technical documentation"@en .

euai:INTENDED_PURPOSE_MODIFICATION a owl:NamedIndividual,
        euai:ClassificationRule ;
    rdfs:label "INTENDED PURPOSE MODIFICATION"@en ;
    skos:definition "The act of changing the intended purpose of an AI system (including general-purpose AI) so it becomes a high-risk AI system; this triggers provider obligations for the modifying party per Recital 84."@en ;
    euai:relatedTo euai:PROVIDER .

euai:INTERACTIVE_GENERATIVE_AI_SYSTEMS a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "INTERACTIVE/GENERATIVE AI SYSTEMS"@en ;
    skos:definition "AI systems intended to interact with natural persons or generate content; they are subject to transparency obligations regardless of their high-risk status"@en ;
    euai:subjectTo euai:TRANSPARENCY_OBLIGATION .

euai:INVESTIGATION_OF_COMPETENCE a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "INVESTIGATION OF COMPETENCE"@en ;
    skos:definition "Duty of the Commission to investigate cases where there are doubts about a notified body's competence or fulfillment of requirements, per Article 37(1)"@en ;
    euai:definedInArticle euai:ARTICLE_37 .

euai:INVESTMENT_FIRMS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "INVESTMENT FIRMS"@en ;
    skos:definition "Entities subject to prudential requirements under Regulation (EU) No 575/2013 (Recital 46)"@en ;
    euai:relatedTo euai:REGULATION__EU__NO_575_2013 .

euai:IN_VITRO_DIAGNOSTIC_MEDICAL_DEVICES_REGULATION a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "IN VITRO DIAGNOSTIC MEDICAL DEVICES REGULATION"@en ;
    skos:definition """The In Vitro Diagnostic Medical Devices Regulation (IVDR), formally known as Regulation (EU) 2017/746, establishes the legal framework governing in vitro diagnostic medical devices within the European Union. This regulation sets out the requirements that manufacturers must meet to place such devices on the market, ensuring high standards of safety, quality, and performance.

A significant aspect of the In Vitro Diagnostic Medical Devices Regulation is its intersection with evolving digital healt"""@en ;
    euai:subjectTo euai:HIGH_RISK_AI_SYSTEM .

euai:IRELAND a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "IRELAND"@en ;
    skos:definition "Ireland is a Member State of the European Union that maintains a distinct legal position regarding certain aspects of judicial and police cooperation in criminal matters. Due to specific opt-out provisions outlined in Article 6a of Protocol No. 21, Ireland is not bound by particular regulations in this domain. This unique status impacts the extent of its obligations under the AI Act, specifically concerning provisions related to police and judicial cooperation within the European Union."@en ;
    euai:relatedTo euai:ARTICLE_26_10_,
        euai:ARTICLE_5,
        euai:CHAPTER_4_OR_CHAPTER_5_OF_TITLE_V_OF_PART_THREE_OF_THE_TFEU .

euai:ISOLATED_DATA_PROCESSING_ENVIRONMENT a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "ISOLATED DATA PROCESSING ENVIRONMENT"@en ;
    skos:definition "A protected environment under the control of the prospective provider where personal data must be kept during sandbox experimentation"@en .

euai:Importer a owl:Class ;
    rdfs:label "Importer"@en ;
    rdfs:subClassOf euai:Actor ;
    skos:definition "A person in the Union who places an AI system from a third country on the market. (Article 3(6))"@en .

euai:JUDICIAL_OR_ADMINISTRATIVE_AUTHORITY a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "JUDICIAL OR ADMINISTRATIVE AUTHORITY"@en ;
    skos:definition "An authority whose decision is binding and subject to judicial review, responsible for granting or rejecting authorisations for the use of post-remote biometric identification systems"@en .

euai:JUDICIAL_OR_INDEPENDENT_ADMINISTRATIVE_AUTHORITY a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "JUDICIAL OR INDEPENDENT ADMINISTRATIVE AUTHORITY"@en ;
    skos:definition "Bodies responsible for granting or rejecting prior authorisation for the use of real-time remote biometric identification systems"@en ;
    euai:grants euai:PRIOR_AUTHORISATION .

euai:JusticeAI a owl:NamedIndividual,
        euai:HighRiskAISystem ;
    rdfs:label "JusticeAI"@en ;
    skos:definition "AI assisting judicial authorities in legal research and decisions"@en ;
    euai:articleReference "Annex III, 8" .

euai:LABELING_OBLIGATION_FOR_TEXT a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "LABELING OBLIGATION FOR TEXT"@en ;
    skos:definition "Requirement to disclose AI-generated or manipulated text published to inform the public on matters of public interest; has exception if content underwent human review/editorial control or a legal person holds editorial responsibility (Recital 134)"@en ;
    euai:relatedTo euai:HOSTING_SERVICES,
        euai:LABELING_OBLIGATION .

euai:LARGE_GENERATIVE_AI_MODEL a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "LARGE GENERATIVE AI MODEL"@en ;
    skos:definition "A typical example of a general-purpose AI model that allows for flexible generation of content like text, audio, images, or video, as described in Recital 99"@en ;
    euai:relatedTo euai:GENERAL_PURPOSE_AI_MODEL .

euai:LARGE_SCALE_IT_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "LARGE-SCALE IT SYSTEM"@en ;
    skos:definition "Large-scale IT systems listed in Annex X; subject to compliance deadlines by 31 December 2030 (Article 111(1))"@en ;
    euai:relatedTo euai:ANNEX_X,
        euai:COMPLIANCE_OBLIGATION .

euai:LAWFUL_BIOMETRIC_LABELLING a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "LAWFUL BIOMETRIC LABELLING"@en ;
    skos:definition "The categorization of biometric data sets (e.g., sorting images by hair or eye colour) acquired in line with Union or national law, which is not covered by the prohibition (Recital 30)."@en ;
    euai:isExemptFromHighRisk euai:BIOMETRIC_CATEGORISATION_SYSTEMS .

euai:LAWFUL_EVALUATION_PRACTICES a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "LAWFUL EVALUATION PRACTICES"@en ;
    skos:definition "Evaluation practices of natural persons carried out for a specific purpose in accordance with Union and national law, which are not prohibited (Recital 31)."@en ;
    euai:isExemptFromHighRisk euai:SOCIAL_SCORING_AI_SYSTEMS .

euai:LAWFUL_MEDICAL_TREATMENT a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "LAWFUL MEDICAL TREATMENT"@en ;
    skos:definition "Exemption for psychological treatment or physical rehabilitation when carried out according to applicable standards and consent."@en ;
    euai:hasException euai:PROHIBITION_OF_MANIPULATIVE_AI_PRACTICES .

euai:LAW_ENFORCEMENT_AND_MIGRATION_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "LAW ENFORCEMENT AND MIGRATION SYSTEM"@en ;
    skos:definition "High-risk AI systems used in specific sensitive domains like law enforcement, migration, asylum, and border control management"@en ;
    euai:isExemptFromHighRisk euai:ELECTRONIC_INSTRUCTIONS_FOR_USE .

euai:LAW_ENFORCEMENT_AUTHORITIES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "LAW ENFORCEMENT AUTHORITIES"@en ;
    skos:definition "**Law Enforcement Authorities** are designated national bodies within Member States that have been granted authorized access to key security and migration systems, such as Eurodac and the Entry/Exit System (EES). These authorities are specifically empowered to request and utilize data from these systems exclusively for the purposes of preventing, detecting, or investigating terrorist activities and other serious criminal offenses."@en ;
    euai:relatedTo euai:ENTRY_EXIT_SYSTEM,
        euai:EURODAC .

euai:LAW_ENFORCEMENT_AUTHORITY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "LAW ENFORCEMENT AUTHORITY"@en ;
    skos:definition """A **Law Enforcement Authority**, as defined in Article 3(45), is a public body or authority entrusted by Member State law with the prevention, investigation, detection, or prosecution of criminal offenses, or the execution of criminal penalties. Tasked with maintaining public security and criminal justice, these entities are increasingly integrating AI systems into their operational functions.

When utilizing AI technologies, particularly high-risk AI systems, Law Enforcement Authorities are sub"""@en ;
    euai:appliesTo euai:AI_SYSTEM_FOR_EVIDENCE_EVALUATION_IN_LAW_ENFORCEMENT,
        euai:AI_SYSTEM_FOR_LAW_ENFORCEMENT_PROFILING,
        euai:AI_SYSTEM_FOR_LAW_ENFORCEMENT_VICTIM_ASSESSMENT,
        euai:AI_SYSTEM_FOR_OFFENDING_RISK_ASSESSMENT,
        euai:AI_SYSTEM_FOR_POLYGRAPHS_IN_LAW_ENFORCEMENT,
        euai:HIGH_RISK_AI_SYSTEM ;
    euai:definedInArticle euai:ARTICLE_3_45_ ;
    euai:hasException euai:URGENT_DEPLOYMENT_EXCEPTION ;
    euai:hasObligation euai:AUTHORISATION_FOR_EXCEPTIONAL_USE,
        euai:DATABASE,
        euai:DOCUMENTATION_OBLIGATION,
        euai:EU_DATABASE_REGISTRATION,
        euai:NOTIFICATION_OBLIGATION,
        euai:REGISTRATION_IN_DATABASE,
        euai:SYSTEM_REGISTRATION,
        euai:TECHNICAL_DOCUMENTATION ;
    euai:relatedTo euai:AI_REGULATORY_SANDBOX,
        euai:AUTHORISATION_OBLIGATION,
        euai:FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT,
        euai:LAW_ENFORCEMENT,
        euai:LAW_ENFORCEMENT_EXCEPTIONS,
        euai:LAW_ENFORCEMENT_SUPPORT_AI,
        euai:PRIOR_AUTHORISATION,
        euai:REAL_TIME_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM,
        euai:REFERENCE_DATABASE_OF_PERSONS,
        euai:URGENCY_EXCEPTION,
        euai:URGENT_DEPLOYMENT_AUTHORISATION ;
    euai:subjectTo euai:NATIONAL_LAW .

euai:LAW_ENFORCEMENT_PROFILING_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "LAW ENFORCEMENT PROFILING AI SYSTEM"@en ;
    skos:definition "AI systems used for profiling in the course of detection, investigation, or prosecution of criminal offences"@en ;
    euai:relatedTo euai:HIGH_RISK .

euai:LEARNING_AFTER_DEPLOYMENT a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "LEARNING AFTER DEPLOYMENT"@en ;
    skos:definition "Changes to algorithm and performance of AI systems that are pre-determined by the provider and assessed at the moment of conformity assessment; these do not constitute a substantial modification"@en ;
    euai:isExemptFromHighRisk euai:SUBSTANTIAL_MODIFICATION .

euai:LEARNING_OUTCOME_EVALUATION_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "LEARNING OUTCOME EVALUATION AI"@en ;
    skos:definition "AI systems used to evaluate learning outcomes or steer the learning process (Annex III 3(b))"@en ;
    euai:belongsToCategory euai:EDUCATION_AND_VOCATIONAL_TRAINING .

euai:LEGALLY_DESIGNATED_REPRESENTATIVE a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "LEGALLY DESIGNATED REPRESENTATIVE"@en ;
    skos:definition "Individual or body authorized to act on behalf of the subjects of the testing in real world conditions"@en .

euai:LIABILITY_FOR_DEFECTIVE_PRODUCTS a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "LIABILITY FOR DEFECTIVE PRODUCTS"@en ;
    skos:definition "The legal duty to compensate for damages caused by defective products, as outlined in Council Directive 85/374/EEC"@en ;
    euai:definedInArticle euai:COUNCIL_DIRECTIVE_85_374_EEC .

euai:LIMITATION_DEROGATIONS a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "LIMITATION DEROGATIONS"@en ;
    skos:definition "Provisions to avoid overlaps by integrating quality management system and monitoring obligations of the AI Act into existing procedures under financial services law for credit/insurance institutions"@en ;
    euai:relatedTo euai:REGULATED_FINANCIAL_INSTITUTIONS .

euai:LOGS_OF_PROCESSING a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "LOGS OF PROCESSING"@en ;
    skos:definition "Records of personal data processing in the sandbox that must be kept for the duration of participation"@en .

euai:LawEnforcementAI a owl:NamedIndividual,
        euai:HighRiskAISystem ;
    rdfs:label "LawEnforcementAI"@en ;
    skos:definition "AI used by law enforcement authorities"@en ;
    euai:articleReference "Annex III, 6" .

euai:LimitedRisk a owl:NamedIndividual,
        euai:RiskCategory ;
    rdfs:label "LimitedRisk"@en ;
    skos:definition "Risk level triggering transparency obligations only"@en ;
    euai:articleReference "Article 50" .

euai:MACHINERY_DIRECTIVE a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "MACHINERY DIRECTIVE"@en ;
    skos:definition "The Machinery Directive, formally known as Directive 2006/42/EC, is a foundational piece of European Union legislation established to regulate product safety for machinery. This directive serves as a critical regulatory framework that manufacturers and providers must adhere to when placing machinery on the market. Furthermore, Directive 2006/42/EC is increasingly recognized as a key piece of legislation regarding the governance and safety compliance of product safety components that involve the "@en ;
    euai:relatedTo euai:HIGH_RISK_AI_SYSTEM .

euai:MACHINE_BRAIN_INTERFACES a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "MACHINE-BRAIN INTERFACES"@en ;
    skos:definition "Technology that facilitates manipulative AI practices by controlling stimuli presented to persons."@en ;
    euai:isBasedOn euai:MANIPULATIVE_OR_DECEPTIVE_AI_SYSTEM .

euai:MAKING_AVAILABLE_ON_THE_MARKET a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "MAKING AVAILABLE ON THE MARKET"@en ;
    skos:definition "The supply of an AI system or a general-purpose AI model for distribution or use on the Union market in the course of a commercial activity, whether in return for payment or free of charge"@en .

euai:MANIPULATIVE_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "MANIPULATIVE AI SYSTEM"@en ;
    skos:definition "An AI system that uses subliminal techniques or manipulative/deceptive practices to distort behavior (Article 5(1)(a))"@en ;
    euai:subjectTo euai:PROHIBITION_OF_MANIPULATIVE_TECHNIQUES .

euai:MARKET_SURVEILLANCE_ACTIVITIES a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "MARKET SURVEILLANCE ACTIVITIES"@en ;
    skos:definition "Activities conducted by market surveillance authorities, which must take into account complaints received under Article 85"@en .

euai:MEDICAL_DEVICES_REGULATION a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "MEDICAL DEVICES REGULATION"@en ;
    skos:definition """The Medical Devices Regulation, formally known as Regulation (EU) 2017/745, serves as the governing legislative framework for medical devices within the European Union. This comprehensive regulation establishes the standards and requirements that must be met to ensure the safety and performance of medical devices placed on the market. 

A significant aspect of Regulation (EU) 2017/745 is its intersection with evolving technological landscapes, particularly the integration of artificial intellige"""@en ;
    euai:relatedTo euai:HIGH_RISK_AI_SYSTEM .

euai:MEMBER_STATE_REPRESENTATIVES rdfs:label "MEMBER STATE REPRESENTATIVES"@en ;
    euai:relatedTo euai:STAKEHOLDERS .

euai:MICROENTERPRISE a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "MICROENTERPRISE"@en ;
    skos:definition "A **microenterprise** is a specific category of small business entity recognized for its size and operational scale. These businesses are eligible for simplified fulfillment procedures regarding their quality management systems. Specifically, under Article 63, a microenterprise is granted the ability to comply with quality management system obligations in a simplified manner. This regulatory approach is designed to ensure proportionality, particularly regarding the costs associated with innovati"@en ;
    euai:relatedTo euai:QUALITY_MANAGEMENT_SYSTEM .

euai:MICRO__SMALL_AND_MEDIUM_SIZED_ENTERPRISES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "MICRO, SMALL AND MEDIUM-SIZED ENTERPRISES"@en ;
    skos:definition "Categories of enterprises defined by Commission Recommendation 2003/361/EC (Recital 44), which may have reduced obligations or support measures under the AI Act"@en .

euai:MIGRATION_AND_BORDER_CONTROL a owl:NamedIndividual,
        euai:AnnexIIICategory ;
    rdfs:label "MIGRATION AND BORDER CONTROL"@en ;
    skos:definition "Domain involved in visa issuance and asylum procedures, referenced via Regulation (EC) No 810/2009 and Directive 2013/32/EU"@en ;
    euai:relatedTo euai:DIRECTIVE_2013_32_EU,
        euai:REGULATION__EC__NO_810_2009 .

euai:MIGRATION__ASYLUM_AND_BORDER_CONTROL_MANAGEMENT a owl:NamedIndividual,
        euai:AnnexIIICategory ;
    rdfs:label "MIGRATION, ASYLUM AND BORDER CONTROL MANAGEMENT"@en ;
    skos:definition "Area involving AI systems used for border management, including polygraphs, risk assessment of entrants, and processing of asylum/visa applications, as listed in Annex III(7)"@en ;
    euai:belongsToCategory euai:AI_SYSTEM_FOR_ASYLUM_AND_VISA_PROCESSING,
        euai:AI_SYSTEM_FOR_MIGRATION_DETECTION_AND_IDENTIFICATION,
        euai:AI_SYSTEM_FOR_MIGRATION_POLYGRAPHS,
        euai:AI_SYSTEM_FOR_MIGRATION_RISK_ASSESSMENT .

euai:MODEL_LIFECYCLE a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "MODEL LIFECYCLE"@en ;
    skos:definition "The entire duration of a model's existence where providers must ensure cybersecurity and risk mitigation, as referenced in Recital 115"@en ;
    euai:relatedTo euai:CYBERSECURITY_PROTECTION .

euai:MODEL_RETRAINING a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "MODEL RETRAINING"@en ;
    skos:definition "An activity in the AI value chain for which providers require assistance from upstream suppliers"@en .

euai:MODEL_TESTING_AND_EVALUATION a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "MODEL TESTING AND EVALUATION"@en ;
    skos:definition "An activity in the AI value chain for which providers require assistance from upstream suppliers"@en .

euai:MODEL_TRAINING a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "MODEL TRAINING"@en ;
    skos:definition "An activity in the AI value chain for which providers require assistance from upstream suppliers"@en .

euai:MONITORING_MECHANISMS rdfs:label "MONITORING MECHANISMS"@en ;
    euai:relatedTo euai:ARTICLE_35_OF_REGULATION__EU__2016_679,
        euai:ARTICLE_39_OF_REGULATION__EU__2018_1725 .

euai:MigrationAsylumAI a owl:NamedIndividual,
        euai:HighRiskAISystem ;
    rdfs:label "MigrationAsylumAI"@en ;
    skos:definition "AI for migration, asylum and border control"@en ;
    euai:articleReference "Annex III, 7" .

euai:MinimalRisk a owl:NamedIndividual,
        euai:RiskCategory ;
    rdfs:label "MinimalRisk"@en ;
    skos:definition "Risk level with no mandatory obligations under the Act"@en ;
    euai:articleReference "Recital 46" .

euai:NARROW_PROCEDURAL_TASK a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "NARROW PROCEDURAL TASK"@en ;
    skos:definition "Condition where an AI system performs a narrow procedural task and is therefore potentially not high-risk despite Annex III listing"@en ;
    euai:isExemptFromHighRisk euai:HIGH_RISK_AI_SYSTEM .

euai:NARROW_PROCEDURAL_TASK_EXCLUSION a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "NARROW PROCEDURAL TASK EXCLUSION"@en ;
    skos:definition "A condition where an AI system performs a narrow procedural task (e.g., transforming unstructured data, classifying documents), resulting in limited risks and potential exclusion from high-risk classification"@en ;
    euai:isExemptFromHighRisk euai:MATERIAL_INFLUENCE_CRITERION ;
    euai:relatedTo euai:HIGH_RISK_AI_SYSTEM .

euai:NATIONAL_AUTHORITY a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "NATIONAL AUTHORITY"@en ;
    skos:definition "National competent authorities (referred to in Article 74(8)) that have access to restricted sections of the EU database"@en ;
    euai:relatedTo euai:ARTICLE_74_8_,
        euai:EU_DATABASE .

euai:NATIONAL_DATA_PROTECTION_AUTHORITIES a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "NATIONAL DATA PROTECTION AUTHORITIES"@en ;
    skos:definition "National Data Protection Authorities are regulatory bodies tasked with overseeing and enforcing data protection standards. These authorities possess the specific power to receive data disclosures. Crucially, the AI Act’s disclosure rules are designed to coexist with their existing mandates, ensuring that the current or future regulatory powers of National Data Protection Authorities remain entirely unaffected by the provisions of this Regulation."@en ;
    euai:relatedTo euai:DIRECTIVE__EU__2016_680,
        euai:INVESTIGATIVE_AND_CORRECTIVE_POWERS .

euai:NATIONAL_PUBLIC_AUTHORITY_PROTECTING_FUNDAMENTAL_RIGHTS a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "NATIONAL PUBLIC AUTHORITY PROTECTING FUNDAMENTAL RIGHTS"@en ;
    skos:definition "Bodies supervising or enforcing Union law on fundamental rights, authorized to request documentation and testing of high-risk AI systems."@en ;
    euai:cooperatesWith euai:MARKET_SURVEILLANCE_AUTHORITY ;
    euai:hasObligation euai:NOTIFICATION_OF_LIST_OF_AUTHORITIES ;
    euai:relatedTo euai:DOCUMENTATION,
        euai:HIGH_RISK_AI_SYSTEM ;
    euai:subjectTo euai:CONFIDENTIALITY_OBLIGATION .

euai:NATIONAL_STANDARDISATION_ORGANISATION rdfs:label "NATIONAL STANDARDISATION ORGANISATION"@en ;
    euai:relatedTo euai:AI_REGULATORY_SANDBOX .

euai:NATURAL_PERSON a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "NATURAL PERSON"@en ;
    skos:definition "The individual who is the subject of biometric identification or verification (Recital 14, 15)."@en ;
    euai:relatedTo euai:BIOMETRIC_DATA,
        euai:TRANSPARENCY_OBLIGATION .

euai:NON_BINDING_GUIDANCE a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "NON-BINDING GUIDANCE"@en ;
    skos:definition "Advice sought by stakeholders via the interface regarding the conformity of innovative products, services, or business models (Article 58(1))."@en ;
    euai:relatedTo euai:SINGLE_DEDICATED_INTERFACE .

euai:NON_PERSONAL_DATA a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "NON-PERSONAL DATA"@en ;
    skos:definition "Non-personal data refers to any information that does not qualify as personal data as defined under Regulation (EU) 2016/679, commonly known as the General Data Protection Regulation (GDPR). This category of information is explicitly defined in Article 3(51) of the relevant legislative framework, which distinguishes it from data that relates to an identified or identifiable natural person. Essentially, non-personal data encompasses all datasets that fall outside the scope of personal privacy pro"@en ;
    euai:definedInArticle euai:ARTICLE_3_51_ .

euai:NON_PROFESSIONAL_SCIENTIFIC_RESEARCH_DEVELOPER a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "NON-PROFESSIONAL/SCIENTIFIC RESEARCH DEVELOPER"@en ;
    skos:definition "Persons developing or using models for non-professional or scientific research, who are exempt from mandatory compliance but encouraged to comply voluntarily"@en ;
    euai:isExemptFromHighRisk euai:GENERAL_PURPOSE_AI_MODEL .

euai:NOTIFICATION_PROCEDURE a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "NOTIFICATION PROCEDURE"@en ;
    skos:definition "The process by which a notifying authority informs the Commission and Member States of a qualified conformity assessment body, as per Article 30"@en ;
    euai:definedInArticle euai:ARTICLE_30 .

euai:NOTIFICATION_PROCESS a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "NOTIFICATION PROCESS"@en ;
    skos:definition "The procedure by which a notifying authority informs the Commission and Member States about a conformity assessment body, triggering a two-week or two-month objection period depending on documentation."@en ;
    euai:triggers euai:OBJECTION_PERIOD .

euai:NOTIFIED_BODIES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "NOTIFIED BODIES"@en ;
    skos:definition "Notified Bodies are professional third-party certifiers that play a critical role in the regulatory framework established by the AI Act. Specifically, these entities serve as conformity assessment bodies tasked with evaluating high-risk AI systems to ensure they meet established safety and performance standards. In this capacity, Notified Bodies are subject to a strict set of obligations and regulatory requirements, ensuring that their oversight procedures remain rigorous, transparent, and compl"@en ;
    euai:relatedTo euai:CONFORMITY_ASSESSMENT ;
    euai:subjectTo euai:PENALTIES_FOR_GENERAL_NON_COMPLIANCE,
        euai:PENALTIES_FOR_MISLEADING_INFORMATION .

euai:NOTIFIED_BODY_STAFF a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "NOTIFIED BODY STAFF"@en ;
    skos:definition "Personnel employed by or working for notified bodies, bound by professional secrecy obligations regarding information obtained during their tasks"@en ;
    euai:subjectTo euai:PROFESSIONAL_SECRECY_OBLIGATION .

euai:NationalCompetentAuthority a owl:Class ;
    rdfs:label "National Competent Authority"@en ;
    rdfs:subClassOf euai:Authority ;
    skos:definition "A Member State authority designated to supervise application of the Act. (Article 70)"@en .

euai:NotifiedBody a owl:Class ;
    rdfs:label "Notified Body"@en ;
    rdfs:subClassOf euai:Authority ;
    skos:definition "A conformity assessment body designated by a Member State. (Article 3(22))"@en .

euai:OBLIGATION_TO_COMPLY a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "OBLIGATION TO COMPLY"@en ;
    skos:definition "The requirement for entities using AI systems originally intended for military, defence, or national security purposes to ensure compliance with the Regulation if those systems are subsequently used for other purposes (e.g., civilian, humanitarian, law enforcement)."@en ;
    euai:subjectTo euai:HIGH_RISK_AI_SYSTEM .

euai:OFFENDING_RISK_ASSESSMENT_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "OFFENDING RISK ASSESSMENT AI SYSTEM"@en ;
    skos:definition "AI systems used by law enforcement to assess the risk of a natural person offending or reoffending"@en ;
    euai:relatedTo euai:HIGH_RISK .

euai:ONLINE_CHATBOT a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "ONLINE CHATBOT"@en ;
    skos:definition "Example of an AI system that performs web searches and generates combined outputs, often acting as an intermediary service"@en ;
    euai:relatedTo euai:AI_SYSTEM .

euai:OPEN_SOURCE_EXCLUSION a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "OPEN-SOURCE EXCLUSION"@en ;
    skos:definition """**OPEN-SOURCE EXCLUSION**

The "Open-Source Exclusion," as defined in Article 2(12) of the AI Act, outlines specific conditions under which the Act does not apply to artificial intelligence systems. Specifically, the regulation excludes AI systems released under free and open-source licenses from the scope of the Act's requirements. 

However, this exclusion is not absolute. The Open-Source Exclusion ceases to apply if such systems are placed on the market or put into service as high-risk AI sys"""@en ;
    euai:definedInArticle euai:ARTICLE_2 ;
    euai:relatedTo euai:ARTICLE_5,
        euai:ARTICLE_50 .

euai:OPEN_SOURCE_GPAI_MODEL a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "OPEN-SOURCE GPAI MODEL"@en ;
    skos:definition "A general-purpose AI model released under open-source licenses, which poses specific compliance challenges regarding the implementation of obligations after release."@en ;
    euai:relatedTo euai:GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISK .

euai:OPERATORS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "OPERATORS"@en ;
    skos:definition "The term \"OPERATORS\" refers to a diverse group of commercial and legal entities involved across the AI value chain. This category encompasses providers, importers, distributors, deployers, and authorized representatives. These entities are subject to specific obligations, requirements, and potential penalties for non-compliance under the AI Act. Furthermore, the regulation aims to minimize the duplication of conformity assessment procedures for these economic operators to ensure a more efficient"@en ;
    euai:relatedTo euai:CONFORMITY_ASSESSMENT,
        euai:HARMONISED_RULES,
        euai:INTERNAL_MARKET_INTEGRATION ;
    euai:subjectTo euai:PENALTIES_FOR_GENERAL_NON_COMPLIANCE,
        euai:RECORD_KEEPING,
        euai:TECHNICAL_DOCUMENTATION,
        euai:TRANSPARENCY .

euai:OPERATORS_OF_AI_SYSTEMS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "OPERATORS OF AI SYSTEMS"@en ;
    skos:definition "Entities responsible for AI systems, including those operating components of large-scale IT systems and high-risk AI systems used by public authorities (Recital 177)"@en ;
    euai:relatedTo euai:LARGE_SCALE_IT_SYSTEMS .

euai:PERFORMANCE_OF_AN_AI_SYSTEM a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "PERFORMANCE OF AN AI SYSTEM"@en ;
    skos:definition "The ability of an AI system to achieve its intended purpose"@en .

euai:PERSONAL_DATA a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "PERSONAL DATA"@en ;
    skos:definition "Personal Data is defined as any information that relates to an identified or identifiable natural person. This definition is established across two key regulatory references: it is described as the data pertaining to such a person under Article 3(50), and it aligns with the broader definition of personal data provided in Article 4, point (1), of Regulation (EU) 2016/679 (the General Data Protection Regulation). In essence, whether referenced through Article 3(50) or the GDPR, Personal Data encom"@en ;
    euai:definedInArticle euai:ARTICLE_3_50_,
        euai:ARTICLE_4_1_ .

euai:PERSONAL_DATA_PROCESSING_IN_SANDBOX a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "PERSONAL DATA PROCESSING IN SANDBOX"@en ;
    skos:definition "The requirement that personal data collected for other purposes may be processed in the sandbox only under specific, strictly defined conditions, including safety and public interest criteria"@en ;
    euai:definedInArticle euai:ARTICLE_59 .

euai:POLYGRAPHS a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "POLYGRAPHS"@en ;
    skos:definition "AI systems used to detect the emotional state of natural persons; their use is not governed by the AI Act as lawful ground, but remains subject to applicable requirements under Union/national law (Recital 63)."@en .

euai:POLYGRAPHS_AND_SIMILAR_TOOLS a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "POLYGRAPHS AND SIMILAR TOOLS"@en ;
    skos:definition "Specific AI-enabled devices used in migration and border control for assessing risks posed by natural persons."@en .

euai:POLYGRAPH_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "POLYGRAPH AI"@en ;
    skos:definition "AI systems used by law enforcement as polygraphs or similar tools (Annex III 6(b))"@en ;
    euai:belongsToCategory euai:LAW_ENFORCEMENT .

euai:POLYGRAPH_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "POLYGRAPH AI SYSTEM"@en ;
    skos:definition "Polygraphs and similar tools used by or on behalf of law enforcement for risk assessment"@en ;
    euai:relatedTo euai:HIGH_RISK .

euai:POST_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "POST REMOTE BIOMETRIC IDENTIFICATION SYSTEM"@en,
        "POST-REMOTE BIOMETRIC IDENTIFICATION SYSTEM"@en ;
    skos:definition """A "Post-Remote Biometric Identification System" is classified as a high-risk AI system designed to identify individuals after an event has occurred, as opposed to real-time systems. As defined in Article 3(43) and Recital 17, these systems operate by capturing, comparing, and identifying biometric data after a significant delay. This process utilizes pre-existing material, such as pictures or video footage generated prior to the system's use, rather than live streams.

These systems serve specif"""@en,
        "A remote biometric identification system where the biometric data has already been captured prior to identification."@en ;
    euai:definedInArticle euai:ARTICLE_3_43_,
        euai:RECITAL_17,
        euai:RECITAL_95 ;
    euai:regulatedBy euai:ADMINISTRATIVE_AUTHORITY ;
    euai:relatedTo euai:BIOMETRIC_DATA_PROCESSING,
        euai:INDISCRIMINATE_SURVEILLANCE,
        euai:REAL_TIME_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM,
        euai:REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM ;
    euai:subjectTo euai:AUTHORISATION_FOR_POST_REMOTE_BIOMETRIC_IDENTIFICATION,
        euai:AUTHORISATION_OBLIGATION,
        euai:CLOSED_DATA_SET,
        euai:PROPORTIONALITY .

euai:PREPARATORY_TASK a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "PREPARATORY TASK"@en ;
    skos:definition "Condition where an AI system performs a preparatory task for an assessment relevant to Annex III use cases, potentially exempting it from high-risk classification"@en ;
    euai:isExemptFromHighRisk euai:HIGH_RISK_AI_SYSTEM .

euai:PRIVACY_AND_DATA_GOVERNANCE a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "PRIVACY AND DATA GOVERNANCE"@en ;
    skos:definition "The requirement that AI systems are developed in accordance with privacy rules and process high-quality, high-integrity data"@en ;
    euai:relatedTo euai:ETHICAL_PRINCIPLES_FOR_TRUSTWORTHY_AI .

euai:PRIVATE_ENTITY_PROVIDING_PUBLIC_SERVICES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "PRIVATE ENTITY PROVIDING PUBLIC SERVICES"@en ;
    skos:definition "Private organisations delivering services of public interest (e.g., education, healthcare, social services) that are treated as deployers of high-risk AI systems under Recital 96"@en ;
    euai:hasObligation euai:FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT .

euai:PRODUCT_BASED_HIGH_RISK_CLASSIFICATION_RULE a owl:NamedIndividual,
        euai:ClassificationRule ;
    rdfs:label "PRODUCT-BASED HIGH-RISK CLASSIFICATION RULE"@en ;
    skos:definition "The criterion stating that if a product (e.g., machinery, toys, lifts) is a safety component and undergoes third-party conformity assessment, the AI within it is classified as high-risk."@en ;
    euai:definedInArticle euai:RECITAL_50 .

euai:PRODUCT_ORIENTED_RESEARCH__TESTING_AND_DEVELOPMENT a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "PRODUCT-ORIENTED RESEARCH, TESTING AND DEVELOPMENT"@en ;
    skos:definition "Activities regarding AI systems or models prior to those systems being put into service or placed on the market are excluded from the Regulation's provisions"@en ;
    euai:subjectTo euai:AI_REGULATORY_SANDBOXES .

euai:PRODUCT_SAFETY_AND_CONSUMER_PROTECTION_RULES a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "PRODUCT SAFETY AND CONSUMER PROTECTION RULES"@en ;
    skos:definition "Regulation is without prejudice to the rules laid down by other Union legal acts related to consumer protection and product safety. Defined in Article 2(9)."@en ;
    euai:definedInArticle euai:ARTICLE_2 .

euai:PRODUCT_SAFETY_COMPONENT_RULE rdfs:label "PRODUCT SAFETY COMPONENT RULE"@en ;
    euai:appliesTo euai:UNION_HARMONISATION_LEGISLATION_PRODUCTS ;
    euai:relatedTo euai:CONFORMITY_ASSESSMENT_BODY .

euai:PROFESSIONAL_INTEGRITY a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "PROFESSIONAL INTEGRITY"@en ;
    skos:definition "A standard of conduct requiring notified bodies to carry out tasks with the highest degree of integrity and requisite competence"@en .

euai:PROHIBITED_AI_PRACTICES a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "PROHIBITED AI PRACTICES"@en ;
    skos:definition "Prohibited AI practices, as outlined under Article 5, encompass a specific set of actions that are forbidden due to the risks they pose to individuals and society. These regulations strictly prohibit the deployment or use of AI systems that utilize manipulative techniques designed to distort human behavior or exploit the specific vulnerabilities of particular groups or individuals. Such practices are banned because they threaten fundamental rights, can cause significant harm, and directly contra"@en ;
    euai:relatedTo euai:AI_SYSTEM,
        euai:ARTICLE_5,
        euai:MARKET_SURVEILLANCE_AUTHORITY .

euai:PROHIBITED_PRACTICES a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "PROHIBITED PRACTICES"@en ;
    skos:definition "\"Prohibited practices\" refers to specific artificial intelligence activities that are banned under the Regulation. This list of prohibited AI practices is not static; it is subject to regular review, with the Commission tasked with conducting an annual assessment to ensure the list remains relevant and aligned with technological and societal developments, as outlined in Recital 174 and Recital 179. To ensure compliance and oversight, market surveillance authorities are mandated to submit annual "@en ;
    euai:relatedTo euai:EARLY_APPLICATION_DATE,
        euai:REPORTING_OBLIGATION .

euai:PROHIBITION_OF_BIOMETRIC_DATA_PROCESSING a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "PROHIBITION OF BIOMETRIC DATA PROCESSING"@en ;
    skos:definition "General prohibition under Regulation (EU) 2016/679 and Regulation (EU) 2018/1725 regarding biometric data processing, subject to limited exceptions"@en ;
    euai:definedInArticle euai:ARTICLE_10_1__OF_REGULATION__EU__2018_1725,
        euai:ARTICLE_9_1__OF_REGULATION__EU__2016_679 .

euai:PROSPECTIVE_DEPLOYER a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "PROSPECTIVE DEPLOYER"@en ;
    skos:definition "A natural or legal person intending to use an AI system under their authority."@en .

euai:PROVIDER_OF_AI_SYSTEMS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "PROVIDER OF AI SYSTEMS"@en ;
    skos:definition "An entity that intends to integrate a general-purpose AI model into their own AI systems, receiving documentation from the GPAI model provider."@en .

euai:PROVIDER_OF_GPAI_MODELS_WITH_SYSTEMIC_RISK a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "PROVIDER OF GPAI MODELS WITH SYSTEMIC RISK"@en ;
    skos:definition "Legal person or entity responsible for the development and placing on the market of general-purpose AI models that carry systemic risks"@en ;
    euai:hasObligation euai:CYBERSECURITY_PROTECTION,
        euai:MODEL_EVALUATION,
        euai:SERIOUS_INCIDENT_REPORTING,
        euai:SYSTEMIC_RISK_MITIGATION ;
    euai:relatedTo euai:ARTICLE_53,
        euai:ARTICLE_54,
        euai:ARTICLE_56,
        euai:CODE_OF_PRACTICE ;
    euai:subjectTo euai:CONFIDENTIALITY_OBLIGATION .

euai:PROVIDER_OF_HIGH_RISK_AI_SYSTEMS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "PROVIDER OF HIGH-RISK AI SYSTEMS"@en ;
    skos:definition "Legal or natural person responsible for placing high-risk AI systems on the market, required to implement post-market monitoring systems."@en ;
    euai:relatedTo euai:POST_MARKET_MONITORING_OBLIGATION .

euai:PROVIDER_OF_INTERMEDIARY_SERVICES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "PROVIDER OF INTERMEDIARY SERVICES"@en ;
    skos:definition """The term "provider of intermediary services" refers to market actors that operate under the framework established by Regulation (EU) 2022/2065 (the Digital Services Act). These entities are defined by the specific service roles outlined in that regulation and often incorporate AI systems or models into their platforms and operational workflows.

Within the regulatory landscape of the EU, these providers are not treated in isolation. As referenced in Recital 118 of the AI Act, providers of interm"""@en ;
    euai:relatedTo euai:PROVIDER ;
    euai:subjectTo euai:RISK_MANAGEMENT_FRAMEWORK .

euai:PROVISIONAL_MEASURE a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "PROVISIONAL MEASURE"@en ;
    skos:definition "An enforcement action taken by a market surveillance authority of a Member State, which can be deemed justified if no objections are raised within the designated period under Article 79(8)"@en ;
    euai:definedInArticle euai:ARTICLE_79 ;
    euai:relatedTo euai:MARKET_SURVEILLANCE_AUTHORITY .

euai:PUBLIC_ASSISTANCE_BENEFIT_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "PUBLIC ASSISTANCE BENEFIT AI"@en ;
    skos:definition "AI systems used by public authorities to evaluate eligibility for essential public assistance benefits and services (Annex III 5(a))"@en ;
    euai:belongsToCategory euai:ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES .

euai:PUBLIC_ASSISTANCE_ELIGIBILITY_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "PUBLIC ASSISTANCE ELIGIBILITY AI"@en ;
    skos:definition "AI system used by public authorities to evaluate eligibility for essential public benefits and services."@en ;
    euai:belongsToCategory euai:ESSENTIAL_PRIVATE_AND_PUBLIC_SERVICES .

euai:PUBLIC_AUTHORITIES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "PUBLIC AUTHORITIES"@en ;
    skos:definition """Public authorities are defined as entities tasked with the responsibility of providing essential services, social benefits, and various forms of assistance to the public. As part of their operations, these authorities utilize artificial intelligence (AI) systems to facilitate and streamline decision-making processes. 

Due to the significant impact of these decisions on individuals and society, public authorities that utilize high-risk AI systems are subject to specific regulatory compliance req"""@en ;
    euai:relatedTo euai:ESSENTIAL_PUBLIC_SERVICES_AI_SYSTEM,
        euai:HIGH_RISK_AI_SYSTEM .

euai:PUBLIC_AUTHORITY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "PUBLIC AUTHORITY"@en ;
    skos:definition """A public authority is a government body or public entity that qualifies as a "deployer" under the definition provided in Recital 13 of the relevant regulations. When acting in the capacity of a deployer, a public authority is subject to specific regulatory requirements, which include fulfilling additional transparency and registration obligations to ensure accountability and oversight.

Furthermore, when a public authority puts high-risk AI systems into service for its own use, it operates withi"""@en ;
    euai:hasObligation euai:REGISTRATION_OBLIGATION ;
    euai:relatedTo euai:DEPLOYER,
        euai:QUALITY_MANAGEMENT_SYSTEM .

euai:PUBLIC_AUTHORITY_DEPLOYER a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "PUBLIC AUTHORITY DEPLOYER"@en ;
    skos:definition "Deployers that are public authorities, Union institutions, bodies, offices, or agencies, subject to specific registration requirements under the AI Act"@en ;
    euai:relatedTo euai:REGISTRATION_IN_EU_DATABASE .

euai:PUBLIC_ENTITY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "PUBLIC ENTITY"@en ;
    skos:definition "A body governed by public law that deploys high-risk AI systems and must perform fundamental rights impact assessments per Recital 96"@en ;
    euai:hasObligation euai:FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT .

euai:PUBLIC_SECTOR_BODIES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "PUBLIC SECTOR BODIES"@en ;
    skos:definition "Entities subject to Directive (EU) 2016/2102 regarding accessibility of websites and mobile applications (Recital 38)"@en .

euai:PostMarketMonitoring a owl:Class ;
    rdfs:label "Post-Market Monitoring"@en ;
    rdfs:subClassOf euai:Obligation ;
    skos:definition "Systematic collection and review of experience with deployed AI systems. (Article 72)"@en .

euai:QUALITY_MANAGEMENT_SYSTEM_ASSESSMENT a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "QUALITY MANAGEMENT SYSTEM ASSESSMENT"@en ;
    skos:definition "A conformity assessment procedure involving a notified body as described in Annex VII"@en .

euai:QualityManagementSystem a owl:Class ;
    rdfs:label "Quality Management System"@en ;
    rdfs:subClassOf euai:Obligation ;
    skos:definition "A system providers must establish to ensure compliance. (Article 17)"@en .

euai:REAL_WORLD_TESTING_REGISTRATION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "REAL-WORLD TESTING REGISTRATION"@en ;
    skos:definition "Duty to register real-world testing in the EU database or according to Art 71(4), with exceptions for specific Annex III high-risk systems"@en ;
    euai:definedInArticle euai:ARTICLE_49_4_,
        euai:ARTICLE_49_5_,
        euai:ARTICLE_71_4_ .

euai:REASONABLY_FORESEEABLE_MISUSE a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "REASONABLY FORESEEABLE MISUSE"@en ;
    skos:definition "Use of an AI system not in accordance with its intended purpose, potentially resulting from human behavior or interaction with other systems"@en .

euai:RECIPIENT_NATIONAL_AUTHORITIES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "RECIPIENT NATIONAL AUTHORITIES"@en ;
    skos:definition "National authorities receiving outputs from third-country cooperation agreements; they remain accountable for compliance with Union law."@en ;
    euai:relatedTo euai:ACCOUNTABILITY_OBLIGATION .

euai:RECITALS_144_148 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "RECITALS 144-148"@en ;
    skos:definition "Specific recitals in the Regulation providing context on innovation, support measures for SMEs, and implementation"@en ;
    euai:relatedTo euai:COMPLIANCE_WITH_THIS_REGULATION .

euai:RECITAL_111 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "RECITAL 111"@en ;
    skos:definition "The section of the AI Act establishing the methodology for classifying GPAI models with systemic risks based on capabilities, computation thresholds, and impact."@en ;
    euai:definedInArticle euai:GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISKS .

euai:RECITAL_27 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "RECITAL 27"@en ;
    skos:definition "Reference to Recital 27, covering ethical guidelines, principles for AI, and the AI HLEG's contribution to the Regulation"@en .

euai:RECITAL_34 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "RECITAL 34"@en ;
    skos:definition "A section of the Regulation detailing the requirement for responsible, proportionate use, necessity, and the mandatory fundamental rights impact assessment for biometric identification systems."@en ;
    euai:relatedTo euai:FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT .

euai:RECITAL_35 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "RECITAL 35"@en ;
    skos:definition "A section of the Regulation addressing the general application and use of real-time remote biometric identification systems."@en ;
    euai:relatedTo euai:REAL_TIME_REMOTE_BIOMETRIC_IDENTIFICATION_SYSTEM .

euai:RECITAL_48 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "RECITAL 48"@en ;
    skos:definition """**RECITAL 48**

RECITAL 48 serves as a critical component of the AI Act’s preamble, establishing the foundational principles that govern the assessment and classification of artificial intelligence systems. This section emphasizes the paramount importance of fundamental rights, mandating that the potential impact of AI systems on these rights be carefully considered during the risk assessment process. Furthermore, RECITAL 48 specifically highlights the necessity of safeguarding children's rights"""@en ;
    euai:relatedTo euai:FUNDAMENTAL_RIGHTS .

euai:RECITAL_77 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "RECITAL 77"@en ;
    skos:definition "Text describing the role of cybersecurity in AI systems and how high-risk systems can demonstrate compliance via horizontal cybersecurity regulations."@en .

euai:RECITAL_79 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "RECITAL 79"@en ;
    skos:definition "The section of the AI Act defining that a specific natural or legal person, the provider, takes responsibility for placing the system on the market."@en .

euai:RECORDS_OF_PROCESSING_ACTIVITIES a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "RECORDS OF PROCESSING ACTIVITIES"@en ;
    skos:definition "Documentation of processing activities which must include the reasons why the processing of special categories of personal data was strictly necessary"@en ;
    euai:relatedTo euai:PROCESSING_OF_SPECIAL_CATEGORIES_OF_PERSONAL_DATA .

euai:RECRUITMENT_AND_JOB_ADVERTISEMENT_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "RECRUITMENT AND JOB ADVERTISEMENT AI"@en ;
    skos:definition "AI systems used for recruitment, placement of targeted job advertisements, and filtering applications (Annex III 4(a))"@en ;
    euai:belongsToCategory euai:EMPLOYMENT__WORKERS__MANAGEMENT_AND_ACCESS_TO_SELF_EMPLOYMENT .

euai:RECRUITMENT_AND_SELECTION_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "RECRUITMENT AND SELECTION AI"@en ;
    skos:definition "AI system used for targeted job advertisements, filtering applications, and evaluating candidates."@en ;
    euai:belongsToCategory euai:EMPLOYMENT__WORKERS__MANAGEMENT_AND_ACCESS_TO_SELF_EMPLOYMENT .

euai:REGULATION_2017_745 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "REGULATION 2017/745"@en ;
    skos:definition "Union harmonisation legislation applicable to medical devices that may apply to products with high-risk AI (Recital 46)"@en ;
    euai:relatedTo euai:RECITAL_46 .

euai:REGULATION_2017_746 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "REGULATION 2017/746"@en ;
    skos:definition "Union harmonisation legislation applicable to in vitro diagnostic medical devices (Recital 46)"@en ;
    euai:relatedTo euai:RECITAL_46 .

euai:REGULATION__EU__167_2013 rdfs:label "REGULATION  EU  167 2013"@en ;
    euai:relatedTo euai:MARKET_SURVEILLANCE_AUTHORITY .

euai:REGULATION__EU__168_2013 rdfs:label "REGULATION  EU  168 2013"@en ;
    euai:relatedTo euai:MARKET_SURVEILLANCE_AUTHORITY .

euai:REGULATION__EU__2019_2144 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "REGULATION (EU) 2019/2144"@en ;
    skos:definition "Regulation (EU) 2019/2144, formally known as the regulation on type-approval requirements for motor vehicles and their trailers, is a critical legislative framework designed to enhance road safety and security. It establishes comprehensive safety and protection standards aimed at safeguarding both vehicle occupants and vulnerable road users. By setting these rigorous type-approval requirements, Regulation (EU) 2019/2144 ensures that motor vehicles and trailers manufactured for use in the Europea"@en ;
    euai:relatedTo euai:EUROPEAN_COMMISSION .

euai:REGULATION__EU__2022_2065__DIGITAL_SERVICES_ACT_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "REGULATION (EU) 2022/2065 (DIGITAL SERVICES ACT)"@en ;
    skos:definition "Regulation on a Single Market For Digital Services, which intersects with the EU AI Act regarding online platform regulation and transparency"@en ;
    euai:relatedTo euai:DIRECTIVE_2000_31_EC .

euai:REGULATION__EU__2022_868 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "REGULATION (EU) 2022/868"@en ;
    skos:definition "**REGULATION (EU) 2022/868**, also known as the **Data Governance Act** or the **Regulation on European data governance**, is a significant legislative framework within the European Union. This regulation is explicitly referenced in Recital 42 of broader legal or regulatory documentation, highlighting its relevance to specific governance protocols and data management standards within the European Union."@en .

euai:REGULATION__EU__2023_2854 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "REGULATION (EU) 2023/2854"@en ;
    skos:definition "Regulation (EU) 2023/2854 is the official designation for the legislation widely known as the Data Act. This regulation establishes harmonized rules regarding the fair access to and use of data. Furthermore, it is explicitly referenced within Recital 43 of the European Union's legislative framework, underscoring its relevance and integration into the broader body of EU law."@en .

euai:REJECTION_CONSEQUENCE a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "REJECTION CONSEQUENCE"@en ;
    skos:definition "If authorisation is rejected, use must cease immediately, and all related data must be discarded/deleted."@en ;
    euai:appliesTo euai:PRIOR_AUTHORISATION .

euai:REMOTE_BIOMETRIC_IDENTIFICATION_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "REMOTE BIOMETRIC IDENTIFICATION AI SYSTEM"@en ;
    skos:definition "AI system used for remote biometric identification, subject to specific data processing rules under the AI Act"@en ;
    euai:subjectTo euai:HARMONISED_RULES .

euai:REPORTING_OF_INFRINGEMENTS a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "REPORTING OF INFRINGEMENTS"@en ;
    skos:definition "Duty to report infringements of the Regulation, governed by Directive (EU) 2019/1937 per Article 87"@en ;
    euai:relatedTo euai:DIRECTIVE__EU__2019_1937 .

euai:REQUIREMENT a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "REQUIREMENT"@en ;
    skos:definition "Specific technical or organisational measures (e.g., environmental sustainability, AI literacy, accessibility) that can be incorporated into codes of conduct under Article 95"@en .

euai:RESEARCH_AND_DEVELOPMENT_EXCLUSION a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "RESEARCH AND DEVELOPMENT EXCLUSION"@en ;
    skos:definition """The "RESEARCH AND DEVELOPMENT EXCLUSION" within the context of the AI Act, formally defined in Article 2(8), establishes that the regulations set forth by the Act do not apply to activities involving the research, testing, or development of AI systems or AI models before they are officially placed on the market or put into service. 

It is important to note that this exclusion is specific and limited in scope: while it protects preliminary development phases, it explicitly excludes any testing c"""@en ;
    euai:definedInArticle euai:ARTICLE_2 .

euai:RESEARCH_AND_EXPERIMENTATION_LAB a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "RESEARCH AND EXPERIMENTATION LAB"@en ;
    skos:definition """**RESEARCH AND EXPERIMENTATION LAB**

The RESEARCH AND EXPERIMENTATION LAB encompasses facilities dedicated to the advancement of artificial intelligence through rigorous research, development, and iterative testing. These labs serve as pivotal components within the broader AI ecosystem, providing the necessary infrastructure and environment to support ongoing innovation. Furthermore, the RESEARCH AND EXPERIMENTATION LAB may actively participate in the regulatory sandbox ecosystem, allowing for """@en .

euai:RESILIENCE_OF_CRITICAL_ENTITIES_DIRECTIVE a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "RESILIENCE OF CRITICAL ENTITIES DIRECTIVE"@en ;
    skos:definition "The Resilience of Critical Entities Directive, formally known as Directive (EU) 2022/2557, serves as a crucial piece of European Union legislation focused on strengthening the physical and digital security of vital infrastructure. This directive establishes a comprehensive framework designed to enhance the resilience of entities that provide essential services to society, ensuring that critical infrastructure remains robust in the face of various threats, including natural disasters, terrorism, "@en ;
    euai:relatedTo euai:HIGH_RISK_AI_SYSTEM .

euai:RESPONSE_MECHANISMS a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "RESPONSE MECHANISMS"@en ;
    skos:definition "Mechanisms required in the sandbox to promptly mitigate risks to data subjects and stop processing if necessary"@en .

euai:RESTRICTED_ACCESS_SPACE a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "RESTRICTED ACCESS SPACE"@en ;
    skos:definition "Spaces explicitly excluded from the definition of \"publicly accessible space\" per Recital 19, such as prisons, border control, or private workplaces/offices intended only for specific employees."@en ;
    euai:relatedTo euai:PUBLICLY_ACCESSIBLE_SPACE .

euai:RESTRICTIVE_MEASURES a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "RESTRICTIVE MEASURES"@en ;
    skos:definition "RESTRICTIVE MEASURES refer to regulatory actions, such as the withdrawal of an AI system from the market or the prohibition of its use, which are mandated when a national measure regarding that system is determined to be justified under Article 81. These measures serve as an enforcement mechanism to ensure compliance and safety, necessitating that specific AI systems be removed from availability or halted in operation once the legal grounds for such intervention have been established."@en ;
    euai:enforces euai:MARKET_SURVEILLANCE_AUTHORITY ;
    euai:relatedTo euai:ARTICLE_81,
        euai:UNION_SAFEGUARD_PROCEDURE .

euai:RIGHTSHOLDER a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "RIGHTSHOLDER"@en ;
    skos:definition "Entity or person holding copyright and related rights over works, authorized to reserve rights against text and data mining under Directive (EU) 2019/790"@en ;
    euai:relatedTo euai:RESERVATION_OF_RIGHTS .

euai:RISK_ASSESSMENT_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "RISK ASSESSMENT AI SYSTEM"@en ;
    skos:definition "AI system used for risk assessments of natural persons for law enforcement purposes, subject to specific data processing rules"@en ;
    euai:subjectTo euai:HARMONISED_RULES .

euai:RISK_BASED_APPROACH a owl:NamedIndividual,
        euai:ClassificationRule ;
    rdfs:label "RISK-BASED APPROACH"@en ;
    skos:definition """The Risk-Based Approach is a regulatory framework and methodology designed to manage the development and deployment of artificial intelligence (AI) systems. It functions by tailoring the intensity and scope of binding rules and regulatory requirements according to the specific level of risk generated by an AI system. 

Under this framework, the approach is categorized into three primary components: the prohibition of practices deemed unacceptable, the imposition of strict requirements for system"""@en ;
    euai:enforces euai:UNACCEPTABLE_AI_PRACTICES ;
    euai:relatedTo euai:HIGH_RISK_AI_SYSTEMS,
        euai:TRANSPARENCY_OBLIGATIONS .

euai:ROAD_TRAFFIC_SAFETY_COMPONENT a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "ROAD TRAFFIC SAFETY COMPONENT"@en ;
    skos:definition "AI systems used as safety components in the management and operation of road traffic (Annex III 2)"@en ;
    euai:belongsToCategory euai:CRITICAL_INFRASTRUCTURE .

euai:RealTimeBiometricSurveillance a owl:NamedIndividual,
        euai:ProhibitedAIPractice ;
    rdfs:label "RealTimeBiometricSurveillance"@en ;
    skos:definition "Real-time remote biometric identification in publicly accessible spaces (with narrow exceptions)"@en ;
    euai:articleReference "Article 5(1)(h)" .

euai:RiskManagementSystem a owl:Class ;
    rdfs:label "Risk Management System"@en ;
    rdfs:subClassOf euai:Requirement ;
    skos:definition "A continuous iterative process to identify and mitigate risks. (Article 9)"@en .

euai:Robustness a owl:Class ;
    rdfs:label "Accuracy, Robustness and Cybersecurity"@en ;
    rdfs:subClassOf euai:Requirement ;
    skos:definition "Requirements for AI system performance and resilience. (Article 15)"@en .

euai:SAFEGUARDS_FOR_FUNDAMENTAL_RIGHTS a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "SAFEGUARDS FOR FUNDAMENTAL RIGHTS"@en ;
    skos:definition "The requirement for third countries and international organisations to protect fundamental rights and freedoms of individuals to qualify for the exclusion from the Regulation's scope."@en .

euai:SAFETY_COMPONENTS a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "SAFETY COMPONENTS"@en ;
    skos:definition "AI systems used as safety components, subject to specific requirements in Chapter III, Section 2, when referenced in other regulations like 167/2013 or 168/2013"@en ;
    euai:subjectTo euai:CHAPTER_III__SECTION_2,
        euai:DIRECTIVE_2014_90_EU,
        euai:REGULATION__EC__NO_300_2008,
        euai:REGULATION__EU__NO_167_2013,
        euai:REGULATION__EU__NO_168_2013 .

euai:SECURE_NON_PUBLIC_SECTION a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "SECURE NON-PUBLIC SECTION"@en ;
    skos:definition "A specific section of the EU database for registering law enforcement, migration, and border control AI systems"@en ;
    euai:relatedTo euai:REGISTRATION .

euai:SENSITIVE_OPERATIONAL_DATA a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "SENSITIVE OPERATIONAL DATA"@en ;
    skos:definition "Operational data related to the prevention, detection, investigation, or prosecution of criminal offences, where disclosure could harm criminal proceedings."@en ;
    euai:definedInArticle euai:ARTICLE_3_38_ .

euai:SEPARATE_VERIFICATION_REQUIREMENT a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "SEPARATE VERIFICATION REQUIREMENT"@en ;
    skos:definition "Requirement for at least two natural persons to verify and confirm identification resulting from certain high-risk AI systems (Annex III point 1(a)), with specific exemptions for law enforcement/migration contexts"@en ;
    euai:relatedTo euai:ANNEX_III,
        euai:ARTICLE_14 ;
    euai:subjectTo euai:DEPLOYER .

euai:SERIOUS_CRIMINAL_OFFENCES a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "SERIOUS CRIMINAL OFFENCES"@en ;
    skos:definition "Crimes punishable by a custodial sentence or detention order for at least four years, serving as a threshold to justify the use of real-time remote biometric identification (Recital 33)."@en ;
    euai:definedInArticle euai:LAW_ENFORCEMENT_EXCEPTIONS .

euai:SERIOUS_RISK a owl:NamedIndividual,
        euai:RiskCategory ;
    rdfs:label "SERIOUS RISK"@en ;
    skos:definition "\"SERIOUS RISK\" refers to a classification assigned to high-risk AI systems that have been identified as presenting a significant level of danger across two or more Member States. This designation serves as a formal trigger for regulatory action, specifically enabling authorities to initiate and propose joint investigations into the system in question to address the widespread threat."@en ;
    euai:triggers euai:JOINT_INVESTIGATIONS .

euai:SIGNIFICANT_GENERALITY_THRESHOLD a owl:NamedIndividual,
        euai:ClassificationRule ;
    rdfs:label "SIGNIFICANT GENERALITY THRESHOLD"@en ;
    skos:definition "A criteria defined by the Regulation, specifically models with at least a billion parameters and trained with large amounts of data using self-supervision, to determine if a model displays significant generality"@en ;
    euai:relatedTo euai:GENERAL_PURPOSE_AI_MODEL .

euai:SINGLE_POINT_OF_CONTACT a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "SINGLE POINT OF CONTACT"@en ;
    skos:definition "A Single Point of Contact is a specific market surveillance authority designated by a Member State to serve as the primary liaison for the Regulation. This role is formally required under Article 70(2), ensuring there is a dedicated entity responsible for coordinating and facilitating communication regarding the Regulation's implementation and enforcement."@en ;
    euai:relatedTo euai:MARKET_SURVEILLANCE_AUTHORITY .

euai:SMALL_AND_MEDIUM_ENTERPRISES__SMES_ a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "SMALL AND MEDIUM ENTERPRISES (SMES)"@en ;
    skos:definition "Specific group of economic operators, including startups, receiving supportive measures under the Regulation"@en .

euai:SMES rdfs:label "SMES"@en ;
    euai:relatedTo euai:PUBLIC_AND_PRIVATE_ACTORS .

euai:SME_PENALTY_PROVISION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "SME PENALTY PROVISION"@en ;
    skos:definition "A provision ensuring penalties for SMEs and start-ups do not exceed the specified percentages or amounts if they are lower than the standard fines"@en ;
    euai:appliesTo euai:PENALTIES_FOR_GENERAL_NON_COMPLIANCE,
        euai:PENALTIES_FOR_MISLEADING_INFORMATION,
        euai:PENALTIES_FOR_PROHIBITED_PRACTICES .

euai:SOCIAL_SCORING_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "SOCIAL SCORING AI SYSTEM"@en ;
    skos:definition "AI system evaluating or classifying persons based on social behavior or personality traits leading to detrimental or unjustified treatment"@en ;
    euai:belongsToCategory euai:PROHIBITED_AI_PRACTICE .

euai:STAKEHOLDER a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "STAKEHOLDER"@en ;
    skos:definition "Parties including representatives of affected groups, independent experts, and civil society organisations who may be involved in the fundamental rights impact assessment process per Recital 96"@en ;
    euai:relatedTo euai:FUNDAMENTAL_RIGHTS_IMPACT_ASSESSMENT .

euai:STAKEHOLDER_AND_CIVIL_SOCIETY_ORGANISATION a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "STAKEHOLDER AND CIVIL SOCIETY ORGANISATION"@en ;
    skos:definition "Groups that may be involved in the AI regulatory sandbox to provide input and oversight"@en .

euai:STAKEHOLDER_ORGANISATION a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "STAKEHOLDER ORGANISATION"@en ;
    skos:definition "Civil society or relevant bodies involved in the AI ecosystem"@en .

euai:STANDING_SUB_GROUP_FOR_MARKET_SURVEILLANCE a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "STANDING SUB-GROUP FOR MARKET SURVEILLANCE"@en ;
    skos:definition "A sub-group of the Board acting as the administrative cooperation group (ADCO) for the Regulation, as per Article 30 of Regulation (EU) 2019/1020."@en ;
    euai:definedInArticle euai:ARTICLE_30_OF_REGULATION__EU__2019_1020 .

euai:STAND_ALONE_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "STAND-ALONE AI SYSTEM"@en ;
    skos:definition "High-risk AI systems that are not safety components of products and are not products themselves"@en ;
    euai:relatedTo euai:HIGH_RISK_CLASSIFICATION_RULE .

euai:STAND_ALONE_AI_SYSTEM_RULE a owl:NamedIndividual,
        euai:ClassificationRule ;
    rdfs:label "STAND-ALONE AI SYSTEM RULE"@en ;
    skos:definition "The rule determining high-risk status for systems that are not safety components, based on intended purpose and risk of harm to health, safety, or fundamental rights (Recital 52)"@en .

euai:STUDENT_BEHAVIOUR_MONITORING_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "STUDENT BEHAVIOUR MONITORING AI"@en ;
    skos:definition "AI system used for monitoring and detecting prohibited student behaviour during tests."@en ;
    euai:belongsToCategory euai:EDUCATION_AND_VOCATIONAL_TRAINING .

euai:STUDENT_PROHIBITED_BEHAVIOUR_MONITORING_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "STUDENT PROHIBITED BEHAVIOUR MONITORING AI"@en ;
    skos:definition "AI systems monitoring and detecting prohibited student behaviour during tests (Annex III 3(d))"@en ;
    euai:belongsToCategory euai:EDUCATION_AND_VOCATIONAL_TRAINING .

euai:SUBJECT a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "SUBJECT"@en ;
    skos:definition "A natural person who participates in testing in real-world conditions, as defined in Article 3(58)"@en ;
    euai:relatedTo euai:INFORMED_CONSENT .

euai:SUBJECTS_OF_TESTING a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "SUBJECTS OF TESTING"@en ;
    skos:definition "Individuals participating in testing in real-world conditions whose informed consent must be obtained"@en ;
    euai:relatedTo euai:RIGHT_TO_WITHDRAW .

euai:SUBLIMINAL_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "SUBLIMINAL AI SYSTEM"@en ;
    skos:definition "AI system deploying subliminal techniques beyond consciousness or manipulative/deceptive techniques to distort behavior and cause significant harm"@en ;
    euai:belongsToCategory euai:PROHIBITED_AI_PRACTICE .

euai:SUB_THRESHOLD_GPAI_MODEL a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "SUB-THRESHOLD GPAI MODEL"@en ;
    skos:definition "A general-purpose AI model that does not meet the high-impact capabilities threshold (Recital 63-64)"@en .

euai:SUB_THRESHOLD_GPAI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "SUB-THRESHOLD GPAI SYSTEM"@en ;
    skos:definition "An AI system based on a general-purpose AI model that does not carry systemic risk (Recital 66)"@en .

euai:SUPERVISORY_AUTHORITIES a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "SUPERVISORY AUTHORITIES"@en ;
    skos:definition "Authorities competent for the supervision of law enforcement and judicial authorities; they assess whether international cooperation frameworks include adequate safeguards for fundamental rights."@en ;
    euai:relatedTo euai:INTERNATIONAL_ORGANISATIONS,
        euai:PUBLIC_AUTHORITIES_OF_A_THIRD_COUNTRY .

euai:SUPERVISORY_AUTHORITY a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "SUPERVISORY AUTHORITY"@en ;
    skos:definition "Authorities responsible for the supervision of law enforcement and judicial authorities; they assess if international cooperation frameworks include adequate safeguards."@en ;
    euai:conductsEvaluationOf euai:PUBLIC_AUTHORITIES_OF_A_THIRD_COUNTRY .

euai:SUSPECTS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "SUSPECTS"@en ;
    skos:definition "Natural persons under investigation whose defence rights may be impacted by AI tool use and opacity."@en ;
    euai:relatedTo euai:LAW_ENFORCEMENT_AI_SYSTEM .

euai:SYNTHETIC_CONTENT_GENERATOR a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "SYNTHETIC CONTENT GENERATOR"@en ;
    skos:definition "AI systems (including general-purpose AI systems) that generate synthetic audio, image, video, or text content, subject to marking obligations"@en ;
    euai:subjectTo euai:MARKING_OF_SYNTHETIC_CONTENT .

euai:SYSTEMIC_RISK_ASSESSMENT_CRITERIA a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "SYSTEMIC RISK ASSESSMENT CRITERIA"@en ;
    skos:definition "Factors used to designate a GPAI model as having systemic risk, including training data quality, user base size, autonomy, scalability, and modalities."@en .

euai:SYSTEMIC_RISK_CLASSIFICATION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "SYSTEMIC RISK CLASSIFICATION"@en ;
    skos:definition "The process by which a GPAI model is designated as having systemic risk, either by meeting the compute threshold or through Commission decision."@en .

euai:SYSTEMIC_RISK_DESIGNATION_CRITERIA a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "SYSTEMIC RISK DESIGNATION CRITERIA"@en ;
    skos:definition "Specific benchmarks used for the designation of a GPAI model as having systemic risk, including training data quality, user base size, autonomy, scalability, and modalities."@en ;
    euai:isBasedOn euai:GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISKS .

euai:SYSTEMIC_RISK_THRESHOLD_RULE a owl:NamedIndividual,
        euai:ClassificationRule ;
    rdfs:label "SYSTEMIC RISK THRESHOLD RULE"@en ;
    skos:definition "Criterion under Article 51 defining the classification of GPAI models based on high impact capabilities or compute thresholds (10^25 FLOPs)"@en ;
    euai:relatedTo euai:GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISK .

euai:SocialScoringPublicAuthority a owl:NamedIndividual,
        euai:ProhibitedAIPractice ;
    rdfs:label "SocialScoringPublicAuthority"@en ;
    skos:definition "Social scoring by public authorities leading to detrimental treatment"@en ;
    euai:articleReference "Article 5(1)(c)" .

euai:SubliminaltechniquesAI a owl:NamedIndividual,
        euai:ProhibitedAIPractice ;
    rdfs:label "SubliminaltechniquesAI"@en ;
    skos:definition "AI using subliminal techniques to distort behaviour causing harm"@en ;
    euai:articleReference "Article 5(1)(a)" .

euai:SystemicRiskGPAI a owl:Class ;
    rdfs:label "General-Purpose AI Model with Systemic Risk"@en ;
    rdfs:subClassOf euai:GeneralPurposeAIModel ;
    skos:definition "A GPAI model designated as posing systemic risk, typically above 10^25 FLOPs. (Article 51)"@en .

euai:TAX_AND_CUSTOMS_ADMINISTRATIVE_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "TAX AND CUSTOMS ADMINISTRATIVE AI SYSTEM"@en ;
    skos:definition "AI systems used specifically for administrative proceedings by tax and customs authorities"@en ;
    euai:relatedTo euai:TAX_AND_CUSTOMS_EXCLUSION .

euai:TAX_AND_CUSTOMS_AUTHORITIES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "TAX AND CUSTOMS AUTHORITIES"@en ;
    skos:definition "Authorities carrying out administrative tasks whose AI tools for administrative proceedings are generally excluded from law enforcement high-risk classification."@en .

euai:TAX_AND_CUSTOMS_AUTHORITY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "TAX AND CUSTOMS AUTHORITY"@en ;
    skos:definition "Authorities responsible for tax and customs, using AI for administrative proceedings"@en ;
    euai:relatedTo euai:TAX_AND_CUSTOMS_EXCLUSION .

euai:TECHNICAL_DOCUMENTATION_ASSESSMENT a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "TECHNICAL DOCUMENTATION ASSESSMENT"@en ;
    skos:definition "A conformity assessment procedure involving a notified body as described in Annex VII"@en .

euai:TECHNICAL_ROBUSTNESS_AND_SAFETY a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "TECHNICAL ROBUSTNESS AND SAFETY"@en ;
    skos:definition "The requirement that AI systems are developed and used to ensure resilience against alteration, unlawful use, and unintended harm"@en ;
    euai:relatedTo euai:ETHICAL_PRINCIPLES_FOR_TRUSTWORTHY_AI .

euai:TECHNICAL_SPECIFICATIONS_AND_TESTING_STANDARDS a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "TECHNICAL SPECIFICATIONS AND TESTING STANDARDS"@en ;
    skos:definition "Technical standards and specifications adopted by the Commission for AI systems, which must incorporate the requirements of Chapter III, Section 2 of the AI Act"@en ;
    euai:relatedTo euai:REQUIREMENTS_OF_CHAPTER_III_SECTION_2 .

euai:TESTING_DATA a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "TESTING DATA"@en ;
    skos:definition "Data used for providing an independent evaluation of an AI system to confirm expected performance before placing it on the market or putting it into service."@en .

euai:TEU a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "TEU"@en ;
    skos:definition "The Treaty on European Union; referenced alongside TFEU in the context of Denmark's legal position."@en .

euai:TEXT_GENERATION_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "TEXT GENERATION SYSTEM"@en ;
    skos:definition "An AI system that generates or manipulates text which is published with the purpose of informing the public on matters of public interest"@en ;
    euai:hasException euai:HUMAN_REVIEW_OR_EDITORIAL_CONTROL_EXCEPTION .

euai:THIRD_PARTY_CONFORMITY_ASSESSMENT a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "THIRD-PARTY CONFORMITY ASSESSMENT"@en ;
    skos:definition "A requirement for products or AI systems acting as safety components under Annex I to undergo assessment by a third party prior to market placement"@en ;
    euai:relatedTo euai:ANNEX_I .

euai:THIRD_PARTY_CONFORMITY_ASSESSMENT_BODY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "THIRD-PARTY CONFORMITY ASSESSMENT BODY"@en ;
    skos:definition "A third-party conformity assessment body is an independent organization formally authorized to conduct regulatory conformity assessments for products. The involvement of such a body is a significant regulatory factor, as its participation often triggers the formal classification of an embedded AI system as \"high-risk.\" Consequently, this entity plays a crucial role in the compliance landscape, serving as the responsible party for performing the necessary evaluations that determine whether an AI-"@en ;
    euai:relatedTo euai:CONFORMITY_ASSESSMENT_PROCEDURE .

euai:TRAINING_DATA a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "TRAINING DATA"@en ;
    skos:definition "TRAINING DATA refers to the foundational datasets, encompassing both text and other forms of information, that are utilized in the development and refinement of AI systems. This data is essential for both the pre-training and specialized training phases of general-purpose AI models, serving as the raw material through which the system fits and optimizes its learnable parameters. By processing this information, the AI model gains the ability to identify patterns, make predictions, and enhance its"@en ;
    euai:isBasedOn euai:AISYSTEM ;
    euai:relatedTo euai:TRAINING_DATA_SUMMARY .

euai:TRANSITIONAL_PERIOD_OBLIGATIONS a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "TRANSITIONAL PERIOD OBLIGATIONS"@en ;
    skos:definition "Voluntary compliance with Regulation obligations during the transitional period for providers of high-risk AI systems"@en .

euai:TRANSPARENCY_REQUIREMENTS a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "TRANSPARENCY REQUIREMENTS"@en ;
    skos:definition "Obligations under the Regulation regarding the transparent provision of AI systems; violation of these when accompanied by a risk triggers specific enforcement procedures."@en .

euai:TechnicalDocumentation a owl:Class ;
    rdfs:label "Technical Documentation"@en ;
    rdfs:subClassOf euai:Requirement ;
    skos:definition "Documentation providers must maintain before placing on the market. (Article 11, Annex IV)"@en .

euai:TransparencyObligation a owl:Class ;
    rdfs:label "Transparency Obligation"@en ;
    rdfs:subClassOf euai:Obligation ;
    skos:definition "Obligations to inform users that they are interacting with an AI system. (Article 50)"@en .

euai:UNACCEPTABLE_RISK_PROHIBITIONS a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "UNACCEPTABLE RISK PROHIBITIONS"@en ;
    skos:definition "Prohibitions of certain AI practices deemed to carry an unacceptable risk, applicable from 2 February 2025"@en ;
    euai:relatedTo euai:ARTICLE_1 .

euai:UNFAIR_COMMERCIAL_PRACTICES_DIRECTIVE a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "UNFAIR COMMERCIAL PRACTICES DIRECTIVE"@en ;
    skos:definition """The Unfair Commercial Practices Directive, formally known as Directive 2005/29/EC, establishes a comprehensive framework designed to regulate business-to-consumer commercial practices across the European Union. Its primary objective is to prevent businesses from engaging in misleading or aggressive tactics that could distort the economic behavior of consumers, thereby ensuring a fair marketplace and high level of consumer protection.

In the contemporary digital landscape, the Unfair Commercial """@en ;
    euai:subjectTo euai:AISYSTEM .

euai:UNINTENTIONAL_DISTORTION a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "UNINTENTIONAL DISTORTION"@en ;
    skos:definition "Exemption for distortion resulting from unforeseeable factors external to the AI system and outside provider/deployer control."@en ;
    euai:hasException euai:PROHIBITION_OF_MANIPULATIVE_AI_PRACTICES .

euai:UNION_AI_TESTING_SUPPORT a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "UNION AI TESTING SUPPORT"@en ;
    skos:definition "Entities providing technical support to Member States, coordinated with experts pursuant to Article 84."@en .

euai:UNION_INSTITUTION a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "UNION INSTITUTION"@en ;
    skos:definition "Union institutions, bodies, offices, and agencies refer to the entities within the European Union structure that operate under specific legal frameworks governing their functions, technological deployments, and data practices. These organizations are subject to Regulation (EU) 2018/1725, which establishes specific rules regarding the protection of natural persons with regard to the processing of personal data. Furthermore, these institutions are subject to regulatory oversight regarding their ut"@en ;
    euai:relatedTo euai:LAW_ENFORCEMENT_SUPPORT_AI ;
    euai:subjectTo euai:PERSONAL_DATA_PROTECTION .

euai:UNION_INSTITUTIONS__BODIES__OFFICES_OR_AGENCIES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "UNION INSTITUTIONS, BODIES, OFFICES OR AGENCIES"@en ;
    skos:definition "UNION INSTITUTIONS, BODIES, OFFICES OR AGENCIES comprise those European Union organizations that are subject to the requirements of the Regulation and fall under the supervision of the European Data Protection Supervisor. This group specifically encompasses EU bodies tasked with responsibilities related to migration, asylum, and border control management, particularly those that deploy artificial intelligence systems in the execution of these duties."@en ;
    euai:relatedTo euai:EUROPEAN_DATA_PROTECTION_SUPERVISOR,
        euai:MIGRATION__ASYLUM_AND_BORDER_CONTROL_AI_SYSTEM .

euai:UNION_INSTITUTIONS__BODIES__OFFICES__OR_AGENCIES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "UNION INSTITUTIONS, BODIES, OFFICES, OR AGENCIES"@en ;
    skos:definition "Entities that may use or support law enforcement authorities in using AI systems for law enforcement purposes"@en ;
    euai:relatedTo euai:LAW_ENFORCEMENT .

euai:UN_CONVENTION_RELATING_TO_THE_STATUS_OF_REFUGEES a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "UN CONVENTION RELATING TO THE STATUS OF REFUGEES"@en ;
    skos:definition "International obligation that must not be circumvented by the use of AI systems in migration management."@en .

euai:USER_FRIENDLY_EU_DATABASE a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "USER-FRIENDLY EU DATABASE"@en ;
    skos:definition "The EU database must be publicly accessible, free of charge, easy to navigate, understandable, machine-readable, and feature search functionalities"@en .

euai:UnacceptableRisk a owl:NamedIndividual,
        euai:RiskCategory ;
    rdfs:label "UnacceptableRisk"@en ;
    skos:definition "Risk level triggering an outright prohibition"@en ;
    euai:articleReference "Article 5" .

euai:VALIDATION_DATA a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "VALIDATION DATA"@en ;
    skos:definition "Data used for evaluating the trained AI system, tuning non-learnable parameters, and optimizing the learning process to prevent underfitting or overfitting."@en .

euai:VERY_LARGE_ONLINE_SEARCH_ENGINE a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "VERY LARGE ONLINE SEARCH ENGINE"@en ;
    skos:definition "Service provider regulated under Regulation (EU) 2022/2065, subject to specific risk-management frameworks when embedding AI systems or models"@en ;
    euai:relatedTo euai:SYSTEMIC_RISK ;
    euai:subjectTo euai:RISK_MANAGEMENT_FRAMEWORK .

euai:VERY_LARGE_ONLINE_SEARCH_ENGINES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "VERY LARGE ONLINE SEARCH ENGINES"@en ;
    skos:definition "Providers of search engines subject to obligations to mitigate systemic risks arising from artificially generated content"@en ;
    euai:regulatedBy euai:REGULATION__EU__2022_2065 ;
    euai:relatedTo euai:SYSTEMIC_RISK .

euai:VICTIM_RISK_ASSESSMENT_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "VICTIM RISK ASSESSMENT AI SYSTEM"@en ;
    skos:definition "AI systems used by or on behalf of law enforcement authorities to assess the risk of a natural person becoming a victim of criminal offences"@en ;
    euai:relatedTo euai:ACCURACY,
        euai:HIGH_RISK,
        euai:PERFORMANCE,
        euai:RECITAL_59,
        euai:ROBUSTNESS,
        euai:TRANSPARENCY .

euai:VIRTUAL_REALITY a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "VIRTUAL REALITY"@en ;
    skos:definition "Technology that facilitates manipulative AI practices by controlling stimuli presented to persons."@en ;
    euai:isBasedOn euai:MANIPULATIVE_OR_DECEPTIVE_AI_SYSTEM .

euai:VOLUNTARY_CODES_OF_CONDUCT a owl:NamedIndividual,
        euai:CodeOfPractice ;
    rdfs:label "VOLUNTARY CODES OF CONDUCT"@en ;
    skos:definition "Voluntary compliance instruments designed to be effective, inclusive, and based on clear objectives and key performance indicators as mentioned in Recital 166"@en ;
    euai:isBasedOn euai:KEY_PERFORMANCE_INDICATORS .

euai:VULNERABILITY_EXPLOITATION_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "VULNERABILITY EXPLOITATION AI SYSTEM"@en ;
    skos:definition "AI system exploiting vulnerabilities of persons due to age, disability, or social/economic situation to distort behavior and cause significant harm"@en ;
    euai:belongsToCategory euai:PROHIBITED_AI_PRACTICE .

euai:WHISTLEBLOWERS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "WHISTLEBLOWERS"@en ;
    skos:definition "Persons reporting infringements of the AI Act, who are protected under Directive (EU) 2019/1937"@en ;
    euai:relatedTo euai:COMPLAINT ;
    euai:subjectTo euai:PROTECTION_OF_WHISTLEBLOWERS .

euai:WIDESPREAD_INFRINGEMENT a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "WIDESPREAD INFRINGEMENT"@en ;
    skos:definition "Any act or omission contrary to Union law protecting the interest of individuals that affects individuals in at least two Member States or occurs concurrently in at least three Member States, as defined in Article 3(61)"@en ;
    euai:relatedTo euai:DEPLOYER .

euai:WORKERS_AND_PLATFORM_SERVICE_PROVIDERS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "WORKERS AND PLATFORM SERVICE PROVIDERS"@en ;
    skos:definition "Individuals in work-related contractual relationships who are subject to AI-based monitoring, evaluation, or management"@en ;
    euai:subjectTo euai:EMPLOYMENT_AND_WORKERS_MANAGEMENT_AI_SYSTEM .

euai:WORKERS_CONTRACTUAL_RELATIONSHIP_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "WORKERS CONTRACTUAL RELATIONSHIP AI"@en ;
    skos:definition "AI systems making decisions affecting terms of work-related relationships, promotion, or termination (Annex III 4(b))"@en ;
    euai:belongsToCategory euai:EMPLOYMENT__WORKERS__MANAGEMENT_AND_ACCESS_TO_SELF_EMPLOYMENT .

euai:WORKERS_MANAGEMENT_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "WORKERS MANAGEMENT AI"@en ;
    skos:definition "AI system used for decisions affecting terms of work-related relationships, promotions, terminations, task allocation, or performance monitoring."@en ;
    euai:belongsToCategory euai:EMPLOYMENT__WORKERS__MANAGEMENT_AND_ACCESS_TO_SELF_EMPLOYMENT .

euai:WORKER_PERFORMANCE_MONITORING_AI a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "WORKER PERFORMANCE MONITORING AI"@en ;
    skos:definition "AI systems used to monitor and evaluate performance and behaviour in work-related relationships (Annex III 4(b))"@en ;
    euai:belongsToCategory euai:EMPLOYMENT__WORKERS__MANAGEMENT_AND_ACCESS_TO_SELF_EMPLOYMENT .

euai:WORKER_RIGHTS_PROTECTION_CLAUSE a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "WORKER RIGHTS PROTECTION CLAUSE"@en ;
    skos:definition "Regulation does not preclude the Union or Member States from maintaining/introducing laws more favourable to workers or allowing collective agreements that are more favourable. Defined in Article 2(11)."@en ;
    euai:definedInArticle euai:ARTICLE_2 .

euai:alwaysClassifiedAs a owl:ObjectProperty ;
    rdfs:label "alwaysClassifiedAs"@en .

euai:annexReference a owl:DatatypeProperty ;
    rdfs:label "annex reference"@en ;
    rdfs:range xsd:string ;
    skos:definition "Reference to a relevant Annex of the EU AI Act."@en .

euai:appliesThroughout a owl:ObjectProperty ;
    rdfs:label "appliesThroughout"@en .

euai:appliesTo a owl:ObjectProperty ;
    rdfs:label "appliesTo"@en .

euai:articleReference a owl:DatatypeProperty ;
    rdfs:label "article reference"@en ;
    rdfs:range xsd:string ;
    skos:definition "The article number(s) in the EU AI Act where this concept is defined."@en .

euai:belongsToCategory a owl:ObjectProperty ;
    rdfs:label "belongsToCategory"@en .

euai:conductedBy a owl:ObjectProperty ;
    rdfs:label "conducted by"@en ;
    rdfs:domain euai:ConformityAssessment ;
    rdfs:range euai:Actor ;
    skos:definition "Relates a conformity assessment to the body conducting it."@en .

euai:conductsEvaluationOf a owl:ObjectProperty ;
    rdfs:label "conductsEvaluationOf"@en .

euai:cooperatesWith a owl:ObjectProperty ;
    rdfs:label "cooperatesWith"@en .

euai:definedInArticle a owl:ObjectProperty ;
    rdfs:label "definedInArticle"@en .

euai:deploysSystem a owl:ObjectProperty ;
    rdfs:label "deploys system"@en ;
    rdfs:domain euai:Deployer ;
    rdfs:range euai:AISystem ;
    skos:definition "Relates a deployer to an AI system they operate."@en .

euai:enforces a owl:ObjectProperty ;
    rdfs:label "enforces"@en ;
    rdfs:domain euai:Authority ;
    rdfs:range euai:Obligation ;
    skos:definition "Relates an authority to the obligations it enforces."@en .

euai:grants a owl:ObjectProperty ;
    rdfs:label "grants"@en .

euai:hasConsequence a owl:ObjectProperty ;
    rdfs:label "hasConsequence"@en .

euai:hasDeadline a owl:ObjectProperty ;
    rdfs:label "hasDeadline"@en .

euai:hasException a owl:ObjectProperty ;
    rdfs:label "hasException"@en .

euai:hasObligation a owl:ObjectProperty ;
    rdfs:label "has obligation"@en ;
    rdfs:domain euai:Actor ;
    rdfs:range euai:Obligation ;
    skos:definition "Relates an actor to an obligation they must fulfil."@en .

euai:hasRequirement a owl:ObjectProperty ;
    rdfs:label "has requirement"@en ;
    rdfs:domain euai:AISystem ;
    rdfs:range euai:Requirement ;
    skos:definition "Relates a high-risk AI system to a technical requirement."@en .

euai:hasRiskCategory a owl:ObjectProperty ;
    rdfs:label "has risk category"@en ;
    rdfs:domain euai:AISystem ;
    rdfs:range euai:RiskCategory ;
    skos:definition "Classifies an AI system into a risk category."@en .

euai:isBasedOn a owl:ObjectProperty ;
    rdfs:label "isBasedOn"@en .

euai:isExemptFromHighRisk a owl:ObjectProperty ;
    rdfs:label "isExemptFromHighRisk"@en .

euai:meetsSystemicRiskThreshold a owl:ObjectProperty ;
    rdfs:label "meetsSystemicRiskThreshold"@en .

euai:modifies a owl:ObjectProperty ;
    rdfs:label "modifies"@en .

euai:placeOnMarket a owl:ObjectProperty ;
    rdfs:label "places on market"@en ;
    rdfs:domain euai:Provider ;
    rdfs:range euai:AISystem ;
    skos:definition "Relates a provider to an AI system they make available."@en .

euai:presumesConformity a owl:ObjectProperty ;
    rdfs:label "presumesConformity"@en .

euai:providesInstructionsTo a owl:ObjectProperty ;
    rdfs:label "providesInstructionsTo"@en .

euai:reducedObligationsApplyTo a owl:ObjectProperty ;
    rdfs:label "reducedObligationsApplyTo"@en .

euai:regulatedBy a owl:ObjectProperty ;
    rdfs:label "regulated by"@en ;
    rdfs:range euai:Authority ;
    skos:definition "Relates an actor or AI system to the authority overseeing it."@en .

euai:relatedTo a owl:ObjectProperty ;
    rdfs:label "relatedTo"@en .

euai:riskLevel a owl:DatatypeProperty ;
    rdfs:label "risk level"@en ;
    rdfs:range xsd:string ;
    skos:definition "The risk level designation (unacceptable/high/limited/minimal)."@en .

euai:subjectTo a owl:ObjectProperty ;
    rdfs:label "subject to"@en ;
    rdfs:domain euai:AISystem ;
    rdfs:range euai:Obligation ;
    skos:definition "Relates an AI system to an applicable obligation."@en .

euai:triggers a owl:ObjectProperty ;
    rdfs:label "triggers"@en ;
    rdfs:domain euai:RiskCategory ;
    rdfs:range euai:Obligation ;
    skos:definition "Relates a risk category to the obligations it activates."@en .

euai:ABSENCE_OF_CONFLICTS_OF_INTERESTS a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "ABSENCE OF CONFLICTS OF INTERESTS"@en ;
    skos:definition "Specific requirement for notified bodies to operate without bias or competing commercial interests"@en .

euai:ACADEMIA a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "ACADEMIA"@en ;
    skos:definition "ACADEMIA refers to academic institutions and stakeholders invited to participate in the development of regulatory frameworks. Specifically, ACADEMIA is recognized as an interested party capable of supporting the process of drafting both codes of practice and codes of conduct. In the context of regulatory compliance, academic institutions are invited to provide their expertise to assist in drawing up codes of practice, as outlined in Article 56(3). Furthermore, these academic stakeholders are als"@en ;
    euai:relatedTo euai:CODE_OF_CONDUCT,
        euai:CODE_OF_PRACTICE .

euai:ACCESSIBILITY_REQUIREMENTS a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "ACCESSIBILITY REQUIREMENTS"@en ;
    skos:definition "Technical standards for ensuring information provided about AI systems is accessible to all users, referred to in Article 50(5)"@en .

euai:ACCESS_TO_TECHNICAL_DOCUMENTATION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "ACCESS TO TECHNICAL DOCUMENTATION"@en ;
    skos:definition "Requirement for law enforcement, immigration, or asylum authorities (when acting as providers) to ensure market surveillance authorities have immediate access to technical documentation (Annex IV) on their premises"@en .

euai:ACCOUNTABILITY_OBLIGATION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "ACCOUNTABILITY OBLIGATION"@en ;
    skos:definition "The duty of recipient national authorities and Union institutions, bodies, offices, and agencies to ensure the use of outputs complies with Union law."@en .

euai:ACCURACY_REQUIREMENT a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "ACCURACY REQUIREMENT"@en ;
    skos:definition "Requirement for AI systems in migration, asylum, and border control to be accurate to guarantee fundamental rights."@en .

euai:ADAPTIVE_DESIGNATION a owl:NamedIndividual,
        euai:ClassificationRule ;
    rdfs:label "ADAPTIVE DESIGNATION"@en ;
    skos:definition "The Commission's power to designate a GPAI model as having systemic risk even if it does not meet the initial quantitative threshold, based on criteria like training data quality, size, autonomy, and scalability."@en .

euai:ADCO_SUB_GROUP a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "ADCO SUB-GROUP"@en ;
    skos:definition "The standing sub-group for market surveillance, acting as the administrative cooperation group (ADCO) for the Regulation per Regulation (EU) 2019/1020"@en ;
    euai:definedInArticle euai:REGULATION__EU__2019_1020 ;
    euai:relatedTo euai:ARTICLE_33_OF_REGULATION__EU__2019_1020 .

euai:ADMINISTRATION_OF_JUSTICE a owl:NamedIndividual,
        euai:AnnexIIICategory ;
    rdfs:label "ADMINISTRATION OF JUSTICE"@en ;
    skos:definition "The Administration of Justice is classified as a high-risk domain regarding the implementation of artificial intelligence. In this context, AI systems utilized by judicial authorities are subject to strict scrutiny because of their significant potential impact on fundamental rights, specifically the right to a fair trial and the provision of an effective remedy. This high-risk classification encompasses a broad spectrum of applications, including the use of AI for legal research, the interpretat"@en ;
    euai:belongsToCategory euai:HIGH_RISK .

euai:ADMINISTRATION_OF_JUSTICE_AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "ADMINISTRATION OF JUSTICE AI SYSTEM"@en ;
    skos:definition """**ADMINISTRATION OF JUSTICE AI SYSTEM**

The "Administration of Justice AI System" refers to advanced artificial intelligence technologies designed specifically for use by, or on behalf of, judicial authorities. The primary purpose of these systems is to support the judiciary in the complex tasks inherent in legal proceedings. Specifically, these AI tools are intended to assist in the comprehensive processes of researching, interpreting, and analyzing both facts and the law, as well as applying """@en ;
    euai:alwaysClassifiedAs euai:HIGH_RISK_AI_SYSTEM ;
    euai:belongsToCategory euai:ADMINISTRATION_OF_JUSTICE .

euai:ADMINISTRATION_OF_JUSTICE_AND_DEMOCRATIC_PROCESSES a owl:NamedIndividual,
        euai:AnnexIIICategory ;
    rdfs:label "ADMINISTRATION OF JUSTICE AND DEMOCRATIC PROCESSES"@en ;
    skos:definition "The \"Administration of Justice and Democratic Processes\" encompasses high-risk artificial intelligence use case domains that are integral to the functioning of critical public sectors. Specifically, this area pertains to AI systems utilized to assist judicial authorities in performing legal tasks, as well as systems that have the potential to influence the outcomes of elections or referenda. These applications are formally categorized as high-risk within the framework of AI regulations, such as "@en ;
    euai:belongsToCategory euai:AI_SYSTEM_FOR_INFLUENCING_ELECTIONS,
        euai:AI_SYSTEM_FOR_JUDICIAL_ASSISTANCE .

euai:ADMINISTRATIVE_AUTHORITY a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "ADMINISTRATIVE AUTHORITY"@en ;
    skos:definition "The ADMINISTRATIVE AUTHORITY functions as a regulatory body tasked with the oversight and governance of post-remote biometric identification systems. As an administrative entity, it holds the power to issue binding decisions regarding the authorization of these systems. Furthermore, the actions and decisions made by the ADMINISTRATIVE AUTHORITY are subject to judicial review, ensuring that its regulatory processes remain accountable and legally compliant."@en .

euai:ADMINISTRATIVE_COOPERATION_GROUP a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "ADMINISTRATIVE COOPERATION GROUP"@en ;
    skos:definition "Also referred to as ADCO; an administrative cooperation structure under Regulation (EU) 2019/1020, aligned with the Board's standing sub-group for market surveillance per Article 65(6)."@en .

euai:ADMINISTRATIVE_PROCEEDING_EXCLUSION a owl:NamedIndividual,
        euai:ExclusionCondition ;
    rdfs:label "ADMINISTRATIVE PROCEEDING EXCLUSION"@en ;
    skos:definition """**ADMINISTRATIVE PROCEEDING EXCLUSION**

AI systems utilized for administrative proceedings within tax, customs, and financial intelligence units are expressly excluded from the high-risk classification that is otherwise applied to artificial intelligence systems used in the context of law enforcement. This specific exclusion ensures that these financial and regulatory administrative processes are not subject to the same regulatory requirements mandated for high-risk law enforcement AI."""@en .

euai:ADVERSE_LEGAL_EFFECT a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "ADVERSE LEGAL EFFECT"@en ;
    skos:definition "A prohibited outcome where a decision is taken based solely on the output of a remote biometric identification system."@en .

euai:ADVERSE_LEGAL_EFFECT_PROHIBITION a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "ADVERSE LEGAL EFFECT PROHIBITION"@en ;
    skos:definition "A requirement that no decision producing an adverse legal effect on a person may be taken based solely on the output of a real-time remote biometric identification system."@en .

euai:AFFECTED_PERSON a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "AFFECTED PERSON"@en ;
    skos:definition """An "Affected Person" is defined as any natural person whose rights, health, or safety may be impacted by the output or operation of an AI system. This designation encompasses individuals located within the Union who are subject to or influenced by these technologies.

Within the regulatory framework, an Affected Person is recognized as a subject of decisions made by a deployer based on the outputs generated by a high-risk AI system. In such instances, this individual possesses the specific right"""@en ;
    euai:definedInArticle euai:ARTICLE_2 ;
    euai:relatedTo euai:AI_LITERACY .

euai:AFFECTED_WORKERS a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "AFFECTED WORKERS"@en ;
    skos:definition "Workers who are directly subject to the use of a high-risk AI system in the workplace and must be informed by their employer."@en .

euai:AI_ECOSYSTEM rdfs:label "AI ECOSYSTEM"@en .

euai:AI_HLEG a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "AI HLEG"@en ;
    skos:definition """The High-Level Expert Group on Artificial Intelligence, commonly referred to as the AI HLEG, is an independent body appointed by the European Commission. Established to provide expert guidance on AI development and deployment, the AI HLEG is primarily recognized for its pivotal role in formulating ethical standards for the technology.

Most notably, the AI HLEG was responsible for developing the 2019 Ethics Guidelines for Trustworthy AI. This foundational document was authored by the group to es"""@en ;
    euai:relatedTo euai:ETHICAL_PRINCIPLES_FOR_TRUSTWORTHY_AI,
        euai:ETHICS_GUIDELINES_FOR_TRUSTWORTHY_AI,
        euai:EUROPEAN_COMMISSION .

euai:AI_LITERACY_TRAINING a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "AI LITERACY TRAINING"@en ;
    skos:definition "Specific training required for persons responsible for human oversight to ensure they can adequately perform their tasks (Recital 91)"@en .

euai:AI_SYSTEMS_FOR_EMOTION_INFERENCE a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEMS FOR EMOTION INFERENCE"@en ;
    skos:definition "Systems that identify or infer emotions of natural persons; criticized for lack of reliability and potential for discrimination per Recital 44."@en .

euai:AI_SYSTEM_FOR_INFLUENCING_ELECTIONS a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM FOR INFLUENCING ELECTIONS"@en ;
    skos:definition "System used to influence election/referendum outcomes or voting behavior, identified in Annex III(8)(b)"@en ;
    euai:hasException euai:EXCLUSION_FOR_POLITICAL_CAMPAIGN_TOOLS .

euai:AI_SYSTEM_FOR_MIGRATION_DETECTION_AND_IDENTIFICATION a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM FOR MIGRATION DETECTION AND IDENTIFICATION"@en ;
    skos:definition "System used in migration/border control for detecting, recognizing, or identifying natural persons, identified in Annex III(7)(d)"@en ;
    euai:hasException euai:EXCLUSION_FOR_TRAVEL_DOCUMENT_VERIFICATION .

euai:AI_VALUE_CHAIN_PARTIES a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "AI VALUE CHAIN PARTIES"@en ;
    skos:definition "Parties that supply AI systems, tools, services, or components incorporated by providers into high-risk AI systems"@en ;
    euai:relatedTo euai:INTELLECTUAL_PROPERTY_RIGHTS,
        euai:PROVIDER,
        euai:TRADE_SECRETS,
        euai:WRITTEN_AGREEMENT .

euai:ALTERNATIVE_ADEQUATE_MEANS_OF_COMPLIANCE a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "ALTERNATIVE ADEQUATE MEANS OF COMPLIANCE"@en ;
    skos:definition "A mechanism for providers who do not follow codes of practice or harmonised standards to prove compliance, subject to Commission assessment per Article 53(4)."@en ;
    euai:relatedTo euai:EUROPEAN_COMMISSION .

euai:ALTERNATIVE_DISPUTE_RESOLUTION_BODY a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "ALTERNATIVE DISPUTE RESOLUTION BODY"@en ;
    skos:definition "A body that settles disputes outside of court, which may use AI systems that have legal effects on parties (Recital 61)."@en .

euai:ANNEX_II a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ANNEX II"@en ;
    skos:definition "\"ANNEX II\" serves as a critical component within the legal framework governing Artificial Intelligence, specifically detailing a list of specific criminal offences. This Annex is directly referenced in Article 5(1), first subparagraph, point (h)(iii), of the relevant legislation. Its primary purpose is to define the precise scope of criminal activities that trigger specific legal considerations regarding the use of AI systems in law enforcement contexts. Furthermore, \"ANNEX II\" identifies the sp"@en ;
    euai:relatedTo euai:ARTICLE_5_1__H__III_,
        euai:CRIMINAL_OFFENCES .

euai:ANNEX_IIICATEGORY rdfs:label "ANNEX IIICATEGORY"@en .

euai:ANNEX_III_CATEGORY a owl:NamedIndividual,
        euai:AnnexIIICategory ;
    rdfs:label "ANNEX III CATEGORY"@en ;
    skos:definition "**ANNEX III CATEGORY** represents a classification of domains within the framework of artificial intelligence regulation. These specific domains include law enforcement, migration, asylum, border control, the administration of justice, and democratic processes. Within these sectors, AI systems classified as high-risk are subject to stringent oversight, necessitating specific investigative and corrective powers to ensure compliance, safety, and accountability."@en .

euai:ANNEX_III_POINT_1_A_ a owl:NamedIndividual,
        euai:AnnexIIICategory ;
    rdfs:label "ANNEX III POINT 1(A)"@en ;
    skos:definition "A specific sub-category of high-risk AI systems identified in Annex III that triggers additional minimum logging requirements under Article 12(3)"@en .

euai:ANNEX_VIII a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ANNEX VIII"@en ;
    skos:definition "Annex VIII serves as a critical regulatory component within the framework governing artificial intelligence, specifically outlining the mandatory information requirements for the registration of high-risk AI systems in the EU database. This annex ensures compliance and transparency by detailing the specific data that must be submitted under Article 49 of the relevant regulations. Furthermore, Annex VIII is structured into specific sections—designated as sections A, B, and C—which comprehensively"@en ;
    euai:relatedTo euai:EU_DATABASE_FOR_HIGH_RISK_AI_SYSTEMS,
        euai:REGISTRATION_OBLIGATION .

euai:ANNEX_X a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ANNEX X"@en ;
    skos:definition "**ANNEX X** refers to a specific section within the EU AI Act that serves to identify and list relevant Union legislative acts. This annex focuses exclusively on legislation pertaining to large-scale information technology (IT) systems within the domain of Freedom, Security, and Justice. The information contained in ANNEX X is particularly significant because it is often utilized to help determine the classification of AI systems, specifically when evaluating whether a system qualifies as a high"@en ;
    euai:belongsToCategory euai:EURODAC,
        euai:SCHENGEN_INFORMATION_SYSTEM,
        euai:VISA_INFORMATION_SYSTEM .

euai:ANNEX__LIST_OF_CRIMINAL_OFFENCES_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ANNEX (LIST OF CRIMINAL OFFENCES)"@en ;
    skos:definition "The annex containing the list of 32 criminal offences derived from Council Framework Decision 2002/584/JHA for which real-time remote biometric identification may be considered."@en .

euai:ANNUAL_NOTIFICATION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "ANNUAL NOTIFICATION"@en ;
    skos:definition "The duty of the European Data Protection Supervisor to provide an annual report to the Commission regarding administrative fines imposed and any initiated litigation or judicial proceedings."@en .

euai:ANNUAL_REPORTING_OBLIGATION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "ANNUAL REPORTING OBLIGATION"@en ;
    skos:definition "Requirement for deployers to submit annual reports to market surveillance and data protection authorities on the use of post-remote biometric identification systems"@en .

euai:ANNUAL_REPORT_ON_AI_REGULATORY_SANDBOXES a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "ANNUAL REPORT ON AI REGULATORY SANDBOXES"@en ;
    skos:definition "A mandatory report submitted by national competent authorities to the AI Office and the Board regarding the progress, results, best practices, and incidents within the sandboxes (Recital 16)."@en ;
    euai:relatedTo euai:AI_OFFICE,
        euai:EUROPEAN_ARTIFICIAL_INTELLIGENCE_BOARD .

euai:ANNUAL_REPORT_PREPARATION a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "ANNUAL REPORT PREPARATION"@en ;
    skos:definition "The advisory forum is required to prepare an annual report on its activities and make it publicly available"@en .

euai:APPEAL_PROCEDURE a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "APPEAL PROCEDURE"@en ;
    skos:definition "A mechanism that must be available to challenge decisions made by notified bodies regarding conformity certificates, as mentioned in the text following Article 45."@en .

euai:APPLICATION_DATE_2_AUGUST_2025 rdfs:label "APPLICATION DATE 2 AUGUST 2025"@en .

euai:APPLICATION_DATE_2_FEBRUARY_2025 rdfs:label "APPLICATION DATE 2 FEBRUARY 2025"@en .

euai:APPOINTMENT_OF_AUTHORISED_REPRESENTATIVE a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "APPOINTMENT OF AUTHORISED REPRESENTATIVE"@en ;
    skos:definition "Providers established in third countries must, by written mandate, appoint an authorised representative established in the Union before making systems available."@en .

euai:ARTICLES_102_TO_109 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLES 102 TO 109"@en ;
    skos:definition "Specific articles regarding market surveillance or specific obligations applied to high-risk systems under Article 2(2)"@en .

euai:ARTICLE_1 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 1"@en ;
    skos:definition "Article defining the subject matter and purpose of the Regulation, including harmonised rules, prohibitions, and requirements"@en ;
    euai:relatedTo euai:AI_SYSTEM,
        euai:MARKET_MONITORING,
        euai:SUPPORT_FOR_INNOVATION,
        euai:TRANSPARENCY_RULES .

euai:ARTICLE_100 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 100"@en ;
    skos:definition "Article 100 serves as the specific regulatory provision governing the imposition and calculation of administrative fines applicable to Union institutions, bodies, offices, and agencies. This article outlines the framework and procedures for these entities regarding financial penalties, ensuring a standardized approach within the context of their administrative obligations."@en .

euai:ARTICLE_105 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 105"@en ;
    skos:definition "Article amending Directive 2014/90/EU regarding AI safety components"@en ;
    euai:relatedTo euai:DIRECTIVE_2014_90_EU .

euai:ARTICLE_106 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 106"@en ;
    skos:definition "Article amending Directive (EU) 2016/797 regarding AI safety components"@en ;
    euai:relatedTo euai:DIRECTIVE__EU__2016_797 .

euai:ARTICLE_107 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 107"@en ;
    skos:definition "Article amending Regulation (EU) 2018/858 regarding AI safety components"@en ;
    euai:relatedTo euai:REGULATION__EU__2018_858 .

euai:ARTICLE_108 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 108"@en ;
    skos:definition "Article amending Regulation (EU) 2018/1139 regarding AI safety components"@en ;
    euai:relatedTo euai:REGULATION__EU__2018_1139 .

euai:ARTICLE_109 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 109"@en ;
    skos:definition "Article 109 of the AI Act, which provides the amendment to Regulation (EU) 2019/2144 regarding the consideration of requirements for safety component AI systems."@en ;
    euai:modifies euai:REGULATION_2019_2144 .

euai:ARTICLE_10_1__OF_REGULATION__EU__2018_1725 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 10(1) OF REGULATION (EU) 2018/1725"@en ;
    skos:definition "EU regulation provision prohibiting the processing of biometric data for non-law enforcement purposes, subject to limited exceptions"@en .

euai:ARTICLE_10_1__REGULATION__EU__NO_1025_2012 rdfs:label "ARTICLE 10 1  REGULATION  EU  NO 1025 2012"@en .

euai:ARTICLE_10_4_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 10(4)"@en ;
    skos:definition "**Article 10(4)** outlines the regulatory requirements concerning data governance and the quality of data sets used for high-risk AI systems. This article specifically details the mandatory standards for training, validation, and testing data sets, ensuring that these systems are developed and evaluated using robust and reliable information. By addressing these criteria, Article 10(4) aims to ensure high-risk AI systems are grounded in sound data management practices, ultimately promoting accura"@en ;
    euai:relatedTo euai:HIGH_RISK_AI_SYSTEM .

euai:ARTICLE_10_OF_DIRECTIVE__EU_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 10 OF DIRECTIVE (EU)"@en ;
    skos:definition "Refers to the rules on the processing of biometric data in the context of Directive (EU) (often relating to the GDPR or Law Enforcement Directive context)."@en .

euai:ARTICLE_114 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 114"@en ;
    skos:definition "The article of the Treaty on the Functioning of the European Union (TFEU) providing the legal basis for ensuring a high level of protection and preventing market divergences"@en .

euai:ARTICLE_114_TFEU a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 114 TFEU"@en ;
    skos:definition "Legal basis for the AI Act regarding the functioning of the internal market and harmonized rules for AI"@en .

euai:ARTICLE_11_1_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 11(1)"@en ;
    skos:definition "**Article 11(1)** mandates that providers of high-risk AI systems are responsible for the creation and ongoing maintenance of comprehensive technical documentation. This documentation must be drafted in accordance with the specifications outlined in Annex IV of the regulation. Crucially, Article 11(1) requires that this documentation be fully prepared before the high-risk AI system is placed on the market."@en .

euai:ARTICLE_12_1_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 12(1)"@en ;
    skos:definition "Article regarding automatic logging capabilities for high-risk AI systems which the authorised representative must provide access to."@en .

euai:ARTICLE_13_3_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 13(3)"@en ;
    skos:definition "**ARTICLE 13(3)** is a provision focused on the principles of transparency, specifically regarding the obligations to provide information to deployers. Within this article, point (d) plays a crucial role in ensuring that deployers are adequately equipped to understand and utilize the AI system effectively. Specifically, this provision mandates that deployers must be facilitated in the interpretation of the AI system's outputs, ensuring that the information provided is sufficient to enable a clea"@en .

euai:ARTICLE_13_OF_DIRECTIVE__EU__2016_680 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 13 OF DIRECTIVE (EU) 2016/680"@en ;
    skos:definition "Article governing the implementation of information obligations for law enforcement use of AI systems (Recital 93)"@en .

euai:ARTICLE_16_1_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 16(1)"@en ;
    skos:definition "Provision in Regulation (EU) 2022/2065 regarding the notification of illegal content (Recital 136)"@en .

euai:ARTICLE_16_6_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 16(6)"@en ;
    skos:definition "Provision in Regulation (EU) 2022/2065 requiring hosting services to process notices on illegal content (Recital 136)"@en .

euai:ARTICLE_17 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 17"@en ;
    skos:definition "**ARTICLE 17** details the necessary requirements for the implementation and maintenance of a quality management system. Specifically, it establishes the regulatory framework and operational standards that providers of high-risk AI systems must adhere to, ensuring these systems meet established quality and safety benchmarks throughout their lifecycle."@en ;
    euai:relatedTo euai:QUALITY_MANAGEMENT_SYSTEM .

euai:ARTICLE_18_REGULATION_2019_1020 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 18 REGULATION 2019/1020"@en ;
    skos:definition "Article regarding procedural rights of economic operators, applied mutatis mutandis to GPAI model providers"@en .

euai:ARTICLE_19_OF_REGULATION__EU__2019_1020 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 19 OF REGULATION (EU) 2019/1020"@en ;
    skos:definition "Specific article governing appropriate measures to be taken by market surveillance authorities within seven days of a serious incident notification."@en .

euai:ARTICLE_20_OF_REGULATION__EU__2019_1020 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 20 OF REGULATION (EU) 2019/1020"@en ;
    skos:definition "Specific article governing the procedure for national competent authorities to notify the Commission of serious incidents."@en .

euai:ARTICLE_21 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 21"@en ;
    skos:definition "Specifies requirements for cooperation with competent authorities, including documentation and log provision"@en .

euai:ARTICLE_22 a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 22"@en ;
    skos:definition "**ARTICLE 22** outlines the regulatory framework and specific obligations pertaining to authorised representatives. Primarily, this article defines the responsibilities that authorised representatives must uphold within their professional capacity. Additionally, it specifies the necessary requirements for the appointment of these representatives, particularly for providers based in third countries, ensuring that proper representation is established in compliance with relevant regulations."@en ;
    euai:definedInArticle euai:PENALTIES_FOR_GENERAL_NON_COMPLIANCE .

euai:ARTICLE_22_1_ a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ARTICLE 22(1)"@en ;
    skos:definition "Refers to the requirement for the provider to appoint an authorised representative"@en .

