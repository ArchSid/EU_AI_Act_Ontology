euai:AI_REGULATORY_SANDBOX a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "AI REGULATORY SANDBOX"@en ;
    skos:definition """An **AI Regulatory Sandbox** is a controlled environment established by national competent authorities designed to foster innovation by facilitating the development, testing, training, and validation of innovative AI systems. Governed by provisions such as Article 3(55), Article 57, and Article 58, this framework provides a structured space for providers to refine their systems under regulatory oversight and supervision before they are placed on the market.

The primary objective of the AI Regul"""@en ;
    euai:definedInArticle euai:ARTICLE_58 ;
    euai:regulatedBy euai:COMMON_RULES_FOR_AI_REGULATORY_SANDBOXES ;
    euai:relatedTo euai:ARTICLE_57,
        euai:CODE_OF_CONDUCT,
        euai:COMPETENT_AUTHORITY,
        euai:CONFORMITY_ASSESSMENT,
        euai:EUROPEAN_DATA_PROTECTION_SUPERVISOR,
        euai:INNOVATIVE_AI_SYSTEM,
        euai:NATIONAL_COMPETENT_AUTHORITY,
