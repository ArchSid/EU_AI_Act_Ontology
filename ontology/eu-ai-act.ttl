euai:ExclusionCondition a owl:Class ;
    rdfs:label "ExclusionCondition"@en ;
    skos:definition "A condition under which an Annex III AI system is NOT classified as high-risk."@en .

euai:AISystem a owl:Class ;
    rdfs:label "AI System"@en ;
    skos:definition "A machine-based system designed to operate with varying levels of autonomy and that may exhibit adaptiveness after deployment. (Article 3(1))"@en .

euai:Actor a owl:Class ;
    rdfs:label "Actor"@en ;
    skos:definition "An entity with legal standing under the EU AI Act."@en .

euai:Requirement a owl:Class ;
    rdfs:label "Technical Requirement"@en ;
    skos:definition "A technical or organisational requirement for high-risk AI systems."@en .

euai:Obligation a owl:Class ;
    rdfs:label "Obligation"@en ;
    skos:definition "A duty, requirement, or prohibition imposed by the Act."@en .

euai:Article a owl:Class ;
    rdfs:label "Article"@en ;
    skos:definition "A reference to a specific article, annex, or recital of the EU AI Act."@en .

