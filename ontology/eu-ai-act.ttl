        euai:GENERAL_PURPOSE_AI_MODEL_WITH_SYSTEMIC_RISKS,
        euai:GENERAL_PURPOSE_AI_SYSTEM,
        euai:HIGH_IMPACT_CAPABILITIES,
        euai:INPUT_AND_OUTPUT_MODALITIES,
        euai:INTERNAL_MARKET_IMPACT,
        euai:MODALITY_THRESHOLD,
        euai:MODEL_CAPABILITY_EVALUATION,
        euai:PRESUMPTION_OF_CONFORMITY,
        euai:SYSTEMIC_RISK_THRESHOLD,
        euai:TECHNICAL_DOCUMENTATION,
        euai:TEXT_AND_DATA_MINING,
        euai:USER_REACH_METRIC ;
