        euai:UNION_COPYRIGHT_LAW ;
    euai:triggers euai:ARTICLE_51,
        euai:SYSTEMIC_RISK .

euai:NATIONAL_COMPETENT_AUTHORITY a owl:NamedIndividual,
        euai:Authority ;
    rdfs:label "NATIONAL COMPETENT AUTHORITY"@en ;
    skos:definition """A National Competent Authority (NCA) is a regulatory or enforcement body designated by a Member State to oversee the application, implementation, and enforcement of the AI Act at the national level. These entities act as the primary interface between national jurisdictions and the European Union’s regulatory framework for artificial intelligence.

The scope of a National Competent Authority is broad and multifaceted. Primarily, they are responsible for ensuring compliance with the AI Act, which """@en ;
    euai:belongsToCategory euai:NOTIFYING_AUTHORITY ;
