euai:TECHNICAL_DOCUMENTATION a owl:NamedIndividual,
        euai:Requirement ;
    rdfs:label "TECHNICAL DOCUMENTATION"@en ;
    skos:definition """**TECHNICAL DOCUMENTATION** refers to a comprehensive and mandatory set of records that providers must create and maintain to demonstrate that an AI system complies with the requirements set forth in the AI Act. This documentation serves as a critical tool for regulatory oversight, conformity assessment, and post-market monitoring, allowing competent authorities to evaluate the system’s design, development, and overall safety.

For high-risk AI systems, as mandated by Article 11(1) and detailed """@en ;
    euai:definedInArticle euai:ANNEXES,
        euai:ARTICLE_83,
        euai:RECITAL_72 ;
    euai:isBasedOn euai:RISK_MANAGEMENT_SYSTEM ;
