euai:DEPLOYER a owl:NamedIndividual,
        euai:Actor ;
    rdfs:label "DEPLOYER"@en ;
    skos:definition "A \"DEPLOYER\" is defined as any natural or legal person—including public authorities, agencies, or other bodies—that operates an AI system under their authority. This definition expressly excludes instances where an AI system is used in the course of a personal, non-professional activity. The classification of a DEPLOYER applies to entities established within the European Union, as well as those established in third countries, provided the output of the AI system they operate is intended for use "@en ;
    euai:cooperatesWith euai:NATIONAL_DATA_PROTECTION_AUTHORITY ;
