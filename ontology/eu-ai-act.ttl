euai:RiskCategory a owl:Class ;
    rdfs:label "Risk Category"@en ;
    skos:definition "A level of risk under the EU AI Act classification framework."@en .

euai:CODE_OF_PRACTICE a owl:NamedIndividual,
        euai:CodeOfPractice ;
    rdfs:label "CODE OF PRACTICE"@en ;
    skos:definition """The Code of Practice serves as a voluntary compliance instrument designed for providers of General-Purpose AI (GPAI) models to effectively demonstrate their adherence to the obligations mandated by the AI Act, particularly those outlined in Articles 53 and 55. These obligations include, but are not limited to, the implementation of requirements regarding the detection and labelling of artificially generated content.

Drafted with the goal of fostering best practices and high standards, the Code """@en ;
    euai:definedInArticle euai:ARTICLE_56 ;
    euai:relatedTo euai:ARTICLE_53,
        euai:ARTICLE_55,
        euai:ARTICLE_98_2_,
        euai:GENERAL_PURPOSE_AI_MODEL,
        euai:TRANSPARENCY_OBLIGATION ;
    euai:subjectTo euai:REPORTING_OBLIGATION .

euai:HIGH_RISK a owl:NamedIndividual,
        euai:RiskCategory ;
    rdfs:label "HIGH RISK"@en,
        "HIGH-RISK"@en ;
    skos:definition """"HIGH RISK" is a classification level applied to AI systems that have the potential to significantly impact fundamental rights, safety, health, livelihood, democracy, the rule of law, and individual freedoms. These systems are subject to specific regulatory oversight and must adhere to mandatory requirements to mitigate these risks.

Under the framework of the AI Act, specifically as outlined in Article 6, AI systems designated as "HIGH RISK" are legally obligated to comply with stringent requir"""@en,
        "Classification status for AI systems, including those in Annex III or those involving profiling or remote biometric identification, that pose significant risks to health, safety, or fundamental rights."@en .

euai:AI_SYSTEM a owl:NamedIndividual,
        euai:AISystem ;
    rdfs:label "AI SYSTEM"@en ;
    skos:definition "An AI System is defined as a fast-evolving, machine-based family of technologies designed to operate with varying levels of autonomy. Utilizing machine learning, logic-based, or knowledge-based approaches, these systems infer from human-defined objectives and inputs—such as data or other stimuli—how to generate outputs like predictions, content, recommendations, or decisions. These outputs have the capacity to influence physical or virtual environments. Crucially, an AI system is distinct from t"@en ;
    euai:definedInArticle euai:ARTICLE_3 ;
    euai:isExemptFromHighRisk euai:EXCLUSION_FOR_ASSISTIVE_FUNCTIONS,
        euai:MILITARY__DEFENCE_OR_NATIONAL_SECURITY_ACTIVITY,
        euai:NATIONAL_SECURITY_AND_MILITARY_EXCLUSION,
        euai:SCIENTIFIC_RESEARCH_AND_DEVELOPMENT_ACTIVITY,
        euai:SCIENTIFIC_RESEARCH_EXCLUSION ;
    euai:regulatedBy euai:DIRECTIVE_2002_58_EC,
        euai:NEW_LEGISLATIVE_FRAMEWORK ;
    euai:relatedTo euai:ADMINISTRATIVE_FINE,
        euai:ARTICLE_2_TEU,
