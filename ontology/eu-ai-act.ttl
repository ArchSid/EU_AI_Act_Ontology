euai:PENALTIES_FOR_GENERAL_NON_COMPLIANCE a owl:NamedIndividual,
        euai:Obligation ;
    rdfs:label "PENALTIES FOR GENERAL NON-COMPLIANCE"@en ;
    skos:definition "Administrative fines for non-compliance with provisions other than Article 5 (e.g., obligations of providers, importers, distributors, notified bodies). Amount: up to EUR 15,000,000 or 3% of total worldwide annual turnover, whichever is higher"@en ;
    euai:definedInArticle euai:ARTICLE_99 .

euai:ANNEX_III a owl:NamedIndividual,
        euai:Article ;
    rdfs:label "ANNEX III"@en ;
    skos:definition """**ANNEX III** of the EU AI Act serves as a critical regulatory component, specifically functioning as the definitive list of high-risk AI system categories and use case domains. Referenced directly under Article 6(2), this annex delineates the specific areas and applications of AI that are subject to heightened regulatory scrutiny, oversight measures, and compliance obligations due to their potential impact on fundamental rights and safety.

The systems identified within ANNEX III are subject to"""@en ;
    euai:appliesTo euai:ANNEX_III_USE_CASE_RULE ;
    euai:relatedTo euai:ARTICLE_6_2_,
        euai:BIOMETRICS,
        euai:HIGH_RISK_AI_SYSTEM .

